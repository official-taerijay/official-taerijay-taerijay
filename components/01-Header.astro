---
// 01-Header.astro
---
<header class="w-full px-4 md:px-12 py-3.5 border-b border-[#5B0E1B] bg-[#0A192F]/95 backdrop-blur sticky top-0 z-50 flex flex-col gap-3">
	<div class="flex items-center justify-between w-full">
		<button id="menuTrigger" class="text-white hover:text-[#00F0FF] transition-colors p-1.5 -ml-1.5 focus:outline-none">
			<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 md:h-8 md:w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
				<path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
			</svg>
		</button>

		<!-- 우측 실시간 구글 계정 연동 버튼 -->
		<button id="globalAuthBtn" class="px-3.5 py-1.5 border border-[#5B0E1B] rounded bg-[#5B0E1B]/30 hover:bg-[#5B0E1B]/60 text-white text-[11px] md:text-xs font-bold uppercase tracking-wider transition-all shadow-md font-noto focus:outline-none">
			로그아웃 또는 회원가입
		</button>
	</div>

	<div class="flex justify-center w-full pb-0.5">
		<a href="/" class="font-spartan text-xl md:text-3xl font-black tracking-[0.18em] text-white leading-none uppercase select-none hover:text-[#00F0FF] transition-colors">
			TAERIJAY+
		</a>
	</div>
</header>

<!-- SIDEBAR DRAWER -->
<div id="sideDrawer" class="fixed inset-0 z-[100] bg-black/80 backdrop-blur-sm hidden justify-start w-full transition-opacity duration-300">
	<div class="w-[320px] h-full bg-[#071120] border-r border-[#5B0E1B] p-6 flex flex-col gap-6 relative shadow-2xl overflow-y-auto font-noto">
		<div class="flex items-center justify-between border-b border-[#5B0E1B] pb-4">
			<span class="font-spartan text-lg font-black tracking-widest text-[#00F0FF] uppercase">CHANNELS</span>
			<button id="menuCloser" class="text-slate-400 hover:text-white text-3xl font-light leading-none focus:outline-none">&times;</button>
		</div>
		<nav class="flex flex-col gap-3 font-bold text-sm" id="sidebarNav">
			<a href="/" class="w-full text-left p-3.5 rounded border border-[#5B0E1B]/60 bg-[#0A192F] text-white hover:border-white transition-all font-playfair font-black tracking-wider uppercase text-base">0. TAERIJAY</a>
			<a href="/04-channels/01-entertainment" class="w-full text-left p-3.5 rounded border border-[#5B0E1B]/40 bg-[#0A192F] text-[#00F0FF] hover:border-[#00F0FF] transition-all text-base lowercase">1. taerijay+entertainment</a>
			<a href="/04-channels/02-protocol" class="w-full text-left p-3.5 rounded border border-[#5B0E1B]/40 bg-[#0A192F] text-[#FF6B00] hover:border-[#FF6B00] transition-all text-base lowercase">2. taerijay+protocol</a>
			<a href="/04-channels/03-mini" class="w-full text-left p-3.5 rounded border border-[#5B0E1B]/40 bg-[#0A192F] text-[#FBF9F4] hover:border-white transition-all text-base lowercase">3. taerijay+mini</a>
			<a href="/04-channels/04-daiso" class="w-full text-left p-3.5 rounded border border-[#5B0E1B]/40 bg-[#0A192F] text-[#FF2E2E] hover:border-[#FF2E2E] transition-all text-base lowercase">4. taerijay+daiso</a>
			<a href="/04-channels/05-oliveyoung" class="w-full text-left p-3.5 rounded border border-[#5B0E1B]/40 bg-[#0A192F] text-[#6F8B2E] hover:border-[#6F8B2E] transition-all text-base lowercase">5. taerijay+oliveyoung</a>
			<a href="/04-channels/06-emart" class="w-full text-left p-3.5 rounded border border-[#5B0E1B]/40 bg-[#0A192F] text-[#FFFB00] hover:border-[#FFFB00] transition-all text-base lowercase">6. taerijay+emart</a>
			<a href="/04-channels/07-convenience" class="w-full text-left p-3.5 rounded border border-[#5B0E1B]/40 bg-[#0A192F] text-[#A14D7C] hover:border-[#A14D7C] transition-all text-base lowercase">7. taerijay+convenience</a>
		</nav>
	</div>
</div>

<script is:inline>
	// 💡 구글 인증 세팅을 위한 Supabase 연동 정보 (대표님 계정 연동용 임시 자격 정보)
	const SUPABASE_URL = "https://your-supabase-project.supabase.co"; 
	const SUPABASE_ANON_KEY = "your-supabase-anon-key";
	
	let supabaseClient = null;
	if (typeof supabase !== 'undefined') {
		supabaseClient = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
	}

	const initHeaderAuth = async () => {
		const menuTrigger = document.getElementById('menuTrigger');
		const sideDrawer = document.getElementById('sideDrawer');
		const menuCloser = document.getElementById('menuCloser');
		const authBtn = document.getElementById('globalAuthBtn');

		if (menuTrigger && sideDrawer) {
			menuTrigger.addEventListener('click', () => {
				sideDrawer.classList.remove('hidden');
				sideDrawer.classList.add('flex');
			});
		}
		if (menuCloser && sideDrawer) {
			menuCloser.addEventListener('click', () => {
				sideDrawer.classList.add('hidden');
				sideDrawer.classList.remove('flex');
			});
		}

		// 💡 로컬 스토리지 또는 수파베이스 실제 구글 세션 검사
		let userProfile = null;
		if (supabaseClient) {
			const { data: { session } } = await supabaseClient.auth.getSession();
			if (session) {
				userProfile = session.user;
				localStorage.setItem('taerijay_auth_state', 'authorized');
			}
		} else {
			// 수파베이스 초기화 전 수동 로컬 테스트 동기화용 백업 루프
			if (localStorage.getItem('taerijay_auth_state') === 'authorized') {
				userProfile = { user_metadata: { full_name: "GUEST_USER" } };
			}
		}

		if (authBtn) {
			if (userProfile) {
				// 💡 [대표님 지시 구절] 로그인 완료 시 "로그인" 텍스트 노출 및 사용자 이름 표기
				const name = userProfile.user_metadata?.full_name || "사용자";
				authBtn.textContent = `${name} 님`;
				authBtn.className = "px-3.5 py-1.5 border border-emerald-500 rounded bg-emerald-950/60 text-emerald-400 text-[11px] md:text-xs font-bold transition-all shadow-md font-noto focus:outline-none";
			} else {
				// 💡 [대표님 지시 구절] 로그아웃 상태 시 "로그아웃 또는 회원가입" 노출
				authBtn.textContent = '로그아웃 또는 회원가입';
				authBtn.className = "px-3.5 py-1.5 border border-[#5B0E1B] rounded bg-[#5B0E1B]/30 hover:bg-[#5B0E1B]/60 text-white text-[11px] md:text-xs font-bold transition-all shadow-md font-noto focus:outline-none";
			}

			authBtn.replaceWith(authBtn.cloneNode(true));
			const activeAuthBtn = document.getElementById('globalAuthBtn');

			activeAuthBtn.addEventListener('click', async () => {
				const checkState = localStorage.getItem('taerijay_auth_state');
				if (checkState === 'authorized') {
					// 💡 로그아웃 진행 시 완전히 소각 처리함
					if (supabaseClient) {
						await supabaseClient.auth.signOut();
					}
					localStorage.removeItem('taerijay_auth_state');
					alert("정상적으로 로그아웃 처리가 수립되었습니다.");
					window.location.href = "/";
				} else {
					window.location.href = '/01-auth';
				}
			});
		}
	};

	document.addEventListener('DOMContentLoaded', initHeaderAuth);
</script>