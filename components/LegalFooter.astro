---
---
<footer class="w-full px-6 md:px-12 py-12 border-t border-[#5B0E1B] bg-[#040c17]">
	<div class="flex flex-wrap justify-center gap-8 md:gap-16 mb-12 max-w-4xl mx-auto text-sm text-slate-400 font-light font-spartan">
		<button class="modal-trigger hover:text-[#00F0FF] transition-colors" data-target="modal-business">Business Info (사업자 정보)</button>
		<button class="modal-trigger hover:text-[#00F0FF] transition-colors" data-target="modal-terms">Terms of Service (이용약관)</button>
		<button class="modal-trigger hover:text-[#00F0FF] transition-colors" data-target="modal-privacy">Privacy Policy (개인정보처리방침)</button>
		<button class="modal-trigger hover:text-[#00F0FF] transition-colors" data-target="modal-refund">Refund Policy (환불정책)</button>
	</div>

	<!-- BRAND CHIPS INTERACTIVE LOGO LINEUP MAPPING -->
	<div class="flex flex-col gap-6 border-t border-[#5B0E1B]/30 pt-8 items-center max-w-7xl mx-auto">
		<div class="flex flex-wrap justify-center items-center gap-4 md:gap-6 w-full">
			
			<!-- 1. YOUTUBE -->
			<a href="https://www.youtube.com/@taerijay" target="_blank" class="w-16 h-16 md:w-20 md:h-20 border border-red-600 bg-[#FF0000] rounded-2xl flex items-center justify-center hover:scale-110 hover:shadow-xl hover:shadow-red-600/50 transition-all duration-300" title="YouTube">
				<svg class="w-8 h-8 text-white fill-current" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.016 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93 .502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
			</a>
			<div class="w-1.5 h-1.5 rounded-full bg-slate-700 hidden md:block"></div>
			
			<!-- 2. INSTAGRAM -->
			<a href="https://www.instagram.com/taerijay" target="_blank" class="w-16 h-16 md:w-20 md:h-20 border border-fuchsia-400 bg-gradient-to-tr from-[#FFB900] via-[#E1306C] to-[#C13584] rounded-2xl flex items-center justify-center hover:scale-110 hover:shadow-xl hover:shadow-fuchsia-500/50 transition-all duration-300" title="Instagram">
				<svg class="w-8 h-8 text-white fill-none stroke-current stroke-[2.2]" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><circle cx="12" cy="12" r="4"></circle><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
			</a>
			<div class="w-1.5 h-1.5 rounded-full bg-slate-700 hidden md:block"></div>
			
			<!-- 3. TIKTOK -->
			<a href="https://www.tiktok.com/@taerijay" target="_blank" class="w-16 h-16 md:w-20 md:h-20 border border-slate-600 bg-black rounded-2xl flex items-center justify-center hover:scale-110 hover:shadow-xl hover:shadow-cyan-400/30 transition-all duration-300 relative overflow-hidden" title="TikTok">
				<svg class="w-8 h-8 text-white fill-current filter drop-shadow-[2px_0_0_#00F0FF] drop-shadow-[-2px_0_0_#FF2E2E]" viewBox="0 0 24 24"><path d="M12.53.02C13.84 0 15.14.01 16.44 0c.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.06-2.89-.54-4.06-1.5-1.23-1-2.01-2.52-2.28-4.1-.02-.08-.05-.07-.05.02v10.15c0 1.25-.24 2.54-.87 3.6-1.11 1.91-3.32 3.19-5.55 3.11-2.88-.1-5.46-2.31-5.71-5.22-.36-4.14 2.87-7.66 7.01-7.53.07 0 .14.01.27.02v4.03c-1.24-.18-2.61.34-3.23 1.47-.63 1.15-.36 2.75.64 3.61 1.02.87 2.65.71 3.47-.41.42-.57.54-1.3.52-2V.02z"/></svg>
			</a>
			<div class="w-1.5 h-1.5 rounded-full bg-slate-700 hidden md:block"></div>
			
			<!-- 4. GOOGLE BLOG -->
			<a href="https://taerijay.blogspot.com" target="_blank" class="w-16 h-16 md:w-20 md:h-20 border border-blue-900 bg-[#030b1a] rounded-2xl flex items-center justify-center hover:scale-110 hover:shadow-xl hover:shadow-blue-600/40 transition-all duration-300 group" title="Google Blog">
				<div class="w-11 h-11 bg-white rounded-full flex items-center justify-center shadow-inner"><svg class="w-6 h-6" viewBox="0 0 24 24"><path fill="#4285F4" d="M23.745 12.27c0-.7-.06-1.4-.19-2.07H12v3.92h6.61c-.29 1.53-1.11 2.83-2.4 3.87v3.2h3.86c2.26-2.09 3.67-5.17 3.67-8.92z"/><path fill="#34A853" d="M12 24c3.24 0 5.95-1.08 7.93-2.91l-3.86-3.2c-1.08.72-2.45 1.16-4.07 1.16-3.13 0-5.78-2.11-6.73-4.96H1.29v3.3C3.26 21.3 7.31 24 12 24z"/><path fill="#FBBC05" d="M5.27 14.09c-.25-.72-.39-1.5-.39-2.3 0-.79.14-1.57.39-2.3V6.19H1.29C.47 7.81 0 9.63 0 11.79c0 2.17.47 3.99 1.29 5.61l3.98-3.31z"/><path fill="#EA4335" d="M12 4.75c1.77 0 3.35.61 4.6 1.8l3.42-3.42C17.95 1.19 15.24 0 12 0 7.31 0 3.26 2.7 1.29 6.19l3.98 3.3c.95-2.85 3.6-4.96 6.73-4.96z"/></svg></div>
			</a>
			<div class="w-1.5 h-1.5 rounded-full bg-slate-700 hidden md:block"></div>
			
			<!-- 5. NAVER BLOG -->
			<a href="https://blog.naver.com/taerijay" target="_blank" class="w-16 h-16 md:w-20 md:h-20 border border-emerald-950 bg-[#02140b] rounded-2xl flex items-center justify-center hover:scale-110 hover:shadow-xl hover:shadow-emerald-500/40 transition-all duration-300">
				<div class="w-11 h-11 bg-[#03C75A] rounded-xl flex items-center justify-center font-spartan text-xl font-black text-white">N</div>
			</a>
		</div>
	</div>
</footer>

<!-- CORE LEGAL AUDIT MODAL CHIPS -->
<div id="modal-business" class="modal-overlay fixed inset-0 z-[120] bg-black/85 backdrop-blur-sm hidden items-center justify-center p-4">
	<div class="bg-[#0A192F] border-2 border-[#5B0E1B] rounded-xl max-w-[550px] w-full p-6 flex flex-col gap-4 relative max-h-[85vh] overflow-y-auto shadow-2xl">
		<h3 class="text-base font-bold text-white border-b border-[#5B0E1B] pb-3 uppercase flex items-center justify-between font-spartan"><span>Business Info (사업자 정보)</span><button class="modal-close text-2xl text-slate-400 hover:text-white">&times;</button></h3>
		<div class="text-xs text-slate-300 flex flex-col gap-2 font-noto">
			<div class="grid grid-cols-2 border-b border-[#5B0E1B]/20 pb-2"><div>상호명 (Business Name)</div><div class="text-[#00F0FF] font-bold">TAERIJAY (태리재이)</div></div>
			<div class="grid grid-cols-2 border-b border-[#5B0E1B]/20 pb-2"><div>사업자등록번호 (Registration No)</div><div class="text-[#00F0FF] font-bold">673-51-01148</div></div>
			<div class="grid grid-cols-2 border-b border-[#5B0E1B]/20 pb-2"><div>사업장 소재지 (Address)</div><div>경기도 남양주시 화도읍</div></div>
			<div class="grid grid-cols-2"><div>이메일 (Email)</div><div class="text-[#00F0FF]">official@taerijay.com</div></div>
		</div>
	</div>
</div>

<script is:inline>
	document.querySelectorAll('.modal-trigger').forEach(trig => {
		trig.addEventListener('click', () => {
			const target = document.getElementById(trig.dataset.target);
			if(target) { target.classList.remove('hidden'); target.classList.add('flex'); }
		});
	});
	document.querySelectorAll('.modal-close').forEach(closer => {
		closer.addEventListener('click', () => {
			const targetOverlay = closer.closest('.modal-overlay');
			if(targetOverlay) { targetOverlay.classList.add('hidden'); targetOverlay.classList.remove('flex'); }
		});
	});
</script>