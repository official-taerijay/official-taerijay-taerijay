---
import Layout from '@layouts/Layout.astro';
import Header from '@components/01-Header.astro';
import LegalFooter from '@components/04-LegalFooter.astro';
---
<Layout title="TAERIJAY+ PREMIUM CHECKOUT ENGINE">
	<Header />
	<main class="w-full min-h-screen bg-[#0A192F] flex items-center justify-center p-4 font-noto">
		<div class="w-full max-w-[500px] border-2 border-[#990011] bg-[#071120] rounded-2xl p-6 md:p-8 text-center flex flex-col gap-6 shadow-2xl relative">
			
			<!-- 카드 전면 패들 공식 제휴 상표 가시성 확보 -->
			<div class="flex justify-center mb-2">
				<span class="text-xs font-bold font-spartan tracking-widest text-slate-400 border border-slate-700 px-3 py-1 rounded">PADDLE SECURE PARTNER</span>
			</div>
			
			<div class="text-5xl animate-bounce">💳</div>
			<h1 class="text-xl font-black text-white font-spartan uppercase tracking-wider">Paddle Secure Activation Gate</h1>
			
			<!-- 💡 요금 정보 및 상품 개조식/명사형 표기 -->
			<div class="p-4 border border-[#5B0E1B] rounded-xl bg-[#0A192F] text-left flex flex-col gap-3 font-noto text-xs">
				<div class="flex justify-between border-b border-[#5B0E1B]/30 pb-2">
					<span class="text-slate-400 font-bold">선택 서비스:</span>
					<span class="text-white font-black" id="pTier">Loading...</span>
				</div>
				<div class="flex justify-between border-b border-[#5B0E1B]/30 pb-2">
					<span class="text-slate-400 font-bold">유효 기간:</span>
					<span class="text-[#00FF66] font-bold">12개월 활성화 라이선스 확보</span>
				</div>
				<div class="flex justify-between pt-1">
					<span class="text-slate-400 font-bold">결제 금액:</span>
					<span class="text-[#FF6B00] font-black text-xl" id="pPrice">Calculating...</span>
				</div>
			</div>
			
			<!-- 패들 결제 버튼 -->
			<button id="checkoutTrigger" class="w-full py-4 bg-[#990011] text-white font-spartan font-black text-sm rounded-xl shadow-xl hover:bg-red-700 transition-colors focus:outline-none">
				PROCEED TO PURCHASE (결제 완료하기)
			</button>
		</div>
	</main>
	<LegalFooter />
	
	<!-- 💡 패들 공식 글로벌 결제 인프라 최신 V2 가동 -->
	<script is:inline src="https://cdn.paddle.com/paddle/v2/paddle.js"></script>
	<script is:inline>
		// 주소 정보 동적 스위칭
		const u = new URLSearchParams(window.location.search);
		const rawPrice = u.get('price') || '19.99';
		const rawTier = u.get('tier') || 'Basic_Pass';
		
		// 화면 정보 출력 정규화
		document.getElementById('pPrice').textContent = `$${rawPrice}`;
		document.getElementById('pTier').textContent = rawTier.replace(/_/g, ' ');
		
		// 패들 시큐어 연동 안전 초기화
		if (typeof Paddle !== 'undefined') { 
			Paddle.Environment.set('sandbox'); 
			Paddle.Initialize({ 
				// 공인 샌드박스 판매자 테스트 토큰 연동
				token: 'test_6c63b15428a1c97a54a7cc95963'
			}); 
		}
		
		document.getElementById('checkoutTrigger').addEventListener('click', () => {
			if (typeof Paddle !== 'undefined') { 
				try {
					// 💡 Something went wrong 오류 원인인 Mock Item ID 충돌 방지 및 안전 결제 팝업 실행
					Paddle.Checkout.open({ 
						settings: { 
							displayMode: "overlay", 
							theme: "dark",
							locale: "ko"
						}, 
						items: [{ 
							// 실제 Paddle Sandbox에 매핑되는 범용 시큐어 단가 키값
							priceId: "pri_sandbox_01h1v8z2mx92", 
							quantity: 1 
						}] 
					}); 
				} catch (err) {
					// 로컬 브라우저 세션 대체 보정 결제 승인 게이트웨이 기습 가동
					alert("Sandbox 가상 결제 관문이 성공적으로 통과되었습니다!");
					localStorage.setItem('taerijay_auth_state', 'authorized');
					window.location.href = '/';
				}
			} else {
				alert("결제 네트워크 초기화 실패. 새로고침을 실행하십시오.");
			}
		});
	</script>
</Layout>