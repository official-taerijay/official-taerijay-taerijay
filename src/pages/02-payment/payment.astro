      },
    };

    // DOM 참조
    const params    = new URLSearchParams(window.location.search);
    const key       = params.get('key') || '';
    const product   = PRICE_MAP[key];

    const payCard       = document.getElementById('payCard');
    const channelBar    = document.getElementById('channelBar');
    const productName   = document.getElementById('productName');
    const productTier   = document.getElementById('productTier');
    const priceAmount   = document.getElementById('priceAmount');
    const benefitList   = document.getElementById('benefitList');
    const userRow       = document.getElementById('userRow');
    const userEmailShow = document.getElementById('userEmailShow');
    const payBtn        = document.getElementById('payBtn');
    const statusBox     = document.getElementById('statusBox');
    const invalidScreen = document.getElementById('invalidScreen');

    if (!product) {
      invalidScreen.classList.add('visible');
      payCard.classList.add('invalid');

    } else {
      // 상품 정보 렌더링
      document.documentElement.style.setProperty('--accent', product.accent);
      channelBar.style.background = product.accent;

      productName.textContent  = product.label;
      productTier.textContent  = product.tier;
      priceAmount.textContent  = product.price % 1 === 0 ? product.price.toString() : product.price.toFixed(2);

      benefitList.innerHTML = product.benefits
        .map(b => `<li><div class="benefit-icon">✓</div><div class="benefit-text"><span class="benefit-kr">${b.kr}</span><span class="benefit-en">${b.en}</span></div></li>`)
        .join('');

      // 로그인 상태 확인
      const userEmail = sessionStorage.getItem('user_email');

      if (!userEmail) {
        const returnUrl = encodeURIComponent(window.location.href);
        window.location.href = `/01-auth/auth?redirect=${returnUrl}`;
      } else {
        userRow.style.display = 'flex';
        userEmailShow.textContent = userEmail;
        payBtn.disabled = false;
        payBtn.textContent = `Activate · $${product.price.toFixed(2)} USD`;
      }

      // Paddle 초기화 (SDK 로드 실패, 토큰 누락 등 방어)
      if (typeof Paddle === 'undefined') {
        statusBox.className = 'status-box err';
        statusBox.textContent = '⚠️ Paddle SDK failed to load. Check network/ad-blocker and refresh.';
        payBtn.disabled = true;
        return;
      }
      if (!window.__TJ_PADDLE__) {
        statusBox.className = 'status-box err';
        statusBox.textContent = '⚠️ Payment config missing (PUBLIC_PADDLE_VENDOR_TOKEN not set).';
        payBtn.disabled = true;
        return;
      }
      try {
        Paddle.Initialize({ token: window.__TJ_PADDLE__ });
      } catch (e) {
        statusBox.className = 'status-box err';
        statusBox.textContent = `⚠️ Paddle init error: ${e.message || e}`;
        payBtn.disabled = true;
        return;
      }

      // 결제 버튼
      payBtn.addEventListener('click', function () {
        payBtn.disabled = true;
        payBtn.innerHTML = '<div class="btn-spinner"></div>&nbsp; Opening checkout...';
        statusBox.className = 'status-box';

        const userEmail = sessionStorage.getItem('user_email');

        try {
        Paddle.Checkout.open({
          items: [{ priceId: product.priceId, quantity: 1 }],
          customer: { email: userEmail || undefined },
          settings: {
            displayMode: 'overlay',
            theme: 'dark',
            locale: 'en',
            successUrl: `${window.location.origin}/?payment=success`,
            frameTarget: 'self',
          },
          eventCallback: function (data) {
            if (data.name === 'checkout.completed') {
              statusBox.className = 'status-box ok';
              statusBox.textContent = '✓ Payment complete! Activating your access...';
              setTimeout(() => { window.location.href = '/'; }, 2000);

            } else if (data.name === 'checkout.closed') {
              payBtn.disabled = false;
              payBtn.textContent = `Activate · $${product.price.toFixed(2)} USD`;

            } else if (data.name === 'checkout.error') {
              statusBox.className = 'status-box err';
              statusBox.textContent = '⚠️ Checkout error. Please try again or contact support.';
              payBtn.disabled = false;
              payBtn.textContent = `Activate · $${product.price.toFixed(2)} USD`;
            }
          },
        });
        } catch (e) {
          console.error(e);
          statusBox.className = 'status-box err';
          statusBox.textContent = `⚠️ Checkout failed to open: ${e.message || e}`;
          payBtn.disabled = false;
          payBtn.textContent = `Activate · $${product.price.toFixed(2)} USD`;
        }
      });
    }

  });
  </script>
