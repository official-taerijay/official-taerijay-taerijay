---
// src/pages/02-payment/payment.astro
import Layout from '../../layouts/Layout.astro';
---

<Layout title="TAERIJAY+ Premium Checkout">
  <main class="payment-container">
    <div class="checkout-card">
      <div class="partner-badge">PADDLE SECURE PARTNER</div>
      
      <div class="paddle-logo-zone">
        <h2>PADDLE SECURE ACTIVATION GATE</h2>
      </div>

      <div class="user-status-bar">
        <p id="user-display-email">인증 유저 세션 분석 중임...</p>
      </div>

      <!-- 실전 패들 결제 상품 선택 라인업 -->
      <div class="price-selection-box">
        <div class="info-row">
          <span class="label">결제 라이선스:</span>
          <span class="value">TAERIJAY+ PREMIUM PASS</span>
        </div>
        <div class="info-row">
          <span class="label">유효 기간:</span>
          <span class="value" style="color: #4eedb5;">12개월 활성화 라이선스 확보</span>
        </div>
      </div>

      <!-- 대표님 패들 Price ID 삽입 세션 (※ pri_로 시작하는 진짜 코드값으로 대체 필수) -->
      <div class="action-zone">
        <button class="pay-btn" data-price="pri_프로토콜_베이직_진짜ID_입력">
          PROCEED TO PURCHASE (베이직 $19.99 결제)
        </button>
        <button class="pay-btn" data-price="pri_프로토콜_스탠다드_진짜ID_입력" style="background: #1f6feb; margin-top: 10px;">
          PROCEED TO PURCHASE (스탠다드 $29.99 결제)
        </button>
      </div>
    </div>
  </main>
</Layout>

<style>
  .payment-container {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 90vh;
    background-color: #1a1e29;
    color: #ffffff;
    font-family: sans-serif;
  }
  .checkout-card {
    width: 100%;
    max-width: 480px;
    padding: 2.5rem;
    background-color: #222738;
    border: 1px solid #ff3344;
    border-radius: 16px;
    box-shadow: 0 12px 32px rgba(0,0,0,0.6);
    text-align: center;
  }
  .partner-badge {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    color: #8b949e;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }
  h2 {
    font-size: 1.3rem;
    font-weight: 800;
    letter-spacing: 0.5px;
    color: #c9d1d9;
    margin-bottom: 1.5rem;
  }
  .user-status-bar {
    background: #161b22;
    padding: 0.6rem;
    border-radius: 6px;
    font-size: 0.85rem;
    color: #58a6ff;
    margin-bottom: 2rem;
  }
  .price-selection-box {
    text-align: left;
    background: #1f2434;
    padding: 1.2rem;
    border-radius: 8px;
    margin-bottom: 2rem;
  }
  .info-row {
    display: flex;
    justify-content: space-between;
    margin-bottom: 0.8rem;
    font-size: 0.9rem;
  }
  .info-row:last-child {
    margin-bottom: 0;
  }
  .label { color: #8b949e; }
  .value { font-weight: 600; }
  
  .pay-btn {
    width: 100%;
    padding: 1.1rem;
    background: #ff3344;
    color: #ffffff;
    border: none;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition: transform 0.1s, background 0.2s;
  }
  .pay-btn:hover {
    background: #e02f3f;
    transform: scale(1.01);
  }
</style>

<!-- 패들 공식 자바스크립트 엔진 주입선 -->
<script is:inline src="https://cdn.paddle.com/paddle/v3/paddle.js"></script>

<script>
  // 브라우저 세션 스토리지 기반의 비정상 유저 접근 커트 아키텍처
  const userEmail = window.sessionStorage.getItem('user_email');
  const userDisplay = document.getElementById('user-display-email');

  if (!userEmail) {
    alert("인증 세션 없음. 로그인 콘솔로 즉시 자동 튕김 처리(Redirect) 슛함.");
    window.location.href = '/01-auth/auth';
  } else {
    if (userDisplay) userDisplay.innerText = `ACTIVE SESSION: ${userEmail}`;
  }

  // 패들 클라이언트 샌드박스 인프라 초기화
  // @ts-ignore
  Paddle.Environment.set("sandbox"); // 라이브 실전 전환 시 "live"로 교체함.
  // @ts-ignore
  Paddle.Initialize({ 
    token: import.meta.env.PUBLIC_PADDLE_VENDOR_TOKEN 
  });

  // 다중 결제 버튼 레이어 핸들러 슛
  const checkoutButtons = document.querySelectorAll('.pay-btn');
  checkoutButtons.forEach(button => {
    button.addEventListener('click', () => {
      const selectedPriceId = button.getAttribute('data-price');
      
      if (!selectedPriceId || selectedPriceId.includes('진짜ID')) {
        alert("시스템 오류: 패들 대시보드에서 발급된 올바른 Price ID가 셋팅되지 않았음.");
        return;
      }

      // @ts-ignore
      Paddle.Checkout.open({
        items: [{ priceId: selectedPriceId, quantity: 1 }],
        customer: { email: userEmail },
        settings: {
          displayMode: "overlay",
          theme: "dark",
          locale: "ko"
        }
      });
    });
  });
</script>