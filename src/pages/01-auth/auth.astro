---
// src/pages/01-auth/auth.astro
// Firebase Google OAuth 인증 페이지
// 환경변수: PUBLIC_FIREBASE_API_KEY / PUBLIC_FIREBASE_AUTH_DOMAIN / PUBLIC_FIREBASE_PROJECT_ID

const firebaseConfig = {
  apiKey: import.meta.env.PUBLIC_FIREBASE_API_KEY,
  authDomain: import.meta.env.PUBLIC_FIREBASE_AUTH_DOMAIN,
  projectId: import.meta.env.PUBLIC_FIREBASE_PROJECT_ID,
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
  <meta name="google" content="notranslate" />
  <meta name="robots" content="noindex, nofollow" />
  <title>TAERIJAY+ · Sign In</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=League+Spartan:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg:           #0A192F;
      --burgundy:     #5B0E1B;
      --burgundy-dim: rgba(91, 14, 27, 0.35);
      --burgundy-mid: rgba(91, 14, 27, 0.55);
      --burgundy-hi:  rgba(91, 14, 27, 0.80);
      --ivory:        #FBF9F4;
      --muted:        #7A9AB5;
      --green:        #00C97A;
      --red:          #E1261C;
      --orange:       #F16B24;
    }

    body {
      background: var(--bg);
      color: var(--ivory);
      font-family: 'League Spartan', sans-serif;
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 32px 16px;
      background-image: radial-gradient(ellipse 70% 50% at 50% 30%, rgba(91,14,27,0.12) 0%, transparent 70%);
    }

    /* ══════════════════════════════════
       CONTAINER
     ══════════════════════════════════ */
    .auth-wrap {
      width: 100%;
      max-width: 440px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0;
    }

    /* ══════════════════════════════════
       BRAND HEADER
     ══════════════════════════════════ */
    .brand-header {
      text-align: center;
      margin-bottom: 36px;
    }

    .brand-wordmark {
      font-family: 'Playfair Display', serif;
      font-size: 30px;
      font-weight: 700;
      letter-spacing: 0.1em;
      color: var(--ivory);
      line-height: 1;
    }

    .brand-plus {
      color: #ff3344;
      font-style: italic;
    }

    .brand-tagline {
      margin-top: 8px;
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--muted);
    }

    /* ══════════════════════════════════
       AUTH CARD
     ══════════════════════════════════ */
    .auth-card {
      width: 100%;
      border: 1px solid var(--burgundy);
      border-radius: 3px;
      padding: 36px 28px 32px;
      background: linear-gradient(160deg, rgba(255,255,255,0.025) 0%, rgba(255,255,255,0.005) 100%);
      backdrop-filter: blur(4px);
      position: relative;
      overflow: hidden;
    }

    .auth-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 48px; height: 1px;
      background: var(--orange);
      opacity: 0.6;
    }

    /* ══════════════════════════════════
       STATUS BADGE
     ══════════════════════════════════ */
    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 6px 14px;
      border: 1px solid rgba(91,14,27,0.45);
      border-radius: 100px;
      margin-bottom: 28px;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.08em;
      color: var(--muted);
      text-transform: uppercase;
      transition: border-color 0.4s;
    }

    .status-badge.active  { border-color: rgba(0,201,122,0.45); }
    .status-badge.error   { border-color: rgba(225,38,28,0.45); }

    .status-dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--muted);
      flex-shrink: 0;
      transition: background 0.4s, box-shadow 0.4s;
    }

    .status-dot.checking {
      background: var(--orange);
      animation: blink 1.1s ease-in-out infinite;
    }

    .status-dot.ok  { background: var(--green); box-shadow: 0 0 8px rgba(0,201,122,0.6); }
    .status-dot.err { background: var(--red); }

    @keyframes blink {
      0%, 100% { opacity: 1; }
      50%       { opacity: 0.25; }
    }

    /* ══════════════════════════════════
       HEADING AREA
     ══════════════════════════════════ */
    .auth-heading {
      font-family: 'Playfair Display', serif;
      font-size: 21px;
      font-weight: 600;
      line-height: 1.2;
      margin-bottom: 10px;
      transition: opacity 0.3s;
    }

    .auth-body {
      font-size: 13px;
      color: var(--muted);
      line-height: 1.7;
      margin-bottom: 32px;
      transition: opacity 0.3s;
    }

    /* ══════════════════════════════════
       LOGIN PANEL
     ══════════════════════════════════ */
    .login-panel { }
    .login-panel.hidden { display: none; }

    .google-btn {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      padding: 15px 20px;
      background: var(--burgundy-dim);
      border: 1px solid var(--burgundy);
      border-radius: 3px;
      color: var(--ivory);
      font-family: 'League Spartan', sans-serif;
      font-size: 14px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      cursor: pointer;
      transition: background 0.2s, border-color 0.2s, transform 0.15s, box-shadow 0.2s;
    }

    .google-btn:hover:not(:disabled) {
      background: var(--burgundy-mid);
      border-color: #8B1426;
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(91,14,27,0.3);
    }

    .google-btn:active:not(:disabled) {
      transform: translateY(0);
      box-shadow: none;
    }

    .google-btn:disabled {
      opacity: 0.45;
      cursor: not-allowed;
    }

    .google-icon {
      width: 19px; height: 19px;
      flex-shrink: 0;
    }

    .btn-spinner {
      width: 18px; height: 18px;
      border: 2px solid rgba(251,249,244,0.25);
      border-top-color: var(--ivory);
      border-radius: 50%;
      animation: spin 0.65s linear infinite;
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    .err-box {
      display: none;
      margin-top: 14px;
      padding: 11px 14px;
      background: rgba(225,38,28,0.1);
      border: 1px solid rgba(225,38,28,0.3);
      border-radius: 3px;
      font-size: 12px;
      color: #FF6B6B;
      text-align: center;
      line-height: 1.5;
    }

    .err-box.visible { display: block; }

    .legal-note {
      margin-top: 22px;
      font-size: 10.5px;
      color: rgba(122, 154, 181, 0.55);
      text-align: center;
      line-height: 1.7;
      letter-spacing: 0.02em;
    }

    /* ══════════════════════════════════
       USER PANEL (로그인 후)
     ══════════════════════════════════ */
    .user-panel { display: none; }
    .user-panel.visible { display: block; }

    .user-ident {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 14px 16px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 3px;
      margin-bottom: 24px;
    }

    .user-avatar {
      width: 40px; height: 40px;
      border-radius: 50%;
      border: 1px solid var(--burgundy);
      object-fit: cover;
      flex-shrink: 0;
    }

    .avatar-fallback {
      width: 40px; height: 40px;
      border-radius: 50%;
      border: 1px solid var(--burgundy);
      background: var(--burgundy-dim);
      display: flex; align-items: center; justify-content: center;
      font-size: 16px;
      flex-shrink: 0;
    }

    .user-meta { flex: 1; min-width: 0; }

    .user-email-txt {
      font-size: 13px;
      font-weight: 500;
      color: var(--ivory);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .user-active-tag {
      margin-top: 3px;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--green);
    }

    .action-stack { display: flex; flex-direction: column; gap: 10px; }

    .action-btn {
      width: 100%;
      padding: 14px;
      border-radius: 3px;
      font-family: 'League Spartan', sans-serif;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      cursor: pointer;
      transition: transform 0.15s, opacity 0.2s, box-shadow 0.2s;
      border: 1px solid;
    }

    .action-btn:hover { transform: translateY(-1px); opacity: 0.88; }
    .action-btn:active { transform: translateY(0); }

    .btn-primary {
      background: var(--burgundy);
      border-color: var(--burgundy);
      color: var(--ivory);
      box-shadow: 0 4px 16px rgba(91,14,27,0.4);
    }

    .btn-ghost {
      background: transparent;
      border-color: rgba(91,14,27,0.4);
      color: var(--muted);
    }

    .back-link {
      display: block;
      text-align: center;
      margin-top: 20px;
      font-size: 11.5px;
      color: var(--muted);
      text-decoration: none;
      letter-spacing: 0.06em;
      transition: color 0.2s;
    }

    .back-link:hover { color: var(--ivory); }
  </style>
</head>

<body>
  <div class="auth-wrap">

    <!-- ① 브랜드 헤더 -->
    <div class="brand-header">
      <div class="brand-wordmark">TAERIJAY<span class="brand-plus">+</span></div>
      <div class="brand-tagline">Republic of Korea · Premium Access</div>
    </div>

    <!-- ② 인증 카드 -->
    <div class="auth-card">

      <!-- 상태 배지 -->
      <div class="status-badge" id="statusBadge">
        <div class="status-dot checking" id="statusDot"></div>
        <span id="statusText">Verifying session...</span>
      </div>

      <!-- 타이틀 -->
      <div class="auth-heading" id="authHeading">Access Gate</div>
      <div class="auth-body" id="authBody">
        Sign in with your Google account to unlock exclusive Korea travel intelligence.
      </div>

      <!-- ─ 로그인 전 패널 ─ -->
      <div class="login-panel" id="loginPanel">

        <button class="google-btn" id="googleBtn">
          <svg class="google-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          Continue with Google
        </button>

        <div class="err-box" id="errBox"></div>

        <div class="legal-note">
          By signing in, you agree to our Terms of Service &amp; Privacy Policy.<br>
          No password required · Google account only · 🇰🇷
        </div>

      </div>

      <!-- ─ 로그인 후 패널 ─ -->
      <div class="user-panel" id="userPanel">

        <div class="user-ident">
          <img src="" alt="Profile" class="user-avatar" id="userAvatar" style="display:none" />
          <div class="avatar-fallback" id="avatarFallback">🇰🇷</div>
          <div class="user-meta">
            <div class="user-email-txt" id="userEmailDisplay">—</div>
            <div class="user-active-tag">✓ Authenticated · Session Active</div>
          </div>
        </div>

        <div class="action-stack">
          <button class="action-btn btn-primary" id="enterBtn">
            Enter Channel Hub →
          </button>
          <button class="action-btn btn-ghost" id="signOutBtn">
            Sign Out
          </button>
        </div>

      </div>

    </div>

    <a href="/" class="back-link">← Back to TAERIJAY+</a>

  </div>

  <!-- ══ Firebase SDK 및 컴파일 아키텍처 연동선 (is:inline 완전 소각) ══ -->
  <script define:vars={{ firebaseConfig }}>
    window.__TJ_FC__ = firebaseConfig;
  </script>

  <!-- script 태그의 모듈 시스템을 이용해 비동기 순서 보장 및 빌드 환경 최적화 완수 -->
  <script>
    import { initializeApp, getApps } from "firebase/app";
    import { getAuth, GoogleAuthProvider, signInWithPopup, signOut, onAuthStateChanged } from "firebase/auth";

    const config = window.__TJ_FC__;
    
    // 글로벌 앱 인프라 이중 초기화 방지
    const app = getApps().length === 0 ? initializeApp(config) : getApps()[0];
    const auth = getAuth(app);
    const provider = new GoogleAuthProvider();
    provider.setCustomParameters({ prompt: 'select_account' });

    // ── DOM 참조 ──
    const statusBadge  = document.getElementById('statusBadge');
    const statusDot    = document.getElementById('statusDot');
    const statusText   = document.getElementById('statusText');
    const authHeading  = document.getElementById('authHeading');
    const authBody     = document.getElementById('authBody');
    const loginPanel   = document.getElementById('loginPanel');
    const userPanel    = document.getElementById('userPanel');
    const userAvatar   = document.getElementById('userAvatar') as HTMLImageElement;
    const avatarFb     = document.getElementById('avatarFallback');
    const userEmailDisplay = document.getElementById('userEmailDisplay');
    const googleBtn    = document.getElementById('googleBtn') as HTMLButtonElement;
    const errBox       = document.getElementById('errBox');
    const enterBtn     = document.getElementById('enterBtn');
    const signOutBtn   = document.getElementById('signOutBtn') as HTMLButtonElement;

    const redirectTo = new URLSearchParams(window.location.search).get('redirect') || '/';

    // ── 라이프사이클 인증 세션 감지 핸들러 ──
    onAuthStateChanged(auth, (user) => {
      if (user) {
        sessionStorage.setItem('user_email', user.email || '');
        sessionStorage.setItem('user_name',  user.displayName || '');
        sessionStorage.setItem('user_photo', user.photoURL || '');
        sessionStorage.setItem('user_uid',   user.uid || '');

        if (statusDot) statusDot.className = 'status-dot ok';
        if (statusBadge) statusBadge.className = 'status-badge active';
        if (statusText) statusText.textContent = 'Session verified · Access granted';

        if (authHeading) authHeading.textContent = 'Welcome back';
        if (authBody) authBody.textContent = 'Your TAERIJAY+ access is active.';

        loginPanel?.classList.add('hidden');
        userPanel?.classList.add('visible');

        if (user.photoURL && userAvatar) {
          userAvatar.src = user.photoURL;
          userAvatar.style.display = 'block';
          if (avatarFb) avatarFb.style.display = 'none';
        }
        if (userEmailDisplay) userEmailDisplay.textContent = user.email || 'Unknown';
      } else {
        sessionStorage.removeItem('user_email');
        sessionStorage.removeItem('user_name');
        sessionStorage.removeItem('user_photo');
        sessionStorage.removeItem('user_uid');

        if (statusDot) statusDot.className = 'status-dot';
        if (statusBadge) statusBadge.className = 'status-badge';
        if (statusText) statusText.textContent = 'Not signed in';

        if (authHeading) authHeading.textContent = 'Access Gate';
        if (authBody) authBody.textContent = 'Sign in with your Google account to unlock exclusive Korea travel intelligence.';

        loginPanel?.classList.remove('hidden');
        userPanel?.classList.remove('visible');
      }
    });

    // ── Google 인증 팝업 액션 슛 ──
    googleBtn?.addEventListener('click', async () => {
      googleBtn.disabled = true;
      googleBtn.innerHTML = '<div class="btn-spinner"></div>';
      errBox?.classList.remove('visible');

      try {
        await signInWithPopup(auth, provider);
      } catch (err: any) {
        let msg = 'Sign-in failed. Please try again.';
        if (err.code === 'auth/popup-closed-by-user') msg = 'Sign-in cancelled. Please try again.';
        if (err.code === 'auth/popup-blocked') msg = '⚠️ Pop-up blocked by your browser. Please allow pop-ups for this site.';
        if (err.code === 'auth/network-request-failed') msg = '⚠️ Network error. Please check your connection.';

        if (errBox) {
          errBox.textContent = msg;
          errBox.classList.add('visible');
        }

        googleBtn.disabled = false;
        googleBtn.innerHTML = `
          <svg class="google-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          Continue with Google
        `;
      }
    });

    // ── 허브 노선 진입 ──
    enterBtn?.addEventListener('click', () => {
      window.location.href = redirectTo;
    });

    // ── 로그아웃 세션 소각 ──
    signOutBtn?.addEventListener('click', async () => {
      signOutBtn.textContent = 'Signing out...';
      signOutBtn.disabled = true;
      try {
        await signOut(auth);
        sessionStorage.clear();
      } catch (e) {
        signOutBtn.textContent = 'Sign Out';
        signOutBtn.disabled = false;
      }
    });
  </script>
</body>
</html>