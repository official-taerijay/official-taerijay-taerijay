---
const FIREBASE_API_KEY = "AIzaSyDohULKEyCcSi30UpbLJSwPwHJ0Vad8J5M";
const FIREBASE_AUTH_DOMAIN = "taerijay-official.firebaseapp.com";
const FIREBASE_PROJECT_ID = "taerijay-official";
---
<!doctype html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
  <title>TAERIJAY</title>
</head>
<body>
  <div id="splash" class="splash"><span class="splash-brand">TAERIJAY</span></div>
  <div class="app">
    <header class="header">
      <a href="/" class="header-logo">TAERIJAY</a>
    </header>

    <main class="main">
      <button type="button" class="back-btn" onclick="history.back()">← 뒤로가기</button>

      <div class="status-panel" id="statusPanel" hidden>
        <p class="status-kr">로그인 완료</p>
        <p class="status-en">You're signed in</p>
        <p class="status-email" id="statusEmail"></p>
        <button type="button" class="btn-signout" id="btn-signout" hidden>
          <span class="btn-kr">로그아웃</span>
          <span class="btn-en">Log Out</span>
        </button>
      </div>

      <button type="button" class="btn-open-modal" id="btn-signin">
        <span class="btn-kr">회원가입 / 로그인</span>
        <span class="btn-en">Sign Up / Log In</span>
      </button>
    </main>
  </div>

  <div class="modal" id="auth-modal" hidden>
    <div class="modal-card">
      <button type="button" class="modal-close" id="modal-close-btn">×</button>
      <h1 class="modal-brand">TAERIJAY</h1>
      <p class="modal-sub-kr">구글 계정 로그인, 전 채널 콘텐츠 확인</p>
      <p class="modal-sub-en" data-i18n="en">Sign in with Google — unlock all channels</p>
      <button class="btn-google" id="google-btn">
        <svg width="20" height="20" viewBox="0 0 18 18"><path fill="#4285F4" d="M17.64 9.2c0-.64-.06-1.25-.16-1.84H9v3.48h4.84a4.14 4.14 0 0 1-1.8 2.72v2.26h2.9c1.7-1.57 2.7-3.88 2.7-6.62z"/><path fill="#34A853" d="M9 18c2.43 0 4.47-.8 5.96-2.18l-2.9-2.26c-.8.54-1.84.86-3.06.86-2.35 0-4.34-1.59-5.05-3.72H.95v2.33A9 9 0 0 0 9 18z"/><path fill="#FBBC05" d="M3.95 10.7A5.4 5.4 0 0 1 3.66 9c0-.59.1-1.17.29-1.7V4.97H.95A9 9 0 0 0 0 9c0 1.45.35 2.83.95 4.03l3-2.33z"/><path fill="#EA4335" d="M9 3.58c1.32 0 2.5.45 3.44 1.35l2.58-2.58C13.46.89 11.43 0 9 0A9 9 0 0 0 .95 4.97l3 2.33C4.66 5.17 6.65 3.58 9 3.58z"/></svg>
        <span class="btn-google-kr">Google로 로그인</span>
      </button>
      <div id="login-error" style="display:none;margin-top:12px;color:#F16B24;font-size:.82rem;text-align:center;">
        <span class="err-kr">로그인 실패, 재시도 필요</span>
        <span class="err-en">Sign-in failed — try again</span>
        <div id="login-error-detail" style="margin-top:6px;font-size:.7rem;color:var(--dim);word-break:break-all;"></div>
      </div>
    </div>
  </div>

  <style>
    :root{--bg:#0A192F;--border:#5B0E1B;--fg:#FBF9F4;--ivory:#FBF9F4;--muted:#8b96a8;--dim:#6b7789;--f-display:-apple-system,BlinkMacSystemFont,"SF Pro Display","Segoe UI",Roboto,Helvetica,Arial,sans-serif;--f-body:-apple-system,BlinkMacSystemFont,"SF Pro Text","Segoe UI",Roboto,Helvetica,Arial,sans-serif}
    *{box-sizing:border-box;margin:0;padding:0}
    html,body{background:var(--bg);color:var(--fg);font-family:var(--f-body);min-height:100vh}
    .splash{position:fixed;inset:0;background:var(--bg);display:flex;align-items:center;justify-content:center;z-index:999;transition:opacity .5s}
    .splash-brand{font-family:var(--f-display);font-weight:900;font-size:2rem;color:#B33A52}
    .header{padding:20px 24px}
    .header-logo{font-family:var(--f-display);font-weight:900;font-size:1.15rem;color:#B33A52;text-decoration:none}
    .main{max-width:480px;margin:0 auto;padding:20px 24px 80px;display:flex;flex-direction:column;align-items:center;gap:20px;text-align:center}
    .back-btn{align-self:flex-start;background:transparent;border:1px solid rgba(255,255,255,.2);color:var(--fg);font-size:.8rem;font-weight:600;padding:8px 16px;border-radius:100px;cursor:pointer}
    .back-btn:hover{background:rgba(255,255,255,.1)}

    .btn-open-modal{width:100%;background:#B33A52;color:var(--fg);border:none;border-radius:10px;padding:16px;cursor:pointer;display:flex;flex-direction:column;gap:2px;margin-top:40px}
    .btn-open-modal .btn-kr{font-weight:700;font-size:.95rem}
    .btn-open-modal .btn-en{font-size:.78rem;opacity:.85}

    .status-panel{width:100%;border:1px solid rgba(255,255,255,.15);border-radius:12px;padding:24px;margin-top:40px;display:flex;flex-direction:column;gap:6px;align-items:center}
    .status-kr{font-weight:700;font-size:1.05rem}
    .status-en{font-size:.82rem;color:var(--muted)}
    .status-email{font-size:.8rem;color:var(--dim);margin-top:8px}
    .btn-signout{margin-top:16px;background:rgba(91,14,27,.55);border:1px solid #8B1A2A;color:var(--fg);border-radius:8px;padding:10px 20px;cursor:pointer;display:flex;flex-direction:column;gap:1px}
    .btn-signout .btn-kr{font-weight:700;font-size:.85rem}
    .btn-signout .btn-en{font-size:.68rem;color:var(--muted)}

    .modal{position:fixed;inset:0;background:rgba(0,0,0,.6);display:flex;align-items:center;justify-content:center;z-index:500;padding:20px}
    .modal-card{position:relative;width:100%;max-width:400px;background:var(--bg);border:1px solid #8B1A2A;border-radius:16px;padding:36px 28px;text-align:center}
    .modal-close{position:absolute;top:14px;right:16px;background:none;border:none;color:var(--muted);font-size:1.6rem;cursor:pointer;line-height:1}
    .modal-brand{font-family:var(--f-display);font-weight:900;font-size:1.5rem;color:#B33A52;margin-bottom:20px}
    .modal-sub-kr{font-size:.88rem;color:var(--fg);line-height:1.6;margin-bottom:4px}
    .modal-sub-en{font-size:.76rem;color:var(--muted);line-height:1.5;margin-bottom:24px}
    .btn-google{width:100%;display:flex;align-items:center;justify-content:center;gap:10px;background:var(--fg);color:var(--bg);border:none;border-radius:10px;padding:13px;font-family:var(--f-body);font-weight:700;font-size:.92rem;cursor:pointer}
  </style>

  <script type="module" define:vars={{ FIREBASE_API_KEY, FIREBASE_AUTH_DOMAIN, FIREBASE_PROJECT_ID }}>
    import { initializeApp } from 'https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js';
    import { getAuth, GoogleAuthProvider, signInWithRedirect, getRedirectResult, signOut, onAuthStateChanged }
      from 'https://www.gstatic.com/firebasejs/10.12.2/firebase-auth.js';

    const app = initializeApp({
      apiKey: FIREBASE_API_KEY,
      authDomain: FIREBASE_AUTH_DOMAIN,
      projectId: FIREBASE_PROJECT_ID,
    });
    const auth = getAuth(app);
    const provider = new GoogleAuthProvider();

    function getRedirectTarget() {
      const params = new URLSearchParams(window.location.search);
      return params.get('redirect');
    }

    onAuthStateChanged(auth, (user) => {
      const signinBtn = document.getElementById('btn-signin');
      const statusPanel = document.getElementById('statusPanel');
      const signoutBtn = document.getElementById('btn-signout');
      const statusEmail = document.getElementById('statusEmail');

      if (user) {
        sessionStorage.setItem('user_email', user.email);
        if (signinBtn) signinBtn.hidden = true;
        if (statusPanel) statusPanel.hidden = false;
        if (signoutBtn) signoutBtn.hidden = false;
        if (statusEmail) statusEmail.textContent = user.email;

        const modal = document.getElementById('auth-modal');
        if (modal) modal.hidden = true;

        const target = getRedirectTarget();
        if (target) {
          window.location.href = target;
        }
      } else {
        sessionStorage.removeItem('user_email');
        if (signinBtn) signinBtn.hidden = false;
        if (statusPanel) statusPanel.hidden = true;
      }
    });

    // 리다이렉트 로그인 후 돌아왔을 때 결과 처리 (팝업 방식의 COOP/서드파티쿠키 차단 문제 회피)
    getRedirectResult(auth).catch((e) => {
      console.error('redirect result error', e);
      const err = document.getElementById('login-error');
      const detail = document.getElementById('login-error-detail');
      if (err) err.style.display = 'block';
      if (detail) detail.textContent = `[${e.code || 'unknown'}] ${e.message || e}`;
      const modal = document.getElementById('auth-modal');
      if (modal) modal.hidden = false;
    });

    document.getElementById('btn-signin')?.addEventListener('click', () => {
      document.getElementById('auth-modal').hidden = false;
    });

    document.getElementById('btn-signout')?.addEventListener('click', async () => {
      await signOut(auth);
      sessionStorage.removeItem('user_email');
    });

    document.getElementById('modal-close-btn')?.addEventListener('click', () => {
      document.getElementById('auth-modal').hidden = true;
    });

    document.getElementById('google-btn')?.addEventListener('click', async () => {
      const err = document.getElementById('login-error');
      const detail = document.getElementById('login-error-detail');
      err.style.display = 'none';
      try {
        await signInWithRedirect(auth, provider);
      } catch(e) {
        console.error(e);
        err.style.display = 'block';
        if (detail) detail.textContent = `[${e.code || 'unknown'}] ${e.message || e}`;
      }
    });

    setTimeout(() => {
      const s = document.getElementById('splash');
      if (s) { s.style.opacity = '0'; setTimeout(() => s.remove(), 500); }
    }, 500);
  </script>
</body>
</html>