---
// src/pages/01-auth/auth.astro
import Layout from '../../layouts/Layout.astro';
---

<Layout title="TAERIJAY+ Auth 센터">
  <main class="auth-container">
    <div class="auth-box">
      <h2>TAERIJAY+ AUTH GATE</h2>
      <p class="auth-subtitle">글로벌 서비스 노선 진입을 위한 구글 인증 세션임.</p>
      
      <!-- 구글 로그인 버튼 -->
      <button id="google-login-btn" class="btn-google">
        <img src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_\"Circles\"_Sign-In_Logo.svg" alt="Google" width="20" />
        <span>Google 계정으로 인증 가동</span>
      </button>

      <!-- 로그아웃 버튼 -->
      <button id="logout-btn" class="btn-logout" style="display: none;">
        인증 세션 종료 (로그아웃)
      </button>
    </div>
  </main>
</Layout>

<style>
  .auth-container {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 80vh;
    background-color: #0d1117;
    color: #ffffff;
    font-family: sans-serif;
  }
  .auth-box {
    text-align: center;
    padding: 2.5rem;
    border: 1px solid #30363d;
    border-radius: 12px;
    background: #161b22;
    box-shadow: 0 8px 24px rgba(0,0,0,0.5);
  }
  h2 {
    font-size: 1.8rem;
    font-weight: 800;
    letter-spacing: 1px;
    margin-bottom: 0.5rem;
    color: #58a6ff;
  }
  .auth-subtitle {
    font-size: 0.9rem;
    color: #8b949e;
    margin-bottom: 2rem;
  }
  .btn-google {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    padding: 0.8rem 1.5rem;
    background-color: #ffffff;
    color: #000000;
    border: none;
    border-radius: 6px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
  }
  .btn-google:hover {
    background-color: #f1f1f1;
  }
  .btn-logout {
    width: 100%;
    padding: 0.8rem 1.5rem;
    background-color: #da3633;
    color: #ffffff;
    border: none;
    border-radius: 6px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
  }
  .btn-logout:hover {
    background-color: #b62b28;
  }
</style>

<script>
  import { initializeApp } from "firebase/app";
  import { getAuth, signInWithPopup, GoogleAuthProvider, signOut, onAuthStateChanged } from "firebase/auth";

  // Vercel 및 로컬 환경변수 연동 선언
  const firebaseConfig = {
    apiKey: import.meta.env.PUBLIC_FIREBASE_API_KEY,
    authDomain: import.meta.env.PUBLIC_FIREBASE_AUTH_DOMAIN,
    projectId: import.meta.env.PUBLIC_FIREBASE_PROJECT_ID,
  };

  const app = initializeApp(firebaseConfig);
  const auth = getAuth(app);
  const provider = new GoogleAuthProvider();

  const loginBtn = document.getElementById('google-login-btn');
  const logoutBtn = document.getElementById('logout-btn');

  // 실시간 유저 인증 트래킹 라이프사이클
  onAuthStateChanged(auth, (user) => {
    if (user) {
      console.log("인증 완료 세션 이메일:", user.email);
      if (loginBtn) loginBtn.style.display = 'none';
      if (logoutBtn) logoutBtn.style.display = 'block';
      window.sessionStorage.setItem('user_email', user.email || '');
    } else {
      if (loginBtn) loginBtn.style.display = 'flex';
      if (logoutBtn) logoutBtn.style.display = 'none';
      window.sessionStorage.removeItem('user_email');
    }
  });

  // 구글 로그인 팝업 활성화 트리거
  loginBtn?.addEventListener('click', async () => {
    try {
      await signInWithPopup(auth, provider);
      // 로그인 종결 즉시 다음 단계인 02-payment/payment 노선으로 슛
      window.location.href = '/02-payment/payment';
    } catch (error) {
      console.error("구글 인증 오류 발생:", error);
    }
  });

  // 로그아웃 트리거
  logoutBtn?.addEventListener('click', async () => {
    try {
      await signOut(auth);
      window.location.reload();
    } catch (error) {
      console.error("로그아웃 처리 오류 발생:", error);
    }
  });
</script>