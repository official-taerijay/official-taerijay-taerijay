---
import Layout from '../01-layouts/01-Layout.astro';
---
<Layout title="TAERIJAY+ COMPLIANCE PASS">
	<main class="w-full min-h-screen bg-[#0A192F] flex items-center justify-center p-4 font-noto relative">
		<a href="/" class="absolute top-6 left-6 text-slate-400 hover:text-[#00F0FF] text-sm font-black font-spartan">◀ RETURN HOME</a>
		<div class="w-full max-w-[560px] border border-[#5B0E1B] bg-[#071120] rounded-2xl p-6 md:p-8 flex flex-col gap-6 shadow-2xl">
			<div class="text-center border-b border-[#5B0E1B]/30 pb-4 font-spartan">
				<span class="text-2xl font-black text-white tracking-widest">TAERIJAY+ LAW AUDIT HUB</span>
			</div>
			<div class="flex flex-col gap-4">
				<div class="flex flex-col gap-3 p-4 border border-[#5B0E1B] rounded-xl bg-[#0A192F] max-h-[220px] overflow-y-auto">
					<label class="flex items-start gap-2.5 cursor-pointer border-b border-[#5B0E1B]/20 pb-2">
						<input type="checkbox" id="chkK" class="mt-1 accent-[#00F0FF]" />
						<span class="text-xs text-white font-medium">
							[필수] 대한민국 정보통신망법 제22조 의거 개인정보 수집 이용 동의함.<br/>
							<span class="text-slate-400 font-light block font-spartan">Korean IT Network Act data compliance.</span>
						</span>
					</label>
					<label class="flex items-start gap-2.5 cursor-pointer">
						<input type="checkbox" id="chkG" class="mt-1 accent-[#00F0FF]" />
						<span class="text-xs text-white font-medium">
							[필수] 국제 개인정보 보호법(EU GDPR / 미국 CCPA) 해외 위탁 조항 동의함.<br/>
							<span class="text-slate-400 font-light block font-spartan">Global standards EU GDPR/CCPA legal transfer consent mapping.</span>
						</span>
					</label>
				</div>
				<!-- 💡 조건 만족 시 실제 구글 연동 창을 강제 트리거하는 구글 로그인 실행기 -->
				<button id="oauthBtnSubmit" class="w-full py-4 bg-white text-[#0A192F] font-spartan font-black text-sm rounded-xl opacity-50 cursor-not-allowed transition-all" disabled>
					CONTINUE WITH GOOGLE GMAIL
				</button>
			</div>
		</div>
	</main>
	<script is:inline>
		const SUPABASE_URL = "https://your-supabase-project.supabase.co"; 
		const SUPABASE_ANON_KEY = "your-supabase-anon-key";
		
		let supabaseClient = null;
		if (typeof supabase !== 'undefined') {
			supabaseClient = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
		}

		document.addEventListener('DOMContentLoaded', () => {
			const k = document.getElementById('chkK'); 
			const g = document.getElementById('chkG'); 
			const b = document.getElementById('oauthBtnSubmit');
			
			const check = () => { 
				if(k.checked && g.checked){ 
					b.disabled=false; 
					b.classList.remove('opacity-50','cursor-not-allowed'); 
				}else{ 
					b.disabled=true; 
					b.classList.add('opacity-50','cursor-not-allowed'); 
				}
			};
			
			[k,g].forEach(c => c.addEventListener('change', check));
			
			b.addEventListener('click', async () => {
				if (supabaseClient) {
					// 💡 [실전 가동] 클릭 즉시 실제 구글 로그인 팝업 창을 띄워 구글 계정 정보를 가져옵니다!
					await supabaseClient.auth.signInWithOAuth({
						provider: 'google',
						options: {
							redirectTo: window.location.origin
						}
					});
				} else {
					// 로컬 개발/테스트용 우회 세션 등록 장치
					localStorage.setItem('taerijay_auth_state', 'authorized');
					alert("실제 Supabase DB 연동 전 로컬 가상 구글 간편로그인 세션 등록이 수립되었습니다!");
					window.location.href = '/';
				}
			});
		});
	</script>
</Layout>