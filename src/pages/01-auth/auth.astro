cat > src/pages/01-auth/auth.astro << 'EOF'
---
// src/pages/01-auth/auth.astro
---
<!doctype html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
  <title>Access Gate | TAERIJAY</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=League+Spartan:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <script type="module">
    import { initializeApp } from 'https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js';
    import { getAuth, GoogleAuthProvider, signInWithPopup, onAuthStateChanged }
      from 'https://www.gstatic.com/firebasejs/10.12.2/firebase-auth.js';
    const app = initializeApp({
      apiKey: import.meta.env.PUBLIC_FIREBASE_API_KEY,
      authDomain: 'taerijay-platform.firebaseapp.com',
      projectId: 'taerijay-platform',
    });
    const auth = getAuth(app);
    const provider = new GoogleAuthProvider();
    onAuthStateChanged(auth, (user) => {
      if (user) {
        sessionStorage.setItem('user_email', user.email);
        const redirect = sessionStorage.getItem('auth_redirect') || '/';
        sessionStorage.removeItem('auth_redirect');
        window.location.href = redirect;
      }
    });
    window._authPage = { auth, provider, signInWithPopup };
  </script>
</head>
<body>
  <div class="page">
    <div class="top-logo">
      <span class="logo-text">TAERIJAY</span><span class="logo-plus">+</span>
      <p class="logo-sub">REPUBLIC OF KOREA · PREMIUM ACCESS</p>
    </div>
    <div class="gate-card">
      <div class="status-badge"><span class="status-dot"></span>NOT SIGNED IN</div>
      <h1 class="gate-title">Access Gate</h1>
      <p class="gate-desc">Sign in with your Google account to unlock exclusive Korea travel intelligence.</p>
      <button id="google-btn" class="btn-google">
        <svg class="g-logo" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
          <path fill="#EA4335" d="M24 9.5c3.14 0 5.95 1.08 8.17 2.84l6.1-6.1C34.46 3.05 29.52 1 24 1 14.82 1 7.07 6.55 3.96 14.36l7.09 5.51C12.79 14.04 17.99 9.5 24 9.5z"/>
          <path fill="#4285F4" d="M46.53 24.5c0-1.55-.14-3.06-.4-4.5H24v8.52h12.69c-.56 2.96-2.22 5.47-4.72 7.15l7.27 5.64C43.42 37.51 46.53 31.44 46.53 24.5z"/>
          <path fill="#FBBC05" d="M11.05 28.13A14.55 14.55 0 0 1 9.5 24c0-1.43.25-2.82.55-4.13l-7.09-5.51A23.97 23.97 0 0 0 0 24c0 3.88.93 7.55 2.55 10.82l8.5-6.69z"/>
          <path fill="#34A853" d="M24 47c5.52 0 10.16-1.83 13.54-4.97l-7.27-5.64c-1.81 1.22-4.13 1.93-6.27 1.93-5.99 0-11.08-4.04-12.95-9.47l-8.5 6.69C7.25 42.04 15.06 47 24 47z"/>
        </svg>
        <span class="g-label">CONTINUE<br/>WITH GOOGLE</span>
      </button>
      <div id="error-box" class="error-box" hidden>Sign-in failed. Please try again.</div>
      <p class="legal">By signing in, you agree to our Terms of Service &amp; Privacy Policy.<br/>No password required · Google account only</p>
    </div>
    <a href="/" class="back-link">← Back to TAERIJAY</a>
  </div>
  <script>
    document.getElementById('google-btn').addEventListener('click', async () => {
      const err = document.getElementById('error-box');
      err.hidden = true;
      try {
        const { auth, provider, signInWithPopup } = window._authPage;
        const r = await signInWithPopup(auth, provider);
        sessionStorage.setItem('user_email', r.user.email);
        const redirect = sessionStorage.getItem('auth_redirect') || '/';
        sessionStorage.removeItem('auth_redirect');
        window.location.href = redirect;
      } catch(e) { console.error(e); err.hidden = false; }
    });
  </script>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{--bg:#0A192F;--border:#5B0E1B;--fg:#FBF9F4;--f-display:'Playfair Display',serif;--f-body:'League Spartan',sans-serif}
    html,body{background:var(--bg);color:var(--fg);font-family:var(--f-body);min-height:100vh}
    .page{max-width:480px;margin:0 auto;min-height:100vh;border-left:1px solid var(--border);border-right:1px solid var(--border);display:flex;flex-direction:column;align-items:center;padding:40px 24px 48px}
    .top-logo{text-align:center;margin-bottom:36px}
    .logo-text{font-family:var(--f-display);font-weight:900;font-size:2rem;letter-spacing:.06em}
    .logo-plus{color:var(--border);font-size:2rem;font-weight:900}
    .logo-sub{margin-top:8px;font-size:.7rem;letter-spacing:.14em;font-weight:600;color:#8b96a8}
    .gate-card{width:100%;border:1px solid var(--border);border-radius:18px;padding:28px 24px 32px;background:#0f2240}
    .status-badge{display:inline-flex;align-items:center;gap:8px;border:1px solid var(--border);border-radius:20px;padding:6px 14px;font-size:.72rem;font-weight:700;letter-spacing:.08em;margin-bottom:24px}
    .status-dot{width:7px;height:7px;border-radius:50%;background:var(--border)}
    .gate-title{font-family:var(--f-display);font-weight:700;font-size:1.7rem;margin-bottom:12px}
    .gate-desc{font-size:.88rem;line-height:1.65;color:#9aa5b5;margin-bottom:28px}
    .btn-google{width:100%;display:flex;align-items:center;gap:20px;background:#3a0d1a;border:1px solid var(--border);border-radius:14px;padding:20px 24px;cursor:pointer;transition:background .2s}
    .btn-google:hover{background:#4a1222}
    .g-logo{width:64px;height:64px;flex-shrink:0}
    .g-label{font-family:var(--f-body);font-weight:800;font-size:1.05rem;letter-spacing:.08em;color:var(--fg);line-height:1.3;text-align:left}
    .error-box{margin-top:14px;padding:14px 18px;border:1px solid var(--border);border-radius:10px;color:#F16B24;font-size:.84rem;font-weight:600;text-align:center}
    .legal{margin-top:20px;font-size:.72rem;color:#6b7789;line-height:1.7;text-align:center}
    .back-link{margin-top:28px;font-size:.8rem;font-weight:600;color:#8b96a8;text-decoration:none;letter-spacing:.04em}
    .back-link:hover{color:var(--fg)}
  </style>
</body>
</html>
EOF