---
interface Props {
	title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<!-- 💡 1. 한글 고정 기본값 설정 & 자동 번역기에 의한 폰트 깨짐 강제 방지 -->
<html lang="ko" translate="no" class="h-full scroll-smooth select-none">
	<head>
		<meta charset="UTF-8" />
		<meta name="google" content="notranslate" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
		<title>{title}</title>
		
		<!-- 💡 2. 대표님의 영문 오리지널 폰트(League Spartan) 및 Noto Sans 구글 웹폰트 완벽 재탑재 -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=League+Spartan:wght@400;600;700;800;900&family=Noto+Sans+KR:wght@300;400;500;700;900&display=swap" rel="stylesheet">
		
		<script is:inline src="https://cdn.tailwindcss.com"></script>
		<script is:inline>
			tailwind.config = {
				theme: {
					extend: {
						colors: {
							baseBg: '#0A192F',
							brandBorder: '#5B0E1B',
							neonCyan: '#00F0FF',
							neonOrange: '#FF6B00',
							neonYellow: '#FFFB00',
							neonRed: '#FF2E2E',
							neonGreen: '#00FF66',
							neonPurple: '#E000FF',
							masterBurgundy: '#990011',
						},
						// 💡 꼬였던 폰트 패밀리 매핑 복구 및 한/영 분리 설정
						fontFamily: {
							'spartan': ['"League Spartan"', 'sans-serif'],
							'noto': ['"Noto Sans KR"', 'sans-serif']
						}
					}
				}
			}
		</script>
		<style>
			html, body {
				height: 100%;
				background-color: #0A192F;
				-webkit-font-smoothing: antialiased;
				-moz-osx-font-smoothing: grayscale;
				text-rendering: optimizeLegibility;
			}
			body {
				/* 💡 한글은 Noto Sans KR로 고정해 맑고 가독성 있게 표현 */
				font-family: "Noto Sans KR", sans-serif;
				word-break: keep-all;
				overflow-wrap: anywhere;
			}
			/* 💡 대표님이 극찬하셨던 그 웅장하고 세련된 시그니처 자간 세팅 복구 */
			.font-spartan {
				font-family: "League Spartan", sans-serif;
				letter-spacing: 0.08em;
			}
		</style>
	</head>
	<body class="bg-[#0A192F] text-[#FBF9F4] flex flex-col min-h-screen">
		<slot />
	</body>
</html>