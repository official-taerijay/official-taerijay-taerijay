---
import Layout from '../layouts/Layout.astro';
---

<Layout title="TAERIJAY+">
	<main class="w-full min-h-screen bg-[#0A192F] flex flex-col relative pb-24 overflow-x-hidden font-noto">
		
		<!-- TOP HEADER CONTROL BAR -->
		<header class="w-full px-6 md:px-12 py-4 border-b border-[#5B0E1B] bg-[#0A192F]/95 backdrop-blur sticky top-0 z-50 flex items-center justify-between">
			<button id="menuTrigger" class="text-white hover:text-[#00F0FF] transition-colors p-2 -ml-2">
				<svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 md:h-8 md:w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
					<path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
				</svg>
			</button>

			<div class="flex flex-col items-center absolute left-1/2 transform -translate-x-1/2">
				<span class="font-spartan text-2xl md:text-4xl font-black tracking-widest text-white leading-none uppercase">TAERIJAY+</span>
			</div>
			
			<!-- 네 번째 스냅샷 지시: 4단계 스위칭 간편인증 통합 버튼 -->
			<button id="authBtn" class="px-3 md:px-5 py-1.5 md:py-2 border border-[#5B0E1B] rounded bg-[#5B0E1B]/30 hover:bg-[#5B0E1B]/60 text-white text-xs font-black uppercase font-spartan tracking-wider transition-all shadow-md">
				Google Login
			</button>
		</header>

		<!-- SIDEBAR OVERLAY DRAWER -->
		<div id="sideDrawer" class="fixed inset-0 z-50 bg-black/80 backdrop-blur-sm hidden justify-start w-full transition-opacity duration-300">
			<div class="w-[320px] h-full bg-[#071120] border-r border-[#5B0E1B] p-6 flex flex-col gap-6 relative shadow-2xl overflow-y-auto font-noto">
				<div class="flex items-center justify-between border-b border-[#5B0E1B] pb-4">
					<span class="font-spartan text-lg font-black tracking-widest text-[#00F0FF] uppercase">CHANNELS</span>
					<button id="menuCloser" class="text-slate-400 hover:text-white text-3xl font-light leading-none">&times;</button>
				</div>
				
				<nav class="flex flex-col gap-3 font-bold text-sm">
					<button class="channel-nav-link w-full text-left p-3.5 rounded border border-[#5B0E1B]/60 bg-[#0A192F] text-white hover:border-white transition-all font-playfair font-black tracking-wider uppercase text-base" data-idx="0">0. TAERIJAY</button>
					<button class="channel-nav-link w-full text-left p-3.5 rounded border border-[#5B0E1B]/40 bg-[#0A192F] text-[#00F0FF] hover:border-[#00F0FF] transition-all text-base lowercase" data-idx="1">1. taerijay+entertainment</button>
					<button class="channel-nav-link w-full text-left p-3.5 rounded border border-[#5B0E1B]/40 bg-[#0A192F] text-[#FF6B00] hover:border-[#FF6B00] transition-all text-base lowercase" data-idx="2">2. taerijay+protocol</button>
					<button class="channel-nav-link w-full text-left p-3.5 rounded border border-[#5B0E1B]/40 bg-[#0A192F] text-[#FBF9F4] hover:border-white transition-all text-base lowercase" data-idx="3">3. taerijay+mini</button>
					<button class="channel-nav-link w-full text-left p-3.5 rounded border border-[#5B0E1B]/40 bg-[#0A192F] text-[#FF2E2E] hover:border-[#FF2E2E] transition-all text-base lowercase" data-idx="4">4. taerijay+daiso</button>
					<button class="channel-nav-link w-full text-left p-3.5 rounded border border-[#5B0E1B]/40 bg-[#0A192F] text-[#6F8B2E] hover:border-[#6F8B2E] transition-all text-base lowercase" data-idx="5">5. taerijay+oliveyoung</button>
					<button class="channel-nav-link w-full text-left p-3.5 rounded border border-[#5B0E1B]/40 bg-[#0A192F] text-[#FFFB00] hover:border-[#FFFB00] transition-all text-base lowercase" data-idx="6">6. taerijay+emart</button>
					<button class="channel-nav-link w-full text-left p-3.5 rounded border border-[#5B0E1B]/40 bg-[#0A192F] text-[#A14D7C] hover:border-[#A14D7C] transition-all text-base lowercase" data-idx="7">7. taerijay+convenience</button>
				</nav>
				<div class="mt-auto border-t border-[#5B0E1B] pt-4 text-center">
					<span class="text-xs text-slate-400 font-mono" id="drawerUserBadge">STATUS: GUEST_MODE</span>
				</div>
			</div>
		</div>

		<!-- HERO MASTHEAD SECTION -->
		<section class="w-full relative px-6 md:px-12 py-16 md:py-24 border-b border-[#5B0E1B] bg-gradient-to-b from-[#0e2544] to-[#0A192F] overflow-hidden">
			<div class="absolute inset-0 bg-cover bg-center opacity-20 mix-blend-overlay" style="background-image: url('https://images.unsplash.com/photo-1538481199705-c710c4e965fc?auto=format&fit=crop&w=1920&q=80');"></div>
			<div class="relative z-10 max-w-7xl mx-auto flex flex-col items-center md:items-start text-center md:text-left">
				<div class="inline-flex items-center gap-1.5 bg-[#5B0E1B] border border-[#5B0E1B] px-4 py-1.5 rounded-full mb-6 shadow-xl">
					<span class="w-2.5 h-2.5 rounded-full bg-red-500 animate-pulse"></span>
					<span class="text-xs font-spartan tracking-widest text-white uppercase font-black">SYSTEM LIVE ACTIVE</span>
				</div>
				<!-- 네 번째 스냅샷 지시: 메인 헤드라인 가독성 및 1:1 한영 배치 -->
				<h1 class="text-3xl md:text-5xl lg:text-6xl font-black tracking-tight mb-4 text-white uppercase font-spartan">
					프리미엄 한국 여행 데이터베이스 개방함 <br/>
					<span class="text-slate-400 font-light block mt-2 text-2xl md:text-4xl normal-case">Unlocking Premium K-Heritage</span>
				</h1>
				<p class="text-base md:text-lg text-slate-200 font-light max-w-3xl leading-relaxed drop-shadow">
					Access restricted curated database representing prime destination flow blueprints. <br class="hidden md:block"/>
					Use hamburger menu infrastructure to navigate pipelines.
				</p>
			</div>
		</section>

		<!-- DISNEY+ SCROLLER ROW -->
		<section class="w-full py-12 flex flex-col gap-8">
			<div class="w-full max-w-[1600px] mx-auto flex flex-col gap-6">
				<div class="px-6 md:px-12 flex items-center justify-between font-spartan">
					<h3 class="text-lg md:text-2xl font-black uppercase tracking-widest text-white flex items-center gap-3">
						<span class="w-2.5 h-7 bg-[#5B0E1B] rounded-sm"></span>
						<span>Exclusive Master Pipelines Track</span>
					</h3>
				</div>

				<div class="w-full overflow-x-auto flex gap-6 px-6 md:px-12 py-4 no-scrollbar snap-x snap-mandatory scroll-smooth" id="masterSliderTrack">
					
					<!-- CARD 1: ENTERTAINMENT -->
					<div class="min-w-[85vw] md:min-w-[420px] lg:min-w-[480px] snap-center shrink-0 rounded-xl border border-[#5B0E1B] bg-[#0A192F] overflow-hidden flex flex-col transition-all duration-300 hover:scale-[1.02]" id="slider-card-1">
						<div class="px-5 py-4 bg-[#061224] border-b border-[#5B0E1B] flex items-center justify-between">
							<span class="text-base md:text-xl font-black text-[#00F0FF] lowercase tracking-wider">taerijay+entertainment</span>
							<span class="text-xs text-[#00F0FF] font-bold uppercase font-spartan">🌐 ott bridge</span>
						</div>
						<div class="p-6 flex flex-col gap-5 flex-grow bg-[#0A192F]">
							<h3 class="text-lg font-bold text-white tracking-tight flex items-center gap-2"><span>🎬</span><span>official video bridge hub</span></h3>
							
							<div class="flex flex-col gap-2 border-l-2 border-[#00F0FF] pl-3 text-base">
								<p class="text-white font-medium">드라마, 영화, 예능, 대표님 유튜브 채널 트래픽 허브 연계함.</p>
								<p class="text-slate-400 font-light text-sm font-spartan">Explore K-content, original films, and outbound looping parameters.</p>
							</div>
							
							<div class="flex flex-col gap-2.5 p-3 border-2 border-[#00F0FF] rounded-xl bg-transparent">
								<div class="ep-row flex items-center justify-between p-2 rounded bg-transparent border border-[#5B0E1B]/50 cursor-pointer hover:bg-[#00F0FF]/10 text-sm transition-all" data-preview="true" data-url="https://www.youtube.com/@taerijay">
									<span class="text-slate-200 truncate font-mono">EP 01. Origin of K-Heritage</span>
									<span class="text-xs px-3 py-1 bg-emerald-900 text-emerald-300 rounded font-black tracking-widest">FREE</span>
								</div>
								<div class="ep-row flex items-center justify-between p-2 rounded bg-transparent border border-[#5B0E1B]/50 cursor-pointer hover:bg-black/40 text-sm opacity-60 transition-all" data-preview="false">
									<span class="text-slate-400 truncate font-mono">EP 13. Deep Forest Circuit</span>
									<span class="text-xs px-3 py-1 bg-[#5B0E1B] text-white rounded font-black tracking-widest">LOCK</span>
								</div>
							</div>

							<div class="pt-4 border-t border-[#5B0E1B]/30 flex flex-col gap-3 mt-auto font-spartan">
								<div class="flex items-center justify-between gap-3">
									<div class="flex items-center gap-2 min-w-0">
										<span class="text-base">📍</span>
										<span class="text-sm text-slate-200 font-mono truncate" id="addr-1">Central Hub Video Stream Station</span>
									</div>
									<button class="copy-btn shrink-0 bg-[#5B0E1B]/30 border border-[#5B0E1B] text-white px-4 py-1.5 rounded hover:bg-[#5B0E1B] text-xs font-black tracking-wider transition-all" data-target="addr-1">COPY</button>
								</div>
								<div class="grid grid-cols-3 gap-2 pt-1">
									<a href="https://maps.google.com" target="_blank" class="bg-[#071120] border border-[#5B0E1B]/50 text-center py-1 rounded text-[10px] text-slate-400 hover:text-white transition-all">GOOGLE MAP</a>
									<a href="https://map.naver.com" target="_blank" class="bg-[#071120] border border-[#5B0E1B]/50 text-center py-1 rounded text-[10px] text-slate-400 hover:text-white transition-all">NAVER MAP</a>
									<a href="https://map.kakao.com" target="_blank" class="bg-[#071120] border border-[#5B0E1B]/50 text-center py-1 rounded text-[10px] text-slate-400 hover:text-white transition-all">KAKAO MAP</a>
								</div>
							</div>
						</div>
					</div>

					<!-- CARD 2: PROTOCOL -->
					<div class="min-w-[85vw] md:min-w-[420px] lg:min-w-[480px] snap-center shrink-0 rounded-xl border border-[#5B0E1B] bg-[#0A192F] overflow-hidden flex flex-col transition-all duration-300 hover:scale-[1.02]" id="slider-card-2">
						<div class="px-5 py-4 bg-[#061224] border-b border-[#5B0E1B] flex items-center justify-between">
							<span class="text-base md:text-xl font-black text-[#FF6B00] lowercase tracking-wider">taerijay+protocol</span>
							<span class="text-xs text-[#FF6B00] font-bold uppercase font-spartan">🌐 rule</span>
						</div>
						<div class="p-6 flex flex-col gap-5 flex-grow bg-[#0A192F]">
							<h3 class="text-lg font-bold text-white tracking-tight flex items-center gap-2"><span>🌐</span><span>Global Traveler Code & Security Matrix</span></h3>
							
							<div class="flex flex-col gap-2 border-l-2 border-[#FF6B00] pl-3 text-base">
								<p class="text-white font-medium">해외 입국객 필수 공항 세관 및 대중교통 탑승 10대 안전 수칙 명시함.</p>
								<p class="text-slate-400 font-light text-sm font-spartan">Legal security frameworks and 316 restricted code items initialization.</p>
							</div>

							<div class="flex flex-col gap-2.5 p-3 border-2 border-[#FF6B00] rounded-xl bg-transparent">
								<div class="flex items-center justify-between p-2 text-sm font-mono text-slate-200">
									<span>SEC. 01 Customs Dec</span>
									<span class="text-xs px-3 py-1 bg-emerald-900 text-emerald-300 rounded font-black">FREE</span>
								</div>
							</div>

							<div class="pt-4 border-t border-[#5B0E1B]/30 flex flex-col gap-3 mt-auto font-spartan">
								<div class="flex items-center justify-between gap-3">
									<div class="flex items-center gap-2 min-w-0">
										<span class="text-base">📍</span>
										<span class="text-sm text-slate-200 font-mono truncate" id="addr-2">Incheon International Airport Terminal 1 & 2</span>
									</div>
									<button class="copy-btn shrink-0 bg-[#5B0E1B]/30 border border-[#5B0E1B] text-white px-4 py-1.5 rounded hover:bg-[#5B0E1B] text-xs font-black tracking-wider transition-all" data-target="addr-2">COPY</button>
								</div>
								<div class="grid grid-cols-3 gap-2 pt-1">
									<a href="https://maps.google.com" target="_blank" class="bg-[#071120] border border-[#5B0E1B]/50 text-center py-1 rounded text-[10px] text-slate-400 hover:text-white transition-all">GOOGLE MAP</a>
									<a href="https://map.naver.com" target="_blank" class="bg-[#071120] border border-[#5B0E1B]/50 text-center py-1 rounded text-[10px] text-slate-400 hover:text-white transition-all">NAVER MAP</a>
									<a href="https://map.kakao.com" target="_blank" class="bg-[#071120] border border-[#5B0E1B]/50 text-center py-1 rounded text-[10px] text-slate-400 hover:text-white transition-all">KAKAO MAP</a>
								</div>
							</div>
						</div>
					</div>

				</div>
			</div>
		</section>

		<!-- 세 번째 스냅샷 지시: 12개월 프리미엄 패스 타이틀 고시인성 개조 및 한글 고정화 -->
		<section class="w-full px-6 md:px-12 py-16 bg-gradient-to-b from-[#0A192F] to-[#050f1a] border-t border-[#5B0E1B] mt-auto">
			<div class="text-center mb-12 font-spartan">
				<h2 class="text-3xl md:text-5xl font-black mb-2 text-white uppercase">
					12개월 프리미엄 활성화 패스 수립함
				</h2>
				<p class="text-base text-slate-400 max-w-2xl mx-auto font-light normal-case">
					12 Months Premium Activation Pass. Choose custom 1-year access parameters loop.
				</p>
			</div>
			
			<div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 max-w-7xl mx-auto mb-8 font-spartan">
				<!-- TIER 1: BASIC (마크배색: 화이트) -->
				<div class="rounded-xl border border-white bg-[#071120]/90 p-6 md:p-8 flex flex-col justify-between relative overflow-hidden transition-all duration-300 hover:scale-[1.03]">
					<div>
						<span class="text-[11px] font-black uppercase text-slate-400 tracking-widest">Basic Pass (단일 요금제)</span>
						<div class="text-3xl lg:text-4xl font-black text-white mt-2 mb-4">$19.99 <span class="text-sm text-slate-500 font-normal">/ 1 Years</span></div>
						
						<!-- 지시사항: 한글 고정 절대값 x 영문 동적 추적 1:1 배치 -->
						<div class="border-t border-white/20 pt-4 flex flex-col gap-4 text-sm font-light text-slate-200">
							<div class="flex flex-col gap-0.5"><p class="text-white font-medium">1개 구글 아이디 연동함.</p><p class="text-slate-400 text-xs lowercase">1 google account integrated.</p></div>
							<div class="flex flex-col gap-0.5"><p class="text-white font-medium">1개 디바이스 등록 제한함.</p><p class="text-slate-400 text-xs lowercase">1 registered device limitation active.</p></div>
							<div class="flex flex-col gap-0.5"><p class="text-white font-medium">동시접속 해당 없음 명시함.</p><p class="text-slate-400 text-xs lowercase">concurrent stream sessions not applicable.</p></div>
						</div>
					</div>
					<button class="pay-btn w-full py-3 bg-white/10 hover:bg-white hover:text-black border border-white text-white rounded text-xs font-black uppercase tracking-wider transition-all mt-8" data-amount="19.99">Activate Basic Plan</button>
				</div>

				<!-- TIER 2: STANDARD (마크배색: 네온 그린) -->
				<div class="rounded-xl border border-[#00FF66] bg-[#071120]/90 p-6 md:p-8 flex flex-col justify-between relative overflow-hidden transition-all duration-300 hover:scale-[1.03]">
					<div>
						<span class="text-[11px] font-black uppercase text-slate-400 tracking-widest">Standard Pass (단일 요금제)</span>
						<div class="text-3xl lg:text-4xl font-black text-[#00FF66] mt-2 mb-4">$29.99 <span class="text-sm text-slate-500 font-normal">/ 1 Years</span></div>
						
						<div class="border-t border-[#00FF66]/20 pt-4 flex flex-col gap-4 text-sm font-light text-slate-200">
							<div class="flex flex-col gap-0.5"><p class="text-white font-medium">1개 구글 아이디 연동함.</p><p class="text-slate-400 text-xs lowercase">1 google account integrated.</p></div>
							<div class="flex flex-col gap-0.5"><p class="text-white font-medium">2개 디바이스 등록 제공함.</p><p class="text-slate-400 text-xs lowercase">2 registered devices tracking provided.</p></div>
							<div class="flex flex-col gap-0.5"><p class="text-white font-medium">동시접속 2개 디바이스 허용함.</p><p class="text-slate-400 text-xs lowercase">concurrent multi-terminal streaming permitted.</p></div>
						</div>
					</div>
					<button class="pay-btn w-full py-3 bg-[#00FF66]/10 hover:bg-[#00FF66] hover:text-black border border-[#00FF66] text-[#00FF66] rounded text-xs font-black uppercase tracking-wider transition-all mt-8" data-amount="29.99">Activate Standard Plan</button>
				</div>

				<!-- TIER 3: PRO (마크배색: 네온 오렌지) -->
				<div class="rounded-xl border border-[#FF6B00] bg-[#071120]/90 p-6 md:p-8 flex flex-col justify-between relative overflow-hidden transition-all duration-300 hover:scale-[1.03]">
					<div>
						<span class="text-[11px] font-black uppercase text-slate-400 tracking-widest">Pro Pass (단일 요금제)</span>
						<div class="text-3xl lg:text-4xl font-black text-[#FF6B00] mt-2 mb-4">$39.99 <span class="text-sm text-slate-500 font-normal">/ 1 Years</span></div>
						
						<div class="border-t border-[#FF6B00]/20 pt-4 flex flex-col gap-4 text-sm font-light text-slate-200">
							<div class="flex flex-col gap-0.5"><p class="text-white font-medium">1개 구글 아이디 연동함.</p><p class="text-slate-400 text-xs lowercase">1 google account integrated.</p></div>
							<div class="flex flex-col gap-0.5"><p class="text-white font-medium">3개 디바이스 등록 제공함.</p><p class="text-slate-400 text-xs lowercase">3 registered devices tracking provided.</p></div>
							<div class="flex flex-col gap-0.5"><p class="text-white font-medium">동시접속 3개 디바이스 허용함.</p><p class="text-slate-400 text-xs lowercase">concurrent multi-terminal streaming permitted.</p></div>
						</div>
					</div>
					<button class="pay-btn w-full py-3 bg-[#FF6B00]/10 hover:bg-[#FF6B00] hover:text-black border border-[#FF6B00] text-[#FF6B00] rounded text-xs font-black uppercase tracking-wider transition-all mt-8" data-amount="39.99">Activate Pro Plan</button>
				</div>
			</div>

			<!-- SPLIT COMBINATION TIERS -->
			<div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8 max-w-5xl mx-auto font-spartan">
				<!-- TIER 4: DOUBLE VALUE (마크배색: 네온 일렉트릭 퍼플) -->
				<div class="rounded-xl border border-[#E000FF] bg-[#071120]/90 p-6 md:p-8 flex flex-col justify-between relative overflow-hidden transition-all duration-300 hover:scale-[1.03]">
					<div>
						<span class="text-[11px] font-black uppercase text-slate-400 tracking-widest">Double Value Pass (더블 요금제)</span>
						<div class="text-3xl font-black text-[#E000FF] mt-2 mb-4">$34.99 <span class="text-sm text-slate-500 font-normal">/ 1 Years</span></div>
						
						<div class="border-t border-[#E000FF]/20 pt-4 flex flex-col gap-4 text-sm font-light text-slate-200">
							<div class="flex flex-col gap-2"><p class="text-white font-medium">6개 서비스 중 원하는 채널 2개 직접 커스텀 조합하여 인가함.</p><p class="text-slate-400 text-xs lowercase">select 2 premium channels freely from 6 core pipelines.</p></div>
							<div class="flex flex-wrap gap-2 pt-2">
								<span class="px-2 py-0.5 bg-[#071120] border border-[#E000FF]/40 rounded text-[10px] text-white">protocol × mini</span>
								<span class="px-2 py-0.5 bg-[#071120] border border-[#E000FF]/40 rounded text-[10px] text-white">daiso x oliveyoung</span>
								<span class="px-2 py-0.5 bg-[#071120] border border-[#E000FF]/40 rounded text-[10px] text-white">emart x convenience</span>
							</div>
						</div>
					</div>
					<button class="pay-btn w-full py-3 bg-[#E000FF]/10 hover:bg-[#E000FF] hover:text-black border border-[#E000FF] text-[#E000FF] rounded text-xs font-black uppercase tracking-wider transition-all mt-8" data-amount="34.99">Activate Double Plan</button>
				</div>

				<!-- TIER 5: TOTAL PASS (마크배색: 하이엔드 럭셔리 버건디 고정) -->
				<div class="rounded-xl border-2 border-[#990011] bg-[#0A192F] p-6 md:p-8 flex flex-col justify-between relative overflow-hidden shadow-2xl shadow-[#990011]/50 transition-all duration-300 hover:scale-[1.03] z-10">
