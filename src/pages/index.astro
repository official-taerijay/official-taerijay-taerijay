		};

		document.addEventListener('DOMContentLoaded', () => {
			
			// A. Hamburger Menu Layer Animation Control
			const menuTrigger = document.getElementById('menuTrigger');
			const sideDrawer = document.getElementById('sideDrawer');
			const menuCloser = document.getElementById('menuCloser');
			const navLinks = document.querySelectorAll('.channel-nav-link');

			menuTrigger.addEventListener('click', () => {
				sideDrawer.classList.remove('hidden');
				sideDrawer.classList.add('flex');
			});

			const closeMenu = () => {
				sideDrawer.classList.add('hidden');
				sideDrawer.classList.remove('flex');
			};

			menuCloser.addEventListener('click', closeMenu);
			sideDrawer.addEventListener('click', (e) => {
				if (e.target === sideDrawer) closeMenu();
			});

			// B. Dynamic Channel Injection Display Controller
			const coreDisplaySection = document.getElementById('coreDisplaySection');
			const channelContentWrapper = document.getElementById('channelContentWrapper');
			
			const cardBrandHeader = document.getElementById('cardBrandHeader');
			const cardHeaderTitle = document.getElementById('cardHeaderTitle');
			const cardHeaderBadge = document.getElementById('cardHeaderBadge');
			const cardBannerBg = document.getElementById('cardBannerBg');
			const cardBannerTag = document.getElementById('cardBannerTag');
			const cardSubCategory = document.getElementById('cardSubCategory');
			const cardMainTitle = document.getElementById('cardMainTitle');
			const cardDescription = document.getElementById('cardDescription');
			const cardAddressText = document.getElementById('cardAddressText');
			const gatingScrollerZone = document.getElementById('gatingScrollerZone');

			navLinks.forEach(link => {
				link.addEventListener('click', () => {
					const channelKey = link.dataset.target;
					const data = channelDatabase[channelKey];
					
					if (data) {
						coreDisplaySection.classList.add('hidden');
						channelContentWrapper.classList.remove('hidden');
						channelContentWrapper.classList.add('flex');

						// Override dynamic colors, borders, titles text
						cardHeaderTitle.textContent = data.title;
						cardHeaderTitle.style.color = data.color;
						cardHeaderBadge.textContent = data.badge;
						cardBannerBg.style.backgroundImage = `url('${data.img}')`;
						cardBannerTag.textContent = data.tag;
						cardBannerTag.style.backgroundColor = data.color;
						cardBannerTag.style.color = (data.color === '#FBF9F4' || data.color === '#FFDD00') ? '#0A192F' : '#FBF9F4';
						
						cardSubCategory.textContent = data.cat;
						cardMainTitle.textContent = data.mainTitle;
						cardDescription.textContent = data.desc;
						cardAddressText.textContent = data.addr;

						// Conditional activation for Episode Gating zone
						if (data.gating) {
							gatingScrollerZone.classList.remove('hidden');
						} else {
							gatingScrollerZone.classList.add('hidden');
						}

						closeMenu();
					}
				});
			});

			// C. Master State Switcher Badge Interaction (Register / Login / Logout)
			const authBtn = document.getElementById('authBtn');
			const userEmail = document.getElementById('userEmail');
			const drawerUserBadge = document.getElementById('drawerUserBadge');
			let authState = 0; // 0: Guest, 1: Registering, 2: LoggedIn

			authBtn.addEventListener('click', () => {
				if (authState === 0) {
					// Switch to state 1: Registering/Signing Up process
					authBtn.textContent = 'Registering';
					authBtn.className = "px-2.5 py-1.5 border border-[#FFDD00] rounded bg-amber-500/20 text-[#FFDD00] text-[10px] font-bold uppercase tracking-wider transition-all shadow";
					authState = 1;
				} else if (authState === 1) {
					// Switch to state 2: Verified Active VIP Session Logged In
					userEmail.textContent = 'active-vip@taerijay.com';
					drawerUserBadge.textContent = 'Session: active-vip@taerijay.com';
					authBtn.textContent = 'Logout';
					authBtn.className = "px-2.5 py-1.5 border border-emerald-600 rounded bg-emerald-800 text-white text-[10px] font-bold uppercase tracking-wider transition-all shadow";
					authState = 2;
				} else {
					// Return to default state 0: Guest Sign Out
					userEmail.textContent = 'guest@taerijay.com';
					drawerUserBadge.textContent = 'Session: guest@taerijay.com';
					authBtn.textContent = 'Google Login';
					authBtn.className = "px-2.5 py-1.5 border border-[#5B0E1B] rounded bg-[#5B0E1B]/30 hover:bg-[#5B0E1B]/60 text-slate-200 text-[10px] font-bold uppercase tracking-wider transition-all shadow";
					authState = 0;
				}
			});

			// D. One-Touch Copy Engine
			const cardCopyBtn = document.getElementById('cardCopyBtn');
			cardCopyBtn.addEventListener('click', () => {
				navigator.clipboard.writeText(cardAddressText.textContent)
					.then(() => {
						const originalText = cardCopyBtn.textContent;
						cardCopyBtn.textContent = 'COPIED!';
						cardCopyBtn.classList.add('bg-emerald-900', 'border-emerald-600');
						setTimeout(() => {
							cardCopyBtn.textContent = originalText;
							cardCopyBtn.classList.remove('bg-emerald-900', 'border-emerald-600');
						}, 1500);
					});
			});

			// E. Paddle Trigger Simulation
			const payBtn = document.getElementById('payBtn');
			const checkoutModal = document.getElementById('modal-checkout');
			payBtn.addEventListener('click', () => {
				checkoutModal.classList.remove('hidden');
				checkoutModal.classList.add('flex');
			});

			// F. Episode Locking Gating Trigger Matrix
			const epRows = document.querySelectorAll('.ep-row');
			const gatingModal = document.getElementById('modal-gating');
			epRows.forEach(row => {
				row.addEventListener('click', () => {
					if (row.dataset.preview === 'true') {
						window.open(row.dataset.url, '_blank');
					} else {
						gatingModal.classList.remove('hidden');
						gatingModal.classList.add('flex');
					}
				});
			});

			// G. General Modals Closure System
			const modalOverlays = document.querySelectorAll('.modal-overlay');
			const modalTriggers = document.querySelectorAll('.modal-trigger');
			const modalClosers = document.querySelectorAll('.modal-close');

			modalTriggers.forEach(trig => {
				trig.addEventListener('click', () => {
					document.getElementById(trig.dataset.target).classList.remove('hidden');
					document.getElementById(trig.dataset.target).classList.add('flex');
				});
			});

			modalClosers.forEach(closer => {
				closer.addEventListener('click', () => {
					const overlay = closer.closest('.modal-overlay');
					overlay.classList.add('hidden');
					overlay.classList.remove('flex');
				});
			});

			modalOverlays.forEach(overlay => {
				overlay.addEventListener('click', (e) => {
					if (e.target === overlay) {
						overlay.classList.add('hidden');
						overlay.classList.remove('flex');
					}
				});
			});

		});
	</script>
</Layout>