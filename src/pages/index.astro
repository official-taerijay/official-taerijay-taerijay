---
const channels = [
  { slug: 'entertainment', label: 'entertainment', color: '#00E5FF', free: true,  desc: '엔터테인먼트 매치업 정보',   descEn: 'K-content spot guide' },
  { slug: 'protocol',      label: 'protocol',      color: '#F16B24', free: false, desc: '공항·세관·대중교통 규약',     descEn: 'Airport & transit rules' },
  { slug: 'mini',          label: 'mini',          color: '#e8e4dc', free: false, desc: '큐레이션 여행 코스',          descEn: 'Curated travel courses' },
  { slug: 'daiso',         label: 'daiso',         color: '#E1261C', free: false, desc: '다이소 뷰티 대란템 DB',       descEn: 'Daiso beauty best-sellers' },
  { slug: 'oliveyoung',    label: 'oliveyoung',    color: '#6F8B2E', free: false, desc: 'MZ 스킨케어 트렌드',          descEn: 'Skincare trend DB' },
  { slug: 'emart',         label: 'emart',         color: '#FFDD00', free: false, desc: '이마트 쇼핑 스펙 DB',         descEn: 'E-Mart shopping specs' },
  { slug: 'convenience',   label: 'convenience',   color: '#A14D7C', free: false, desc: '편의점 PB 꿀조합 가이드',     descEn: 'CVS combo guide' },
];

const doublePlans = [
  { a: channels[1], b: channels[2], price: '34.99' }, // protocol x mini
  { a: channels[3], b: channels[4], price: '34.99' }, // daiso x oliveyoung
  { a: channels[5], b: channels[6], price: '34.99' }, // emart x convenience
];

const socialLinks = [
  { name: 'YouTube',  icon: '▶' },
  { name: 'Instagram', icon: '◎' },
  { name: 'TikTok',    icon: '♪' },
  { name: 'Google Blog', icon: 'G' },
  { name: 'Naver Blog',  icon: 'N' },
];
---
<!doctype html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>TAERIJAY</title>
  <meta name="description" content="TAERIJAY — 검증된 한국 여행/라이프스타일 정보 스트리밍" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,900;1,600&family=League+Spartan:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
</head>
<body>
  <div id="splash" class="splash"><span class="splash-brand">TAERIJAY</span></div>

  <header class="nav" id="nav">
    <div class="nav-inner">
      <button class="hamburger" id="hamburger-btn" aria-label="메뉴">
        <span></span><span></span><span></span>
      </button>
      <div class="nav-right">
        <button class="btn-text" disabled title="준비 중입니다">Sign Up</button>
        <button class="btn-text" disabled title="준비 중입니다">Log In</button>
      </div>
    </div>
  </header>

  <div class="side-menu" id="side-menu" hidden>
    <div class="side-menu-inner">
      <button class="side-close" id="side-close">×</button>
      <a href="/" class="side-logo">TAERIJAY</a>
      <nav class="side-links">
        {channels.map((ch) => (
          <a href={`/04-channels/${ch.slug}`} style={`--c:${ch.color}`}>taerijay+{ch.label}</a>
        ))}
      </nav>
    </div>
  </div>

  <main>
    <section class="hero">
      <div class="hero-bg"></div>
      <div class="hero-scrim"></div>
      <div class="hero-content">
        <p class="hero-eyebrow">TAERIJAY REPUBLIC OF KOREA</p>
        <div class="hero-cta-row">
          <button class="btn-primary" onclick="document.getElementById('plans').scrollIntoView({behavior:'smooth'})">PRICING</button>
          <button class="btn-ghost" onclick="document.getElementById('channels').scrollIntoView({behavior:'smooth'})">CHANNELS</button>
        </div>
      </div>
    </section>

    <!-- ══════════ 채널 섹션: 시그니처 컬러 카드 ══════════ -->
    <section class="channels-section" id="channels">
      <div class="channel-grid">
        {channels.map((ch) => (
          <a href={`/04-channels/${ch.slug}`} class="service-card" style={`--c:${ch.color}`}>
            <span class={`service-status ${ch.free ? 'status-free' : 'status-soon'}`}>
              {ch.free ? 'FREE' : 'SOON'}
            </span>
            <span class="service-name">taerijay+{ch.label}</span>
            <span class="service-desc-kr">{ch.desc}</span>
            <span class="service-desc-en">{ch.descEn}</span>
          </a>
        ))}
      </div>
    </section>

    <!-- ══════════ 요금제 섹션 ══════════ -->
    <section class="plans-section" id="plans">
      <p class="plans-eyebrow">요금 선택 · SELECT TIER</p>

      <!-- 싱글 요금제: 채널별 시그니처 컬러 -->
      <div class="tier-block">
        <span class="tier-block-label">싱글 요금제 · SINGLE</span>
        <div class="tier-service-grid">
          {channels.filter(ch => !ch.free).map((ch) => (
            <div class="tier-service-card" style={`--c:${ch.color}`}>
              <span class="tier-service-name">taerijay+{ch.label}</span>
              <div class="tier-price-row">
                <div class="tier-price-cell">
                  <span class="tier-price-num">$19.99</span>
                  <span class="tier-price-kr">베이직</span>
                  <span class="tier-price-en">Basic</span>
                </div>
                <div class="tier-price-cell">
                  <span class="tier-price-num">$29.99</span>
                  <span class="tier-price-kr">스탠다드</span>
                  <span class="tier-price-en">Standard</span>
                </div>
                <div class="tier-price-cell">
                  <span class="tier-price-num">$39.99</span>
                  <span class="tier-price-kr">프로</span>
                  <span class="tier-price-en">Pro</span>
                </div>
              </div>
              <p class="tier-service-note">1 ID · 1~4 디바이스 · 동시접속 1~4 (등급별)</p>
            </div>
          ))}
        </div>
      </div>

      <!-- 더블 요금제 -->
      <div class="tier-block">
        <span class="tier-block-label">더블 요금제 · DOUBLE</span>
        {doublePlans.map((dp) => (
          <div class="double-card">
            <div class="double-card-names">
              <span class="double-chip" style={`--c:${dp.a.color}`}>taerijay+{dp.a.label}</span>
              <span class="double-x">×</span>
              <span class="double-chip" style={`--c:${dp.b.color}`}>taerijay+{dp.b.label}</span>
            </div>
            <span class="double-price">${dp.price}</span>
          </div>
        ))}
      </div>

      <!-- 토탈 요금제 -->
      <div class="tier-block">
        <span class="tier-block-label tier-block-label-gold">토탈 요금제 · TOTAL</span>
        <div class="total-card">
          <div class="total-card-names">
            {channels.filter(ch => !ch.free).map((ch) => (
              <span class="total-chip" style={`--c:${ch.color}`}>{ch.label}</span>
            ))}
          </div>
          <div class="total-card-bottom">
            <span class="total-card-note">6개 서비스 전부 · 신규 채널 자동 포함</span>
            <span class="total-price">$99.99</span>
          </div>
        </div>
      </div>
    </section>

    <section class="social-section">
      {socialLinks.map((s) => (
        <a href="#" class="social-icon" title={s.name} aria-label={s.name}>{s.icon}</a>
      ))}
    </section>
  </main>

  <footer class="footer">
    <div class="footer-links">
      <a href="#">이용약관<br/><span class="footer-en">Terms</span></a>
      <a href="#">개인정보<br/><span class="footer-en">Privacy</span></a>
      <a href="#">환불정책<br/><span class="footer-en">Refund</span></a>
      <a href="#">사업자정보<br/><span class="footer-en">Business</span></a>
    </div>
    <p class="footer-copy">© 2026 TAERIJAY · 사업자등록번호 673-51-01148 · taerijay.com</p>
  </footer>

  <script>
    const nav = document.getElementById('nav');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 40) nav.classList.add('nav-scrolled');
      else nav.classList.remove('nav-scrolled');
    });

    const hamburgerBtn = document.getElementById('hamburger-btn');
    const sideMenu = document.getElementById('side-menu');
    const sideClose = document.getElementById('side-close');
    hamburgerBtn.addEventListener('click', () => { sideMenu.hidden = false; });
    sideClose.addEventListener('click', () => { sideMenu.hidden = true; });
    sideMenu.addEventListener('click', (e) => { if (e.target === sideMenu) sideMenu.hidden = true; });

    window.addEventListener('DOMContentLoaded', () => {
      setTimeout(() => {
        const s = document.getElementById('splash');
        if (s) { s.style.opacity = '0'; setTimeout(() => s.remove(), 500); }
      }, 700);
    });
  </script>

  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --bg:#0A192F;--border:#5B0E1B;--ivory:#FBF9F4;--muted:#8b96a8;--dim:#5d6c82;--gold:#D4AF37;--accent:#F16B24;
      --f-display:'Playfair Display',serif;--f-body:'League Spartan',sans-serif;
      --container: min(1200px, 92vw);
    }
    html,body{background:var(--bg);color:var(--ivory);font-family:var(--f-body);min-height:100vh;overflow-x:hidden;scroll-behavior:smooth}
    button{font:inherit}
    a{color:inherit}

    .splash{position:fixed;inset:0;background:var(--bg);display:flex;align-items:center;justify-content:center;z-index:9999;transition:opacity .5s ease}
    .splash-brand{font-family:var(--f-display);font-weight:900;font-size:clamp(1.8rem,6vw,2.6rem);letter-spacing:.06em}

    .nav{position:fixed;top:0;left:0;right:0;z-index:200;transition:background .3s ease,border-color .3s ease}
    .nav-scrolled{background:rgba(10,25,47,.92);backdrop-filter:blur(10px);border-bottom:1px solid rgba(91,14,27,.4)}
    .nav-inner{width:var(--container);margin:0 auto;display:flex;align-items:center;justify-content:space-between;padding:16px 0}
    .hamburger{display:flex;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:6px}
    .hamburger span{display:block;width:22px;height:2px;background:var(--ivory)}
    .nav-right{display:flex;align-items:center;gap:16px}
    .btn-text{background:none;border:none;color:var(--ivory);font-size:.8rem;font-weight:600;letter-spacing:.03em;cursor:not-allowed;opacity:.5}

    .side-menu{position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:300}
    .side-menu-inner{position:absolute;top:0;left:0;height:100%;width:min(320px,80vw);background:#0d1f3d;padding:24px;display:flex;flex-direction:column}
    .side-close{align-self:flex-end;background:none;border:none;color:var(--ivory);font-size:1.8rem;cursor:pointer;margin-bottom:20px}
    .side-logo{font-family:var(--f-display);font-weight:900;font-size:1.3rem;margin-bottom:32px;text-decoration:none}
    .side-links{display:flex;flex-direction:column;gap:18px}
    .side-links a{text-decoration:none;font-size:.9rem;color:var(--c,var(--muted));font-weight:600}

    .hero{position:relative;min-height:64vh;min-height:64dvh;display:flex;align-items:center;overflow:hidden}
    .hero-bg{
      position:absolute;inset:0;
      background:
        radial-gradient(ellipse 90% 60% at 15% 20%, rgba(91,14,27,.55) 0%, transparent 60%),
        radial-gradient(ellipse 70% 50% at 85% 80%, rgba(212,175,55,.12) 0%, transparent 55%),
        linear-gradient(160deg, #0d1f3d 0%, #0A192F 55%, #060f1e 100%);
    }
    .hero-scrim{position:absolute;inset:0;background:linear-gradient(180deg, rgba(10,25,47,.2) 0%, rgba(10,25,47,.4) 55%, var(--bg) 100%)}
    .hero-content{position:relative;z-index:2;width:var(--container);margin:0 auto;text-align:left}
    .hero-eyebrow{font-size:clamp(.8rem,2vw,1rem);letter-spacing:.22em;font-weight:700;color:var(--gold);margin-bottom:34px}
    .hero-cta-row{display:flex;gap:12px;flex-wrap:wrap}
    .btn-primary{background:var(--ivory);color:var(--bg);border:none;border-radius:8px;padding:14px 28px;font-weight:700;font-size:.85rem;letter-spacing:.05em;cursor:pointer;transition:transform .15s,box-shadow .2s}
    .btn-primary:hover{transform:translateY(-2px);box-shadow:0 10px 30px rgba(0,0,0,.35)}
    .btn-ghost{background:rgba(255,255,255,.08);color:var(--ivory);border:1px solid rgba(255,255,255,.25);border-radius:8px;padding:14px 28px;font-weight:700;font-size:.85rem;letter-spacing:.05em;cursor:pointer;transition:background .2s}
    .btn-ghost:hover{background:rgba(255,255,255,.16)}

    /* ── 서비스 선택 카드 (시그니처 컬러) ── */
    .channels-section{width:var(--container);margin:0 auto;padding:56px 0 20px}
    .channel-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
    .service-card{
      position:relative;display:flex;flex-direction:column;gap:6px;text-decoration:none;
      padding:20px 18px;border-radius:14px;
      border:1px solid color-mix(in srgb, var(--c) 45%, transparent);
      background:linear-gradient(160deg, color-mix(in srgb, var(--c) 14%, var(--bg)) 0%, var(--bg) 88%);
      transition:transform .2s ease;
    }
    .service-card:hover{transform:translateY(-3px)}
    .service-status{position:absolute;top:12px;right:12px;font-size:.6rem;font-weight:800;letter-spacing:.06em;padding:3px 9px;border-radius:100px}
    .status-free{background:var(--gold);color:var(--bg)}
    .status-soon{background:rgba(255,255,255,.12);color:var(--muted)}
    .service-name{font-family:var(--f-display);font-weight:700;font-size:1.02rem;color:var(--c);margin-top:6px}
    .service-desc-kr{font-size:.78rem;color:var(--ivory)}
    .service-desc-en{font-size:.7rem;color:var(--dim)}

    /* ── 요금제 섹션 ── */
    .plans-section{width:var(--container);margin:0 auto;padding:60px 0 90px}
    .plans-eyebrow{font-size:.82rem;letter-spacing:.1em;font-weight:700;color:var(--muted);margin-bottom:32px}

    .tier-block{margin-bottom:44px}
    .tier-block-label{display:block;font-size:.78rem;font-weight:700;letter-spacing:.08em;color:var(--muted);text-transform:uppercase;margin-bottom:16px}
    .tier-block-label-gold{color:var(--gold)}

    .tier-service-grid{display:flex;flex-direction:column;gap:14px}
    .tier-service-card{border:1px solid color-mix(in srgb, var(--c) 45%, transparent);border-radius:14px;padding:20px;background:color-mix(in srgb, var(--c) 6%, transparent)}
    .tier-service-name{display:block;font-family:var(--f-display);font-weight:700;font-size:1rem;color:var(--c);margin-bottom:14px}
    .tier-price-row{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
    .tier-price-cell{display:flex;flex-direction:column;gap:2px;border:1px solid rgba(255,255,255,.1);border-radius:10px;padding:12px 14px}
    .tier-price-num{font-family:var(--f-display);font-weight:900;font-size:1.15rem;color:var(--c)}
    .tier-price-kr{font-size:.82rem;font-weight:600;color:var(--ivory)}
    .tier-price-en{font-size:.68rem;color:var(--dim)}
    .tier-service-note{font-size:.7rem;color:var(--dim);margin-top:12px}

    .double-card{display:flex;align-items:center;justify-content:space-between;gap:16px;border:1px solid rgba(91,14,27,.4);border-radius:12px;padding:16px 20px;margin-bottom:10px;flex-wrap:wrap}
    .double-card-names{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
    .double-chip{font-family:var(--f-display);font-weight:700;font-size:.88rem;color:var(--c)}
    .double-x{color:var(--dim);font-size:.8rem}
    .double-price{font-family:var(--f-display);font-weight:900;font-size:1.1rem;color:var(--gold)}

    .total-card{border:1px solid var(--gold);border-radius:14px;padding:22px;background:linear-gradient(160deg, rgba(212,175,55,.1) 0%, rgba(212,175,55,.02) 100%)}
    .total-card-names{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:16px}
    .total-chip{font-size:.74rem;font-weight:700;color:var(--c);border:1px solid var(--c);border-radius:100px;padding:4px 12px}
    .total-card-bottom{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px}
    .total-card-note{font-size:.8rem;color:var(--muted)}
    .total-price{font-family:var(--f-display);font-weight:900;font-size:1.6rem;color:var(--gold)}

    .social-section{width:var(--container);margin:0 auto;padding:20px 0 60px;display:flex;gap:14px;justify-content:center}
    .social-icon{width:42px;height:42px;border-radius:50%;border:1px solid rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;text-decoration:none;font-size:1rem;font-weight:700;transition:background .2s}
    .social-icon:hover{background:rgba(255,255,255,.1)}

    .footer{width:var(--container);margin:0 auto;padding:32px 0 48px;border-top:1px solid rgba(255,255,255,.08);text-align:center}
    .footer-links{display:flex;justify-content:center;gap:28px;flex-wrap:wrap;margin-bottom:16px}
    .footer-links a{text-decoration:none;font-size:.82rem;color:var(--muted);text-align:center;line-height:1.6}
    .footer-en{font-size:.7rem;color:var(--dim)}
    .footer-copy{font-size:.74rem;color:var(--dim)}

    @media (max-width: 900px){
      .channel-grid{grid-template-columns:repeat(2,1fr)}
    }
    @media (max-width: 560px){
      .channel-grid{grid-template-columns:1fr}
      .tier-price-row{grid-template-columns:1fr}
      .double-card{flex-direction:column;align-items:flex-start}
    }

    @media (prefers-reduced-motion: reduce){
      *{transition-duration:.01ms!important;animation-duration:.01ms!important;scroll-behavior:auto!important}
    }
  </style>
</body>
</html>