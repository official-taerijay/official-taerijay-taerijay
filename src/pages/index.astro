---
import Layout from '../layouts/Layout.astro';

const lastUpdateDate = "2026.07.20";
const totalItemCount = 613; 
const monthlyUpdatedCount = 5;
---

<Layout title="TAERIJAY+">
	<main class="w-full min-h-screen bg-[#0A192F] flex flex-col relative pb-24 overflow-x-hidden font-noto">
		
		<!-- TOP MAIN 플랫폼 헤더 -->
		<header class="w-full px-6 md:px-12 py-4 border-b border-[#5B0E1B] bg-[#0A192F]/95 backdrop-blur sticky top-0 z-50 flex items-center justify-between">
			<button id="menuTrigger" class="text-white hover:text-[#00E5FF] transition-colors p-2 -ml-2">
				<svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 md:h-8 md:w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
					<path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
				</svg>
			</button>

			<div class="flex flex-col items-center absolute left-1/2 transform -translate-x-1/2">
				<span class="font-['League_Spartan'] text-2xl md:text-3xl font-black tracking-widest text-transparent bg-clip-text bg-gradient-to-r from-white via-amber-100 to-[#00E5FF] leading-none uppercase">taerijay+</span>
			</div>
			
			<button id="authBtn" class="px-3 md:px-5 py-1.5 md:py-2 border border-[#5B0E1B] rounded bg-[#5B0E1B]/30 hover:bg-[#5B0E1B]/60 text-slate-200 text-[10px] md:text-xs font-black uppercase tracking-wider font-spartan transition-all shadow-md">
				Google Login
			</button>
		</header>

		<!-- 사이드 메뉴 바 드로어 -->
		<div id="sideDrawer" class="fixed inset-0 z-50 bg-black/80 backdrop-blur-sm hidden justify-start w-full transition-opacity duration-300">
			<div class="w-[300px] h-full bg-[#071120] border-r border-[#5B0E1B] p-6 flex flex-col gap-6 relative shadow-2xl overflow-y-auto font-spartan">
				<div class="flex items-center justify-between border-b border-[#5B0E1B] pb-4">
					<span class="text-base md:text-lg font-black tracking-widest text-[#00E5FF] uppercase">Channels</span>
					<button id="menuCloser" class="text-slate-400 hover:text-white text-3xl font-light leading-none">&times;</button>
				</div>
				
				<nav class="flex flex-col gap-3 font-bold text-sm">
					<button class="channel-nav-link w-full text-left p-3 rounded border border-[#5B0E1B]/40 bg-[#0A192F] text-brandBorder hover:bg-[#5B0E1B]/20 transition-all font-['Playfair_Display'] font-black tracking-wider uppercase" data-idx="0">0. TAERIJAY</button>
					<button class="channel-nav-link w-full text-left p-3 rounded border border-[#5B0E1B]/40 bg-[#0A192F] text-[#00E5FF] hover:bg-[#5B0E1B]/20 transition-all lowercase" data-idx="1">1. taerijay+entertainment</button>
					<button class="channel-nav-link w-full text-left p-3 rounded border border-[#5B0E1B]/40 bg-[#0A192F] text-[#F16B24] hover:bg-[#5B0E1B]/20 transition-all lowercase" data-idx="2">2. taerijay+protocol</button>
					<button class="channel-nav-link w-full text-left p-3 rounded border border-[#5B0E1B]/40 bg-[#0A192F] text-[#FBF9F4] hover:bg-[#5B0E1B]/20 transition-all lowercase" data-idx="3">3. taerijay+mini</button>
					<button class="channel-nav-link w-full text-left p-3 rounded border border-[#5B0E1B]/40 bg-[#0A192F] text-[#E1261C] hover:bg-[#5B0E1B]/20 transition-all lowercase" data-idx="4">4. taerijay+daiso</button>
					<button class="channel-nav-link w-full text-left p-3 rounded border border-[#5B0E1B]/40 bg-[#0A192F] text-[#6F8B2E] hover:bg-[#5B0E1B]/20 transition-all lowercase" data-idx="5">5. taerijay+oliveyoung</button>
					<button class="channel-nav-link w-full text-left p-3 rounded border border-[#5B0E1B]/40 bg-[#0A192F] text-[#FFDD00] hover:bg-[#5B0E1B]/20 transition-all lowercase" data-idx="6">6. taerijay+emart</button>
					<button class="channel-nav-link w-full text-left p-3 rounded border border-[#5B0E1B]/40 bg-[#0A192F] text-[#A14D7C] hover:bg-[#5B0E1B]/20 transition-all lowercase" data-idx="7">7. taerijay+convenience</button>
				</nav>
			</div>
		</div>

		<!-- 대시보드 시스템 스펙 바 -->
		<section class="w-full px-6 md:px-12 py-10 md:py-16 border-b border-[#5B0E1B] bg-gradient-to-b from-[#0e2544] to-[#0A192F] relative overflow-hidden">
			<div class="absolute inset-0 bg-cover bg-center opacity-25 mix-blend-overlay" style="background-image: url('https://images.unsplash.com/photo-1538481199705-c710c4e965fc?auto=format&fit=crop&w=1920&q=80');"></div>
			<div class="relative z-10 max-w-7xl mx-auto flex flex-col md:flex-row items-center md:items-end justify-between gap-6">
				<div class="flex flex-col items-center md:items-start text-center md:text-left">
					<div class="inline-flex items-center gap-1.5 bg-[#5B0E1B]/80 border border-[#5B0E1B] px-3 py-1 rounded-full mb-4 shadow">
						<span class="w-2 h-2 rounded-full bg-red-500 animate-pulse"></span>
						<span class="text-[9px] md:text-xs font-spartan tracking-widest text-white uppercase font-bold">System Active</span>
					</div>
					<h1 class="text-3xl md:text-5xl lg:text-6xl font-black tracking-tight mb-3 leading-tight font-playfair italic text-white drop-shadow-lg">
						Unlocking Premium K-Heritage
					</h1>
					<p class="text-sm md:text-base text-slate-300 leading-relaxed font-light max-w-2xl drop-shadow">
						Access restricted curated database representing prime destination flow blueprints. <br class="hidden md:block"/>
						Use hamburger menu infrastructure to navigate pipelines.
					</p>
				</div>

				<div class="grid grid-cols-3 gap-2 md:gap-4 bg-[#071120]/80 backdrop-blur-md border border-[#5B0E1B] rounded-lg p-3 md:p-5 text-center shadow-2xl w-full md:w-auto font-spartan">
					<div class="px-2">
						<div class="text-lg md:text-2xl font-black text-[#00E5FF]">{totalItemCount}</div>
						<div class="text-[9px] md:text-[10px] text-slate-400 font-semibold uppercase tracking-widest mt-1">Total DB</div>
					</div>
					<div class="px-2 border-x border-[#5B0E1B]/50">
						<div class="text-lg md:text-2xl font-black text-[#FFDD00]">+{monthlyUpdatedCount}</div>
						<div class="text-[9px] md:text-[10px] text-slate-400 font-semibold uppercase tracking-widest mt-1">Monthly Add</div>
					</div>
					<div class="px-2">
						<div class="text-sm md:text-lg font-bold text-slate-200 pt-1">{lastUpdateDate}</div>
						<div class="text-[9px] md:text-[10px] text-slate-400 font-semibold uppercase tracking-widest mt-1">Last Sync</div>
					</div>
				</div>
			</div>
		</section>

		<!-- DISNEY+ SCROLLER TRACK LAYOUT -->
		<section class="w-full py-8 md:py-12 flex flex-col gap-6 md:gap-8">
			<div class="w-full max-w-[1600px] mx-auto flex flex-col gap-4">
				<div class="px-6 md:px-12 flex items-center justify-between font-spartan">
					<h3 class="text-base md:text-xl font-black uppercase tracking-widest text-white flex items-center gap-3">
						<span class="w-2 h-6 bg-[#5B0E1B] rounded-sm"></span>
						<span>Exclusive Master Pipelines Track</span>
					</h3>
					<span class="text-xs md:text-sm text-slate-500 font-mono hidden md:block">Scroll Horizontally to Explore Track Loop</span>
				</div>

				<div class="w-full overflow-x-auto flex gap-4 md:gap-6 px-6 md:px-12 py-4 no-scrollbar snap-x snap-mandatory scroll-smooth" id="masterSliderTrack">
					
					<!-- CARD 0: [0. TAERIJAY] -->
					<div class="min-w-[85vw] md:min-w-[400px] lg:min-w-[450px] snap-center shrink-0 rounded-xl border border-[#5B0E1B] bg-[#0A192F] overflow-hidden flex flex-col transition-all duration-300 hover:scale-[1.02] hover:shadow-2xl hover:shadow-[#5B0E1B]/30 scroll-item group" id="slider-card-0">
						<div class="px-5 py-3 bg-[#061224] border-b border-[#5B0E1B] flex items-center justify-between">
							<span class="text-sm md:text-base font-black uppercase font-playfair text-[#5B0E1B] tracking-widest">TAERIJAY</span>
							<span class="text-[10px] md:text-xs text-slate-500 font-bold uppercase font-spartan">🇰🇷 core</span>
						</div>
						<div class="h-56 md:h-64 bg-slate-900 relative overflow-hidden flex items-center justify-center">
							<div class="absolute inset-0 bg-cover bg-center opacity-10 group-hover:opacity-15 transition-opacity duration-500" style="background-image: url('https://images.unsplash.com/photo-1493976040374-85c8e12f0c0e?auto=format&fit=crop&w=800&q=80');"></div>
							<div class="relative z-10 text-center px-4">
								<span class="font-playfair text-4xl md:text-5xl font-black italic tracking-tight text-[#5B0E1B]/15 block mb-2 drop-shadow-xl select-none">TAERIJAY</span>
							</div>
						</div>
						<div class="p-5 md:p-6 flex flex-col gap-4 flex-grow bg-gradient-to-b from-[#0A192F] to-[#071120]">
							<h3 class="text-base md:text-lg font-bold text-white tracking-tight leading-snug flex items-center gap-2">
								<span>👑</span>
								<span>Ultimate K-Travel Master Blueprint</span>
							</h3>
							<div class="text-sm text-slate-300 leading-relaxed font-normal min-h-[60px] flex flex-col gap-1.5">
								<p class="text-white font-medium border-l-2 border-[#5B0E1B] pl-2">대한민국 대표 여행지 총 집합 마스터 기획안 수록함.</p>
								<p class="text-slate-400 font-light text-xs font-spartan">Premium curated travel destinations optimized for international VIP travelers.</p>
							</div>
							<div class="pt-4 border-t border-[#5B0E1B]/30 flex items-center justify-between gap-3 mt-auto font-spartan">
								<div class="flex items-center gap-2 min-w-0">
									<span class="text-base">📍</span>
									<span class="text-xs md:text-sm text-slate-300 font-mono truncate" id="addr-0">Gyeonggi-do, Namyangju-si, Hwado-eup</span>
								</div>
								<button class="copy-btn shrink-0 bg-[#5B0E1B]/20 border border-[#5B0E1B]/60 text-slate-200 px-3 md:px-4 py-1.5 rounded hover:bg-[#5B0E1B]/50 text-[10px] md:text-xs font-bold uppercase tracking-wider transition-all" data-target="addr-0">Copy</button>
							</div>
						</div>
					</div>

					<!-- CARD 1: [1. taerijay+entertainment] -->
					<div class="min-w-[85vw] md:min-w-[400px] lg:min-w-[450px] snap-center shrink-0 rounded-xl border border-[#5B0E1B] bg-[#0A192F] overflow-hidden flex flex-col transition-all duration-300 hover:scale-[1.02] hover:shadow-2xl hover:shadow-[#00E5FF]/20 scroll-item group" id="slider-card-1">
						<div class="px-5 py-3 bg-[#061224] border-b border-[#5B0E1B] flex items-center justify-between font-spartan">
							<span class="text-sm md:text-base font-black text-[#00E5FF] lowercase">taerijay+entertainment</span>
							<span class="text-[10px] md:text-xs text-[#00E5FF] font-bold uppercase">🌐 ott bridge</span>
						</div>
						<div class="h-56 md:h-64 bg-slate-900 relative overflow-hidden flex items-center justify-center">
							<div class="absolute inset-0 bg-cover bg-center opacity-40 group-hover:opacity-50 transition-opacity duration-500" style="background-image: url('https://images.unsplash.com/photo-1598899134739-24c46f58b8c0?auto=format&fit=crop&w=800&q=80');"></div>
							<div class="absolute inset-0 bg-gradient-to-t from-[#0A192F] via-transparent to-transparent"></div>
						</div>
						<div class="p-5 md:p-6 flex flex-col gap-4 flex-grow bg-gradient-to-b from-[#0A192F] to-[#071120]">
							<h3 class="text-base md:text-lg font-bold text-white tracking-tight leading-snug lowercase flex items-center gap-2">
								<span>🎬</span>
								<span>official video bridge hub</span>
							</h3>
							<div class="text-sm text-slate-300 leading-relaxed font-normal min-h-[60px] flex flex-col gap-1.5">
								<p class="text-white font-medium border-l-2 border-[#00E5FF] pl-2">드라마, 영화, 예능, 대표님 유튜브 채널 트래픽 허브 연계함.</p>
								<p class="text-slate-400 font-light text-xs font-spartan">Explore K-content, original films, and outbound looping parameters.</p>
							</div>
							
							<div class="flex flex-col gap-2 mt-2 max-h-[140px] overflow-y-auto border border-[#5B0E1B]/50 rounded p-2 bg-[#071120]/80">
								<div class="ep-row flex items-center justify-between p-2 rounded bg-[#0A192F] border border-[#5B0E1B]/30 cursor-pointer hover:bg-[#5B0E1B]/20 text-xs transition-colors font-spartan" data-preview="true" data-url="https://youtube.com">
									<span class="text-slate-300 truncate font-mono">EP 01. Origin of K-Heritage</span>
									<span class="text-[10px] px-2 py-0.5 bg-emerald-900 text-emerald-300 rounded font-bold uppercase shrink-0">Free</span>
								</div>
								<div class="ep-row flex items-center justify-between p-2 rounded bg-[#0A192F] border border-[#5B0E1B]/30 cursor-pointer hover:bg-black/40 text-xs opacity-60 transition-colors font-spartan" data-preview="false">
									<span class="text-slate-500 truncate font-mono">EP 13. Deep Forest Circuit</span>
									<span class="text-[10px] px-2 py-0.5 bg-[#5B0E1B] text-white rounded font-bold shrink-0">🔒 Lock</span>
								</div>
							</div>

							<div class="pt-4 border-t border-[#5B0E1B]/30 flex items-center justify-between gap-3 mt-auto font-spartan">
								<div class="flex items-center gap-2 min-w-0">
									<span class="text-base">📍</span>
									<span class="text-xs md:text-sm text-slate-300 font-mono truncate" id="addr-1">Central Hub Video Stream Station</span>
								</div>
								<button class="copy-btn shrink-0 bg-[#5B0E1B]/20 border border-[#5B0E1B]/60 text-slate-200 px-3 md:px-4 py-1.5 rounded hover:bg-[#5B0E1B]/50 text-[10px] md:text-xs font-bold uppercase tracking-wider transition-all" data-target="addr-1">Copy</button>
							</div>
						</div>
					</div>

					<!-- CARD 2: [2. taerijay+protocol] -->
					<div class="min-w-[85vw] md:min-w-[400px] lg:min-w-[450px] snap-center shrink-0 rounded-xl border border-[#5B0E1B] bg-[#0A192F] overflow-hidden flex flex-col transition-all duration-300 hover:scale-[1.02] hover:shadow-2xl hover:shadow-[#F16B24]/20 scroll-item group" id="slider-card-2">
						<div class="px-5 py-3 bg-[#061224] border-b border-[#5B0E1B] flex items-center justify-between font-spartan">
							<span class="text-sm md:text-base font-black text-[#F16B24] lowercase">taerijay+protocol</span>
							<span class="text-[10px] md:text-xs text-slate-500 font-bold uppercase">🌐 rule</span>
						</div>
						<div class="h-56 md:h-64 bg-slate-900 relative overflow-hidden flex items-center justify-center">
							<div class="absolute inset-0 bg-cover bg-center opacity-40 group-hover:opacity-50 transition-opacity duration-500" style="background-image: url('https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?auto=format&fit=crop&w=800&q=80');"></div>
							<div class="absolute inset-0 bg-gradient-to-t from-baseBg via-transparent to-transparent"></div>
						</div>
						<div class="p-5 md:p-6 flex flex-col gap-4 flex-grow bg-gradient-to-b from-[#0A192F] to-[#071120]">
							<h3 class="text-base md:text-lg font-bold text-white tracking-tight leading-snug flex items-center gap-2">
								<span>🌐</span>
								<span>Global Traveler Code & Security Policy</span>
							</h3>
							<div class="text-sm text-slate-300 leading-relaxed font-normal min-h-[60px] flex flex-col gap-1.5">
								<p class="text-white font-medium border-l-2 border-[#F16B24] pl-2">해외 입국객 필수 공항 세관 및 대중교통 탑승 10대 안전 수칙 명시함.</p>
								<p class="text-slate-400 font-light text-xs font-spartan">Legal security frameworks and 316 restricted code items initialization.</p>
							</div>
							<div class="pt-4 border-t border-[#5B0E1B]/30 flex items-center justify-between gap-3 mt-auto font-spartan">
								<div class="flex items-center gap-2 min-w-0">
									<span class="text-base">📍</span>
									<span class="text-xs md:text-sm text-slate-300 font-mono truncate" id="addr-2">Incheon International Airport Terminal 1 & 2</span>
								</div>
								<button class="copy-btn shrink-0 bg-[#5B0E1B]/20 border border-[#5B0E1B]/60 text-slate-200 px-3 md:px-4 py-1.5 rounded hover:bg-[#5B0E1B]/50 text-[10px] md:text-xs font-bold uppercase tracking-wider transition-all" data-target="addr-2">Copy</button>
							</div>
						</div>
					</div>

					<!-- CARD 3: [3. taerijay+mini] -->
					<div class="min-w-[85vw] md:min-w-[400px] lg:min-w-[450px] snap-center shrink-0 rounded-xl border border-[#5B0E1B] bg-[#0A192F] overflow-hidden flex flex-col transition-all duration-300 hover:scale-[1.02] hover:shadow-2xl hover:shadow-[#FBF9F4]/20 scroll-item group" id="slider-card-3">
						<div class="px-5 py-3 bg-[#061224] border-b border-[#5B0E1B] flex items-center justify-between font-spartan">
							<span class="text-sm md:text-base font-black text-[#FBF9F4] lowercase">taerijay+mini</span>
							<span class="text-[10px] md:text-xs text-slate-500 font-bold uppercase">📍 route</span>
						</div>
						<div class="h-56 md:h-64 bg-slate-900 relative overflow-hidden flex items-center justify-center">
							<div class="absolute inset-0 bg-cover bg-center opacity-40 group-hover:opacity-50 transition-opacity duration-500" style="background-image: url('https://images.unsplash.com/photo-1517048676732-d65bc937f952?auto=format&fit=crop&w=800&q=80');"></div>
							<div class="absolute inset-0 bg-gradient-to-t from-baseBg via-transparent to-transparent"></div>
						</div>
						<div class="p-5 md:p-6 flex flex-col gap-4 flex-grow bg-gradient-to-b from-[#0A192F] to-[#071120]">
							<h3 class="text-base md:text-lg font-bold text-white tracking-tight leading-snug flex items-center gap-2">
								<span>📍</span>
								<span>Dense One-Day Travel Blueprints</span>
							</h3>
							<div class="text-sm text-slate-300 leading-relaxed font-normal min-h-[60px] flex flex-col gap-1.5">
								<p class="text-white font-medium border-l-2 border-[#FBF9F4] pl-2">거점 도시별 시간 낭비 없는 원데이 초압축 코스 타임라인 구축함.</p>
								<p class="text-slate-400 font-light text-xs font-spartan">Dense 24-hour itinerary tracking loop with optimized routing pipelines.</p>
							</div>
							<div class="pt-4 border-t border-[#5B0E1B]/30 flex items-center justify-between gap-3 mt-auto font-spartan">
								<div class="flex items-center gap-2 min-w-0">
									<span class="text-base">📍</span>
									<span class="text-xs md:text-sm text-slate-300 font-mono truncate" id="addr-3">Myeong-dong, Jung-gu, Seoul</span>
								</div>
								<button class="copy-btn shrink-0 bg-[#5B0E1B]/20 border border-[#5B0E1B]/60 text-slate-200 px-3 md:px-4 py-1.5 rounded hover:bg-[#5B0E1B]/50 text-[10px] md:text-xs font-bold uppercase tracking-wider transition-all" data-target="addr-3">Copy</button>
							</div>
						</div>
					</div>

					<!-- CARD 4: [4. taerijay+daiso] -->
					<div class="min-w-[85vw] md:min-w-[400px] lg:min-w-[450px] snap-center shrink-0 rounded-xl border border-[#5B0E1B] bg-[#0A192F] overflow-hidden flex flex-col transition-all duration-300 hover:scale-[1.02] hover:shadow-2xl hover:shadow-[#E1261C]/20 scroll-item group" id="slider-card-4">
						<div class="px-5 py-3 bg-[#061224] border-b border-[#5B0E1B] flex items-center justify-between font-spartan">
							<span class="text-sm md:text-base font-black text-[#E1261C] lowercase">taerijay+daiso</span>
							<span class="text-[10px] md:text-xs text-slate-500 font-bold uppercase">💡 beauty</span>
						</div>
						<div class="h-56 md:h-64 bg-slate-900 relative overflow-hidden flex items-center justify-center">
							<div class="absolute inset-0 bg-cover bg-center opacity-40 group-hover:opacity-50 transition-opacity duration-500" style="background-image: url('https://images.unsplash.com/photo-1596462502278-27bfdc403348?auto=format&fit=crop&w=800&q=80');"></div>
							<div class="absolute inset-0 bg-gradient-to-t from-baseBg via-transparent to-transparent"></div>
						</div>
						<div class="p-5 md:p-6 flex flex-col gap-4 flex-grow bg-gradient-to-b from-[#0A192F] to-[#071120]">
							<h3 class="text-base md:text-lg font-bold text-white tracking-tight leading-snug flex items-center gap-2">
								<span>💡</span>
								<span>Viral K-Beauty Cosmetics & Gear under $5</span>
							</h3>
							<div class="text-sm text-slate-300 leading-relaxed font-normal min-h-[60px] flex flex-col gap-1.5">
								<p class="text-white font-medium border-l-2 border-[#E1261C] pl-2">SNS 품절 대란 다이소 화장품 스킨케어 정보 및 전국 대형 매장 리스트 수록함.</p>
