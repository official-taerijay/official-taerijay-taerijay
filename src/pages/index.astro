---
// src/pages/index.astro
// 메인 페이지 — 반응형(PC/태블릿/폰) + 한글/영문 토글
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
  <meta name="google" content="notranslate" />
  <title>TAERIJAY+ MASTER PORTAL</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=League+Spartan:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg:       #0A192F;
      --burgundy: #5B0E1B;
      --ivory:    #FBF9F4;
      --muted:    #7A9AB5;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--ivory);
      font-family: 'League Spartan', sans-serif;
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .page-wrap {
      width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    /* ═════════════════════════════
       NAV — 반응형
    ═════════════════════════════ */
    .nav {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 16px 20px;
      border-bottom: 1px solid rgba(91,14,27,0.35);
      position: sticky;
      top: 0;
      background: rgba(10,25,47,0.95);
      backdrop-filter: blur(8px);
      z-index: 100;
    }

    .nav-logo {
      font-family: 'Playfair Display', serif;
      font-size: 18px;
      font-weight: 700;
      letter-spacing: 0.08em;
      color: var(--ivory);
      text-decoration: none;
    }

    .nav-logo span { color: var(--burgundy); font-style: italic; }

    .nav-controls {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .lang-toggle {
      display: flex;
      align-items: center;
      border: 1px solid rgba(91,14,27,0.4);
      border-radius: 100px;
      overflow: hidden;
    }

    .lang-btn {
      padding: 5px 10px;
      font-family: 'League Spartan', sans-serif;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      background: transparent;
      border: none;
      color: var(--muted);
      cursor: pointer;
      transition: background 0.2s, color 0.2s;
    }

    .lang-btn.active {
      background: var(--burgundy);
      color: var(--ivory);
    }

    .lang-btn:hover:not(.active) { color: var(--ivory); }

    .nav-auth {
      padding: 6px 14px;
      border: 1px solid var(--burgundy);
      border-radius: 2px;
      background: rgba(91,14,27,0.2);
      color: var(--ivory);
      font-family: 'League Spartan', sans-serif;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      text-decoration: none;
      cursor: pointer;
      transition: background 0.2s;
      white-space: nowrap;
    }

    .nav-auth:hover { background: rgba(91,14,27,0.45); }

    /* ═════════════════════════════
       MAIN CONTENT
    ═════════════════════════════ */
    .main-content {
      width: 100%;
      max-width: 1200px;
      padding: 40px 24px;
    }

    /* 모바일 */
    @media (max-width: 480px) {
      .main-content { padding: 24px 16px; }
      .nav { padding: 14px 16px; }
    }

    /* 태블릿 */
    @media (min-width: 481px) and (max-width: 1024px) {
      .main-content { padding: 32px 24px; }
    }

    /* PC */
    @media (min-width: 1025px) {
      .main-content { padding: 48px 40px; }
    }

    /* ═════════════════════════════
       HERO
    ═════════════════════════════ */
    .hero {
      text-align: center;
      margin-bottom: 48px;
    }

    .hero-live {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 6px 14px;
      border: 1px solid rgba(0,201,122,0.3);
      border-radius: 100px;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: #00C97A;
      margin-bottom: 24px;
    }

    .live-dot {
      width: 5px; height: 5px;
      border-radius: 50%;
      background: #00C97A;
      box-shadow: 0 0 6px rgba(0,201,122,0.7);
      animation: pulse 2s ease-in-out infinite;
    }

    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }

    .hero-title {
      font-family: 'Playfair Display', serif;
      font-size: 28px;
      font-weight: 700;
      line-height: 1.25;
      margin-bottom: 8px;
      letter-spacing: 0.02em;
    }

    .hero-title em { font-style: italic; color: var(--burgundy); }

    .hero-sub {
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 14px;
    }

    .hero-desc {
      font-size: 13px;
      color: rgba(122,154,181,0.8);
      line-height: 1.7;
      max-width: 340px;
      margin: 0 auto;
    }

    @media (max-width: 480px) {
      .hero-title { font-size: 22px; }
      .hero-desc { font-size: 12px; }
    }

    @media (min-width: 1025px) {
      .hero-title { font-size: 32px; }
      .hero-desc { max-width: 500px; font-size: 14px; }
    }

    /* ═════════════════════════════
       SECTION LABEL
    ═════════════════════════════ */
    .section-label {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 16px;
      padding-top: 8px;
      border-top: 1px solid rgba(91,14,27,0.25);
    }

    /* ═════════════════════════════
       CHANNELS GRID — 반응형
    ═════════════════════════════ */
    .channels-grid {
      display: grid;
      gap: 12px;
      margin-bottom: 48px;
    }

    @media (max-width: 480px) {
      .channels-grid { grid-template-columns: 1fr; }
    }

    @media (min-width: 481px) and (max-width: 1024px) {
      .channels-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (min-width: 1025px) {
      .channels-grid { grid-template-columns: repeat(3, 1fr); gap: 16px; }
    }

    .ch-card {
      border: 1px solid var(--burgundy);
      border-radius: 3px;
      overflow: hidden;
      transition: transform 0.2s, box-shadow 0.2s;
      text-decoration: none;
      display: flex;
      flex-direction: column;
      background: rgba(255,255,255,0.018);
    }

    .ch-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(0,0,0,0.35);
    }

    .ch-top { height: 3px; }

    .ch-inner {
      padding: 16px;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .ch-icon {
      width: 40px; height: 40px;
      border-radius: 50%;
      border: 1px solid currentColor;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      opacity: 0.85;
    }

    .ch-brand {
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .ch-name {
      font-family: 'Playfair Display', serif;
      font-size: 16px;
      font-weight: 600;
      line-height: 1.2;
    }

    .ch-desc {
      font-size: 11px;
      color: var(--muted);
      line-height: 1.5;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    /* ═════════════════════════════
       PRICING — 반응형
    ═════════════════════════════ */
    .pricing-section { margin-bottom: 48px; }

    .plan-grid {
      display: grid;
      gap: 12px;
    }

    @media (max-width: 480px) {
      .plan-grid { grid-template-columns: 1fr; }
    }

    @media (min-width: 481px) and (max-width: 1024px) {
      .plan-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (min-width: 1025px) {
      .plan-grid { grid-template-columns: repeat(3, 1fr); gap: 16px; }
    }

    .plan-card {
      border: 1px solid var(--burgundy);
      border-radius: 3px;
      padding: 18px 16px;
      position: relative;
      overflow: hidden;
      background: rgba(255,255,255,0.02);
    }

    .plan-card.featured { border-color: #D4AF37; }

    .plan-card::before {
      content: '';
      position: absolute;
      left: 0; top: 0; bottom: 0;
      width: 3px;
    }

    .plan-badge {
      display: inline-block;
      padding: 4px 10px;
      border-radius: 100px;
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      margin-bottom: 10px;
    }

    .plan-name {
      font-family: 'Playfair Display', serif;
      font-size: 16px;
      font-weight: 600;
      margin-bottom: 6px;
      line-height: 1.2;
    }

    .plan-desc {
      font-size: 11px;
      color: var(--muted);
      line-height: 1.6;
      margin-bottom: 12px;
    }

    .plan-price-row {
      display: flex;
      align-items: baseline;
      gap: 4px;
      margin-bottom: 12px;
    }

    .plan-currency { font-size: 13px; color: var(--muted); }
    .plan-amount { font-family: 'Playfair Display', serif; font-size: 28px; font-weight: 700; color: var(--ivory); }
    .plan-period { font-size: 10px; color: var(--muted); letter-spacing: 0.04em; }

    .plan-btn {
      display: block;
      width: 100%;
      padding: 11px;
      border-radius: 2px;
      border: 1px solid;
      text-align: center;
      font-family: 'League Spartan', sans-serif;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      text-decoration: none;
      cursor: pointer;
      transition: opacity 0.2s, transform 0.15s;
      margin-bottom: 6px;
    }

    .plan-btn:hover { opacity: 0.85; transform: translateY(-1px); }

    .plan-btn.solid {
      background: var(--burgundy);
      border-color: var(--burgundy);
      color: var(--ivory);
    }

    .plan-btn.outline {
      background: transparent;
      border-color: rgba(91,14,27,0.5);
      color: var(--muted);
    }

    .plan-btn.gold {
      background: #D4AF37;
      border-color: #D4AF37;
      color: #0A192F;
    }

    /* ═════════════════════════════
       FOOTER
    ═════════════════════════════ */
    .footer {
      width: 100%;
      border-top: 1px solid rgba(91,14,27,0.3);
      padding: 28px 24px 40px;
      margin-top: auto;
    }

    .footer-social {
      display: flex;
      gap: 12px;
      margin-bottom: 16px;
      flex-wrap: wrap;
    }

    .social-link {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.08em;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }

    .social-link:hover { color: var(--ivory); }

    .footer-biz {
      font-size: 10px;
      color: rgba(122,154,181,0.5);
      line-height: 1.8;
    }

    .footer-biz strong { color: rgba(122,154,181,0.75); }

    /* ═════════════════════════════
       언어 표시 — 한글 기본, 영문 선택
    ═════════════════════════════ */
    .hero-en,
    .ch-name-en,
    .ch-desc-en,
    .plan-name-en,
    .plan-desc-en,
    .plan-badge-en,
    .plan-btn-en,
    .section-label-en,
    .social-en,
    .footer-en {
      opacity: 0.65;
      font-size: 0.85em;
      margin-top: 2px;
    }

    .plan-btn-en {
      display: none;
    }

    /* 영문 모드는 언어 토글 JS에서 관리 */

  </style>
</head>

<body>

  <!-- NAV -->
  <nav class="nav">
    <a href="/" class="nav-logo">TAERIJAY<span>+</span></a>
    <div class="nav-controls">
      <div class="lang-toggle" id="langToggle" role="group" aria-label="Language">
        <button class="lang-btn active" data-lang="en" title="English">EN</button>
        <button class="lang-btn" data-lang="ko" title="한국어">한</button>
        <button class="lang-btn" data-lang="auto" title="Auto">AUTO</button>
      </div>
      <a href="/01-auth/auth" class="nav-auth" id="navAuthBtn">Sign In</a>
    </div>
  </nav>

  <!-- MAIN -->
  <div class="page-wrap">
    <div class="main-content">

      <!-- HERO -->
      <section class="hero">
        <div class="hero-live">
          <div class="live-dot"></div>
          System Live Active
        </div>
        <h1 class="hero-title">
          대한민국 🇰🇷<br/>
          <span class="hero-en">Korea Intelligence Hub</span><br/>
          <em>글로벌 여행자를 위한</em><br/>
          <em class="hero-en">for Global Travelers</em>
        </h1>
        <div class="hero-sub">태리재이플러스 · 프리미엄 채널 네트워크</div>
        <div class="hero-sub hero-en">TAERIJAY+ · Premium Channel Network</div>
        <p class="hero-desc">검증된 한국 여행/라이프스타일 정보 — 글로벌 방문객을 위해 제작됨. 실제 주소. 번역 오류 0%. 🌐</p>
        <p class="hero-desc hero-en">Verified travel &amp; lifestyle DB — built exclusively for global visitors to Korea. Real addresses. Zero translation errors. 🌐</p>
      </section>

      <!-- CHANNELS -->
      <section>
        <div class="section-label">프리미엄 채널 오픈</div>
        <div class="section-label section-label-en">Premium Channels Deployment</div>

        <div class="channels-grid">
          <a href="/04-channels/01-entertainment" class="ch-card">
            <div class="ch-top" style="background:#00E5FF;"></div>
            <div class="ch-inner">
              <div class="ch-icon" style="color:#00E5FF;">🎬</div>
              <div class="ch-brand">taerijay+</div>
              <div class="ch-name" style="color:#00E5FF;">엔터테인먼트</div>
              <div class="ch-name ch-name-en" style="color:#00E5FF;">entertainment</div>
              <div class="ch-desc">드라마 · 영화 · 쇼 · 유튜브</div>
              <div class="ch-desc ch-desc-en">Drama · Movie · Show · YouTube</div>
            </div>
          </a>

          <a href="/04-channels/02-protocol" class="ch-card">
            <div class="ch-top" style="background:#F16B24;"></div>
            <div class="ch-inner">
              <div class="ch-icon" style="color:#F16B24;">🌐</div>
              <div class="ch-brand">taerijay+</div>
              <div class="ch-name" style="color:#F16B24;">프로토콜</div>
              <div class="ch-name ch-name-en" style="color:#F16B24;">protocol</div>
              <div class="ch-desc">공항 · 세관 · 입국 규약</div>
              <div class="ch-desc ch-desc-en">Airport customs · transit · entry</div>
            </div>
          </a>

          <a href="/04-channels/03-mini" class="ch-card">
            <div class="ch-top" style="background:#FBF9F4;"></div>
            <div class="ch-inner">
              <div class="ch-icon" style="color:#FBF9F4;">📍</div>
              <div class="ch-brand">taerijay+</div>
              <div class="ch-name" style="color:#FBF9F4;">미니</div>
              <div class="ch-name ch-name-en" style="color:#FBF9F4;">mini</div>
              <div class="ch-desc">여행 코스 · 도시 가이드</div>
              <div class="ch-desc ch-desc-en">Travel courses · city guides</div>
            </div>
          </a>

          <a href="/04-channels/04-daiso" class="ch-card">
            <div class="ch-top" style="background:#E1261C;"></div>
            <div class="ch-inner">
              <div class="ch-icon" style="color:#E1261C;">🇰🇷</div>
              <div class="ch-brand">taerijay+</div>
              <div class="ch-name" style="color:#E1261C;">다이소</div>
              <div class="ch-name ch-name-en" style="color:#E1261C;">daiso</div>
              <div class="ch-desc">뷰티템 · 재고 정보</div>
              <div class="ch-desc ch-desc-en">Beauty items · stock info</div>
            </div>
          </a>

          <a href="/04-channels/05-oliveyoung" class="ch-card">
            <div class="ch-top" style="background:#6F8B2E;"></div>
            <div class="ch-inner">
              <div class="ch-icon" style="color:#6F8B2E;">💡</div>
              <div class="ch-brand">taerijay+</div>
              <div class="ch-name" style="color:#6F8B2E;">올리브영</div>
              <div class="ch-name ch-name-en" style="color:#6F8B2E;">oliveyoung</div>
              <div class="ch-desc">스킨케어 · 면세 가이드</div>
              <div class="ch-desc ch-desc-en">Skincare · Tax-Free guide</div>
            </div>
          </a>

          <a href="/04-channels/06-emart" class="ch-card">
            <div class="ch-top" style="background:#FFDD00;"></div>
            <div class="ch-inner">
              <div class="ch-icon" style="color:#FFDD00;">🛒</div>
              <div class="ch-brand">taerijay+</div>
              <div class="ch-name" style="color:#FFDD00;">이마트</div>
              <div class="ch-name ch-name-en" style="color:#FFDD00;">emart</div>
              <div class="ch-desc">대형마트 · 휴업 경고</div>
              <div class="ch-desc ch-desc-en">Hypermarket · closure alerts</div>
            </div>
          </a>

          <a href="/04-channels/07-convenience" class="ch-card">
            <div class="ch-top" style="background:#A14D7C;"></div>
            <div class="ch-inner">
              <div class="ch-icon" style="color:#A14D7C;">🌐</div>
              <div class="ch-brand">taerijay+</div>
              <div class="ch-name" style="color:#A14D7C;">편의점</div>
              <div class="ch-name ch-name-en" style="color:#A14D7C;">convenience</div>
              <div class="ch-desc">24시 조합 · PB 상품</div>
              <div class="ch-desc ch-desc-en">24h combos · PB products</div>
            </div>
          </a>
        </div>
      </section>

      <!-- PRICING -->
      <section class="pricing-section">
        <div class="section-label">12개월 프리미엄 활성화 패스</div>
        <div class="section-label section-label-en">12 Months Premium Activation Pass</div>

        <div class="plan-grid">
          <!-- SINGLE BASIC -->
          <div class="plan-card" style="--plan-color:#F16B24;">
            <div style="position:absolute;left:0;top:0;bottom:0;width:3px;background:#F16B24;"></div>
            <div class="plan-badge" style="background:rgba(241,107,36,0.12);color:#F16B24;border:1px solid rgba(241,107,36,0.3);">싱글</div>
            <div class="plan-badge plan-badge-en" style="background:rgba(241,107,36,0.12);color:#F16B24;border:1px solid rgba(241,107,36,0.3);">Single</div>
            <div class="plan-name">기본 티어</div>
            <div class="plan-name plan-name-en">Basic Tier</div>
            <div class="plan-desc">단일 채널 · 12개월 무제한 열람</div>
            <div class="plan-desc plan-desc-en">Single channel · 12-month unlimited access</div>
            <div class="plan-price-row">
              <span class="plan-currency">$</span>
              <span class="plan-amount">19.99</span>
              <span class="plan-period">/ 12mo</span>
            </div>
            <a href="/02-payment/payment?key=protocol_basic" class="plan-btn solid">프로토콜 기본 구매</a>
            <a href="/02-payment/payment?key=protocol_basic" class="plan-btn solid plan-btn-en">Get Protocol Basic</a>
          </div>

          <!-- DOUBLE A -->
          <div class="plan-card">
            <div style="position:absolute;left:0;top:0;bottom:0;width:3px;background:#F16B24;"></div>
            <div class="plan-badge" style="background:rgba(91,14,27,0.2);color:#FBF9F4;border:1px solid rgba(91,14,27,0.4);">더블 A</div>
            <div class="plan-badge plan-badge-en" style="background:rgba(91,14,27,0.2);color:#FBF9F4;border:1px solid rgba(91,14,27,0.4);">Double A</div>
            <div class="plan-name">프로토콜 × 미니</div>
            <div class="plan-name plan-name-en">protocol × mini</div>
            <div class="plan-desc">2개 채널 · 최고 조합</div>
            <div class="plan-desc plan-desc-en">Two channels · Best combo</div>
            <div class="plan-price-row">
              <span class="plan-currency">$</span>
              <span class="plan-amount">34.99</span>
              <span class="plan-period">/ 12mo</span>
            </div>
            <a href="/02-payment/payment?key=protocol_mini" class="plan-btn solid">더블 패스 구매</a>
            <a href="/02-payment/payment?key=protocol_mini" class="plan-btn solid plan-btn-en">Get Double Pass</a>
          </div>

          <!-- TOTAL -->
          <div class="plan-card featured">
            <div style="position:absolute;left:0;top:0;bottom:0;width:3px;background:#D4AF37;"></div>
