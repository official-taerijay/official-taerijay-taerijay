	<!-- 아스트로 정적 페이지 전용 바닐라 스크립트 라이프사이클 통합 제어 -->
	<script is:inline>
		document.addEventListener('DOMContentLoaded', () => {
			// 1. Language Toggle System
			const langButtons = document.querySelectorAll('.lang-btn');
			const translatableElements = document.querySelectorAll('.lang-el');
			let currentLang = 'en';

			function setLanguage(lang) {
				currentLang = lang;
				langButtons.forEach(btn => {
					if (btn.dataset.lang === lang) {
						btn.classList.add('bg-[#5B0E1B]', 'text-white');
						btn.classList.remove('text-slate-400');
					} else {
						btn.classList.remove('bg-[#5B0E1B]', 'text-white');
						btn.classList.add('text-slate-400');
					}
				});

				translatableElements.forEach(el => {
					if (lang === 'en') {
						el.textContent = el.dataset.en || el.textContent;
					} else {
						// Store EN as data-en if not present
						if (!el.dataset.en) {
							el.dataset.en = el.textContent;
						}
						// Search for Korean counterpart or fallback
						el.textContent = el.getAttribute('data-ko') || el.textContent;
					}
				});
			}

			// Capture original Korean texts to data-ko before overriding
			translatableElements.forEach(el => {
				el.dataset.ko = el.textContent;
			});

			// Set initial language to English as requested (🌐 default 우선)
			setLanguage('en');

			langButtons.forEach(btn => {
				btn.addEventListener('click', () => {
					setLanguage(btn.dataset.lang);
				});
			});


			// 2. One-touch Address Copier
			const copyButtons = document.querySelectorAll('.copy-btn');
			copyButtons.forEach(btn => {
				btn.addEventListener('click', () => {
					const targetId = btn.dataset.target;
					const targetElement = document.getElementById(targetId);
					if (targetElement) {
						navigator.clipboard.writeText(targetElement.textContent)
							.then(() => {
								const originalText = btn.textContent;
								btn.textContent = currentLang === 'en' ? 'COPIED!' : '완료!';
								btn.classList.add('bg-emerald-900', 'border-emerald-600');
								setTimeout(() => {
									btn.textContent = originalText;
									btn.classList.remove('bg-emerald-900', 'border-emerald-600');
								}, 1500);
							});
					}
				});
			});


			// 3. Modal System (General Open & Close)
			const triggers = document.querySelectorAll('.modal-trigger');
			const closers = document.querySelectorAll('.modal-close');
			const overlays = document.querySelectorAll('.modal-overlay');

			triggers.forEach(trig => {
				trig.addEventListener('click', () => {
					const targetId = trig.dataset.target;
					const targetModal = document.getElementById(targetId);
					if (targetModal) {
						targetModal.classList.remove('hidden');
						targetModal.classList.add('flex');
					}
				});
			});

			closers.forEach(closer => {
				closer.addEventListener('click', (e) => {
					const activeModal = closer.closest('.modal-overlay');
					if (activeModal) {
						activeModal.classList.add('hidden');
						activeModal.classList.remove('flex');
					}
				});
			});

			// Hide modal when clicking backdrop
			overlays.forEach(overlay => {
				overlay.addEventListener('click', (e) => {
					if (e.target === overlay) {
						overlay.classList.add('hidden');
						overlay.classList.remove('flex');
					}
				});
			});


			// 4. Device Management Simulator (Revoke Action)
			const revokeButtons = document.querySelectorAll('.revoke-dev-btn');
			revokeButtons.forEach(btn => {
				btn.addEventListener('click', () => {
					const rowId = btn.dataset.target;
					const targetRow = document.getElementById(rowId);
					if (targetRow) {
						targetRow.classList.add('opacity-40', 'pointer-events-none');
						btn.disabled = true;
						btn.textContent = currentLang === 'en' ? 'REVOKED' : '해제됨';
					}
				});
			});


			// 5. Paddle Purchase Gating Trigger
			const payButtons = document.querySelectorAll('.pay-btn');
			const checkoutModal = document.getElementById('modal-checkout');
			const checkoutTierText = document.getElementById('checkoutTier');

			payButtons.forEach(btn => {
				btn.addEventListener('click', () => {
					const tier = btn.dataset.tier;
					if (checkoutModal && checkoutTierText) {
						checkoutTierText.textContent = tier;
						checkoutModal.classList.remove('hidden');
						checkoutModal.classList.add('flex');
					}
				});
			});


			// 6. Gating Simulation for Episode Threshold (Item 13+)
			const epRows = document.querySelectorAll('.ep-row');
			const gatingModal = document.getElementById('modal-gating');

			epRows.forEach(row => {
				row.addEventListener('click', () => {
					const isPreview = row.dataset.preview === 'true';
					if (isPreview) {
						// Free redirect stream simulation
						const url = row.dataset.url;
						window.open(url, '_blank');
					} else {
						// Locked threshold limit modal display
						if (gatingModal) {
							gatingModal.classList.remove('hidden');
							gatingModal.classList.add('flex');
						}
					}
				});
			});


			// 7. Session Logout Trigger (Google OAuth simulation update)
			const logoutBtn = document.getElementById('logoutBtn');
			const userEmail = document.getElementById('userEmail');
			logoutBtn.addEventListener('click', () => {
				if (userEmail.textContent !== 'guest@taerijay.com') {
					userEmail.textContent = 'guest@taerijay.com';
					logoutBtn.textContent = currentLang === 'en' ? 'REVOKE' : '해제';
					logoutBtn.classList.add('bg-[#5B0E1B]/30');
					logoutBtn.classList.remove('bg-emerald-800');
				} else {
					// Simulate secure re-login (Google single sign-on verification batch)
					userEmail.textContent = 'active-vip@taerijay.com';
					logoutBtn.textContent = currentLang === 'en' ? 'LOGOUT' : '로그아웃';
					logoutBtn.classList.remove('bg-[#5B0E1B]/30');
					logoutBtn.classList.add('bg-emerald-800');
				}
			});

		});
	</script>
