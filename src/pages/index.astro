	<!-- Standard client-side vanilla interactivity orchestration logic -->
	<script is:inline>
		document.addEventListener('DOMContentLoaded', () => {
			
			// A. Navigation Scroller Anchors logic
			const menuTrigger = document.getElementById('menuTrigger');
			const sideDrawer = document.getElementById('sideDrawer');
			const menuCloser = document.getElementById('menuCloser');
			const navLinks = document.querySelectorAll('.channel-nav-link');
			const sliderTrack = document.getElementById('masterSliderTrack');

			if (menuTrigger) {
				menuTrigger.addEventListener('click', () => {
					sideDrawer.classList.remove('hidden');
					sideDrawer.classList.add('flex');
				});
			}

			const closeMenu = () => {
				sideDrawer.classList.add('hidden');
				sideDrawer.classList.remove('flex');
			};

			if (menuCloser) menuCloser.addEventListener('click', closeMenu);
			if (sideDrawer) {
				sideDrawer.addEventListener('click', (e) => {
					if (e.target === sideDrawer) closeMenu();
				});
			}

			navLinks.forEach(link => {
				link.addEventListener('click', () => {
					const cardIdx = link.dataset.idx;
					const targetCard = document.getElementById(`slider-card-${cardIdx}`);
					if (targetCard && sliderTrack) {
						let offset = targetCard.offsetLeft;
						if (window.innerWidth >= 768) {
							offset -= 48;
						} else {
							offset -= 24;
						}
						sliderTrack.scrollTo({
							left: offset,
							behavior: 'smooth'
						});
						closeMenu();
					}
				});
			});

			// B. Clipboard Copy Button
			const copyButtons = document.querySelectorAll('.copy-btn');
			copyButtons.forEach(btn => {
				btn.addEventListener('click', () => {
					const targetId = btn.dataset.target;
					const targetElement = document.getElementById(targetId);
					if (targetElement) {
						navigator.clipboard.writeText(targetElement.textContent)
							.then(() => {
								const originalText = btn.textContent;
								btn.textContent = 'COPIED!';
								btn.classList.add('bg-emerald-900', 'border-emerald-600', 'text-white');
								setTimeout(() => {
									btn.textContent = originalText;
									btn.classList.remove('bg-emerald-900', 'border-emerald-600', 'text-white');
								}, 1500);
							});
					}
				});
			});

			// C. Unified Authentication State Loop
			const authBtn = document.getElementById('authBtn');
			const drawerUserBadge = document.getElementById('drawerUserBadge');
			let authState = 0; // 0: Login, 1: Registering, 2: Logout/VIP

			if (authBtn) {
				authBtn.addEventListener('click', () => {
					if (authState === 0) {
						authBtn.textContent = 'Google Sign Up';
						authBtn.className = "px-3 md:px-5 py-1.5 md:py-2 border border-[#FFDD00] rounded bg-amber-500/20 text-[#FFDD00] text-[10px] md:text-xs font-bold uppercase tracking-wider transition-all shadow-md";
						authState = 1;
					} else if (authState === 1) {
						authBtn.textContent = 'Google Logout';
						authBtn.className = "px-3 md:px-5 py-1.5 md:py-2 border border-emerald-600 rounded bg-emerald-800 text-white text-[10px] md:text-xs font-bold uppercase tracking-wider transition-all shadow-md";
						if (drawerUserBadge) drawerUserBadge.textContent = 'Session: active-vip@taerijay.com';
						authState = 2;
					} else {
						authBtn.textContent = 'Google Login';
						authBtn.className = "px-3 md:px-5 py-1.5 md:py-2 border border-[#5B0E1B] rounded bg-[#5B0E1B]/30 hover:bg-[#5B0E1B]/60 text-slate-200 text-[10px] md:text-xs font-bold uppercase tracking-wider transition-all shadow-md";
						if (drawerUserBadge) drawerUserBadge.textContent = 'Session: guest@taerijay.com';
						authState = 0;
					}
				});
			}

			// D. Modals Matrix System Controls
			const payBtns = document.querySelectorAll('.pay-btn');
			const checkoutModal = document.getElementById('modal-checkout');
			payBtns.forEach(btn => {
				btn.addEventListener('click', () => {
					if (checkoutModal) {
						checkoutModal.classList.remove('hidden');
						checkoutModal.classList.add('flex');
					}
				});
			});

			const epRows = document.querySelectorAll('.ep-row');
			const gatingModal = document.getElementById('modal-gating');
			epRows.forEach(row => {
				row.addEventListener('click', () => {
					if (row.dataset.preview === 'true') {
						window.open(row.dataset.url, '_blank');
					} else {
						if (gatingModal) {
							gatingModal.classList.remove('hidden');
							gatingModal.classList.add('flex');
						}
					}
				});
			});

			const overlays = document.querySelectorAll('.modal-overlay');
			const triggers = document.querySelectorAll('.modal-trigger');
			const closers = document.querySelectorAll('.modal-close');

			triggers.forEach(trig => {
				trig.addEventListener('click', () => {
					const target = document.getElementById(trig.dataset.target);
					if(target) {
						target.classList.remove('hidden');
						target.classList.add('flex');
					}
				});
			});

			closers.forEach(closer => {
				closer.addEventListener('click', () => {
					const targetOverlay = closer.closest('.modal-overlay');
					if(targetOverlay) {
						targetOverlay.classList.add('hidden');
						targetOverlay.classList.remove('flex');
					}
				});
			});

			overlays.forEach(overlay => {
				overlay.addEventListener('click', (e) => {
					if (e.target === overlay) {
						overlay.classList.add('hidden');
						overlay.classList.remove('flex');
					}
				});
			});

		});
	</script>
</Layout>
"""

