---
import Layout from '../layouts/Layout.astro';

const lastUpdateDate = "2026.07.20";
const totalItemCount = 613; 
const monthlyUpdatedCount = 5;
---

<Layout title="TAERIJAY (태리재이)+">
	<main class="w-full max-w-[480px] min-h-screen bg-[#0A192F] border-x border-[#5B0E1B] flex flex-col relative pb-24 shadow-2xl overflow-hidden">
		
		<!-- TOP PREMIUM NAV BAR -->
		<header class="w-full px-4 py-4 border-b border-[#5B0E1B] bg-[#0A192F]/95 backdrop-blur sticky top-0 z-50 flex items-center justify-between">
			<!-- LEFT: Hamburger Menu Button -->
			<button id="menuTrigger" class="text-white hover:text-[#00E5FF] transition-colors p-1 flex items-center justify-center">
				<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
					<path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
				</svg>
			</button>

			<!-- CENTER: Brand Logo -->
			<div class="flex flex-col items-center">
				<span class="font-['League_Spartan'] text-xl font-black tracking-widest text-transparent bg-clip-text bg-gradient-to-r from-white via-amber-100 to-[#00E5FF] leading-none uppercase">taerijay+</span>
			</div>
			
			<!-- RIGHT: Combined Auth Switcher Badge (Register/Login/Logout) -->
			<button id="authBtn" class="px-2.5 py-1.5 border border-[#5B0E1B] rounded bg-[#5B0E1B]/30 hover:bg-[#5B0E1B]/60 text-slate-200 text-[10px] font-bold uppercase tracking-wider transition-all shadow">
				Google Login
			</button>
		</header>

		<!-- SIDEBAR HAMBURGER MENU DRAWER -->
		<div id="sideDrawer" class="fixed inset-0 z-50 bg-black/80 backdrop-blur-sm hidden justify-start max-w-[480px] mx-auto border-x border-[#5B0E1B]">
			<div class="w-[280px] h-full bg-[#071120] border-r border-[#5B0E1B] p-5 flex flex-col gap-6 relative animate-slide-in">
				<div class="flex items-center justify-between border-b border-[#5B0E1B] pb-3">
					<span class="font-['League_Spartan'] text-base font-black tracking-widest text-[#00E5FF] uppercase">Premium Channels</span>
					<button id="menuCloser" class="text-slate-400 hover:text-white text-2xl font-light leading-none">&times;</button>
				</div>
				
				<!-- 1 to 7 Channels navigation loop -->
				<nav class="flex flex-col gap-2 font-['League_Spartan'] font-bold text-sm">
					<button class="channel-nav-link w-full text-left p-2.5 rounded border border-[#5B0E1B]/40 bg-[#0A192F] text-[#F16B24] hover:bg-[#5B0E1B]/20 transition-all" data-target="ch-protocol">1. taerijay+ protocol</button>
					<button class="channel-nav-link w-full text-left p-2.5 rounded border border-[#5B0E1B]/40 bg-[#0A192F] text-[#FBF9F4] hover:bg-[#5B0E1B]/20 transition-all" data-target="ch-mini">2. taerijay+ mini</button>
					<button class="channel-nav-link w-full text-left p-2.5 rounded border border-[#5B0E1B]/40 bg-[#0A192F] text-[#E1261C] hover:bg-[#5B0E1B]/20 transition-all" data-target="ch-daiso">3. taerijay+ daiso</button>
					<button class="channel-nav-link w-full text-left p-2.5 rounded border border-[#5B0E1B]/40 bg-[#0A192F] text-[#6F8B2E] hover:bg-[#5B0E1B]/20 transition-all" data-target="ch-oliveyoung">4. taerijay+ oliveyoung</button>
					<button class="channel-nav-link w-full text-left p-2.5 rounded border border-[#5B0E1B]/40 bg-[#0A192F] text-[#FFDD00] hover:bg-[#5B0E1B]/20 transition-all" data-target="ch-emart">5. taerijay+ emart</button>
					<button class="channel-nav-link w-full text-left p-2.5 rounded border border-[#5B0E1B]/40 bg-[#0A192F] text-[#A14D7C] hover:bg-[#5B0E1B]/20 transition-all" data-target="ch-convenience">6. taerijay+ convenience</button>
					<button class="channel-nav-link w-full text-left p-2.5 rounded border border-[#5B0E1B]/40 bg-[#0A192F] text-[#00E5FF] hover:bg-[#5B0E1B]/20 transition-all" data-target="ch-entertainment">7. taerijay+ entertainment</button>
				</nav>

				<div class="mt-auto border-t border-[#5B0E1B] pt-4 text-center">
					<span class="text-[9px] text-slate-500 font-mono" id="drawerUserBadge">Session: guest@taerijay.com</span>
				</div>
			</div>
		</div>

		<!-- HERO SPOTLIGHT STAGE -->
		<section class="w-full relative overflow-hidden px-5 py-6 border-b border-[#5B0E1B] bg-gradient-to-b from-[#0e2544] to-[#0A192F]">
			<div class="absolute inset-0 bg-cover bg-center opacity-25" style="background-image: url('https://images.unsplash.com/photo-1538481199705-c710c4e965fc?auto=format&fit=crop&w=600&q=80');"></div>
			<div class="relative z-10">
				<div class="inline-flex items-center gap-1.5 bg-[#5B0E1B]/80 border border-[#5B0E1B] px-2.5 py-0.5 rounded-full mb-3 shadow">
					<span class="w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse"></span>
					<span class="text-[8px] font-['League_Spartan'] tracking-widest text-slate-200 uppercase font-bold">active status</span>
				</div>
				
				<h1 class="text-xl font-bold tracking-tight mb-2 leading-tight font-['Playfair_Display'] italic">
					Unlocking Premium K-Heritage
				</h1>
				<p class="text-xs text-slate-300 leading-relaxed font-light mb-4">
					Access restricted curated database representing prime destination flow blueprints. Use hamburger menu to navigate pipelines.
				</p>

				<div class="grid grid-cols-3 gap-2 bg-[#071120]/90 border border-[#5B0E1B] rounded p-2 text-center shadow-inner">
					<div>
						<div class="text-base font-black text-[#00E5FF] font-['League_Spartan']">{totalItemCount}</div>
						<div class="text-[8px] text-slate-400 font-semibold uppercase">Total DB</div>
					</div>
					<div>
						<div class="text-base font-black text-[#FFDD00] font-['League_Spartan']">+{monthlyUpdatedCount}</div>
						<div class="text-[8px] text-slate-400 font-semibold uppercase">Monthly Add</div>
					</div>
					<div>
						<div class="text-[13px] font-bold text-slate-200 font-['League_Spartan'] pt-0.5">{lastUpdateDate}</div>
						<div class="text-[8px] text-slate-400 font-semibold uppercase">Last Sync</div>
					</div>
				</div>
			</div>
		</section>

		<!-- MASTER CHANNEL STAGE (CONTENT SECTIONS LOAD DYNAMICALLY ON CLICK) -->
		<section class="w-full px-5 py-6 flex flex-col gap-5 min-h-[40vh]">
			
			<!-- DEFAULT CORE DISPLAY CONTENT -->
			<div id="coreDisplaySection" class="w-full py-12 flex flex-col items-center justify-center text-center border-2 border-dashed border-[#5B0E1B]/40 rounded-lg p-5 bg-[#071120]/30 animate-pulse">
				<span class="text-4xl mb-3">🍔</span>
				<h3 class="text-sm font-bold text-white font-['League_Spartan'] uppercase tracking-widest mb-1">Select Channel Lineup</h3>
				<p class="text-xs text-slate-400 max-w-[280px]">Please open the top-left hamburger menu to inspect exclusive pipelines.</p>
			</div>

			<!-- CARD PIPELINES MATRIX CONTAINER -->
			<div id="channelContentWrapper" class="hidden flex-col">
				
				<!-- DYNAMIC INJECTED CONTAINER CARD STRUCTURE -->
				<div class="w-full rounded-lg border border-[#5B0E1B] bg-[#0A192F] overflow-hidden flex flex-col shadow-xl animate-fade-in" id="activeMasterCard">
					<div class="px-4 py-2 bg-[#061224] border-b border-[#5B0E1B] flex items-center justify-between" id="cardBrandHeader">
						<span class="text-xs font-black uppercase font-['League_Spartan'] text-[#F16B24]" id="cardHeaderTitle">taerijay+ pipeline</span>
						<span class="text-[10px] text-slate-500 font-bold uppercase" id="cardHeaderBadge">🌐 view</span>
					</div>
					<div class="h-44 bg-slate-900 relative overflow-hidden flex items-center justify-center">
						<div class="absolute inset-0 bg-cover bg-center opacity-40" id="cardBannerBg"></div>
						<div class="absolute inset-0 bg-gradient-to-t from-[#0A192F] to-transparent"></div>
						<div class="absolute bottom-3 left-4">
							<span class="px-2 py-0.5 bg-slate-800 text-white text-[9px] font-black uppercase rounded font-['League_Spartan']" id="cardBannerTag">active pass</span>
						</div>
					</div>
					<div class="p-4 flex flex-col gap-3">
						<div class="flex flex-col gap-1">
							<span class="text-xs font-bold text-slate-400 uppercase font-['League_Spartan']" id="cardSubCategory">[CATEGORY] INDEX</span>
							<h3 class="text-sm font-bold text-white tracking-tight" id="cardMainTitle">Master Blueprint Pipeline</h3>
						</div>
						<p class="text-xs text-slate-300 leading-relaxed" id="cardDescription">Curated destination asset flows and strict logic constraints layout mapping.</p>
						
						<!-- GATING EPISODES SCROLLER ZONE (ONLY APPEARS ON ENTERTAINMENT) -->
						<div class="flex flex-col gap-1.5 mt-2 max-h-[180px] overflow-y-auto border border-[#5B0E1B]/50 rounded p-2 bg-[#071120]/60 hidden" id="gatingScrollerZone">
							<div class="ep-row flex items-center justify-between p-1.5 rounded bg-[#0A192F] border border-[#5B0E1B]/30 cursor-pointer hover:bg-[#5B0E1B]/20 transition-all" data-preview="true" data-url="https://youtube.com">
								<span class="text-xs text-slate-300 font-medium truncate">EP 01. Origin of Heritage (Drama)</span>
								<span class="text-[9px] px-1.5 py-0.5 bg-emerald-900/80 text-emerald-300 rounded font-bold uppercase shrink-0">Free</span>
							</div>
							<div class="ep-row flex items-center justify-between p-1.5 rounded bg-[#0A192F] border border-[#5B0E1B]/30 cursor-pointer hover:bg-[#5B0E1B]/20 transition-all" data-preview="true" data-url="https://youtube.com">
								<span class="text-xs text-slate-300 font-medium truncate">EP 02. Midnight Food Hunt (Show)</span>
								<span class="text-[9px] px-1.5 py-0.5 bg-emerald-900/80 text-emerald-300 rounded font-bold uppercase shrink-0">Free</span>
							</div>
							<div class="ep-row flex items-center justify-between p-1.5 rounded bg-[#0A192F] border border-[#5B0E1B]/30 cursor-pointer hover:bg-black/40 transition-all opacity-60" data-preview="false">
								<span class="text-xs text-slate-500 font-medium truncate">EP 13. Deep Forest Temple Tour (Movie)</span>
								<span class="text-[9px] px-1.5 py-0.5 bg-[#5B0E1B] text-white rounded font-bold shrink-0">🔒 Lock</span>
							</div>
						</div>

						<div class="pt-2 border-t border-[#5B0E1B]/30 flex items-center justify-between gap-2">
							<div class="flex items-center gap-1.5 min-w-0">
								<span class="text-sm">📍</span>
								<span class="text-[11px] text-slate-300 font-mono truncate" id="cardAddressText">Master Location Roadmap Street</span>
							</div>
							<button class="copy-btn shrink-0 bg-[#5B0E1B]/20 border border-[#5B0E1B]/60 text-slate-200 px-2.5 py-1 rounded hover:bg-[#5B0E1B]/40 text-[10px] font-bold uppercase tracking-wider transition-all" id="cardCopyBtn">Copy</button>
						</div>
					</div>
				</div>

			</div>
		</section>

		<!-- 24-MONTH PASS PLAN SPEC -->
		<section class="w-full px-5 py-6 bg-gradient-to-b from-[#0A192F] to-[#040c17] border-t border-[#5B0E1B]">
			<div class="text-center mb-5">
				<h2 class="text-base font-['Playfair_Display'] italic font-bold mb-1.5 text-white">Unlocks 24 Months Unlimited Pass</h2>
				<p class="text-xs text-slate-400">Simple automatic activation via Paddle without recurring fees.</p>
			</div>
			<div class="rounded-lg border-2 border-[#5B0E1B] bg-[#0A192F] p-4 flex flex-col justify-between relative overflow-hidden shadow-lg shadow-[#5B0E1B]/40">
				<div class="absolute top-0 right-0 px-2.5 py-0.5 bg-cyan-500 text-black text-[8px] font-black uppercase rounded-bl tracking-widest font-['League_Spartan']">best value</div>
				<div class="mb-4">
					<span class="text-[9px] font-black uppercase text-[#00E5FF] font-['League_Spartan'] tracking-widest block mb-1">Double Value Pass</span>
					<div class="flex items-baseline gap-1.5 mb-2">
						<span class="text-2xl font-black font-['League_Spartan'] text-[#00E5FF]">$34.99</span>
						<span class="text-[10px] text-slate-500 font-medium">/ 2 Years</span>
					</div>
					<ul class="text-xs text-slate-300 flex flex-col gap-1.5 list-none border-t border-[#5B0E1B]/30 pt-3 pl-0">
						<li class="flex items-center gap-1.5">
							<span class="text-[#00E5FF]">✔</span>
							<span>1 ID / 1 Registered Device lock control execution.</span>
						</li>
						<li class="flex items-center gap-1.5">
							<span class="text-[#00E5FF]">✔</span>
							<span>2 Separate premium pipeline services whole access.</span>
						</li>
					</ul>
				</div>
				<button id="payBtn" class="w-full py-2 bg-[#5B0E1B] hover:bg-[#8b1328] text-white rounded text-xs font-bold uppercase tracking-wider transition-all shadow-md">Activate Pass</button>
			</div>
		</section>

		<!-- GLOBAL INTEGRATED FOOTER GRID -->
		<footer class="w-full px-5 py-8 border-t border-[#5B0E1B] bg-[#040c17]">
			<div class="grid grid-cols-2 gap-6 mb-8 text-left">
				<div>
					<h4 class="text-xs font-black uppercase tracking-wider text-slate-400 font-['League_Spartan'] mb-2.5">Learn More</h4>
					<div class="flex flex-col gap-1.5">
						<button class="modal-trigger text-xs text-slate-300 hover:text-[#00E5FF] transition-all text-left" data-target="modal-terms">Terms of Service</button>
						<button class="modal-trigger text-xs text-slate-300 hover:text-[#00E5FF] transition-all text-left" data-target="modal-business">Business Info</button>
					</div>
				</div>
				<div>
					<h4 class="text-xs font-black uppercase tracking-wider text-slate-400 font-['League_Spartan'] mb-2.5">Policies</h4>
					<div class="flex flex-col gap-1.5">
						<button class="modal-trigger text-xs text-slate-300 hover:text-[#00E5FF] transition-all text-left" data-target="modal-privacy">Privacy Policy</button>
						<button class="modal-trigger text-xs text-slate-300 hover:text-[#00E5FF] transition-all text-left" data-target="modal-refund">Refund Policy</button>
					</div>
				</div>
			</div>

			<div class="flex flex-col gap-4 border-t border-[#5B0E1B]/30 pt-6">
				<div class="flex flex-wrap justify-center gap-2.5">
					<a href="https://youtube.com" target="_blank" class="px-3 py-1.5 bg-red-950/40 hover:bg-red-950 border border-red-800 text-red-200 rounded text-xs font-black uppercase font-['League_Spartan'] transition-all">YouTube</a>
					<a href="https://instagram.com" target="_blank" class="px-3 py-1.5 bg-fuchsia-950/40 hover:bg-fuchsia-950 border border-fuchsia-800 text-xs font-black uppercase font-['League_Spartan'] transition-all">Instagram</a>
					<a href="https://google.com" target="_blank" class="px-3 py-1.5 bg-blue-950/40 hover:bg-blue-950 border border-blue-800 text-xs font-black uppercase font-['League_Spartan'] transition-all">Google Blog</a>
				</div>
				<div class="bg-amber-950/30 border border-amber-900 rounded p-3 text-center mt-2">
					<p class="text-xs text-amber-200 leading-normal font-medium">
						⚠️ We do not operate any channels other than these five! Beware of imitation websites!
					</p>
				</div>
			</div>

			<div class="text-center mt-8 pt-4 border-t border-[#5B0E1B]/20">
				<span class="font-['League_Spartan'] text-base font-black text-slate-400 uppercase tracking-widest block mb-1">taerijay+</span>
				<p class="text-[9px] text-slate-500 font-mono">© 2026 TAERIJAY. MADE IN KOREA. ALL RIGHTS RESERVED.</p>
			</div>
		</footer>

		<!-- MODALS PORTAL MATRIX -->
		<div id="modal-terms" class="modal-overlay fixed inset-0 z-50 bg-black/80 backdrop-blur-sm hidden items-center justify-center p-4">
			<div class="bg-[#0A192F] border-2 border-[#5B0E1B] rounded-lg max-w-[400px] w-full p-5 flex flex-col gap-3 relative max-h-[85vh] overflow-y-auto">
				<h3 class="text-sm font-bold text-white border-b border-[#5B0E1B] pb-2 uppercase tracking-wide flex items-center justify-between">
					<span>Terms of Service</span>
					<button class="modal-close text-xl text-slate-400 hover:text-white">&times;</button>
				</h3>
				<p class="text-xs text-slate-300 leading-relaxed">
					TAERIJAY+ Terms: This subscription pipeline delivers digital guide asset access mapping across a strict 24-month duration frame. Refunds remain absolutely void upon real-time terminal sync activation.
				</p>
			</div>
		</div>

		<div id="modal-business" class="modal-overlay fixed inset-0 z-50 bg-black/80 backdrop-blur-sm hidden items-center justify-center p-4">
			<div class="bg-[#0A192F] border-2 border-[#5B0E1B] rounded-lg max-w-[400px] w-full p-5 flex flex-col gap-3 relative max-h-[85vh] overflow-y-auto">
				<h3 class="text-sm font-bold text-white border-b border-[#5B0E1B] pb-2 uppercase tracking-wide flex items-center justify-between">
					<span>Business Info</span>
					<button class="modal-close text-xl text-slate-400 hover:text-white">&times;</button>
				</h3>
				<p class="text-xs text-slate-300 leading-relaxed flex flex-col gap-2">
					<span><strong>Brand Title:</strong> TAERIJAY</span>
					<span><strong>License Register ID:</strong> 673-51-01148</span>
					<span><strong>Mail-Order License:</strong> 2026-Hwadosudo-0247</span>
					<span><strong>Location Base:</strong> Hwado-eup, Namyangju-si, Gyeonggi-do</span>
				</p>
			</div>
		</div>

		<div id="modal-privacy" class="modal-overlay fixed inset-0 z-50 bg-black/80 backdrop-blur-sm hidden items-center justify-center p-4">
			<div class="bg-[#0A192F] border-2 border-[#5B0E1B] rounded-lg max-w-[400px] w-full p-5 flex flex-col gap-3 relative max-h-[85vh] overflow-y-auto">
				<h3 class="text-sm font-bold text-white border-b border-[#5B0E1B] pb-2 uppercase tracking-wide flex items-center justify-between">
					<span>Privacy Policy</span>
					<button class="modal-close text-xl text-slate-400 hover:text-white">&times;</button>
				</h3>
				<p class="text-xs text-slate-300 leading-relaxed">
					TAERIJAY+ Privacy: We explicitly restrict profile logs to primary Google OAuth parameters and secure Paddle API pipeline payload tokens.
				</p>
			</div>
		</div>

		<div id="modal-refund" class="modal-overlay fixed inset-0 z-50 bg-black/80 backdrop-blur-sm hidden items-center justify-center p-4">
			<div class="bg-[#0A192F] border-2 border-[#5B0E1B] rounded-lg max-w-[400px] w-full p-5 flex flex-col gap-3 relative max-h-[85vh] overflow-y-auto">
				<h3 class="text-sm font-bold text-white border-b border-[#5B0E1B] pb-2 uppercase tracking-wide flex items-center justify-between">
					<span>Refund Policy</span>
					<button class="modal-close text-xl text-slate-400 hover:text-white">&times;</button>
				</h3>
				<p class="text-xs text-slate-300 leading-relaxed">
					TAERIJAY+ Charge Settlement: Given immediate digital credential routing and master node viewing capability initialization, all fee transactions remain binding and non-refundable.
				</p>
			</div>
		</div>

		<div id="modal-checkout" class="modal-overlay fixed inset-0 z-50 bg-black/80 backdrop-blur-sm hidden items-center justify-center p-4">
			<div class="bg-[#0A192F] border-2 border-[#5B0E1B] rounded-lg max-w-[400px] w-full p-5 flex flex-col gap-4 relative text-center">
				<div class="text-4xl animate-bounce">💳</div>
				<h3 class="text-sm font-bold text-white">Paddle Secure Checkout</h3>
				<p class="text-xs text-slate-300 leading-relaxed px-2">Simulating 24-Month Premium Pass Double Value Tier access activation.</p>
				<button class="modal-close w-full py-2 bg-emerald-600 text-white text-xs font-bold uppercase rounded">Complete Simulation</button>
			</div>
		</div>

		<div id="modal-gating" class="modal-overlay fixed inset-0 z-50 bg-black/80 backdrop-blur-sm hidden items-center justify-center p-4">
			<div class="bg-[#0A192F] border-2 border-[#5B0E1B] rounded-lg max-w-[400px] w-full p-6 flex flex-col gap-4 relative text-center">
				<div class="text-5xl">🔒</div>
				<h3 class="text-sm font-black text-white uppercase tracking-wider">Premium Locked Episode</h3>
				<p class="text-xs text-slate-300 leading-relaxed px-1">Non-paying guest credentials limited to 12 episodes. Subscribe to our 2-Year Premium Membership now!</p>
				<button class="modal-close w-full py-2.5 bg-[#5B0E1B] text-white text-xs font-black tracking-widest">Unlock Premium Pass</button>
			</div>
		</div>

	</main>

	<!-- Master Orchestration Script Matrix -->
	<script is:inline>
		// Database routing table mapping for 1 to 7 Channels
		const channelDatabase = {
			'ch-protocol': {
				title: 'taerijay+ protocol', badge: '🌐 rule', tag: 'must action', cat: '[PROTOCOL] BEHAVIOR',
				mainTitle: 'Global Traveler Code & Security Policy', desc: 'Legal requirements, entry regulations, and secure travel guidelines.',
				addr: 'Incheon International Airport Terminal 1 & 2', color: '#F16B24', img: 'https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?auto=format&fit=crop&w=500&q=80', gating: false
			},
			'ch-mini': {
				title: 'taerijay+ mini', badge: '📍 route', tag: 'city guide', cat: '[MINI] OPTIMIZATION',
				mainTitle: 'Dense One-Day Travel Blueprints', desc: 'Detailed course timelines, step-by-step maps, and optimized transport flow.',
				addr: 'Myeong-dong, Jung-gu, Seoul', color: '#FBF9F4', img: 'https://images.unsplash.com/photo-1517048676732-d65bc937f952?auto=format&fit=crop&w=500&q=80', gating: false
			},
			'ch-daiso': {
				title: 'taerijay+ daiso', badge: '💡 beauty', tag: 'hot items', cat: '[DAISO] MUST-BUY',
				mainTitle: 'Viral K-Beauty Cosmetics & Gear under $5', desc: 'Real-time viral skincare, makeup, and practical travel supplies.',
