---
import Layout from '../layouts/Layout.astro';

// Astro 서버사이드 정적 변수
const lastUpdateDate = "2026.07.20";
const totalItemCount = 613; 
const monthlyUpdatedCount = 5;
---

<Layout title="TAERIJAY (태리재이)+">
	<!-- 모바일 최적화 규칙 기반 max-w-[480px] 디즈니+ 럭셔리 컨테이너 격리 락인 -->
	<main class="w-full max-w-[480px] min-h-screen bg-[#0A192F] border-x border-[#5B0E1B] flex flex-col relative pb-24 shadow-2xl">
		
		<!-- OTT TOP BRAND HEADER -->
		<header class="w-full px-5 py-4 border-b border-[#5B0E1B] bg-[#0A192F]/90 backdrop-blur sticky top-0 z-40 flex items-center justify-between">
			<div class="flex flex-col">
				<span class="font-['League_Spartan'] text-2xl font-black tracking-widest text-transparent bg-clip-text bg-gradient-to-r from-white via-amber-100 to-[#00E5FF] leading-none uppercase">taerijay+</span>
				<span class="text-[8px] tracking-[0.2em] text-[#00E5FF] uppercase font-['League_Spartan'] mt-1">global k-travel platform</span>
			</div>
			
			<!-- 실시간 다국어 인프라 변환 토글 스위치 -->
			<div class="flex items-center bg-[#071120] border border-[#5B0E1B] rounded-full p-0.5" id="langToggleWrapper">
				<button data-lang="en" class="lang-btn px-2.5 py-1 rounded-full text-[9px] font-bold uppercase transition-all duration-300 bg-[#5B0E1B] text-white">en</button>
				<button data-lang="ko" class="lang-btn px-2.5 py-1 rounded-full text-[9px] font-bold uppercase transition-all duration-300 text-slate-400">ko</button>
			</div>
		</header>

		<!-- DISNEY+ STYLE HERO SLIDER BANNER -->
		<section class="w-full relative overflow-hidden px-5 py-6 border-b border-[#5B0E1B] bg-gradient-to-b from-[#0e2544] to-[#0A192F]">
			<div class="absolute inset-0 bg-cover bg-center opacity-25" style="background-image: url('https://images.unsplash.com/photo-1538481199705-c710c4e965fc?auto=format&fit=crop&w=600&q=80');"></div>
			<div class="relative z-10">
				<div class="inline-flex items-center gap-1.5 bg-[#5B0E1B]/80 border border-[#5B0E1B] px-2.5 py-0.5 rounded-full mb-3 shadow">
					<span class="w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse"></span>
					<span class="text-[8px] font-['League_Spartan'] tracking-widest text-slate-200 uppercase font-bold">active status</span>
				</div>
				
				<h1 class="text-xl font-bold tracking-tight mb-2 leading-tight font-['Playfair_Display'] italic">
					<span class="lang-el" data-en="Unlocking Premium K-Heritage">독점적 프리미엄 헤리티지</span>
				</h1>
				<p class="text-xs text-slate-300 leading-relaxed font-light mb-4">
					<span class="lang-el" data-en="Access restricted curated database representing prime destination flow blueprints.">엄선된 핵심 한국 관광 루트 가이드북 및 무제한 액션 플랜 제공함.</span>
				</p>

				<!-- 동적 자산 현황판 -->
				<div class="grid grid-cols-3 gap-2 bg-[#071120]/90 border border-[#5B0E1B] rounded p-2 text-center shadow-inner">
					<div>
						<div class="text-base font-black text-[#00E5FF] font-['League_Spartan']">{totalItemCount}</div>
						<div class="text-[8px] text-slate-400 font-semibold uppercase">
							<span class="lang-el" data-en="Total DB">총 데이터</span>
						</div>
					</div>
					<div>
						<div class="text-base font-black text-[#FFDD00] font-['League_Spartan']">+{monthlyUpdatedCount}</div>
						<div class="text-[8px] text-slate-400 font-semibold uppercase">
							<span class="lang-el" data-en="Monthly Add">매월 추가</span>
						</div>
					</div>
					<div>
						<div class="text-[13px] font-bold text-slate-200 font-['League_Spartan'] pt-0.5">{lastUpdateDate}</div>
						<div class="text-[8px] text-slate-400 font-semibold uppercase">
							<span class="lang-el" data-en="Last Sync">최근 동기화</span>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- AUTH BATCH PANEL (회원가입/로그인/로그아웃 Google OAuth Session Simulator) -->
		<section class="w-full px-5 py-4 border-b border-[#5B0E1B] bg-[#071120]/50">
			<div class="flex items-center justify-between bg-[#0A192F] border border-[#5B0E1B] rounded-lg p-3 shadow-lg" id="authBox">
				<div class="flex items-center gap-3">
					<div class="w-9 h-9 rounded-full bg-gradient-to-tr from-cyan-400 to-fuchsia-600 p-0.5 shadow-md">
						<div class="w-full h-full bg-[#0A192F] rounded-full flex items-center justify-center text-sm font-bold text-white">🌐</div>
					</div>
					<div class="flex flex-col">
						<span class="text-sm font-bold text-white tracking-wide" id="userEmail">guest@taerijay.com</span>
						<span class="text-[9px] text-slate-500 font-semibold tracking-wider uppercase flex items-center gap-1" id="sessionStatus">
							<span class="w-1.5 h-1.5 rounded-full bg-slate-500 shadow" id="sessionDot"></span>
							<span class="lang-el" data-en="Guest Mode">게스트 모드</span>
						</span>
					</div>
				</div>
				<!-- 회원가입/로그인/로그아웃 스위칭 버튼 통합 -->
				<button id="authBtn" class="px-3 py-1.5 border border-[#5B0E1B] rounded bg-[#5B0E1B]/30 hover:bg-[#5B0E1B]/60 text-slate-200 text-xs font-bold uppercase transition-all shadow">
					<span class="lang-el" data-en="Google Login">구글 로그인</span>
				</button>
			</div>
		</section>

		<!-- DISNEY+ OTT 8 CHANNELS FORM FACTOR PLATFORM -->
		<section class="w-full px-5 py-6 flex flex-col gap-5">
			<div class="flex justify-between items-center mb-1">
				<h2 class="text-xs uppercase tracking-wider font-bold text-slate-300 font-['League_Spartan'] flex items-center gap-2">
					<span class="w-2 h-2 bg-[#5B0E1B]"></span>
					<span class="lang-el" data-en="Active Premium Channels">8대 액티브 채널</span>
				</h2>
				<span class="text-[9px] text-slate-500 font-mono tracking-tighter">max-w: 480px / locked</span>
			</div>

			<!-- 마스터 그리드 카드 스택 -->
			<div class="flex flex-col gap-6">

				<!-- BRAND 0: MAIN TAERIJAY -->
				<div class="w-full rounded-lg border border-[#5B0E1B] bg-[#0A192F] overflow-hidden flex flex-col transition-all duration-300 hover:scale-[1.01] shadow-md">
					<div class="px-4 py-2 bg-[#061224] border-b border-[#5B0E1B] flex items-center justify-between">
						<span class="text-xs font-black uppercase font-['League_Spartan'] text-[#5B0E1B]">taerijay+ main</span>
						<span class="text-[10px] text-slate-500 font-bold uppercase">🇰🇷 core</span>
					</div>
					<div class="h-44 bg-slate-900 relative overflow-hidden flex items-center justify-center">
						<div class="absolute inset-0 bg-cover bg-center opacity-20" style="background-image: url('https://images.unsplash.com/photo-1493976040374-85c8e12f0c0e?auto=format&fit=crop&w=500&q=80');"></div>
						<div class="relative z-10 text-center px-4">
							<span class="font-['Playfair_Display'] text-4xl font-black italic tracking-tight text-[#5B0E1B]/40 block mb-1">TAERIJAY</span>
							<p class="text-[10px] text-[#5B0E1B]/60 font-black uppercase tracking-widest font-['League_Spartan']">heritage premium frame</p>
						</div>
					</div>
					<div class="p-4 flex flex-col gap-3">
						<div class="flex flex-col gap-1">
							<span class="text-xs font-bold text-[#5B0E1B] uppercase font-['League_Spartan']">[MAIN] HERITAGE</span>
							<h3 class="text-sm font-bold text-white tracking-tight">
								<span class="lang-el" data-en="Ultimate K-Travel Master Blueprint">대한민국 대표 여행지 총 집합 마스터 기획안</span>
							</h3>
						</div>
						<p class="text-xs text-slate-400 leading-relaxed">
							<span class="lang-el" data-en="Premium curated travel destinations optimized for international VIP travelers.">VIP 방문객 전용 로컬 동선 배치 및 유일무이한 가이드북 완전 탑재함.</span>
						</p>
						<div class="pt-2 border-t border-[#5B0E1B]/30 flex items-center justify-between gap-2">
							<div class="flex items-center gap-1.5 min-w-0">
								<span class="text-sm">📍</span>
								<span class="text-[11px] text-slate-300 font-mono truncate" id="addr-main">Gyeonggi-do, Namyangju-si, Hwado-eup</span>
							</div>
							<button class="copy-btn shrink-0 bg-[#5B0E1B]/20 border border-[#5B0E1B]/60 text-slate-200 px-2.5 py-1 rounded hover:bg-[#5B0E1B]/40 text-[10px] font-bold uppercase tracking-wider transition-all" data-target="addr-main">
								<span class="lang-el" data-en="Copy">복사</span>
							</button>
						</div>
					</div>
				</div>

				<!-- BRAND 1: protocol -->
				<div class="w-full rounded-lg border border-[#5B0E1B] bg-[#0A192F] overflow-hidden flex flex-col transition-all duration-300 hover:scale-[1.01] shadow-md">
					<div class="px-4 py-2 bg-[#061224] border-b border-[#5B0E1B] flex items-center justify-between">
						<span class="text-xs font-black uppercase font-['League_Spartan'] text-[#F16B24]">taerijay+ protocol</span>
						<span class="text-[10px] text-slate-500 font-bold uppercase">🌐 rule</span>
					</div>
					<div class="h-40 bg-slate-900 relative overflow-hidden flex items-center justify-center">
						<div class="absolute inset-0 bg-cover bg-center opacity-40" style="background-image: url('https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?auto=format&fit=crop&w=500&q=80');"></div>
						<div class="absolute inset-0 bg-gradient-to-t from-[#0A192F] to-transparent"></div>
						<div class="absolute bottom-3 left-4">
							<span class="px-2 py-0.5 bg-[#F16B24] text-white text-[9px] font-black uppercase rounded font-['League_Spartan']">must action</span>
						</div>
					</div>
					<div class="p-4 flex flex-col gap-3">
						<div class="flex flex-col gap-1">
							<span class="text-xs font-bold text-[#F16B24] uppercase font-['League_Spartan']">[PROTOCOL] BEHAVIOR</span>
							<h3 class="text-sm font-bold text-white tracking-tight">
								<span class="lang-el" data-en="Global Traveler Code & Security Policy">해외 입국객 행동 강령 및 10대 수칙 명시</span>
							</h3>
						</div>
						<p class="text-xs text-slate-400 leading-relaxed">
							<span class="lang-el" data-en="Legal requirements, entry regulations, and secure travel guidelines.">공항 세관, 대중교통 탑승 룰, 도난 방지 가이드라인 및 필수 규칙만 선별함.</span>
						</p>
						<div class="pt-2 border-t border-[#5B0E1B]/30 flex items-center justify-between gap-2">
							<div class="flex items-center gap-1.5 min-w-0">
								<span class="text-sm">📍</span>
								<span class="text-[11px] text-slate-300 font-mono truncate" id="addr-protocol">Incheon International Airport Terminal 1 & 2</span>
							</div>
							<button class="copy-btn shrink-0 bg-[#5B0E1B]/20 border border-[#5B0E1B]/60 text-slate-200 px-2.5 py-1 rounded hover:bg-[#5B0E1B]/40 text-[10px] font-bold uppercase tracking-wider transition-all" data-target="addr-protocol">
								<span class="lang-el" data-en="Copy">복사</span>
							</button>
						</div>
					</div>
				</div>

				<!-- BRAND 2: mini -->
				<div class="w-full rounded-lg border border-[#5B0E1B] bg-[#0A192F] overflow-hidden flex flex-col transition-all duration-300 hover:scale-[1.01] shadow-md">
					<div class="px-4 py-2 bg-[#061224] border-b border-[#5B0E1B] flex items-center justify-between">
						<span class="text-xs font-black uppercase font-['League_Spartan'] text-[#FBF9F4]">taerijay+ mini</span>
						<span class="text-[10px] text-slate-500 font-bold uppercase">📍 route</span>
					</div>
					<div class="h-40 bg-slate-900 relative overflow-hidden flex items-center justify-center">
						<div class="absolute inset-0 bg-cover bg-center opacity-40" style="background-image: url('https://images.unsplash.com/photo-1517048676732-d65bc937f952?auto=format&fit=crop&w=500&q=80');"></div>
						<div class="absolute inset-0 bg-gradient-to-t from-[#0A192F] to-transparent"></div>
						<div class="absolute bottom-3 left-4">
							<span class="px-2 py-0.5 bg-[#FBF9F4] text-[#0A192F] text-[9px] font-black uppercase rounded font-['League_Spartan']">city guide</span>
						</div>
					</div>
					<div class="p-4 flex flex-col gap-3">
						<div class="flex flex-col gap-1">
							<span class="text-xs font-bold text-[#FBF9F4] uppercase font-['League_Spartan']">[MINI] OPTIMIZATION</span>
							<h3 class="text-sm font-bold text-white tracking-tight">
								<span class="lang-el" data-en="Dense One-Day Travel Blueprints">거점 도시별 초압축 24시간 가성비 투어</span>
							</h3>
						</div>
						<p class="text-xs text-slate-400 leading-relaxed">
							<span class="lang-el" data-en="Detailed course timelines, step-by-step maps, and optimized transport flow.">시간 낭비 없는 완벽한 원데이 서킷 및 환승 정보만 진주빛 미색으로 정갈하게 가시화함.</span>
						</p>
						<div class="pt-2 border-t border-[#5B0E1B]/30 flex items-center justify-between gap-2">
							<div class="flex items-center gap-1.5 min-w-0">
								<span class="text-sm">📍</span>
								<span class="text-[11px] text-slate-300 font-mono truncate" id="addr-mini">Myeong-dong, Jung-gu, Seoul</span>
							</div>
							<button class="copy-btn shrink-0 bg-[#5B0E1B]/20 border border-[#5B0E1B]/60 text-slate-200 px-2.5 py-1 rounded hover:bg-[#5B0E1B]/40 text-[10px] font-bold uppercase tracking-wider transition-all" data-target="addr-mini">
								<span class="lang-el" data-en="Copy">복사</span>
							</button>
						</div>
					</div>
				</div>

				<!-- BRAND 3: daiso -->
				<div class="w-full rounded-lg border border-[#5B0E1B] bg-[#0A192F] overflow-hidden flex flex-col transition-all duration-300 hover:scale-[1.01] shadow-md">
					<div class="px-4 py-2 bg-[#061224] border-b border-[#5B0E1B] flex items-center justify-between">
						<span class="text-xs font-black uppercase font-['League_Spartan'] text-[#E1261C]">taerijay+ daiso</span>
						<span class="text-[10px] text-slate-500 font-bold uppercase">💡 beauty</span>
					</div>
					<div class="h-40 bg-slate-900 relative overflow-hidden flex items-center justify-center">
						<div class="absolute inset-0 bg-cover bg-center opacity-40" style="background-image: url('https://images.unsplash.com/photo-1596462502278-27bfdc403348?auto=format&fit=crop&w=500&q=80');"></div>
						<div class="absolute inset-0 bg-gradient-to-t from-[#0A192F] to-transparent"></div>
						<div class="absolute bottom-3 left-4">
							<span class="px-2 py-0.5 bg-[#E1261C] text-white text-[9px] font-black uppercase rounded font-['League_Spartan']">hot items</span>
						</div>
					</div>
					<div class="p-4 flex flex-col gap-3">
						<div class="flex flex-col gap-1">
							<span class="text-xs font-bold text-[#E1261C] uppercase font-['League_Spartan']">[DAISO] MUST-BUY</span>
							<h3 class="text-sm font-bold text-white tracking-tight">
								<span class="lang-el" data-en="Viral K-Beauty Cosmetics & Gear under $5">다이소 뷰티 품절 대란템 리스트 및 확보 매장</span>
							</h3>
						</div>
						<p class="text-xs text-slate-400 leading-relaxed">
							<span class="lang-el" data-en="Real-time viral skincare, makeup, and practical travel supplies.">SNS 대란 스킨케어, 리들샷 솔직 후기 및 매장 정보를 강렬한 네온 레드 핏으로 락인함.</span>
						</p>
						<div class="pt-2 border-t border-[#5B0E1B]/30 flex items-center justify-between gap-2">
							<div class="flex items-center gap-1.5 min-w-0">
								<span class="text-sm">📍</span>
								<span class="text-[11px] text-slate-300 font-mono truncate" id="addr-daiso">134-1 Myeongdong 2-ga, Jung-gu, Seoul</span>
							</div>
							<button class="copy-btn shrink-0 bg-[#5B0E1B]/20 border border-[#5B0E1B]/60 text-slate-200 px-2.5 py-1 rounded hover:bg-[#5B0E1B]/40 text-[10px] font-bold uppercase tracking-wider transition-all" data-target="addr-daiso">
								<span class="lang-el" data-en="Copy">복사</span>
							</button>
						</div>
					</div>
				</div>

				<!-- BRAND 4: oliveyoung -->
				<div class="w-full rounded-lg border border-[#5B0E1B] bg-[#0A192F] overflow-hidden flex flex-col transition-all duration-300 hover:scale-[1.01] shadow-md">
					<div class="px-4 py-2 bg-[#061224] border-b border-[#5B0E1B] flex items-center justify-between">
						<span class="text-xs font-black uppercase font-['League_Spartan'] text-[#6F8B2E]">taerijay+ oliveyoung</span>
						<span class="text-[10px] text-slate-500 font-bold uppercase">💡 tax-free</span>
					</div>
					<div class="h-40 bg-slate-900 relative overflow-hidden flex items-center justify-center">
						<div class="absolute inset-0 bg-cover bg-center opacity-40" style="background-image: url('https://images.unsplash.com/photo-1522335789203-aabd1fc54bc9?auto=format&fit=crop&w=500&q=80');"></div>
						<div class="absolute inset-0 bg-gradient-to-t from-[#0A192F] to-transparent"></div>
						<div class="absolute bottom-3 left-4">
							<span class="px-2 py-0.5 bg-[#6F8B2E] text-white text-[9px] font-black uppercase rounded font-['League_Spartan']">k-beauty</span>
						</div>
					</div>
					<div class="p-4 flex flex-col gap-3">
						<div class="flex flex-col gap-1">
							<span class="text-xs font-bold text-[#6F8B2E] uppercase font-['League_Spartan']">[OLIVEYOUNG] SKINCARE</span>
							<h3 class="text-sm font-bold text-white tracking-tight">
								<span class="lang-el" data-en="Instant Tax Refund Guide & Best Skincare">글로벌 1위 올리브영 화장품 및 즉시 면세 매장</span>
							</h3>
						</div>
						<p class="text-xs text-slate-400 leading-relaxed">
							<span class="lang-el" data-en="Top recommended brands, facial masks, and on-site duty-free checkout instructions.">MZ 스킨케어 정보 및 즉시 면세 [Tax-Free] 환급 여부를 청량한 올리브 톤으로 격리 수용함.</span>
						</p>
						<div class="pt-2 border-t border-[#5B0E1B]/30 flex items-center justify-between gap-2">
							<div class="flex items-center gap-1.5 min-w-0">
								<span class="text-sm">📍</span>
								<span class="text-[11px] text-slate-300 font-mono truncate" id="addr-olive">53 Myeongdong-gil, Jung-gu, Seoul</span>
							</div>
							<button class="copy-btn shrink-0 bg-[#5B0E1B]/20 border border-[#5B0E1B]/60 text-slate-200 px-2.5 py-1 rounded hover:bg-[#5B0E1B]/40 text-[10px] font-bold uppercase tracking-wider transition-all" data-target="addr-olive">
								<span class="lang-el" data-en="Copy">복사</span>
							</button>
						</div>
					</div>
				</div>

				<!-- BRAND 5: emart -->
				<div class="w-full rounded-lg border border-[#5B0E1B] bg-[#0A192F] overflow-hidden flex flex-col transition-all duration-300 hover:scale-[1.01] shadow-md">
					<div class="px-4 py-2 bg-[#061224] border-b border-[#5B0E1B] flex items-center justify-between">
						<span class="text-xs font-black uppercase font-['League_Spartan'] text-[#FFDD00]">taerijay+ emart</span>
						<span class="text-[10px] text-red-500 font-bold uppercase">⚠️ warning</span>
					</div>
					<div class="h-40 bg-slate-900 relative overflow-hidden flex items-center justify-center">
						<div class="absolute inset-0 bg-cover bg-center opacity-40" style="background-image: url('https://images.unsplash.com/photo-1542838132-92c53300491e?auto=format&fit=crop&w=500&q=80');"></div>
						<div class="absolute inset-0 bg-gradient-to-t from-[#0A192F] to-transparent"></div>
						<div class="absolute bottom-3 left-4">
							<span class="px-2 py-0.5 bg-[#FFDD00] text-[#0A192F] text-[9px] font-black uppercase rounded font-['League_Spartan']">smart buy</span>
						</div>
					</div>
