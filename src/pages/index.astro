			<div class="bg-[#0A192F] border-2 border-[#5B0E1B] rounded-lg max-w-[400px] w-full p-5 flex flex-col gap-3 relative max-h-[85vh] overflow-y-auto">
				<h3 class="text-sm font-bold text-white border-b border-[#5B0E1B] pb-2 uppercase tracking-wide flex items-center justify-between">
					<span>Refund Policy</span>
					<button class="modal-close text-xl text-slate-400 hover:text-white">&times;</button>
				</h3>
				<p class="text-xs text-slate-300 leading-relaxed">
					TAERIJAY+ Charge Settlement: Given immediate digital credential routing and master node viewing capability initialization, all fee transactions remain binding and non-refundable. Verified system-level processing duplication errors stand processed for reversal within 7 standard business cycles.
				</p>
				<button class="modal-close w-full py-2 bg-[#5B0E1B] text-white text-xs font-bold uppercase rounded mt-2">Close</button>
			</div>
		</div>

		<div id="modal-checkout" class="modal-overlay fixed inset-0 z-50 bg-black/80 backdrop-blur-sm hidden items-center justify-center p-4">
			<div class="bg-[#0A192F] border-2 border-[#5B0E1B] rounded-lg max-w-[400px] w-full p-5 flex flex-col gap-4 relative text-center">
				<div class="text-4xl animate-bounce">💳</div>
				<h3 class="text-sm font-bold text-white">Paddle Secure Checkout</h3>
				<p class="text-xs text-slate-300 leading-relaxed px-2">
					Simulating 24-Month Premium Pass API call parameters for tier: <span id="checkoutTier" class="text-[#00E5FF] font-bold"></span>.
				</p>
				<div class="flex flex-col gap-2">
					<button class="modal-close w-full py-2 bg-emerald-600 hover:bg-emerald-700 text-white text-xs font-bold uppercase rounded transition-all">Complete Simulation</button>
					<button class="modal-close w-full py-2 bg-slate-800 hover:bg-slate-700 text-slate-300 text-xs font-bold uppercase rounded transition-all">Cancel</button>
				</div>
			</div>
		</div>

		<div id="modal-gating" class="modal-overlay fixed inset-0 z-50 bg-black/80 backdrop-blur-sm hidden items-center justify-center p-4">
			<div class="bg-[#0A192F] border-2 border-[#5B0E1B] rounded-lg max-w-[400px] w-full p-6 flex flex-col gap-4 relative text-center">
				<div class="text-5xl">🔒</div>
				<h3 class="text-sm font-black text-white uppercase tracking-wider">Premium Locked Episode</h3>
				<p class="text-xs text-slate-300 leading-relaxed px-1">
					Non-paying guest credentials limited to 12 episodes. Subscribe to our 2-Year Premium Membership now to unlock terminal index coverage instantly!
				</p>
				<button class="modal-close w-full py-2.5 bg-[#5B0E1B] hover:bg-[#8b1328] text-white text-xs font-black tracking-widest transition-all">Unlock Premium Membership Pass</button>
			</div>
		</div>

	</main>

	<script is:inline>
		document.addEventListener('DOMContentLoaded', () => {
			// Copy Address
			const copyButtons = document.querySelectorAll('.copy-btn');
			copyButtons.forEach(btn => {
				btn.addEventListener('click', () => {
					const targetId = btn.dataset.target;
					const targetElement = document.getElementById(targetId);
					if (targetElement) {
						navigator.clipboard.writeText(targetElement.textContent)
							.then(() => {
								const originalText = btn.textContent;
								btn.textContent = 'COPIED!';
								btn.classList.add('bg-emerald-900', 'border-emerald-600');
								setTimeout(() => {
									btn.textContent = originalText;
									btn.classList.remove('bg-emerald-900', 'border-emerald-600');
								}, 1500);
							});
					}
				});
			});

			// Modal Core
			const triggers = document.querySelectorAll('.modal-trigger');
			const closers = document.querySelectorAll('.modal-close');
			const overlays = document.querySelectorAll('.modal-overlay');

			triggers.forEach(trig => {
				trig.addEventListener('click', () => {
					const targetId = trig.dataset.target;
					const targetModal = document.getElementById(targetId);
					if (targetModal) {
						targetModal.classList.remove('hidden');
						targetModal.classList.add('flex');
					}
				});
			});

			closers.forEach(closer => {
				closer.addEventListener('click', () => {
					const activeModal = closer.closest('.modal-overlay');
					if (activeModal) {
						activeModal.classList.add('hidden');
						activeModal.classList.remove('flex');
					}
				});
			});

			overlays.forEach(overlay => {
				overlay.addEventListener('click', (e) => {
					if (e.target === overlay) {
						overlay.classList.add('hidden');
						overlay.classList.remove('flex');
					}
				});
			});

			// Revoke Device Simulation
			const revokeButtons = document.querySelectorAll('.revoke-dev-btn');
			revokeButtons.forEach(btn => {
				btn.addEventListener('click', () => {
					const rowId = btn.dataset.target;
					const targetRow = document.getElementById(rowId);
					if (targetRow) {
						targetRow.classList.add('opacity-40', 'pointer-events-none');
						btn.disabled = true;
						btn.textContent = 'REVOKED';
					}
				});
			});

			// Paddle Simulation
			const payButtons = document.querySelectorAll('.pay-btn');
			const checkoutModal = document.getElementById('modal-checkout');
			const checkoutTierText = document.getElementById('checkoutTier');

			payButtons.forEach(btn => {
				btn.addEventListener('click', () => {
					const tier = btn.dataset.tier;
					if (checkoutModal && checkoutTierText) {
						checkoutTierText.textContent = tier;
						checkoutModal.classList.remove('hidden');
						checkoutModal.classList.add('flex');
					}
				});
			});

			// Lock Threshold Limit 13+
			const epRows = document.querySelectorAll('.ep-row');
			const gatingModal = document.getElementById('modal-gating');

			epRows.forEach(row => {
				row.addEventListener('click', () => {
					const isPreview = row.dataset.preview === 'true';
					if (isPreview) {
						const url = row.dataset.url;
						window.open(url, '_blank');
					} else {
						if (gatingModal) {
							gatingModal.classList.remove('hidden');
							gatingModal.classList.add('flex');
						}
					}
				});
			});

			// OAuth Session Simulator
			const authBtn = document.getElementById('authBtn');
			const userEmail = document.getElementById('userEmail');
			const sessionStatus = document.getElementById('sessionStatus');
			const sessionDot = document.getElementById('sessionDot');

			authBtn.addEventListener('click', () => {
				if (userEmail.textContent === 'guest@taerijay.com') {
					userEmail.textContent = 'official-vip@taerijay.com';
					sessionStatus.querySelector('span:last-child').textContent = 'Verified Premium Session';
					sessionStatus.classList.remove('text-slate-500');
					sessionStatus.classList.add('text-[#00E5FF]');
					sessionDot.classList.remove('bg-slate-500');
					sessionDot.classList.add('bg-[#00E5FF]');
					authBtn.textContent = 'LOGOUT';
					authBtn.classList.remove('bg-[#5B0E1B]/30');
					authBtn.classList.add('bg-[#5B0E1B]');
				} else {
					userEmail.textContent = 'guest@taerijay.com';
					sessionStatus.querySelector('span:last-child').textContent = 'Guest Mode';
					sessionStatus.classList.remove('text-[#00E5FF]');
					sessionStatus.classList.add('text-slate-500');
					sessionDot.classList.remove('bg-[#00E5FF]');
					sessionDot.classList.add('bg-slate-500');
					authBtn.textContent = 'GOOGLE LOGIN';
					authBtn.classList.add('bg-[#5B0E1B]/30');
					authBtn.classList.remove('bg-[#5B0E1B]');
				}
			});
		});
	</script>
</Layout>