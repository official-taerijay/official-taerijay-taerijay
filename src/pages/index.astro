---
import Layout from '../layouts/Layout.astro';

const lastUpdateDate = "2026.07.20";
const totalItemCount = 613; 
const monthlyUpdatedCount = 5;
---

<Layout title="TAERIJAY (태리재이)+">
	<!-- 화면 환경에 맞게 좌우로 자유롭게 늘어나는 가로 100% 유연한 레이아웃 구조 -->
	<main class="w-full min-h-screen bg-[#0A192F] flex flex-col relative pb-24 overflow-hidden">
		
		<!-- TOP HEADER INFRASTRUCTURE WITH EMBEDDED AUTH BUTTON -->
		<header class="w-full px-6 py-4 border-b border-[#5B0E1B] bg-[#0A192F]/95 backdrop-blur sticky top-0 z-50 flex items-center justify-between">
			<!-- LEFT: Hamburger Menu Button -->
			<button id="menuTrigger" class="text-white hover:text-[#00E5FF] transition-colors p-2 flex items-center justify-center">
				<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
					<path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
				</svg>
			</button>

			<!-- CENTER: Brand Typography Logo -->
			<div class="flex flex-col items-center">
				<span class="font-['League_Spartan'] text-2xl font-black tracking-widest text-transparent bg-clip-text bg-gradient-to-r from-white via-amber-100 to-[#00E5FF] leading-none uppercase">taerijay+</span>
			</div>
			
			<!-- RIGHT: Combined Auth Switcher Badge (Sign In / Register / Logout) -->
			<button id="authBtn" class="px-4 py-2 border border-[#5B0E1B] rounded bg-[#5B0E1B]/30 hover:bg-[#5B0E1B]/60 text-slate-200 text-xs font-bold uppercase tracking-wider transition-all shadow-md">
				Google Login
			</button>
		</header>

		<!-- SIDEBAR HAMBURGER DRAWER MECHANISM -->
		<div id="sideDrawer" class="fixed inset-0 z-50 bg-black/80 backdrop-blur-sm hidden justify-start w-full">
			<div class="w-[300px] h-full bg-[#071120] border-r border-[#5B0E1B] p-6 flex flex-col gap-6 relative">
				<div class="flex items-center justify-between border-b border-[#5B0E1B] pb-4">
					<span class="font-['League_Spartan'] text-base font-black tracking-widest text-[#00E5FF] uppercase">Premium Channels</span>
					<button id="menuCloser" class="text-slate-400 hover:text-white text-3xl font-light leading-none">&times;</button>
				</div>
				
				<!-- 1번부터 7번 채널까지의 명확한 영문 네비게이션 안착 -->
				<nav class="flex flex-col gap-3 font-['League_Spartan'] font-bold text-sm">
					<button class="channel-nav-link w-full text-left p-3 rounded border border-[#5B0E1B]/40 bg-[#0A192F] text-[#F16B24] hover:bg-[#5B0E1B]/20 transition-all" data-idx="0">1. taerijay+ protocol</button>
					<button class="channel-nav-link w-full text-left p-3 rounded border border-[#5B0E1B]/40 bg-[#0A192F] text-[#FBF9F4] hover:bg-[#5B0E1B]/20 transition-all" data-idx="1">2. taerijay+ mini</button>
					<button class="channel-nav-link w-full text-left p-3 rounded border border-[#5B0E1B]/40 bg-[#0A192F] text-[#E1261C] hover:bg-[#5B0E1B]/20 transition-all" data-idx="2">3. taerijay+ daiso</button>
					<button class="channel-nav-link w-full text-left p-3 rounded border border-[#5B0E1B]/40 bg-[#0A192F] text-[#6F8B2E] hover:bg-[#5B0E1B]/20 transition-all" data-idx="3">4. taerijay+ oliveyoung</button>
					<button class="channel-nav-link w-full text-left p-3 rounded border border-[#5B0E1B]/40 bg-[#0A192F] text-[#FFDD00] hover:bg-[#5B0E1B]/20 transition-all" data-idx="4">5. taerijay+ emart</button>
					<button class="channel-nav-link w-full text-left p-3 rounded border border-[#5B0E1B]/40 bg-[#0A192F] text-[#A14D7C] hover:bg-[#5B0E1B]/20 transition-all" data-idx="5">6. taerijay+ convenience</button>
					<button class="channel-nav-link w-full text-left p-3 rounded border border-[#5B0E1B]/40 bg-[#0A192F] text-[#00E5FF] hover:bg-[#5B0E1B]/20 transition-all" data-idx="6">7. taerijay+ entertainment</button>
				</nav>

				<div class="mt-auto border-t border-[#5B0E1B] pt-4 text-center">
					<span class="text-xs text-slate-500 font-mono" id="drawerUserBadge">Session: guest@taerijay.com</span>
				</div>
			</div>
		</div>

		<!-- BRAND DASHBOARD METRICS SUB-BAR -->
		<section class="w-full px-6 py-4 bg-[#071120]/40 border-b border-[#5B0E1B] flex flex-wrap items-center justify-between gap-4">
			<div class="flex items-center gap-2">
				<span class="w-2 h-2 rounded-full bg-emerald-400 animate-ping"></span>
				<span class="text-xs font-bold text-slate-300 font-['League_Spartan'] uppercase tracking-wider">System Live Platform Monitoring Terminal Connected</span>
			</div>
			<div class="flex items-center gap-6 text-xs text-slate-400 font-mono">
				<div>Total DB: <span class="text-[#00E5FF] font-bold">{totalItemCount}</span></div>
				<div>Monthly Add: <span class="text-[#FFDD00] font-bold">+{monthlyUpdatedCount}</span></div>
				<div>Last Sync: <span class="text-slate-200 font-bold">{lastUpdateDate}</span></div>
			</div>
		</section>

		<!-- DISNEY+ STYLE HORIZONTAL INDEX SLIDER COMPONENT -->
		<section class="w-full py-8 flex flex-col gap-8">
			
			<div class="w-full flex flex-col gap-3">
				<div class="px-6 flex items-center justify-between">
					<h3 class="text-sm font-black uppercase tracking-widest text-slate-300 font-['League_Spartan'] flex items-center gap-2">
						<span class="w-2 h-2 bg-[#5B0E1B]"></span>
						<span>Disney+ Hub Master Scroller Track</span>
					</h3>
					<span class="text-xs text-slate-500 font-mono">Horizontal Scroll Track Active</span>
				</div>

				<!-- 좌우로 시원하게 밀리는 무제한 가로 스크롤 트랙 구조 벨트 -->
				<div class="w-full overflow-x-auto flex gap-6 px-6 py-2 no-scrollbar scroll-smooth" id="masterSliderTrack">
					
					<!-- CARD 0: [MAIN TAERIJAY] -->
					<div class="min-w-[300px] md:min-w-[340px] rounded-lg border-2 border-[#5B0E1B] bg-[#0A192F] overflow-hidden flex flex-col transition-all duration-300 hover:scale-[1.03] hover:shadow-xl hover:shadow-[#5B0E1B]/30 scroll-item" id="slider-card-0">
						<div class="px-4 py-2.5 bg-[#061224] border-b border-[#5B0E1B] flex items-center justify-between">
							<span class="text-xs font-black uppercase font-['League_Spartan'] text-[#5B0E1B]">taerijay+ main</span>
							<span class="text-[10px] text-slate-500 font-bold uppercase">🇰🇷 core</span>
						</div>
						<div class="h-44 bg-slate-900 relative overflow-hidden flex items-center justify-center">
							<div class="absolute inset-0 bg-cover bg-center opacity-25" style="background-image: url('https://images.unsplash.com/photo-1493976040374-85c8e12f0c0e?auto=format&fit=crop&w=500&q=80');"></div>
							<div class="relative z-10 text-center px-4">
								<span class="font-['Playfair_Display'] text-4xl font-black italic tracking-tight text-[#5B0E1B]/30 block mb-1">TAERIJAY</span>
								<p class="text-[10px] text-[#5B0E1B]/50 font-black uppercase tracking-widest font-['League_Spartan']">heritage premium frame</p>
							</div>
						</div>
						<div class="p-4 flex flex-col gap-3">
							<h3 class="text-sm font-bold text-white tracking-tight">Ultimate K-Travel Master Blueprint</h3>
							<p class="text-xs text-slate-400 leading-relaxed min-h-[40px]">
								[TAERIJAY+] 대표 여행지 마스터 기획안 동선 수록함.<br />
								국제 VIP 타겟 맞춤형 프리미엄 로컬 루트 배치 완료함.
							</p>
							<div class="pt-3 border-t border-[#5B0E1B]/30 flex items-center justify-between gap-2 mt-auto">
								<div class="flex items-center gap-1.5 min-w-0">
									<span class="text-sm">📍</span>
									<span class="text-[11px] text-slate-300 font-mono truncate" id="addr-0">Gyeonggi-do, Namyangju-si, Hwado-eup</span>
								</div>
								<button class="copy-btn shrink-0 bg-[#5B0E1B]/20 border border-[#5B0E1B]/60 text-slate-200 px-2.5 py-1 rounded hover:bg-[#5B0E1B]/50 text-[10px] font-bold uppercase tracking-wider transition-all" data-target="addr-0">Copy</button>
							</div>
						</div>
					</div>

					<!-- CARD 1: [1. protocol] -->
					<div class="min-w-[300px] md:min-w-[340px] rounded-lg border border-[#5B0E1B] bg-[#0A192F] overflow-hidden flex flex-col transition-all duration-300 hover:scale-[1.03] hover:shadow-xl hover:shadow-[#5B0E1B]/20 scroll-item" id="slider-card-1">
						<div class="px-4 py-2.5 bg-[#061224] border-b border-[#5B0E1B] flex items-center justify-between">
							<span class="text-xs font-black uppercase font-['League_Spartan'] text-[#F16B24]">taerijay+ protocol</span>
							<span class="text-[10px] text-slate-500 font-bold uppercase">🌐 rule</span>
						</div>
						<div class="h-40 bg-slate-900 relative overflow-hidden flex items-center justify-center">
							<div class="absolute inset-0 bg-cover bg-center opacity-40" style="background-image: url('https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?auto=format&fit=crop&w=500&q=80');"></div>
							<div class="absolute inset-0 bg-gradient-to-t from-[#0A192F] to-transparent"></div>
							<div class="absolute bottom-3 left-4">
								<span class="px-2 py-0.5 bg-[#F16B24] text-white text-[9px] font-black uppercase rounded font-['League_Spartan']">must action</span>
							</div>
						</div>
						<div class="p-4 flex flex-col gap-3">
							<h3 class="text-sm font-bold text-white tracking-tight">Global Traveler Code & Security Policy</h3>
							<p class="text-xs text-slate-400 leading-relaxed min-h-[40px]">
								[인천국제공항] 세관 규정 및 안전 입국 행동 규칙 락인함.<br />
								클래식 오렌지 텍스트 인덱싱을 통한 규약 명확성 상시 확보함.
							</p>
							<div class="pt-3 border-t border-[#5B0E1B]/30 flex items-center justify-between gap-2 mt-auto">
								<div class="flex items-center gap-1.5 min-w-0">
									<span class="text-sm">📍</span>
									<span class="text-[11px] text-slate-300 font-mono truncate" id="addr-1">Incheon International Airport Terminal 1 & 2</span>
								</div>
								<button class="copy-btn shrink-0 bg-[#5B0E1B]/20 border border-[#5B0E1B]/60 text-slate-200 px-2.5 py-1 rounded hover:bg-[#5B0E1B]/50 text-[10px] font-bold uppercase tracking-wider transition-all" data-target="addr-1">Copy</button>
							</div>
						</div>
					</div>

					<!-- CARD 2: [2. mini] -->
					<div class="min-w-[300px] md:min-w-[340px] rounded-lg border border-[#5B0E1B] bg-[#0A192F] overflow-hidden flex flex-col transition-all duration-300 hover:scale-[1.03] hover:shadow-xl hover:shadow-[#5B0E1B]/20 scroll-item" id="slider-card-2">
						<div class="px-4 py-2.5 bg-[#061224] border-b border-[#5B0E1B] flex items-center justify-between">
							<span class="text-xs font-black uppercase font-['League_Spartan'] text-[#FBF9F4]">taerijay+ mini</span>
							<span class="text-[10px] text-slate-500 font-bold uppercase">📍 route</span>
						</div>
						<div class="h-40 bg-slate-900 relative overflow-hidden flex items-center justify-center">
							<div class="absolute inset-0 bg-cover bg-center opacity-40" style="background-image: url('https://images.unsplash.com/photo-1517048676732-d65bc937f952?auto=format&fit=crop&w=500&q=80');"></div>
							<div class="absolute inset-0 bg-gradient-to-t from-[#0A192F] to-transparent"></div>
							<div class="absolute bottom-3 left-4">
								<span class="px-2 py-0.5 bg-[#FBF9F4] text-[#0A192F] text-[9px] font-black uppercase rounded font-['League_Spartan']">city guide</span>
							</div>
						</div>
						<div class="p-4 flex flex-col gap-3">
							<h3 class="text-sm font-bold text-white tracking-tight">Dense One-Day Travel Blueprints</h3>
							<p class="text-xs text-slate-400 leading-relaxed min-h-[40px]">
								[명동] 거점 도시 중심 초압축 24시간 동선 서킷 배치함.<br />
								진주빛 새틴 아이보리 서체 대조 적용을 통해 시인성 극대화함.
							</p>
							<div class="pt-3 border-t border-[#5B0E1B]/30 flex items-center justify-between gap-2 mt-auto">
								<div class="flex items-center gap-1.5 min-w-0">
									<span class="text-sm">📍</span>
									<span class="text-[11px] text-slate-300 font-mono truncate" id="addr-2">Myeong-dong, Jung-gu, Seoul</span>
								</div>
								<button class="copy-btn shrink-0 bg-[#5B0E1B]/20 border border-[#5B0E1B]/60 text-slate-200 px-2.5 py-1 rounded hover:bg-[#5B0E1B]/50 text-[10px] font-bold uppercase tracking-wider transition-all" data-target="addr-2">Copy</button>
							</div>
						</div>
					</div>

					<!-- CARD 3: [3. daiso] -->
					<div class="min-w-[300px] md:min-w-[340px] rounded-lg border border-[#5B0E1B] bg-[#0A192F] overflow-hidden flex flex-col transition-all duration-300 hover:scale-[1.03] hover:shadow-xl hover:shadow-[#5B0E1B]/20 scroll-item" id="slider-card-3">
						<div class="px-4 py-2.5 bg-[#061224] border-b border-[#5B0E1B] flex items-center justify-between">
							<span class="text-xs font-black uppercase font-['League_Spartan'] text-[#E1261C]">taerijay+ daiso</span>
							<span class="text-[10px] text-slate-500 font-bold uppercase">💡 beauty</span>
						</div>
						<div class="h-40 bg-slate-900 relative overflow-hidden flex items-center justify-center">
							<div class="absolute inset-0 bg-cover bg-center opacity-40" style="background-image: url('https://images.unsplash.com/photo-1596462502278-27bfdc403348?auto=format&fit=crop&w=500&q=80');"></div>
							<div class="absolute inset-0 bg-gradient-to-t from-[#0A192F] to-transparent"></div>
							<div class="absolute bottom-3 left-4">
								<span class="px-2 py-0.5 bg-[#E1261C] text-white text-[9px] font-black uppercase rounded font-['League_Spartan']">hot items</span>
							</div>
						</div>
						<div class="p-4 flex flex-col gap-3">
							<h3 class="text-sm font-bold text-white tracking-tight">Viral K-Beauty Cosmetics & Gear under $5</h3>
							<p class="text-xs text-slate-400 leading-relaxed min-h-[40px]">
								[다이소 명동역점] 품절 대란 메가 히트 스킨케어 재고 좌표 추적함.<br />
								비비드 네온 레드 피팅 처리를 통한 핵심 바잉 리스트 락인 완료함.
							</p>
							<div class="pt-3 border-t border-[#5B0E1B]/30 flex items-center justify-between gap-2 mt-auto">
								<div class="flex items-center gap-1.5 min-w-0">
									<span class="text-sm">📍</span>
									<span class="text-[11px] text-slate-300 font-mono truncate" id="addr-3">134-1 Myeongdong 2-ga, Jung-gu, Seoul</span>
								</div>
								<button class="copy-btn shrink-0 bg-[#5B0E1B]/20 border border-[#5B0E1B]/60 text-slate-200 px-2.5 py-1 rounded hover:bg-[#5B0E1B]/50 text-[10px] font-bold uppercase tracking-wider transition-all" data-target="addr-3">Copy</button>
							</div>
						</div>
					</div>

					<!-- CARD 4: [4. oliveyoung] -->
					<div class="min-w-[300px] md:min-w-[340px] rounded-lg border border-[#5B0E1B] bg-[#0A192F] overflow-hidden flex flex-col transition-all duration-300 hover:scale-[1.03] hover:shadow-xl hover:shadow-[#5B0E1B]/20 scroll-item" id="slider-card-4">
						<div class="px-4 py-2.5 bg-[#061224] border-b border-[#5B0E1B] flex items-center justify-between">
							<span class="text-xs font-black uppercase font-['League_Spartan'] text-[#6F8B2E]">taerijay+ oliveyoung</span>
							<span class="text-[10px] text-slate-500 font-bold uppercase">💡 tax-free</span>
						</div>
						<div class="h-40 bg-slate-900 relative overflow-hidden flex items-center justify-center">
							<div class="absolute inset-0 bg-cover bg-center opacity-40" style="background-image: url('https://images.unsplash.com/photo-1522335789203-aabd1fc54bc9?auto=format&fit=crop&w=500&q=80');"></div>
							<div class="absolute inset-0 bg-gradient-to-t from-[#0A192F] to-transparent"></div>
							<div class="absolute bottom-3 left-4">
								<span class="px-2 py-0.5 bg-[#6F8B2E] text-white text-[9px] font-black uppercase rounded font-['League_Spartan']">k-beauty</span>
							</div>
						</div>
						<div class="p-4 flex flex-col gap-3">
							<h3 class="text-sm font-bold text-white tracking-tight">Instant Tax Refund Guide & Best Skincare</h3>
							<p class="text-xs text-slate-400 leading-relaxed min-h-[40px]">
								[올리브영 명동타운] 외국인 즉시 면세 Tax-Free 환급 스펙 완전 적재함.<br />
								청량한 올리브 그린 배색 명세를 통한 최상급 가이드라인 매핑 완료함.
							</p>
							<div class="pt-3 border-t border-[#5B0E1B]/30 flex items-center justify-between gap-2 mt-auto">
								<div class="flex items-center gap-1.5 min-w-0">
									<span class="text-sm">📍</span>
									<span class="text-[11px] text-slate-300 font-mono truncate" id="addr-4">53 Myeongdong-gil, Jung-gu, Seoul</span>
								</div>
								<button class="copy-btn shrink-0 bg-[#5B0E1B]/20 border border-[#5B0E1B]/60 text-slate-200 px-2.5 py-1 rounded hover:bg-[#5B0E1B]/50 text-[10px] font-bold uppercase tracking-wider transition-all" data-target="addr-4">Copy</button>
							</div>
						</div>
					</div>

					<!-- CARD 5: [5. emart] -->
					<div class="min-w-[300px] md:min-w-[340px] rounded-lg border border-[#5B0E1B] bg-[#0A192F] overflow-hidden flex flex-col transition-all duration-300 hover:scale-[1.03] hover:shadow-xl hover:shadow-[#5B0E1B]/20 scroll-item" id="slider-card-5">
						<div class="px-4 py-2.5 bg-[#061224] border-b border-[#5B0E1B] flex items-center justify-between">
							<span class="text-xs font-black uppercase font-['League_Spartan'] text-[#FFDD00]">taerijay+ emart</span>
							<span class="text-[10px] text-red-500 font-bold uppercase">⚠️ warning</span>
						</div>
						<div class="h-40 bg-slate-900 relative overflow-hidden flex items-center justify-center">
							<div class="absolute inset-0 bg-cover bg-center opacity-40" style="background-image: url('https://images.unsplash.com/photo-1542838132-92c53300491e?auto=format&fit=crop&w=500&q=80');"></div>
							<div class="absolute inset-0 bg-gradient-to-t from-[#0A192F] to-transparent"></div>
							<div class="absolute bottom-3 left-4">
								<span class="px-2 py-0.5 bg-[#FFDD00] text-[#0A192F] text-[9px] font-black uppercase rounded font-['League_Spartan']">smart buy</span>
							</div>
						</div>
						<div class="p-4 flex flex-col gap-3">
							<h3 class="text-sm font-bold text-white tracking-tight">Big Box Store Forced Off-Days Index</h3>
							<p class="text-xs text-slate-400 leading-relaxed min-h-[40px]">
								[이마트 영등포점] 매월 둘째/넷째 일요일 의무휴업 ⚠️ 경고 리스트 탑재함.<br />
								브라이트 옐로우 배색 튜닝 처리를 통한 오진입 확률 제로화 구현 완료함.
							</p>
							<div class="pt-3 border-t border-[#5B0E1B]/30 flex items-center justify-between gap-2 mt-auto">
								<div class="flex items-center gap-1.5 min-w-0">
									<span class="text-sm">📍</span>
									<span class="text-[11px] text-slate-300 font-mono truncate" id="addr-5">7-1 Yeongdeungpo-dong 4-ga, Yeongdeungpo-gu, Seoul</span>
								</div>
								<button class="copy-btn shrink-0 bg-[#5B0E1B]/20 border border-[#5B0E1B]/60 text-slate-200 px-2.5 py-1 rounded hover:bg-[#5B0E1B]/50 text-[10px] font-bold uppercase tracking-wider transition-all" data-target="addr-5">Copy</button>
							</div>
						</div>
					</div>

