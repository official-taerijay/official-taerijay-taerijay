---
import Layout from '../layouts/Layout.astro';

const channels = {
  entertainment: { slug: 'entertainment', color: '#00E5FF', free: true,  tag: 'K-엔터' },
  protocol:      { slug: 'protocol',      color: '#F16B24', free: false, tag: 'K-생존' },
  mini:          { slug: 'mini',          color: '#e8e4dc', free: false, tag: 'K-여행' },
  daiso:         { slug: 'daiso',         color: '#E1261C', free: false, tag: 'K-Beauty' },
  oliveyoung:    { slug: 'oliveyoung',    color: '#6F8B2E', free: false, tag: 'K-Beauty' },
  emart:         { slug: 'emart',         color: '#FFDD00', free: false, tag: 'E-Mart × Traders × emart24' },
  convenience:   { slug: 'convenience',   color: '#A14D7C', free: false, tag: 'GS25 × CU × 7-Eleven' },
};
---
<Layout title="TAERIJAY">
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-scrim"></div>
    <div class="hero-content">
      <p class="hero-eyebrow">TAERIJAY REPUBLIC OF KOREA</p>
      <h1 class="hero-wordmark">TAERIJAY</h1>
      <div class="hero-cta-row">
        <button class="btn-primary" onclick="document.getElementById('plans').scrollIntoView({behavior:'smooth'})">PRICING</button>
        <button class="btn-ghost" onclick="document.getElementById('channels').scrollIntoView({behavior:'smooth'})">CHANNELS</button>
      </div>
    </div>
  </section>

  <section class="channels-section" id="channels">

    <div class="channel-row" data-count="1">
      <a href={`/04-channels/${channels.entertainment.slug}`} class="service-card" style={`--c:${channels.entertainment.color}`}>
        <span class="service-status status-free">FREE</span>
        <span class="service-name">taerijay+entertainment</span>
        <span class="service-tag">{channels.entertainment.tag}</span>
      </a>
    </div>

    <div class="channel-row" data-count="2">
      <a href={`/04-channels/${channels.protocol.slug}`} class="service-card" style={`--c:${channels.protocol.color}`}>
        <span class="service-status status-soon">SOON</span>
        <span class="service-name">taerijay+protocol</span>
        <span class="service-tag">{channels.protocol.tag}</span>
      </a>
      <a href={`/04-channels/${channels.mini.slug}`} class="service-card" style={`--c:${channels.mini.color}`}>
        <span class="service-status status-soon">SOON</span>
        <span class="service-name">taerijay+mini</span>
        <span class="service-tag">{channels.mini.tag}</span>
      </a>
    </div>

    <div class="channel-row" data-count="2">
      <a href={`/04-channels/${channels.daiso.slug}`} class="service-card" style={`--c:${channels.daiso.color}`}>
        <span class="service-status status-soon">SOON</span>
        <span class="service-name">taerijay+daiso</span>
        <span class="service-tag">{channels.daiso.tag}</span>
      </a>
      <a href={`/04-channels/${channels.oliveyoung.slug}`} class="service-card" style={`--c:${channels.oliveyoung.color}`}>
        <span class="service-status status-soon">SOON</span>
        <span class="service-name">taerijay+oliveyoung</span>
        <span class="service-tag">{channels.oliveyoung.tag}</span>
      </a>
    </div>

    <div class="channel-row" data-count="2">
      <a href={`/04-channels/${channels.emart.slug}`} class="service-card" style={`--c:${channels.emart.color}`}>
        <span class="service-status status-soon">SOON</span>
        <span class="service-name">taerijay+emart</span>
        <span class="service-tag">{channels.emart.tag}</span>
      </a>
      <a href={`/04-channels/${channels.convenience.slug}`} class="service-card" style={`--c:${channels.convenience.color}`}>
        <span class="service-status status-soon">SOON</span>
        <span class="service-name">taerijay+convenience</span>
        <span class="service-tag">{channels.convenience.tag}</span>
      </a>
    </div>
  </section>

  <section class="plans-section" id="plans">
    <p class="plans-eyebrow-kr">요금 선택</p>
    <p class="plans-eyebrow-en" data-i18n="en">SELECT TIER</p>

    <div class="plan-row">
      <span class="plan-row-label">
        <span class="plan-row-label-kr">싱글 요금제</span>
        <span class="plan-row-label-en" data-i18n="en">SINGLE</span>
      </span>
      <div class="plan-row-items">
        <div class="tier-chip" style="--tc:#FBF9F4">
          <span class="tier-chip-price">$19.99</span>
          <span class="tier-chip-kr">베이직</span>
          <span class="tier-chip-en" data-i18n="en">Basic</span>
        </div>
        <div class="tier-chip" style="--tc:#22C55E">
          <span class="tier-chip-price">$29.99</span>
          <span class="tier-chip-kr">스탠다드</span>
          <span class="tier-chip-en" data-i18n="en">Standard</span>
        </div>
      </div>
    </div>

    <div class="plan-row">
      <span class="plan-row-label">
        <span class="plan-row-label-kr">싱글 요금제</span>
        <span class="plan-row-label-en" data-i18n="en">SINGLE</span>
      </span>
      <div class="plan-row-items">
        <div class="tier-chip tier-chip-wide" style="--tc:#F16B24">
          <span class="tier-chip-price">$39.99</span>
          <span class="tier-chip-kr">프로</span>
          <span class="tier-chip-en" data-i18n="en">Pro</span>
        </div>
      </div>
    </div>

    <div class="plan-row">
      <span class="plan-row-label">
        <span class="plan-row-label-kr">더블 요금제</span>
        <span class="plan-row-label-en" data-i18n="en">DOUBLE</span>
      </span>
      <div class="plan-row-items">
        <div class="plan-chip plan-chip-double" style="--tc:#2DD4BF">
          <span class="plan-chip-name">taerijay+protocol × taerijay+mini</span>
          <span class="plan-chip-price">$34.99</span>
        </div>
      </div>
    </div>

    <div class="plan-row">
      <span class="plan-row-label">
        <span class="plan-row-label-kr">더블 요금제</span>
        <span class="plan-row-label-en" data-i18n="en">DOUBLE</span>
      </span>
      <div class="plan-row-items">
        <div class="plan-chip plan-chip-double" style="--tc:#818CF8">
          <span class="plan-chip-name">taerijay+daiso × taerijay+oliveyoung</span>
          <span class="plan-chip-price">$34.99</span>
        </div>
      </div>
    </div>

    <div class="plan-row">
      <span class="plan-row-label">
        <span class="plan-row-label-kr">더블 요금제</span>
        <span class="plan-row-label-en" data-i18n="en">DOUBLE</span>
      </span>
      <div class="plan-row-items">
        <div class="plan-chip plan-chip-double" style="--tc:#FB923C">
          <span class="plan-chip-name">taerijay+emart × taerijay+convenience</span>
          <span class="plan-chip-price">$34.99</span>
        </div>
      </div>
    </div>

    <div class="plan-row plan-row-total">
      <span class="plan-row-label">
        <span class="plan-row-label-kr" style="color:#B33A52">토탈 요금제</span>
        <span class="plan-row-label-en" style="color:#B33A52" data-i18n="en">TOTAL</span>
      </span>
      <div class="plan-row-items">
        <div class="plan-chip plan-chip-gold" style="--tc:#B33A52">
          <span class="plan-chip-name">6개 서비스 전부</span>
          <span class="plan-chip-price">$99.99</span>
        </div>
      </div>
    </div>
  </section>

  <style>
    .hero{position:relative;min-height:78vh;min-height:78dvh;display:flex;align-items:center;overflow:hidden}
    .hero-bg{
      position:absolute;inset:0;
      background:
        radial-gradient(ellipse 90% 60% at 15% 20%, rgba(91,14,27,.55) 0%, transparent 60%),
        radial-gradient(ellipse 70% 50% at 85% 80%, rgba(212,175,55,.12) 0%, transparent 55%),
        linear-gradient(160deg, #0d1f3d 0%, #0A192F 55%, #060f1e 100%);
    }
    .hero-scrim{position:absolute;inset:0;background:linear-gradient(180deg, rgba(10,25,47,.2) 0%, rgba(10,25,47,.4) 55%, var(--bg) 100%)}
    .hero-content{position:relative;z-index:2;width:var(--container);margin:0 auto;text-align:left}
    .hero-eyebrow{font-size:clamp(.8rem,2vw,1rem);letter-spacing:.22em;font-weight:700;color:var(--gold);margin-bottom:20px}
    .hero-wordmark{
      font-family:var(--f-display);font-weight:900;
      font-size:clamp(3rem,14vw,9rem);
      letter-spacing:.02em;line-height:1;
      background:linear-gradient(120deg, var(--ivory) 0%, var(--ivory) 55%, var(--gold) 100%);
      -webkit-background-clip:text;background-clip:text;color:transparent;
      margin-bottom:36px;
    }
    .hero-cta-row{display:flex;gap:12px;flex-wrap:wrap}
    .btn-primary{background:var(--ivory);color:var(--bg);border:none;border-radius:8px;padding:14px 28px;font-weight:700;font-size:.85rem;letter-spacing:.05em;cursor:pointer;transition:transform .15s,box-shadow .2s}
    .btn-primary:hover{transform:translateY(-2px);box-shadow:0 10px 30px rgba(0,0,0,.35)}
    .btn-ghost{background:rgba(255,255,255,.08);color:var(--ivory);border:1px solid rgba(255,255,255,.25);border-radius:8px;padding:14px 28px;font-weight:700;font-size:.85rem;letter-spacing:.05em;cursor:pointer;transition:background .2s}
    .btn-ghost:hover{background:rgba(255,255,255,.16)}

    .channels-section{width:var(--container);margin:0 auto;padding:56px 0 20px}
    .channel-row{display:grid;gap:16px;margin-bottom:16px}
    .channel-row[data-count="1"]{grid-template-columns:1fr}
    .channel-row[data-count="2"]{grid-template-columns:1fr 1fr}

    .service-card{
      position:relative;display:flex;flex-direction:column;gap:6px;text-decoration:none;
      padding:24px 22px;border-radius:14px;
      border:1px solid color-mix(in srgb, var(--c) 45%, transparent);
      background:linear-gradient(160deg, color-mix(in srgb, var(--c) 14%, var(--bg)) 0%, var(--bg) 88%);
      transition:transform .2s ease;
    }
    .service-card:hover{transform:translateY(-3px)}
    .service-status{position:absolute;top:12px;right:14px;font-size:.6rem;font-weight:800;letter-spacing:.06em;padding:3px 9px;border-radius:100px}
    .status-free{background:var(--gold);color:var(--bg)}
    .status-soon{background:rgba(255,255,255,.12);color:var(--muted)}
    .service-name{font-family:var(--f-display);font-weight:700;font-size:clamp(1.1rem,3vw,1.5rem);line-height:1.15;color:var(--c)}
    .service-tag{font-size:.72rem;font-weight:700;color:var(--muted);letter-spacing:.02em}

    .plans-section{width:var(--container);margin:0 auto;padding:60px 0 90px}
    .plans-eyebrow-kr{font-size:.78rem;font-weight:700;color:var(--muted);margin-bottom:2px}
    .plans-eyebrow-en{font-size:.82rem;letter-spacing:.1em;font-weight:700;color:var(--muted);margin-bottom:28px;text-transform:uppercase}

    .plan-row{display:flex;align-items:center;gap:18px;padding:16px 0;border-bottom:1px solid rgba(255,255,255,.08);flex-wrap:wrap}
    .plan-row-total{border-bottom:none}
    .plan-row-label{flex:0 0 110px;display:flex;flex-direction:column;gap:2px}
    .plan-row-label-kr{font-size:.78rem;font-weight:700;color:var(--muted)}
    .plan-row-label-en{font-size:.64rem;font-weight:600;letter-spacing:.08em;color:var(--dim);text-transform:uppercase}
    .plan-row-items{display:flex;gap:12px;flex-wrap:wrap;flex:1}

    .tier-chip{border:2px solid var(--tc, var(--gold));border-radius:10px;padding:12px 18px;display:flex;flex-direction:column;gap:2px;min-width:140px;flex:1;background:color-mix(in srgb, var(--tc, var(--gold)) 10%, transparent)}
    .tier-chip-wide{flex:1 1 100%;max-width:280px}
    .tier-chip-price{font-family:var(--f-display);font-weight:900;font-size:1.15rem;color:var(--tc, var(--gold))}
    .tier-chip-kr{font-size:.86rem;font-weight:700;color:var(--ivory)}
    .tier-chip-en{font-size:.7rem;font-weight:600;color:var(--tc, var(--gold))}

    .plan-chip{border:2px solid var(--tc, rgba(91,14,27,.4));border-radius:10px;padding:12px 18px;display:flex;flex-direction:column;gap:2px;min-width:150px;flex:1;background:color-mix(in srgb, var(--tc, transparent) 10%, transparent)}
    .plan-chip-double{flex-direction:row;align-items:center;justify-content:space-between;gap:16px;flex:1 1 100%}
    .plan-chip-gold{flex-direction:row;align-items:center;justify-content:space-between;flex:1 1 100%}
    .plan-chip-name{font-family:var(--f-display);font-weight:700;font-size:.88rem;color:var(--ivory)}
    .plan-chip-price{font-family:var(--f-display);font-weight:900;font-size:1.1rem;color:var(--tc, var(--gold))}

    @media (max-width: 900px){
      .hero-wordmark{font-size:clamp(2.6rem,13vw,5rem)}
    }
    @media (max-width: 560px){
      .channel-row[data-count="2"]{grid-template-columns:1fr}
      .plan-row{flex-direction:column;align-items:flex-start}
      .plan-row-label{flex:none}
      .hero{min-height:70vh;min-height:70dvh}
    }
    @media (max-width: 340px){
      .hero-wordmark{font-size:2.2rem;word-break:break-word}
    }
  </style>
</Layout>