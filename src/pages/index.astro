---
const FIREBASE_API_KEY = import.meta.env.PUBLIC_FIREBASE_API_KEY;
const FIREBASE_AUTH_DOMAIN = import.meta.env.PUBLIC_FIREBASE_AUTH_DOMAIN;
const FIREBASE_PROJECT_ID = import.meta.env.PUBLIC_FIREBASE_PROJECT_ID;

const channels = {
  entertainment: { slug: 'entertainment', color: '#00E5FF', free: true,  tag: 'K-엔터' },
  protocol:      { slug: 'protocol',      color: '#F16B24', free: false, tag: 'K-생존' },
  mini:          { slug: 'mini',          color: '#e8e4dc', free: false, tag: 'K-여행' },
  daiso:         { slug: 'daiso',         color: '#E1261C', free: false, tag: 'K-Beauty' },
  oliveyoung:    { slug: 'oliveyoung',    color: '#6F8B2E', free: false, tag: 'K-Beauty' },
  emart:         { slug: 'emart',         color: '#FFDD00', free: false, tag: 'E-Mart × Traders × emart24' },
  convenience:   { slug: 'convenience',   color: '#A14D7C', free: false, tag: 'GS25 × CU × 7-Eleven' },
};

const socialLinks = [
  { name: 'YouTube',    icon: '▶', color: '#FF0000' },
  { name: 'Instagram',  icon: '◎', color: '#E1306C' },
  { name: 'TikTok',     icon: '♪', color: '#25F4EE' },
  { name: 'Google Blog', icon: 'G', color: '#4285F4' },
  { name: 'Naver Blog',  icon: 'N', color: '#03C75A' },
];
---
<!doctype html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>TAERIJAY</title>
  <meta name="description" content="TAERIJAY — 검증된 한국 여행/라이프스타일 정보 스트리밍" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,900;1,600&family=League+Spartan:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
</head>
<body>
  <div id="splash" class="splash"><span class="splash-brand">TAERIJAY</span></div>

  <header class="nav" id="nav">
    <div class="nav-inner">
      <button class="hamburger" id="hamburger-btn" aria-label="메뉴">
        <span></span><span></span><span></span>
      </button>
      <div class="nav-right">
        <button class="btn-login" id="btn-signin">
          <span class="btn-login-kr">Google 로그인</span>
          <span class="btn-login-en">Login with Google →</span>
        </button>
        <button class="btn-login" id="btn-signout" hidden>
          <span class="btn-login-kr">로그아웃</span>
          <span class="btn-login-en">Log Out</span>
        </button>
      </div>
    </div>
  </header>

  <div class="side-menu" id="side-menu" hidden>
    <div class="side-menu-inner">
      <button class="side-close" id="side-close">×</button>
      <a href="/" class="side-logo">TAERIJAY</a>
      <nav class="side-links">
        {Object.values(channels).map((ch) => (
          <a href={`/04-channels/${ch.slug}`} style={`--c:${ch.color}`}>taerijay+{ch.slug}</a>
        ))}
      </nav>
    </div>
  </div>

  <!-- 로그인 모달 -->
  <div id="auth-modal" class="modal-bg" hidden>
    <div class="modal">
      <button class="modal-x" id="modal-close-btn">×</button>
      <div class="modal-brand">TAERIJAY</div>
      <p class="modal-sub">구글 계정으로 로그인하고<br/>전 채널 콘텐츠를 확인하세요</p>
      <button class="btn-google" id="google-btn">
        <svg width="20" height="20" viewBox="0 0 18 18"><path fill="#4285F4" d="M17.64 9.2c0-.64-.06-1.25-.16-1.84H9v3.48h4.84a4.14 4.14 0 0 1-1.8 2.72v2.26h2.9c1.7-1.57 2.7-3.88 2.7-6.62z"/><path fill="#34A853" d="M9 18c2.43 0 4.47-.8 5.96-2.18l-2.9-2.26c-.8.54-1.84.86-3.06.86-2.35 0-4.34-1.59-5.05-3.72H.95v2.33A9 9 0 0 0 9 18z"/><path fill="#FBBC05" d="M3.95 10.7A5.4 5.4 0 0 1 3.66 9c0-.59.1-1.17.29-1.7V4.97H.95A9 9 0 0 0 0 9c0 1.45.35 2.83.95 4.03l3-2.33z"/><path fill="#EA4335" d="M9 3.58c1.32 0 2.5.45 3.44 1.35l2.58-2.58C13.46.89 11.43 0 9 0A9 9 0 0 0 .95 4.97l3 2.33C4.66 5.17 6.65 3.58 9 3.58z"/></svg>
        Google로 로그인
      </button>
      <div id="login-error" class="login-error" hidden></div>
    </div>
  </div>

  <main>
    <section class="hero">
      <div class="hero-bg"></div>
      <div class="hero-scrim"></div>
      <div class="hero-content">
        <p class="hero-eyebrow">TAERIJAY REPUBLIC OF KOREA</p>
        <div class="hero-cta-row">
          <button class="btn-primary" onclick="document.getElementById('plans').scrollIntoView({behavior:'smooth'})">PRICING</button>
          <button class="btn-ghost" onclick="document.getElementById('channels').scrollIntoView({behavior:'smooth'})">CHANNELS</button>
        </div>
      </div>
    </section>

    <section class="channels-section" id="channels">

      <div class="channel-row" data-count="1">
        <a href={`/04-channels/${channels.entertainment.slug}`} class="service-card" style={`--c:${channels.entertainment.color}`}>
          <span class="service-status status-free">FREE</span>
          <span class="service-name">taerijay+entertainment</span>
          <span class="service-tag">{channels.entertainment.tag}</span>
        </a>
      </div>

      <div class="channel-row" data-count="2">
        <a href={`/04-channels/${channels.protocol.slug}`} class="service-card" style={`--c:${channels.protocol.color}`}>
          <span class="service-status status-soon">SOON</span>
          <span class="service-name">taerijay+protocol</span>
          <span class="service-tag">{channels.protocol.tag}</span>
        </a>
        <a href={`/04-channels/${channels.mini.slug}`} class="service-card" style={`--c:${channels.mini.color}`}>
          <span class="service-status status-soon">SOON</span>
          <span class="service-name">taerijay+mini</span>
          <span class="service-tag">{channels.mini.tag}</span>
        </a>
      </div>

      <div class="channel-row" data-count="2">
        <a href={`/04-channels/${channels.daiso.slug}`} class="service-card" style={`--c:${channels.daiso.color}`}>
          <span class="service-status status-soon">SOON</span>
          <span class="service-name">taerijay+daiso</span>
          <span class="service-tag">{channels.daiso.tag}</span>
        </a>
        <a href={`/04-channels/${channels.oliveyoung.slug}`} class="service-card" style={`--c:${channels.oliveyoung.color}`}>
          <span class="service-status status-soon">SOON</span>
          <span class="service-name">taerijay+oliveyoung</span>
          <span class="service-tag">{channels.oliveyoung.tag}</span>
        </a>
      </div>

      <div class="channel-row" data-count="2">
        <a href={`/04-channels/${channels.emart.slug}`} class="service-card" style={`--c:${channels.emart.color}`}>
          <span class="service-status status-soon">SOON</span>
          <span class="service-name">taerijay+emart</span>
          <span class="service-tag">{channels.emart.tag}</span>
        </a>
        <a href={`/04-channels/${channels.convenience.slug}`} class="service-card" style={`--c:${channels.convenience.color}`}>
          <span class="service-status status-soon">SOON</span>
          <span class="service-name">taerijay+convenience</span>
          <span class="service-tag">{channels.convenience.tag}</span>
        </a>
      </div>
    </section>

    <section class="plans-section" id="plans">
      <p class="plans-eyebrow">요금 선택 · SELECT TIER</p>

      <div class="plan-row">
        <span class="plan-row-label">싱글 요금제<span class="plan-row-label-en">SINGLE</span></span>
        <div class="plan-row-items">
          <div class="tier-chip" style="--tc:#FBF9F4">
            <span class="tier-chip-price">$19.99</span>
            <span class="tier-chip-kr">베이직</span>
            <span class="tier-chip-en">Basic</span>
          </div>
          <div class="tier-chip" style="--tc:#22C55E">
            <span class="tier-chip-price">$29.99</span>
            <span class="tier-chip-kr">스탠다드</span>
            <span class="tier-chip-en">Standard</span>
          </div>
        </div>
      </div>

      <div class="plan-row">
        <span class="plan-row-label">싱글 요금제<span class="plan-row-label-en">SINGLE</span></span>
        <div class="plan-row-items">
          <div class="tier-chip tier-chip-wide" style="--tc:#F16B24">
            <span class="tier-chip-price">$39.99</span>
            <span class="tier-chip-kr">프로</span>
            <span class="tier-chip-en">Pro</span>
          </div>
        </div>
      </div>

      <div class="plan-row">
        <span class="plan-row-label">더블 요금제<span class="plan-row-label-en">DOUBLE</span></span>
        <div class="plan-row-items">
          <div class="plan-chip plan-chip-double" style="--tc:#2DD4BF">
            <span class="plan-chip-name">taerijay+protocol × taerijay+mini</span>
            <span class="plan-chip-price">$34.99</span>
          </div>
        </div>
      </div>

      <div class="plan-row">
        <span class="plan-row-label">더블 요금제<span class="plan-row-label-en">DOUBLE</span></span>
        <div class="plan-row-items">
          <div class="plan-chip plan-chip-double" style="--tc:#818CF8">
            <span class="plan-chip-name">taerijay+daiso × taerijay+oliveyoung</span>
            <span class="plan-chip-price">$34.99</span>
          </div>
        </div>
      </div>

      <div class="plan-row">
        <span class="plan-row-label">더블 요금제<span class="plan-row-label-en">DOUBLE</span></span>
        <div class="plan-row-items">
          <div class="plan-chip plan-chip-double" style="--tc:#FB923C">
            <span class="plan-chip-name">taerijay+emart × taerijay+convenience</span>
            <span class="plan-chip-price">$34.99</span>
          </div>
        </div>
      </div>

      <div class="plan-row plan-row-total">
        <span class="plan-row-label" style="color:#B33A52">토탈 요금제<span class="plan-row-label-en" style="color:#B33A52">TOTAL</span></span>
        <div class="plan-row-items">
          <div class="plan-chip plan-chip-gold" style="--tc:#B33A52">
            <span class="plan-chip-name">6개 서비스 전부</span>
            <span class="plan-chip-price">$99.99</span>
          </div>
        </div>
      </div>
    </section>

    <section class="social-section">
      {socialLinks.map((s) => (
        <a href="#" class="social-icon" style={`--sc:${s.color}`} title={s.name} aria-label={s.name}>{s.icon}</a>
      ))}
    </section>
  </main>

  <footer class="footer">
    <div class="footer-links">
      <a href="#">이용약관<br/><span class="footer-en">Terms</span></a>
      <a href="#">개인정보<br/><span class="footer-en">Privacy</span></a>
      <a href="#">환불정책<br/><span class="footer-en">Refund</span></a>
      <a href="#">사업자정보<br/><span class="footer-en">Business</span></a>
    </div>
    <p class="footer-copy">© 2026 TAERIJAY · 사업자등록번호 673-51-01148 · taerijay.com</p>
  </footer>

  <script type="module" define:vars={{ FIREBASE_API_KEY, FIREBASE_AUTH_DOMAIN, FIREBASE_PROJECT_ID }}>
    import { initializeApp } from 'https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js';
    import { getAuth, GoogleAuthProvider, signInWithPopup, signOut, onAuthStateChanged }
      from 'https://www.gstatic.com/firebasejs/10.12.2/firebase-auth.js';

    const app = initializeApp({
      apiKey: FIREBASE_API_KEY,
      authDomain: FIREBASE_AUTH_DOMAIN,
      projectId: FIREBASE_PROJECT_ID,
    });
    const auth = getAuth(app);
    const provider = new GoogleAuthProvider();
    provider.setCustomParameters({ prompt: 'select_account' });

    onAuthStateChanged(auth, (user) => {
      const si = document.getElementById('btn-signin');
      const so = document.getElementById('btn-signout');
      if (user) {
        sessionStorage.setItem('user_email', user.email);
        if (si) si.hidden = true;
        if (so) so.hidden = false;
      } else {
        sessionStorage.removeItem('user_email');
        if (si) si.hidden = false;
        if (so) so.hidden = true;
      }
    });

    const signinBtn = document.getElementById('btn-signin');
    if (signinBtn) signinBtn.addEventListener('click', () => {
      document.getElementById('auth-modal').hidden = false;
    });

    const signoutBtn = document.getElementById('btn-signout');
    if (signoutBtn) signoutBtn.addEventListener('click', async () => {
      await signOut(auth);
      sessionStorage.removeItem('user_email');
    });

    const closeBtn = document.getElementById('modal-close-btn');
    if (closeBtn) closeBtn.addEventListener('click', () => {
      document.getElementById('auth-modal').hidden = true;
      document.getElementById('login-error').hidden = true;
    });

    const googleBtn = document.getElementById('google-btn');
    if (googleBtn) googleBtn.addEventListener('click', async () => {
      const err = document.getElementById('login-error');
      err.hidden = true;
      googleBtn.disabled = true;
      try {
        const result = await signInWithPopup(auth, provider);
        sessionStorage.setItem('user_email', result.user.email);
        document.getElementById('auth-modal').hidden = true;
      } catch (e) {
        console.error('Firebase Auth Error:', e.code, e.message);
        err.hidden = false;
        if (e.code === 'auth/unauthorized-domain') {
          err.textContent = '이 도메인은 아직 로그인 허용 목록에 없습니다. (auth/unauthorized-domain)';
        } else if (e.code === 'auth/popup-blocked') {
          err.textContent = '팝업이 차단되었습니다. 브라우저의 팝업 차단을 해제해주세요.';
        } else if (e.code === 'auth/popup-closed-by-user') {
          err.textContent = '로그인 창이 닫혔습니다. 다시 시도해주세요.';
        } else {
          err.textContent = `로그인 실패: ${e.code || e.message}`;
        }
      } finally {
        googleBtn.disabled = false;
      }
    });

    const nav = document.getElementById('nav');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 40) nav.classList.add('nav-scrolled');
      else nav.classList.remove('nav-scrolled');
    });

    const hamburgerBtn = document.getElementById('hamburger-btn');
    const sideMenu = document.getElementById('side-menu');
    const sideClose = document.getElementById('side-close');
    hamburgerBtn.addEventListener('click', () => { sideMenu.hidden = false; });
    sideClose.addEventListener('click', () => { sideMenu.hidden = true; });
    sideMenu.addEventListener('click', (e) => { if (e.target === sideMenu) sideMenu.hidden = true; });

    window.addEventListener('DOMContentLoaded', () => {
      setTimeout(() => {
        const s = document.getElementById('splash');
        if (s) { s.style.opacity = '0'; setTimeout(() => s.remove(), 500); }
      }, 700);
    });
  </script>

  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --bg:#0A192F;--border:#5B0E1B;--ivory:#FBF9F4;--muted:#8b96a8;--dim:#5d6c82;--gold:#D4AF37;
      --f-display:'Playfair Display',serif;--f-body:'League Spartan',sans-serif;
      --container: min(1200px, 92vw);
    }
    html,body{background:var(--bg);color:var(--ivory);font-family:var(--f-body);min-height:100vh;overflow-x:hidden;scroll-behavior:smooth}
    button{font:inherit}
    a{color:inherit}

    .splash{position:fixed;inset:0;background:var(--bg);display:flex;align-items:center;justify-content:center;z-index:9999;transition:opacity .5s ease}
    .splash-brand{font-family:var(--f-display);font-weight:900;font-size:clamp(1.8rem,6vw,2.6rem);letter-spacing:.06em}

    .nav{position:fixed;top:0;left:0;right:0;z-index:200;transition:background .3s ease,border-color .3s ease}
    .nav-scrolled{background:rgba(10,25,47,.92);backdrop-filter:blur(10px);border-bottom:1px solid rgba(91,14,27,.4)}
    .nav-inner{width:var(--container);margin:0 auto;display:flex;align-items:center;justify-content:space-between;padding:16px 0}
    .hamburger{display:flex;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:6px}
    .hamburger span{display:block;width:22px;height:2px;background:var(--ivory)}
    .nav-right{display:flex;align-items:center;gap:16px}

    /* 로그인 필 버튼 — 버건디 */
    .btn-login{
      background:rgba(91,14,27,.35);border:1px solid rgba(91,14,27,.7);
      border-radius:100px;padding:9px 22px;cursor:pointer;
      display:flex;flex-direction:column;align-items:center;gap:1px;
      transition:background .2s;
    }
    .btn-login:hover{background:rgba(91,14,27,.55)}
    .btn-login-kr{color:var(--ivory);font-size:.82rem;font-weight:700}
    .btn-login-en{color:var(--ivory);font-size:.68rem;font-weight:600;opacity:.85}

    .side-menu{position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:300}
    .side-menu-inner{position:absolute;top:0;left:0;height:100%;width:min(320px,80vw);background:#0d1f3d;padding:24px;display:flex;flex-direction:column}
    .side-close{align-self:flex-end;background:none;border:none;color:var(--ivory);font-size:1.8rem;cursor:pointer;margin-bottom:20px}
    .side-logo{font-family:var(--f-display);font-weight:900;font-size:1.3rem;margin-bottom:32px;text-decoration:none}
    .side-links{display:flex;flex-direction:column;gap:18px}
    .side-links a{text-decoration:none;font-size:.9rem;color:var(--c,var(--muted));font-weight:600}

    /* 로그인 모달 */
    .modal-bg{position:fixed;inset:0;background:rgba(10,25,47,.88);backdrop-filter:blur(6px);display:flex;align-items:center;justify-content:center;z-index:999;padding:24px}
    .modal{position:relative;width:100%;max-width:380px;background:var(--bg);border:1px solid var(--border);border-radius:16px;padding:32px 24px;text-align:center}
    .modal-x{position:absolute;top:10px;right:12px;background:none;border:none;color:var(--ivory);font-size:1.6rem;cursor:pointer;opacity:.8;line-height:1}
    .modal-brand{font-family:var(--f-display);font-weight:900;font-size:1.3rem;margin-bottom:12px}
    .modal-sub{font-size:.85rem;color:var(--muted);line-height:1.7;margin-bottom:22px}
    .btn-google{width:100%;display:flex;align-items:center;justify-content:center;gap:10px;background:var(--ivory);color:var(--bg);border:none;border-radius:10px;padding:13px;font-weight:700;font-size:.92rem;cursor:pointer}
    .btn-google:disabled{opacity:.6;cursor:not-allowed}
    .login-error{margin-top:14px;padding:10px 12px;background:rgba(241,107,36,.12);border:1px solid rgba(241,107,36,.35);border-radius:8px;color:#F16B24;font-size:.78rem;line-height:1.5;text-align:left}

    .hero{position:relative;min-height:64vh;min-height:64dvh;display:flex;align-items:center;overflow:hidden}
    .hero-bg{
      position:absolute;inset:0;
      background:
        radial-gradient(ellipse 90% 60% at 15% 20%, rgba(91,14,27,.55) 0%, transparent 60%),
        radial-gradient(ellipse 70% 50% at 85% 80%, rgba(212,175,55,.12) 0%, transparent 55%),
        linear-gradient(160deg, #0d1f3d 0%, #0A192F 55%, #060f1e 100%);
    }
    .hero-scrim{position:absolute;inset:0;background:linear-gradient(180deg, rgba(10,25,47,.2) 0%, rgba(10,25,47,.4) 55%, var(--bg) 100%)}
    .hero-content{position:relative;z-index:2;width:var(--container);margin:0 auto;text-align:left}
    .hero-eyebrow{font-size:clamp(.8rem,2vw,1rem);letter-spacing:.22em;font-weight:700;color:var(--gold);margin-bottom:34px}
    .hero-cta-row{display:flex;gap:12px;flex-wrap:wrap}
    .btn-primary{background:var(--ivory);color:var(--bg);border:none;border-radius:8px;padding:14px 28px;font-weight:700;font-size:.85rem;letter-spacing:.05em;cursor:pointer;transition:transform .15s,box-shadow .2s}
    .btn-primary:hover{transform:translateY(-2px);box-shadow:0 10px 30px rgba(0,0,0,.35)}
    .btn-ghost{background:rgba(255,255,255,.08);color:var(--ivory);border:1px solid rgba(255,255,255,.25);border-radius:8px;padding:14px 28px;font-weight:700;font-size:.85rem;letter-spacing:.05em;cursor:pointer;transition:background .2s}
    .btn-ghost:hover{background:rgba(255,255,255,.16)}

    .channels-section{width:var(--container);margin:0 auto;padding:56px 0 20px}
    .channel-row{display:grid;gap:16px;margin-bottom:16px}
    .channel-row[data-count="1"]{grid-template-columns:1fr}
    .channel-row[data-count="2"]{grid-template-columns:1fr 1fr}

    .service-card{
      position:relative;display:flex;flex-direction:column;gap:8px;text-decoration:none;
      padding:30px 24px;border-radius:14px;
      border:1px solid color-mix(in srgb, var(--c) 45%, transparent);
      background:linear-gradient(160deg, color-mix(in srgb, var(--c) 14%, var(--bg)) 0%, var(--bg) 88%);
      transition:transform .2s ease;
    }
    .service-card:hover{transform:translateY(-3px)}
    .service-status{position:absolute;top:14px;right:16px;font-size:.62rem;font-weight:800;letter-spacing:.06em;padding:4px 10px;border-radius:100px}
    .status-free{background:var(--gold);color:var(--bg)}
    .status-soon{background:rgba(255,255,255,.12);color:var(--muted)}
    .service-name{font-family:var(--f-display);font-weight:700;font-size:clamp(1.7rem,5vw,2.5rem);line-height:1.1;color:var(--c)}
    .service-tag{font-size:.85rem;font-weight:700;color:var(--muted);letter-spacing:.02em}

    .plans-section{width:var(--container);margin:0 auto;padding:60px 0 90px}
    .plans-eyebrow{font-size:.82rem;letter-spacing:.1em;font-weight:700;color:var(--muted);margin-bottom:28px}

    .plan-row{display:flex;align-items:center;gap:18px;padding:16px 0;border-bottom:1px solid rgba(255,255,255,.08);flex-wrap:wrap}
    .plan-row-total{border-bottom:none}
    .plan-row-label{flex:0 0 110px;display:flex;flex-direction:column;gap:2px;font-size:.78rem;font-weight:700;letter-spacing:.04em;color:var(--muted)}
    .plan-row-label-en{font-size:.64rem;font-weight:600;letter-spacing:.08em;color:var(--dim);text-transform:uppercase}
    .plan-row-items{display:flex;gap:12px;flex-wrap:wrap;flex:1}

    .tier-chip{border:2px solid var(--tc, var(--gold));border-radius:10px;padding:12px 18px;display:flex;flex-direction:column;gap:2px;min-width:140px;flex:1;background:color-mix(in srgb, var(--tc, var(--gold)) 10%, transparent)}
    .tier-chip-wide{flex:1 1 100%;max-width:280px}
    .tier-chip-price{font-family:var(--f-display);font-weight:900;font-size:1.15rem;color:var(--tc, var(--gold))}
    .tier-chip-kr{font-size:.86rem;font-weight:700;color:var(--ivory)}
    .tier-chip-en{font-size:.7rem;font-weight:600;color:var(--tc, var(--gold))}

    .plan-chip{border:2px solid var(--tc, rgba(91,14,27,.4));border-radius:10px;padding:12px 18px;display:flex;flex-direction:column;gap:2px;min-width:150px;flex:1;background:color-mix(in srgb, var(--tc, transparent) 10%, transparent)}
    .plan-chip-double{flex-direction:row;align-items:center;justify-content:space-between;gap:16px;flex:1 1 100%}
    .plan-chip-gold{flex-direction:row;align-items:center;justify-content:space-between;flex:1 1 100%}
    .plan-chip-name{font-family:var(--f-display);font-weight:700;font-size:.88rem;color:var(--ivory)}
    .plan-chip-price{font-family:var(--f-display);font-weight:900;font-size:1.1rem;color:var(--tc, var(--gold))}

    .social-section{width:var(--container);margin:0 auto;padding:20px 0 60px;display:flex;gap:14px;justify-content:center}
    .social-icon{
      width:44px;height:44px;border-radius:50%;
      border:2px solid var(--sc);color:var(--sc);
      display:flex;align-items:center;justify-content:center;
      text-decoration:none;font-size:1.05rem;font-weight:700;
      transition:background .2s,transform .15s;
      background:color-mix(in srgb, var(--sc) 10%, transparent);
    }
    .social-icon:hover{background:color-mix(in srgb, var(--sc) 22%, transparent);transform:translateY(-2px)}

    .footer{width:var(--container);margin:0 auto;padding:32px 0 48px;border-top:1px solid rgba(255,255,255,.08);text-align:center}
    .footer-links{display:flex;justify-content:center;gap:28px;flex-wrap:wrap;margin-bottom:16px}
    .footer-links a{text-decoration:none;font-size:.82rem;color:var(--muted);text-align:center;line-height:1.6}
    .footer-en{font-size:.7rem;color:var(--dim)}
    .footer-copy{font-size:.74rem;color:var(--dim)}

    @media (max-width: 560px){
      .channel-row[data-count="2"]{grid-template-columns:1fr}
      .plan-row{flex-direction:column;align-items:flex-start}
      .plan-row-label{flex:none}
      .btn-login{padding:7px 16px}
      .btn-login-kr{font-size:.74rem}
      .btn-login-en{font-size:.6rem}
    }

    @media (prefers-reduced-motion: reduce){
      *{transition-duration:.01ms!important;animation-duration:.01ms!important;scroll-behavior:auto!important}
    }
  </style>
</body>
</html>