				mainTitle: 'Official Drama, Show & YouTube Streaming Hub', desc: 'Explore K-content, films, reality shows, and official traffic loops.',
				addr: 'Central Hub Video Stream Station', color: '#00E5FF', img: 'https://images.unsplash.com/photo-1598899134739-24c46f58b8c0?auto=format&fit=crop&w=500&q=80', gating: true
