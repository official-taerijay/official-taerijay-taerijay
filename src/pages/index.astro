  <!-- SCRIPTS -->
  <script is:inline>
    (function () {
      // 로그인 상태
      const email = sessionStorage.getItem('user_email');
      const btn   = document.getElementById('navAuthBtn');
      if (email && btn) {
        btn.textContent = 'My Account';
        btn.href = '/01-auth/auth';
      }

      // 언어 토글 — 한글/영문 모두 표시, 강조만 변경
      const LANG_KEY = 'tj_lang';
      const toggle   = document.getElementById('langToggle');
      const buttons  = toggle ? toggle.querySelectorAll('.lang-btn') : [];

      function applyLang(showEn) {
        // 영문 요소들 표시/숨김
        document.querySelectorAll('.hero-en, .ch-name-en, .ch-desc-en, .plan-name-en, .plan-desc-en, .plan-badge-en, .plan-btn-en, .section-label-en, .social-en, .footer-en').forEach(el => {
          el.style.display = showEn ? 'block' : 'none';
        });

        // 한글 버튼 활성화 토글
        buttons.forEach(btn => {
          btn.classList.toggle('active', (btn.dataset.lang === 'en') === showEn || btn.dataset.lang === 'auto');
        });
      }

      // 초기 설정
      const saved = localStorage.getItem(LANG_KEY) || 'ko';
      const showEn = saved === 'en';
      applyLang(showEn);

      // 클릭 처리
      buttons.forEach(btn => {
        btn.addEventListener('click', function () {
          const chosen = this.dataset.lang;
          if (chosen === 'auto') {
            localStorage.setItem(LANG_KEY, 'auto');
            applyLang(false); // Auto는 한글 표시
          } else if (chosen === 'en') {
            localStorage.setItem(LANG_KEY, 'en');
            applyLang(true); // 영문 강조
          } else {
            localStorage.setItem(LANG_KEY, 'ko');
            applyLang(false); // 한글 강조
          }
        });
      });

      // payment=success 배너
      const params = new URLSearchParams(window.location.search);
      if (params.get('payment') === 'success') {
        const banner = document.createElement('div');
        banner.style.cssText = 'position:fixed;top:0;left:0;right:0;padding:12px;background:#00C97A;color:#0A192F;text-align:center;font-family:League Spartan,sans-serif;font-size:13px;font-weight:700;letter-spacing:0.08em;z-index:999;';
        banner.textContent = '✓ Payment complete — your access is now active!';
        document.body.prepend(banner);
        setTimeout(() => banner.remove(), 5000);
        window.history.replaceState({}, '', '/');
      }
    })();
  </script>

