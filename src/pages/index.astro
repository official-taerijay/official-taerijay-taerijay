---
import Layout from '@layouts/Layout.astro';
import Header from '@components/01-Header.astro';
import Masthead from '@components/02-Masthead.astro';
import PricingTable from '@components/03-PricingTable.astro';
import LegalFooter from '@components/04-LegalFooter.astro';
---

<Layout title="TAERIJAY+ MASTER PORTAL">
	<Header />
	<Masthead />

	<!-- 💡 [수정] 두 번째 스샷 컨트롤러 완전 제외 및 자동 조율 최적화 검색 영역 단일 배치 -->
	<section class="w-full py-6 px-4 md:px-12 max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center border-b border-[#5B0E1B]/30">
		<div class="relative w-full max-w-md mx-auto md:mx-0">
			<span class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-slate-400">
				<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
				</svg>
			</span>
			<input 
				type="text" 
				id="channelSearch" 
				placeholder="독립 채널 실시간 검색..." 
				class="w-full pl-10 pr-4 py-3.5 bg-[#071120] border border-[#5B0E1B] rounded-xl text-xs text-white placeholder-slate-400 focus:outline-none focus:border-[#00F0FF] transition-all font-noto"
			/>
		</div>
	</section>

	<!-- CHANNELS -->
	<section class="w-full py-12 px-4 md:px-12 max-w-6xl mx-auto flex flex-col gap-6" id="textAdjustContainer">
		<h2 class="text-base md:text-xl font-bold uppercase tracking-widest text-white border-l-4 border-[#00F0FF] pl-3 font-spartan">
			독립 채널 인프라 진입 허브 (Premium Channels Deployment)
		</h2>
		
		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" id="channelGrid">
			<div class="channel-card p-6 rounded-xl border border-[#5B0E1B] bg-[#071120]/60 hover:border-[#00F0FF] hover:bg-[#00F0FF]/5 transition-all flex flex-col justify-between gap-4" data-title="entertainment 🎬">
				<div class="flex flex-col gap-2">
					<div class="flex items-center justify-between"><span class="text-base font-bold text-[#00F0FF] font-spartan tracking-wide">1. Entertainment</span><span class="text-lg">🎬</span></div>
					<p class="text-xs text-slate-300 font-noto leading-relaxed break-keep break-words">
						비디오 스트림 허브 및 공식 미디어 채널 라우팅 연계 제공함. 단어가 아무리 길어도 모바일 화면 밖으로 삐져나가지 않고 깔끔하게 자동 줄바꿈 처리함.
					</p>
				</div>
				<a href="/04-channels/01-entertainment" class="inline-block text-center w-full py-2 bg-[#00F0FF]/10 hover:bg-[#00F0FF] text-[#00F0FF] hover:text-[#0A192F] font-bold text-xs rounded transition-all font-spartan uppercase">Enter Channel</a>
			</div>

			<div class="channel-card p-6 rounded-xl border border-[#5B0E1B] bg-[#071120]/60 hover:border-[#FF6B00] hover:bg-[#FF6B00]/5 transition-all flex flex-col justify-between gap-4" data-title="protocol 🌐">
				<div class="flex flex-col gap-2">
					<div class="flex items-center justify-between"><span class="text-base font-bold text-[#FF6B00] font-spartan tracking-wide">2. Protocol</span><span class="text-lg">🌐</span></div>
					<p class="text-xs text-slate-300 font-noto leading-relaxed break-keep break-words">
						해외 입국객 필수 공항 세관 및 대중교통 이용 안전 규약 명시함. 법률 표준 규약에 맞춰 정보의 누락이 없도록 전격 보정 조치함.
					</p>
				</div>
				<a href="/04-channels/02-protocol" class="inline-block text-center w-full py-2 bg-[#FF6B00]/10 hover:bg-[#FF6B00] text-[#FF6B00] hover:text-[#0A192F] font-bold text-xs rounded transition-all font-spartan uppercase">Enter Channel</a>
			</div>
		</div>
	</section>

	<PricingTable />
	<LegalFooter />
</Layout>

<script is:inline>
	document.addEventListener('DOMContentLoaded', () => {
		const searchInput = document.getElementById('channelSearch');
		const cards = document.querySelectorAll('.channel-card');
		if (searchInput) {
			searchInput.addEventListener('input', (e) => {
				const val = e.target.value.toLowerCase().trim();
				cards.forEach(card => {
					const title = card.dataset.title.toLowerCase();
					card.classList.toggle('hidden', !title.includes(val));
				});
			});
		}
	});
</script>