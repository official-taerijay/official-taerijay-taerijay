---
import Layout from '../../layouts/Layout.astro';
import Header from '@components/01-Header.astro';
import LegalFooter from '@components/04-LegalFooter.astro';
---
<Layout title="taerijay+oliveyoung">
	<Header />
	<main class="w-full min-h-screen px-6 md:px-12 py-12 max-w-5xl mx-auto flex flex-col gap-6 font-noto">
		<div class="border-b border-[#5B0E1B] pb-4 flex justify-between items-center font-spartan"><h1 class="text-2xl font-black text-[#6F8B2E] lowercase">taerijay+oliveyoung</h1><span class="text-xs px-3 py-1 border border-[#6F8B2E] text-[#6F8B2E] font-black rounded-full">🧴 TAX-FREE CARE</span></div>
		<div class="p-6 rounded-xl border-2 border-[#6F8B2E] flex flex-col gap-4">
			<h3 class="text-lg font-bold text-white">🧴 Instant Tax Refund Guide</h3>
			<p class="text-white border-l-2 border-[#6F8B2E] pl-2">글로벌 MZ 선호 스킨케어 및 즉시 면세 Tax-Free 현장 환급 매장 안내함.<br/><span class="text-slate-400 font-spartan text-xs block mt-0.5">Duty-free checkout automation protocols loop.</span></p>
			<div class="flex items-center justify-between border-t border-[#5B0E1B]/20 pt-4 mt-2 font-spartan text-sm">
				<span class="text-slate-200" id="ad5">53 Myeongdong-gil, Jung-gu, Seoul</span>
				<button class="copy-btn bg-[#5B0E1B]/40 text-white px-3 py-1 rounded border border-[#5B0E1B] text-xs font-bold" data-target="ad5">COPY</button>
			</div>
		</div>
	</main>
	<LegalFooter />
</Layout>