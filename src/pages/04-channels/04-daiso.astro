---
const color = '#E1261C';
---
<!doctype html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>taerijay+daiso | TAERIJAY</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,900;1,600&family=League+Spartan:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
</head>
<body>
  <header class="nav">
    <div class="nav-inner">
      <button class="back-btn" onclick="history.back()">← 뒤로가기</button>
      <div class="nav-brand"><span class="nav-brand-main">taerijay</span><span style={`color:${color}`}>+daiso</span></div>
    </div>
  </header>

  <main>
    <section class="channel-hero" style={`--c:${color}`}>
      <span class="channel-badge channel-badge-lock">맛보기 12개 무료 · 이후 요금제 필요</span>
      <span class="channel-category">BEAUTY</span>
      <h1 class="channel-title">taerijay<span style={`color:${color}`}>+daiso</span></h1>
      <p class="channel-sub">다이소 뷰티 대란템 실시간 DB, 매장별 재고·위치 정보</p>
    </section>

    <section class="item-grid-section">
      <!-- 아이템 카드 자리 — 콘텐츠 준비 중 -->
    </section>

    <section class="empty-note">
      <p>콘텐츠 준비 중입니다. 곧 채워질 예정입니다.</p>
      <p class="empty-note-en">Content coming soon.</p>
    </section>
  </main>

  <style>
    *,*::before,*::as{box-sizing:border-box}
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --bg:#0A192F;--border:#5B0E1B;--ivory:#FBF9F4;--muted:#8b96a8;--dim:#5d6c82;--gold:#D4AF37;
      --f-display:'Playfair Display',serif;--f-body:'League Spartan',sans-serif;
      --container: min(1200px, 92vw);
    }
    html,body{background:var(--bg);color:var(--ivory);font-family:var(--f-body);min-height:100vh;overflow-x:hidden}

    .nav{position:sticky;top:0;z-index:100;background:rgba(10,25,47,.92);backdrop-filter:blur(10px);border-bottom:1px solid rgba(91,14,27,.4)}
    .nav-inner{width:var(--container);margin:0 auto;display:flex;align-items:center;gap:20px;padding:16px 0}
    .back-btn{background:transparent;border:1px solid rgba(255,255,255,.2);color:var(--ivory);font-family:var(--f-body);font-size:.8rem;font-weight:600;padding:8px 16px;border-radius:100px;cursor:pointer;transition:background .2s}
    .back-btn:hover{background:rgba(255,255,255,.1)}
    .nav-brand{font-family:var(--f-display);font-weight:700;font-size:clamp(.9rem,2.6vw,1.05rem)}
    .nav-brand-main{color:var(--ivory)}

    .channel-hero{width:var(--container);margin:36px auto 0;padding-bottom:28px;border-bottom:1px solid color-mix(in srgb, var(--c) 30%, transparent)}
    .channel-badge{display:inline-block;background:var(--gold);color:var(--bg);font-size:.68rem;font-weight:800;letter-spacing:.04em;padding:5px 14px;border-radius:100px;margin-bottom:12px;margin-right:8px}
    .channel-badge-lock{background:color-mix(in srgb, var(--c) 14%, transparent);color:var(--c);border:1px solid color-mix(in srgb, var(--c) 35%, transparent)}
    .channel-category{display:inline-block;font-size:.68rem;letter-spacing:.14em;color:var(--dim);font-weight:700;margin-bottom:16px;text-transform:uppercase}
    .channel-title{font-family:var(--f-display);font-weight:900;font-size:clamp(1.6rem,5vw,2.6rem);margin-bottom:10px}
    .channel-sub{font-size:.88rem;color:var(--muted);max-width:48ch;line-height:1.6}

    .item-grid-section{width:var(--container);margin:36px auto;min-height:120px}

    .empty-note{width:var(--container);margin:24px auto 100px;text-align:center;padding:40px 20px;border:1px dashed rgba(255,255,255,.15);border-radius:14px}
    .empty-note p{font-size:.88rem;color:var(--muted);margin-bottom:6px}
    .empty-note-en{font-size:.76rem;color:var(--dim)}
  </style>
</body>
</html>