---
import Layout from '../../layouts/Layout.astro';
import Header from '@components/01-Header.astro';
import LegalFooter from '@components/04-LegalFooter.astro';
---
<Layout title="taerijay+convenience">
	<Header />
	<main class="w-full min-h-screen px-6 md:px-12 py-12 max-w-5xl mx-auto flex flex-col gap-6 font-noto">
		<div class="border-b border-[#5B0E1B] pb-4 flex justify-between items-center font-spartan"><h1 class="text-2xl font-black text-[#A14D7C] lowercase">taerijay+convenience</h1><span class="text-xs px-3 py-1 border border-[#A14D7C] text-[#A14D7C] font-black rounded-full">💡 NIGHT RECIPE</span></div>
		<div class="p-6 rounded-xl border-2 border-[#A14D7C] flex flex-col gap-4">
			<h3 class="text-lg font-bold text-white">🇰🇷 Midnight Recipe Hacks & PB Guide</h3>
			<p class="text-white border-l-2 border-[#A14D7C] pl-2">국내 편의점 독점 PB 상품 조합 공식 수록 가이드를 전격 명시함.<br/><span class="text-slate-400 font-spartan text-xs block mt-0.5">Secret convenience store item formulation indexes.</span></p>
			<div class="flex items-center justify-between border-t border-[#5B0E1B]/20 pt-4 mt-2 font-spartan text-sm">
				<span class="text-slate-200" id="ad7">Central Post Office GS25, Seoul</span>
				<button class="copy-btn bg-[#5B0E1B]/40 text-white px-3 py-1 rounded border border-[#5B0E1B] text-xs font-bold" data-target="ad7">COPY</button>
			</div>
		</div>
	</main>
	<LegalFooter />
</Layout>