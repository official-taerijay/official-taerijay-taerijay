---
import Layout from '../../layouts/Layout.astro';

const tabs = [
  { slug: 'region',    label: '지역별로',   labelEn: 'By Region' },
  { slug: '3hour',     label: '3시간 코스', labelEn: '3-Hour Course' },
  { slug: '1day',      label: '1일 코스',   labelEn: '1-Day Course' },
  { slug: '2day',      label: '2일 코스',   labelEn: '2-Day Course' },
  { slug: '3day',      label: '3일 코스',   labelEn: '3-Day Course' },
  { slug: 'recommend', label: '추천코스',   labelEn: 'Recommended', sub: '지역 × 카테고리' },
];
const color = '#e8e4dc';
---
<Layout title="taerijay+mini | TAERIJAY">
  <div class="channel-page" style={`--c:${color}`}>
    <div class="channel-topbar">
      <button type="button" class="back-btn" onclick="history.back()">← 뒤로가기</button>
    </div>

    <section class="channel-hero">
      <span class="channel-badge channel-badge-lock">맛보기 12개 무료 · 이후 요금제 필요</span>
      <h1 class="channel-title">taerijay<span style={`color:${color}`}>+mini</span></h1>
      <p class="channel-sub">거점 도시별 최적 동선, 시간대별 큐레이션 코스</p>
      <a href="/pricing" class="channel-subscribe-btn">구독하기 · Subscribe</a>
    </section>

    <section class="cat-grid-section">
      {tabs.map((tab) => (
        <a href={`/04-channels/mini/${tab.slug}`} class="cat-card">
          <div class="cat-card-art">
            <span class="cat-card-name">{tab.label}</span>
            <span class="cat-card-name-en">{tab.labelEn}</span>
            {tab.sub && <span class="cat-card-sub">{tab.sub}</span>}
          </div>
        </a>
      ))}
    </section>

    <section class="empty-note">
      <p>콘텐츠 준비 중입니다.</p>
      <p class="empty-note-en">Content coming soon.</p>
    </section>
  </div>

  <style>
    .channel-page{width:var(--container);margin:0 auto;padding:24px 0 60px}
    .channel-topbar{margin-bottom:20px;padding-top:88px}
    .back-btn{background:transparent;border:1px solid rgba(255,255,255,.2);color:var(--ivory);font-size:.8rem;font-weight:600;padding:8px 16px;border-radius:100px;cursor:pointer;transition:background .2s}
    .back-btn:hover{background:rgba(255,255,255,.1)}

    .channel-hero{padding-bottom:28px;border-bottom:1px solid color-mix(in srgb, var(--c) 30%, transparent);margin-bottom:36px}
    .channel-badge{display:inline-block;background:var(--gold);color:var(--bg);font-size:.68rem;font-weight:800;letter-spacing:.04em;padding:5px 14px;border-radius:100px;margin-bottom:16px}
    .channel-badge-lock{background:rgba(232,228,220,.12);color:#e8e4dc;border:1px solid rgba(232,228,220,.3)}
    .channel-title{font-family:var(--f-display);font-weight:900;font-size:clamp(1.6rem,5vw,2.6rem);margin-bottom:10px}
    .channel-sub{font-size:.88rem;color:var(--muted);max-width:48ch;line-height:1.6}
    .channel-subscribe-btn{display:inline-block;margin-top:16px;text-decoration:none;background:var(--c);color:var(--bg);font-weight:800;font-size:.82rem;letter-spacing:.02em;padding:11px 22px;border-radius:8px}

    .cat-grid-section{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:16px;margin-bottom:40px}
    .cat-card{text-decoration:none;color:var(--ivory);display:block;border:1px solid color-mix(in srgb, var(--c) 35%, transparent);border-radius:14px;overflow:hidden;transition:transform .2s ease}
    .cat-card:hover{transform:translateY(-4px)}
    .cat-card-art{aspect-ratio:16/9;background:linear-gradient(160deg, color-mix(in srgb, var(--c) 20%, var(--bg)) 0%, var(--bg) 80%);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;padding:12px}
    .cat-card-name{font-family:var(--f-display);font-weight:900;font-size:clamp(1.1rem,3.4vw,1.5rem);color:var(--c);text-align:center}
    .cat-card-name-en{font-size:.7rem;letter-spacing:.1em;color:var(--muted);text-transform:uppercase}
    .cat-card-sub{font-size:.68rem;color:var(--dim);margin-top:4px}

    .empty-note{text-align:center;padding:40px 20px;border:1px dashed rgba(255,255,255,.15);border-radius:14px}
    .empty-note p{font-size:.88rem;color:var(--muted);margin-bottom:6px}
    .empty-note-en{font-size:.76rem;color:var(--dim)}

    @media (max-width: 560px){
      .cat-grid-section{grid-template-columns:repeat(2,1fr)}
    }
  </style>
</Layout>