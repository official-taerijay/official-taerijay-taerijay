---
import Layout from '../../layouts/Layout.astro';
import Header from '@components/01-Header.astro';
import LegalFooter from '@components/04-LegalFooter.astro';
---
<Layout title="taerijay+emart">
	<Header />
	<main class="w-full min-h-screen px-6 md:px-12 py-12 max-w-5xl mx-auto flex flex-col gap-6 font-noto">
		<div class="border-b border-[#5B0E1B] pb-4 flex justify-between items-center font-spartan"><h1 class="text-2xl font-black text-[#FFFB00] lowercase">taerijay+emart</h1><span class="text-xs px-3 py-1 border border-[#FFFB00] text-[#FFFB00] font-black rounded-full">⚠️ REGULATORY OFF-DAYS</span></div>
		<div class="p-6 rounded-xl border-2 border-[#FFFB00] flex flex-col gap-4">
			<h3 class="text-lg font-bold text-white">⚠️ Big Box Store Forced Off-Days Index</h3>
			<p class="text-white border-l-2 border-[#FFFB00] pl-2">이마트 매월 둘째/넷째 일요일 강제 의무휴업일 일정을 강조함.<br/><span class="text-slate-400 font-spartan text-xs block mt-0.5">Forced regulatory off-days matrix tracking rules.</span></p>
			<div class="flex items-center justify-between border-t border-[#5B0E1B]/20 pt-4 mt-2 font-spartan text-sm">
				<span class="text-slate-200" id="ad6">7-1 Yeongdeungpo-dong 4-ga, Seoul</span>
				<button class="copy-btn bg-[#5B0E1B]/40 text-white px-3 py-1 rounded border border-[#5B0E1B] text-xs font-bold" data-target="ad6">COPY</button>
			</div>
		</div>
	</main>
	<LegalFooter />
</Layout>