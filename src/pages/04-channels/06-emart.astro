---
import Layout from '../../layouts/Layout.astro';

const subs = [
  { slug: 'emart',   label: '이마트',   labelEn: 'E-Mart' },
  { slug: 'traders', label: '트레이더스', labelEn: 'Traders' },
  { slug: 'nobrand', label: '노브랜드',  labelEn: 'No Brand' },
  { slug: 'emart24', label: '이마트24',  labelEn: 'emart24' },
];
const color = '#FFDD00';
---
<Layout title="taerijay+emart | TAERIJAY">
  <div class="channel-page" style={`--c:${color}`}>
    <div class="channel-topbar">
      <button type="button" class="back-btn" onclick="history.back()">← 뒤로가기</button>
    </div>

    <section class="channel-hero">
      <span class="channel-badge channel-badge-lock">맛보기 12개 무료 · 이후 요금제 필요</span>
      <span class="channel-category">SHOPPING</span>
      <h1 class="channel-title">taerijay<span style={`color:${color}`}>+emart</span></h1>
      <p class="channel-sub">이마트/트레이더스 쇼핑 스펙 DB, 의무휴업일 경고 인덱스</p>
    </section>

    <section class="cat-grid-section">
      {subs.map((sub) => (
        <a href={`/04-channels/emart/${sub.slug}`} class="cat-card">
          <div class="cat-card-art">
            <span class="cat-card-name">{sub.label}</span>
            <span class="cat-card-name-en">{sub.labelEn}</span>
          </div>
        </a>
      ))}
    </section>

    <section class="empty-note">
      <p>콘텐츠 준비 중입니다.</p>
      <p class="empty-note-en">Content coming soon.</p>
    </section>
  </div>

  <style>
    .channel-page{width:var(--container);margin:0 auto;padding:24px 0 60px}
    .channel-topbar{margin-bottom:20px;padding-top:88px}
    .back-btn{background:transparent;border:1px solid rgba(255,255,255,.2);color:var(--ivory);font-size:.8rem;font-weight:600;padding:8px 16px;border-radius:100px;cursor:pointer;transition:background .2s}
    .back-btn:hover{background:rgba(255,255,255,.1)}

    .channel-hero{padding-bottom:28px;border-bottom:1px solid color-mix(in srgb, var(--c) 30%, transparent);margin-bottom:36px}
    .channel-badge{display:inline-block;background:var(--gold);color:var(--bg);font-size:.68rem;font-weight:800;letter-spacing:.04em;padding:5px 14px;border-radius:100px;margin-bottom:12px;margin-right:8px}
    .channel-badge-lock{background:color-mix(in srgb, var(--c) 16%, transparent);color:var(--c);border:1px solid color-mix(in srgb, var(--c) 40%, transparent)}
    .channel-category{display:inline-block;font-size:.68rem;letter-spacing:.14em;color:var(--dim);font-weight:700;margin-bottom:16px;text-transform:uppercase}
    .channel-title{font-family:var(--f-display);font-weight:900;font-size:clamp(1.6rem,5vw,2.6rem);margin-bottom:10px}
    .channel-sub{font-size:.88rem;color:var(--muted);max-width:48ch;line-height:1.6}

    .cat-grid-section{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:16px;margin-bottom:40px}
    .cat-card{text-decoration:none;color:var(--ivory);display:block;border:1px solid color-mix(in srgb, var(--c) 40%, transparent);border-radius:14px;overflow:hidden;transition:transform .2s ease}
    .cat-card:hover{transform:translateY(-4px)}
    .cat-card-art{aspect-ratio:16/9;background:linear-gradient(160deg, color-mix(in srgb, var(--c) 18%, var(--bg)) 0%, var(--bg) 80%);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;padding:12px}
    .cat-card-name{font-family:var(--f-display);font-weight:900;font-size:clamp(1.1rem,3.4vw,1.4rem);color:var(--c);text-align:center}
    .cat-card-name-en{font-size:.7rem;letter-spacing:.1em;color:var(--muted);text-transform:uppercase}

    .empty-note{text-align:center;padding:40px 20px;border:1px dashed rgba(255,255,255,.15);border-radius:14px}
    .empty-note p{font-size:.88rem;color:var(--muted);margin-bottom:6px}
    .empty-note-en{font-size:.76rem;color:var(--dim)}

    @media (max-width: 560px){
      .cat-grid-section{grid-template-columns:repeat(2,1fr)}
    }
  </style>
</Layout>