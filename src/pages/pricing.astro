---
import Layout from '../layouts/Layout.astro';

const channels = {
  entertainment: { slug: 'entertainment', color: '#00E5FF' },
  protocol:      { slug: 'protocol',      color: '#F16B24' },
  mini:          { slug: 'mini',          color: '#e8e4dc' },
  daiso:         { slug: 'daiso',         color: '#E1261C' },
  oliveyoung:    { slug: 'oliveyoung',    color: '#6F8B2E' },
  emart:         { slug: 'emart',         color: '#FFDD00' },
  convenience:   { slug: 'convenience',   color: '#A14D7C' },
};

const singleTiers = [
  { color: '#FBF9F4', price: '19.99', en: 'BASIC',    id: 1, device: 1, concurrent: 1 },
  { color: '#22C55E', price: '29.99', en: 'STANDARD', id: 1, device: 2, concurrent: 2 },
  { color: '#F16B24', price: '39.99', en: 'PRO',      id: 1, device: 4, concurrent: 4 },
];

const doublePlans = [
  { color: '#2DD4BF', a: 'protocol', b: 'mini' },
  { color: '#818CF8', a: 'daiso', b: 'oliveyoung' },
  { color: '#FB923C', a: 'emart', b: 'convenience' },
];
---
<Layout title="요금제 | TAERIJAY">
  <div class="pricing-page">
    <div class="pricing-topbar">
      <button type="button" class="back-btn" onclick="history.back()">← 뒤로가기</button>
    </div>

    <section class="pricing-hero">
      <p class="pricing-eyebrow-kr">요금제</p>
      <p class="pricing-eyebrow-en" data-i18n="en">PRICING</p>
      <p class="pricing-sub-kr">필요한 채널 선택, 필요한 만큼만 결제</p>
      <p class="pricing-sub-en" data-i18n="en">Select only the channels you need</p>
    </section>

    <!-- 싱글 요금제 상세 -->
    <section class="pricing-block">
      <h2 class="pricing-block-title">
        <span class="pricing-block-title-kr">싱글 요금제</span>
        <span class="pricing-block-title-en" data-i18n="en">SINGLE PLAN</span>
      </h2>
      <p class="pricing-block-desc-kr">유료 채널 1개 선택, 3가지 등급 중 필요에 맞게 선택</p>
      <p class="pricing-block-desc-en" data-i18n="en">1 paid channel · 3 tiers to choose from</p>

      <div class="tier-detail-grid">
        {singleTiers.map((t) => (
          <div class="tier-detail-card" style={`--tc:${t.color}`}>
            <span class="tier-detail-price">USD {t.price}</span>
            <span class="tier-detail-name-en" data-i18n="en">{t.en}</span>
            <ul class="tier-detail-specs">
              <li>
                <span class="spec-kr">아이디 {t.id} · 디바이스 {t.device} · 동시접속 {t.concurrent}</span>
                <span class="spec-en" data-i18n="en">{t.id} ID · {t.device} Device{t.device > 1 ? 's' : ''} · {t.concurrent} Concurrent</span>
              </li>
            </ul>
          </div>
        ))}
      </div>

      <div class="pricing-warning">
        <p class="pricing-warning-kr">⚠️ 디바이스·동시접속 초과 시 경고 표시, 초과분 접속 제한</p>
        <p class="pricing-warning-en" data-i18n="en">⚠️ Exceeding device or concurrent limit triggers a warning and access restriction</p>
      </div>

      <div class="pricing-channel-pick">
        {Object.entries(channels).filter(([slug]) => slug !== 'entertainment').map(([slug, ch]) => (
          <a href={`/04-channels/${slug}`} class="ch-pill" style={`--c:${ch.color}`}>taerijay+{slug}</a>
        ))}
      </div>
    </section>

    <!-- 더블 요금제 상세 -->
    <section class="pricing-block">
      <h2 class="pricing-block-title">
        <span class="pricing-block-title-kr">더블 요금제</span>
        <span class="pricing-block-title-en" data-i18n="en">DOUBLE PLAN</span>
      </h2>
      <p class="pricing-block-desc-kr">연관 채널 2개 묶음, 할인 가격 적용</p>
      <p class="pricing-block-desc-en" data-i18n="en">2 related channels bundled at a discount</p>
      <p class="pricing-block-desc-kr">아이디 1 · 디바이스 1 · 동시접속 1</p>
      <p class="pricing-block-desc-en" data-i18n="en">1 ID · 1 Device · 1 Concurrent</p>

      <div class="double-detail-list">
        {doublePlans.map((dp) => (
          <div class="double-detail-row">
            <span class="double-detail-label">
              <span class="double-detail-label-kr">더블 요금제</span>
              <span class="double-detail-label-en" data-i18n="en">DOUBLE</span>
            </span>
            <div class="double-detail-box" style={`--tc:${dp.color}`}>
              <span class="double-detail-names">
                <span style={`color:${channels[dp.a].color}`}>taerijay+{dp.a}</span>
                <span class="double-x">×</span>
                <span style={`color:${channels[dp.b].color}`}>taerijay+{dp.b}</span>
              </span>
              <span class="double-detail-price">USD 34.99</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- 토탈 요금제 상세 -->
    <section class="pricing-block">
      <h2 class="pricing-block-title">
        <span class="pricing-block-title-kr" style="color:#B33A52">토탈 요금제</span>
        <span class="pricing-block-title-en" style="color:#B33A52" data-i18n="en">TOTAL PLAN</span>
      </h2>
      <p class="pricing-block-desc-kr">유료 채널 6개 전체 이용, 신규 채널 자동 포함</p>
      <p class="pricing-block-desc-en" data-i18n="en">All 6 paid channels, new channels included automatically</p>

      <div class="total-detail-row">
        <span class="total-detail-label">
          <span class="total-detail-label-kr" style="color:#B33A52">토탈 요금제</span>
          <span class="total-detail-label-en" style="color:#B33A52" data-i18n="en">TOTAL</span>
        </span>
        <div class="total-detail-card">
          <span class="total-detail-heading" data-i18n="en">ALL SERVICES</span>
          <div class="total-detail-names">
            {Object.entries(channels).filter(([slug]) => slug !== 'entertainment').map(([slug, ch]) => (
              <span class="total-chip-line" style={`color:${ch.color}`}>taerijay+{slug}</span>
            ))}
          </div>
          <span class="total-detail-price">USD 99.99</span>
        </div>
      </div>
    </section>
  </div>

  <style>
    .pricing-page{width:var(--container);margin:0 auto;padding:24px 0 90px}
    .pricing-topbar{margin-bottom:20px;padding-top:88px}
    .back-btn{background:transparent;border:1px solid rgba(255,255,255,.2);color:var(--ivory);font-size:.8rem;font-weight:600;padding:8px 16px;border-radius:100px;cursor:pointer;transition:background .2s}
    .back-btn:hover{background:rgba(255,255,255,.1)}

    .pricing-hero{padding-bottom:32px;border-bottom:1px solid rgba(255,255,255,.08);margin-bottom:44px}
    .pricing-eyebrow-kr{font-size:.82rem;font-weight:700;color:var(--muted);margin-bottom:2px}
    .pricing-eyebrow-en{font-size:.78rem;letter-spacing:.14em;font-weight:700;color:var(--gold);text-transform:uppercase;margin-bottom:16px}
    .pricing-sub-kr{font-size:.95rem;color:var(--ivory);margin-bottom:2px}
    .pricing-sub-en{font-size:.82rem;color:var(--muted)}

    .pricing-block{margin-bottom:56px}
    .pricing-block-title{display:flex;align-items:baseline;gap:10px;margin-bottom:10px}
    .pricing-block-title-kr{font-family:var(--f-display);font-weight:900;font-size:1.4rem}
    .pricing-block-title-en{font-size:.74rem;letter-spacing:.1em;font-weight:700;color:var(--dim);text-transform:uppercase}
    .pricing-block-desc-kr{font-size:.88rem;color:var(--ivory);line-height:1.6;margin-bottom:2px}
    .pricing-block-desc-en{font-size:.78rem;color:var(--muted);line-height:1.5;margin-bottom:8px}

    .tier-detail-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin:20px 0 22px}
    .tier-detail-card{border:2px solid var(--tc);border-radius:14px;padding:20px;background:color-mix(in srgb, var(--tc) 8%, transparent);display:flex;flex-direction:column;gap:4px}
    .tier-detail-price{font-family:var(--f-display);font-weight:900;font-size:1.4rem;color:var(--tc)}
    .tier-detail-name-en{font-size:.86rem;font-weight:700;color:var(--ivory);letter-spacing:.04em;margin-bottom:10px}
    .tier-detail-specs{list-style:none}
    .tier-detail-specs li{margin-bottom:4px}
    .spec-kr{display:block;font-size:.78rem;color:var(--ivory)}
    .spec-en{display:block;font-size:.68rem;color:var(--dim)}

    .pricing-warning{border:1px solid rgba(241,107,36,.35);background:rgba(241,107,36,.08);border-radius:10px;padding:14px 18px;margin-bottom:26px}
    .pricing-warning-kr{font-size:.82rem;color:#F16B24;line-height:1.6;margin-bottom:2px}
    .pricing-warning-en{font-size:.72rem;color:#F16B24;opacity:.8;line-height:1.5}

    .pricing-channel-pick{display:flex;flex-wrap:wrap;gap:8px}
    .ch-pill{text-decoration:none;border:1px solid var(--c);color:var(--c);border-radius:20px;font-size:.76rem;font-weight:600;padding:7px 14px;transition:background .2s}
    .ch-pill:hover{background:color-mix(in srgb, var(--c) 16%, transparent)}

    .double-detail-list{display:flex;flex-direction:column;gap:0;margin-top:20px}
    .double-detail-row{display:flex;align-items:center;gap:18px;padding:14px 0;border-bottom:1px solid rgba(255,255,255,.08);flex-wrap:wrap}
    .double-detail-label{flex:0 0 110px;display:flex;flex-direction:column;gap:2px}
    .double-detail-label-kr{font-size:.78rem;font-weight:700;color:var(--muted)}
    .double-detail-label-en{font-size:.64rem;font-weight:600;letter-spacing:.08em;color:var(--dim);text-transform:uppercase}
    .double-detail-box{border:2px solid var(--tc);border-radius:10px;padding:14px 20px;display:flex;align-items:center;justify-content:space-between;gap:16px;flex:1;background:color-mix(in srgb, var(--tc) 8%, transparent)}
    .double-detail-names{font-weight:700;font-size:.95rem}
    .double-x{color:var(--dim);margin:0 8px}
    .double-detail-price{font-weight:900;font-size:1.2rem;color:var(--tc)}

    .total-detail-row{display:flex;align-items:center;gap:18px;padding-top:14px;flex-wrap:wrap}
    .total-detail-label{flex:0 0 110px;display:flex;flex-direction:column;gap:2px}
    .total-detail-label-kr{font-size:.78rem;font-weight:700}
    .total-detail-label-en{font-size:.64rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase}
    .total-detail-card{border:1px solid #B33A52;border-radius:14px;padding:24px;background:linear-gradient(160deg, rgba(179,58,82,.12) 0%, rgba(179,58,82,.02) 100%);flex:1;min-width:260px}
    .total-detail-heading{display:block;font-weight:800;font-size:.95rem;color:var(--ivory);margin-bottom:14px}
    .total-detail-names{display:flex;flex-direction:column;gap:6px;margin-bottom:18px}
    .total-chip-line{font-size:.82rem;font-weight:700}
    .total-detail-price{font-weight:900;font-size:1.8rem;color:#B33A52}

    @media (max-width: 700px){
      .tier-detail-grid{grid-template-columns:1fr}
    }
  </style>
</Layout>