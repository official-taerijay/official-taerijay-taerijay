---
// src/pages/index.astro
// TAERIJAY+ 글로벌 메인 포털 마스터 콘솔
import Layout from '../layouts/Layout.astro';
---

<Layout title="MASTER PORTAL" channelColor="#D4AF37">
  
  <!-- ① HERO AREA -->
  <section class="hero">
    <div class="hero-live">
      <div class="live-dot"></div>
      System Live Active
    </div>
    <h1 class="hero-title">
      대한민국 🇰🇷<br>
      <em>Korea Intelligence Hub</em>
    </h1>
    <div class="hero-sub">TAERIJAY+ · Premium Channel Network</div>
    <p class="hero-desc">
      Verified travel &amp; lifestyle DB — built exclusively for global visitors to Korea.
      Real addresses. Zero translation errors. 🌐
    </p>
  </section>

  <!-- ② ⚡ SIGNATURE CORE: TAERIJAY KIDS PREMIUM DEPLOYMENT -->
  <section class="core-section" style="margin-bottom:32px;">
    <div class="section-label">⚡ Signature Core Intelligence</div>
    <div class="kids-master-card">
      <div class="kids-card-top"></div>
      <div class="kids-inner">
        <div class="kids-badge-row">
          <span class="badge-tag tag-hot">HOT 30</span>
          <span class="badge-tag tag-local">LOCAL 30</span>
          <span class="badge-tag tag-hidden">HIDDEN 30</span>
        </div>
        <h2 class="kids-title">TAERIJAY KIDS PREMIUM</h2>
        <p class="kids-subtitle">아이와 함께하는 최고급 여행·문화 정보 90선</p>
        <p class="kids-desc">
          대한민국 전역의 프리미엄 키즈 프렌들리 스팟(여행지·맛집·베이커리 카페·실내 액티비티)을 엄선한 마스터 피스. 부모들이 가장 필요로 하는 유모차 대여 여부, 휠체어/유모차 진입 경사로, 층간 엘리베이터 유무 및 사전 예약 장벽 데이터를 단 하나의 뷰로 제공합니다.
        </p>
        
        <!-- 인프라 인덱스 미니 맵 -->
        <div class="infra-mini-map">
          <span>🍼 유모차</span>
          <span>🛗 엘베</span>
          <span>♿ 휠체어</span>
          <span>📅 원스톱예약</span>
        </div>

        <a href="/04-channels/01-entertainment" class="kids-enter-btn">
          키즈 프리미엄 채널 허브 진입 →
        </a>
      </div>
    </div>
  </section>

  <!-- ③ 7 PREMIUM CHANNELS -->
  <section style="margin-bottom:48px;">
    <div class="section-label">Premium Sub-Channels Deployment</div>
    <div class="channels-grid">

      <!-- 1. entertainment -->
      <a href="/04-channels/01-entertainment" class="ch-card">
        <div class="ch-top" style="background:#00E5FF;"></div>
        <div class="ch-inner">
          <div class="ch-icon" style="color:#00E5FF;border-color:#00E5FF;">🎬</div>
          <div class="ch-meta">
            <div class="ch-brand">taerijay+</div>
            <div class="ch-name" style="color:#00E5FF;">entertainment</div>
            <div class="ch-desc">Drama · Movie · Show · Kids Spot Routing Hub</div>
          </div>
          <div class="ch-arrow">›</div>
        </div>
      </a>

      <!-- 2. protocol -->
      <a href="/04-channels/02-protocol" class="ch-card">
        <div class="ch-top" style="background:#F16B24;"></div>
        <div class="ch-inner">
          <div class="ch-icon" style="color:#F16B24;border-color:#F16B24;">🌐</div>
          <div class="ch-meta">
            <div class="ch-brand">taerijay+</div>
            <div class="ch-name" style="color:#F16B24;">protocol</div>
            <div class="ch-desc">Airport customs · public transit · entry regulation DB</div>
          </div>
          <div class="ch-arrow">›</div>
        </div>
      </a>

      <!-- 3. mini -->
      <a href="/04-channels/03-mini" class="ch-card">
        <div class="ch-top" style="background:#FBF9F4;"></div>
        <div class="ch-inner">
          <div class="ch-icon" style="color:#FBF9F4;border-color:#FBF9F4;">📍</div>
          <div class="ch-meta">
            <div class="ch-brand">taerijay+</div>
            <div class="ch-name" style="color:#FBF9F4;">mini</div>
            <div class="ch-desc">Curated travel courses · optimal route guide per city</div>
          </div>
          <div class="ch-arrow">›</div>
        </div>
      </a>

      <!-- 4. daiso -->
      <a href="/04-channels/04-daiso" class="ch-card">
        <div class="ch-top" style="background:#E1261C;"></div>
        <div class="ch-inner">
          <div class="ch-icon" style="color:#E1261C;border-color:#E1261C;">🇰🇷</div>
          <div class="ch-meta">
            <div class="ch-brand">taerijay+</div>
            <div class="ch-name" style="color:#E1261C;">daiso</div>
            <div class="ch-desc">Beauty trend items · store location &amp; stock DB</div>
          </div>
          <div class="ch-arrow">›</div>
        </div>
      </a>

      <!-- 5. oliveyoung -->
      <a href="/04-channels/05-oliveyoung" class="ch-card">
        <div class="ch-top" style="background:#6F8B2E;"></div>
        <div class="ch-inner">
          <div class="ch-icon" style="color:#6F8B2E;border-color:#6F8B2E;">💡</div>
          <div class="ch-meta">
            <div class="ch-brand">taerijay+</div>
            <div class="ch-name" style="color:#6F8B2E;">oliveyoung</div>
            <div class="ch-desc">MZ skincare DB · Tax-Free refund status included</div>
          </div>
          <div class="ch-arrow">›</div>
        </div>
      </a>

      <!-- 6. emart -->
      <a href="/04-channels/06-emart" class="ch-card">
        <div class="ch-top" style="background:#FFDD00;"></div>
        <div class="ch-inner">
          <div class="ch-icon" style="color:#FFDD00;border-color:#FFDD00;">🇰🇷</div>
          <div class="ch-meta">
            <div class="ch-brand">taerijay+</div>
            <div class="ch-name" style="color:#FFDD00;">emart</div>
            <div class="ch-desc">Hypermarket DB · mandatory closure day ⚠️ alert index</div>
          </div>
          <div class="ch-arrow">›</div>
        </div>
      </a>

      <!-- 7. convenience -->
      <a href="/04-channels/07-convenience" class="ch-card">
        <div class="ch-top" style="background:#A14D7C;"></div>
        <div class="ch-inner">
          <div class="ch-icon" style="color:#A14D7C;border-color:#A14D7C;">🌐</div>
          <div class="ch-meta">
            <div class="ch-brand">taerijay+</div>
            <div class="ch-name" style="color:#A14D7C;">convenience</div>
            <div class="ch-desc">24h CVS exclusive PB combo guide · brand matchup DB</div>
          </div>
          <div class="ch-arrow">›</div>
        </div>
      </a>

    </div>
  </section>

  <!-- ④ PRICING ARCHITECTURE -->
  <section class="pricing-section">
    <div class="section-label">12 Months Premium Activation Pass</div>
    <div class="plan-grid">

      <!-- SINGLE PASS -->
      <div class="plan-card">
        <div class="plan-badge" style="background:rgba(241,107,36,0.12);color:#F16B24;border:1px solid rgba(241,107,36,0.3);">Single Access</div>
        <div class="plan-name">단일 채널 패스</div>
        <div class="plan-desc">선택한 단일 채널 12개월 무제한 실시간 오리지널 DB 오픈.</div>
        <div class="plan-price-row">
          <span class="plan-currency">$</span>
          <span class="plan-amount">19.99</span>
          <span class="plan-period">/ 12 months · from</span>
        </div>
        <div class="single-selectors">
          <a href="/02-payment/payment?key=protocol_basic" class="plan-btn outline">protocol Basic →</a>
          <a href="/02-payment/payment?key=mini_basic" class="plan-btn outline">mini Basic →</a>
          <a href="/02-payment/payment?key=daiso_basic" class="plan-btn outline">daiso Basic →</a>
          <a href="/02-payment/payment?key=olive_basic" class="plan-btn outline">oliveyoung Basic →</a>
          <a href="/02-payment/payment?key=emart_basic" class="plan-btn outline">emart Basic →</a>
          <a href="/02-payment/payment?key=cvs_basic" class="plan-btn outline">convenience Basic →</a>
        </div>
      </div>

      <!-- DOUBLE A -->
      <div class="plan-card">
        <div class="plan-badge" style="background:rgba(255,255,255,0.05);color:#FBF9F4;border:1px solid rgba(255,255,255,0.15);">Double Pass A</div>
        <div class="double-channels">
          <span class="ch-tag" style="color:#F16B24;border-color:#F16B24;">protocol</span>
          <span style="color:#7A9AB5;">×</span>
          <span class="ch-tag" style="color:#FBF9F4;border-color:#FBF9F4;">mini</span>
        </div>
        <div class="plan-name">데이터베이스 × 미니 더블 패스</div>
        <div class="plan-desc">입국 규약 DB와 도시별 최적 여행 동선 패키지 결합 솔루션.</div>
        <div class="plan-price-row">
          <span class="plan-currency">$</span>
          <span class="plan-amount">34.99</span>
          <span class="plan-period">/ 12 months</span>
        </div>
        <a href="/02-payment/payment?key=protocol_mini" class="plan-btn solid">Get Double Pass →</a>
      </div>

      <!-- DOUBLE B -->
      <div class="plan-card">
        <div class="plan-badge" style="background:rgba(255,255,255,0.05);color:#FBF9F4;border:1px solid rgba(255,255,255,0.15);">Double Pass B</div>
        <div class="double-channels">
          <span class="ch-tag" style="color:#E1261C;border-color:#E1261C;">daiso</span>
          <span style="color:#7A9AB5;">×</span>
          <span class="ch-tag" style="color:#6F8B2E;border-color:#6F8B2E;">oliveyoung</span>
        </div>
        <div class="plan-name">다이소 × 올리브영 더블 패스</div>
        <div class="plan-desc">케이뷰티 대란템 실시간 라인업 및 올리브영 독점 세일 정보 통합본.</div>
        <div class="plan-price-row">
          <span class="plan-currency">$</span>
          <span class="plan-amount">34.99</span>
          <span class="plan-period">/ 12 months</span>
        </div>
        <a href="/02-payment/payment?key=daiso_olive" class="plan-btn solid">Get Double Pass →</a>
      </div>

      <!-- DOUBLE C -->
      <div class="plan-card">
        <div class="plan-badge" style="background:rgba(255,255,255,0.05);color:#FBF9F4;border:1px solid rgba(255,255,255,0.15);">Double Pass C</div>
        <div class="double-channels">
          <span class="ch-tag" style="color:#FFDD00;border-color:#FFDD00;">emart</span>
          <span style="color:#7A9AB5;">×</span>
          <span class="ch-tag" style="color:#A14D7C;border-color:#A14D7C;">convenience</span>
        </div>
        <div class="plan-name">이마트 × 편의점 더블 패스</div>
        <div class="plan-desc">대형마트 PB 정밀 분석 및 24시간 편의점 꿀조합 루트 동시 개방.</div>
        <div class="plan-price-row">
          <span class="plan-currency">$</span>
          <span class="plan-amount">34.99</span>
          <span class="plan-period">/ 12 months</span>
        </div>
        <a href="/02-payment/payment?key=emart_cvs" class="plan-btn solid">Get Double Pass →</a>
      </div>

      <!-- TOTAL PASS -->
      <div class="plan-card featured">
        <div class="plan-badge" style="background:rgba(212,175,55,0.12);color:#D4AF37;border:1px solid rgba(212,175,55,0.35);">VIP GOLD · Ultimate Access</div>
        <div class="plan-name">TAERIJAY+ 올인원 골드 마스터 패스</div>
        <div class="plan-desc">6대 독립 채널 완전 상시 개방. 모든 프리미엄 인프라 및 키즈 익스클루시브 큐레이션 데이터 무제한 패키지.</div>
        <div class="plan-price-row">
          <span class="plan-currency">$</span>
          <span class="plan-amount" style="color:#D4AF37;">99.99</span>
          <span class="plan-period">/ 12 months · full package</span>
        </div>
        <a href="/02-payment/payment?key=total" class="plan-btn gold">Deploy Master Pass →</a>
      </div>

    </div>
  </section>
</Layout>

<!-- ════════════════════════
      INDEX INLINE STYLES
 ════════════════════════ -->
<style>
  .hero { padding: 48px 0 40px; text-align: center; }
  .hero-live {
    display: inline-flex; align-items: center; gap: 7px; padding: 5px 14px;
    border: 1px solid rgba(0,201,122,0.3); border-radius: 100px;
    font-size: 10px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: #00C97A; margin-bottom: 24px;
  }
  .live-dot { width: 5px; height: 5px; border-radius: 50%; background: #00C97A; box-shadow: 0 0 6px rgba(0,201,122,0.7); animation: pulse 2s ease-in-out infinite; }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }
  .hero-title { font-family: 'Playfair Display', serif; font-size: 28px; font-weight: 700; line-height: 1.25; margin-bottom: 8px; letter-spacing: 0.02em; }
  .hero-title em { font-style: italic; color: #5B0E1B; }
  .hero-sub { font-size: 12px; font-weight: 500; letter-spacing: 0.2em; text-transform: uppercase; color: #7A9AB5; margin-bottom: 14px; }
  .hero-desc { font-size: 13px; color: rgba(122,154,181,0.8); line-height: 1.7; max-width: 340px; margin: 0 auto; }

  .section-label { font-size: 10px; font-weight: 700; letter-spacing: 0.25em; text-transform: uppercase; color: #7A9AB5; margin-bottom: 16px; padding-top: 8px; border-top: 1px solid rgba(91,14,27,0.25); }

  /* 🍼 TAERIJAY 오리지널 키즈 프리미엄 카드 컴포넌트 */
  .kids-master-card {
    border: 1px solid #D4AF37; border-radius: 3px; overflow: hidden;
    background: linear-gradient(145deg, rgba(212,175,55,0.06) 0%, rgba(10,25,47,0.6) 100%);
    box-shadow: 0 12px 32px rgba(0,0,0,0.4);
  }
  .kids-card-top { height: 3px; background: linear-gradient(90deg, #D4AF37, #F16B24); }
  .kids-inner { padding: 22px 20px; }
  .kids-badge-row { display: flex; gap: 6px; margin-bottom: 14px; }
  .badge-tag { font-size: 9px; font-weight: 700; padding: 2px 8px; border-radius: 100px; letter-spacing: 0.05em; text-transform: uppercase; }
  .tag-hot { background: rgba(225,38,28,0.15); color: #FF6B6B; border: 1px solid rgba(225,38,28,0.3); }
  .tag-local { background: rgba(241,107,36,0.15); color: #F16B24; border: 1px solid rgba(241,107,36,0.3); }
  .tag-hidden { background: rgba(212,175,55,0.15); color: #D4AF37; border: 1px solid rgba(212,175,55,0.3); }
  .kids-title { font-family: 'Playfair Display', serif; font-size: 24px; font-weight: 700; color: #FBF9F4; margin-bottom: 2px; }
  .kids-subtitle { font-size: 12px; color: #F16B24; font-weight: 600; margin-bottom: 12px; letter-spacing: -0.01em; }
  .kids-desc { font-size: 12.5px; color: #7A9AB5; line-height: 1.6; margin-bottom: 16px; text-align: justify; }
  
  .infra-mini-map { display: flex; gap: 10px; margin-bottom: 20px; background: rgba(255,255,255,0.03); padding: 8px 12px; border-radius: 2px; border: 1px solid rgba(255,255,255,0.05); }
  .infra-mini-map span { font-size: 11px; font-weight: 500; color: #FBF9F4; }

  .kids-enter-btn {
    display: block; width: 100%; padding: 14px; background: #D4AF37; border: none; border-radius: 2px;
    color: #0A192F; font-family: 'League Spartan', sans-serif; font-size: 13px; font-weight: 700;
    text-align: center; text-decoration: none; letter-spacing: 0.05em; text-transform: uppercase;
    transition: background 0.2s, transform 0.15s;
    box-shadow: 0 4px 14px rgba(212,175,55,0.3);
  }
  .kids-enter-btn:hover { background: #E5C158; transform: translateY(-1px); }

  /* 하위 채널 레이아웃 그리드 */
  .channels-grid { display: flex; flex-direction: column; gap: 10px; }
  .ch-card { border: 1px solid #5B0E1B; border-radius: 3px; overflow: hidden; transition: transform 0.2s, box-shadow 0.2s; text-decoration: none; display: block; background: rgba(255,255,255,0.018); }
  .ch-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.35); }
  .ch-top { height: 2px; }
  .ch-inner { padding: 16px 18px; display: flex; align-items: center; gap: 16px; }
  .ch-icon { width: 44px; height: 44px; border-radius: 50%; border: 1px solid currentColor; display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0; opacity: 0.85; }
  .ch-meta { flex: 1; min-width: 0; }
  .ch-brand { font-size: 9.5px; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: #7A9AB5; margin-bottom: 3px; }
  .ch-name { font-family: 'Playfair Display', serif; font-size: 16px; font-weight: 600; line-height: 1.2; margin-bottom: 4px; }
  .ch-desc { font-size: 11.5px; color: #7A9AB5; line-height: 1.5; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .ch-arrow { font-size: 16px; color: #7A9AB5; flex-shrink: 0; transition: color 0.2s, transform 0.2s; }
  .ch-card:hover .ch-arrow { color: #FBF9F4; transform: translateX(3px); }

  /* 요금제 구조 스타일 */
  .plan-grid { display: flex; flex-direction: column; gap: 12px; }
  .plan-card { border: 1px solid #5B0E1B; border-radius: 3px; padding: 20px 18px; position: relative; background: rgba(255,255,255,0.01); }
  .plan-card.featured { border-color: #D4AF37; background: linear-gradient(180deg, rgba(212,175,55,0.03) 0%, transparent 100%); }
  .plan-badge { display: inline-block; padding: 3px 10px; border-radius: 100px; font-size: 9.5px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 12px; }
  .plan-name { font-family: 'Playfair Display', serif; font-size: 17px; font-weight: 600; margin-bottom: 5px; }
  .plan-desc { font-size: 12px; color: #7A9AB5; line-height: 1.6; margin-bottom: 14px; }
  .plan-price-row { display: flex; align-items: baseline; gap: 4px; margin-bottom: 16px; }
  .plan-currency { font-size: 14px; color: #7A9AB5; }
  .plan-amount { font-family: 'Playfair Display', serif; font-size: 30px; font-weight: 700; color: #FBF9F4; }
  .plan-period { font-size: 11px; color: #7A9AB5; letter-spacing: 0.04em; }
  
  .single-selectors { display: flex; flex-direction: column; gap: 6px; }
  .plan-btn { display: block; width: 100%; padding: 12px; border-radius: 2px; border: 1px solid; text-align: center; font-family: 'League Spartan', sans-serif; font-size: 12px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; text-decoration: none; cursor: pointer; transition: opacity 0.2s, transform 0.15s; }
  .plan-btn:hover { opacity: 0.85; transform: translateY(-1px); }
  .plan-btn.solid { background: #5B0E1B; border-color: #5B0E1B; color: #FBF9F4; }
  .plan-btn.outline { background: transparent; border-color: rgba(91,14,27,0.4); color: #7A9AB5; }
  .plan-btn.gold { background: #D4AF37; border-color: #D4AF37; color: #0A192F; box-shadow: 0 4px 16px rgba(212,175,55,0.25); }
  
  .double-channels { display: flex; gap: 6px; margin-bottom: 10px; flex-wrap: wrap; align-items: center; }
  .ch-tag { padding: 3px 9px; border-radius: 100px; font-size: 10px; font-weight: 600; letter-spacing: 0.08em; border: 1px solid; }
</style>

<!-- ── 결제 완료 배너 프로세서 ── -->
<script is:inline>
  (function () {
    const params = new URLSearchParams(window.location.search);
    if (params.get('payment') === 'success') {
      const banner = document.createElement('div');
      banner.style.cssText = 'position:fixed;top:0;left:0;right:0;padding:14px;background:#00C97A;color:#0A192F;text-align:center;font-family:League Spartan,sans-serif;font-size:13px;font-weight:700;letter-spacing:0.08em;z-index:9999;box-shadow:0 4px 20px rgba(0,0,0,0.5);';
      banner.textContent = '✓ Payment complete — your access is now active!';
      document.body.prepend(banner);
      setTimeout(() => banner.remove(), 5000);
      window.history.replaceState({}, '', '/');
    }
  })();
</script>