---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="기기 제한 | TAERIJAY">
  <div class="limit-page">
    <div class="limit-topbar">
      <button type="button" class="back-btn" onclick="history.back()">← 뒤로가기</button>
    </div>

    <section class="limit-card">
      <div class="limit-icon">🔒</div>

      <h1 class="limit-title-kr">기기 제한 초과</h1>
      <p class="limit-title-en" data-i18n="en">DEVICE LIMIT EXCEEDED</p>

      <p class="limit-desc-kr">등록된 디바이스 수 또는 동시접속 수 초과, 추가 접속 제한</p>
      <p class="limit-desc-en" data-i18n="en">Registered device or concurrent limit exceeded — further access restricted</p>

      <div class="limit-guide">
        <p class="limit-guide-kr">다른 기기에서 로그아웃 후 재시도</p>
        <p class="limit-guide-en" data-i18n="en">Log out from another device and try again</p>
      </div>

      <div class="limit-actions">
        <a href="/pricing" class="btn-upgrade">
          <span class="btn-upgrade-kr">요금제 업그레이드</span>
          <span class="btn-upgrade-en" data-i18n="en">Upgrade Plan →</span>
        </a>
        <a href="/" class="btn-home">
          <span class="btn-home-kr">홈으로 돌아가기</span>
          <span class="btn-home-en" data-i18n="en">Back to Home</span>
        </a>
      </div>
    </section>
  </div>

  <style>
    .limit-page{width:var(--container);margin:0 auto;padding:24px 0 100px;min-height:60vh;display:flex;flex-direction:column}
    .limit-topbar{margin-bottom:20px;padding-top:88px}
    .back-btn{background:transparent;border:1px solid rgba(255,255,255,.2);color:var(--ivory);font-size:.8rem;font-weight:600;padding:8px 16px;border-radius:100px;cursor:pointer;transition:background .2s}
    .back-btn:hover{background:rgba(255,255,255,.1)}

    .limit-card{
      flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;
      text-align:center;max-width:480px;margin:40px auto 0;
      border:1px solid #B33A52;border-radius:18px;padding:48px 32px;
      background:linear-gradient(160deg, rgba(179,58,82,.1) 0%, rgba(179,58,82,.02) 100%);
    }
    .limit-icon{font-size:2.4rem;margin-bottom:20px}
    .limit-title-kr{font-family:var(--f-display);font-weight:900;font-size:1.6rem;margin-bottom:4px}
    .limit-title-en{font-size:.76rem;letter-spacing:.12em;font-weight:700;color:#B33A52;text-transform:uppercase;margin-bottom:24px}
    .limit-desc-kr{font-size:.9rem;color:var(--ivory);line-height:1.7;margin-bottom:2px}
    .limit-desc-en{font-size:.78rem;color:var(--muted);line-height:1.6;margin-bottom:24px}

    .limit-guide{border-top:1px solid rgba(255,255,255,.1);padding-top:20px;margin-bottom:32px;width:100%}
    .limit-guide-kr{font-size:.86rem;color:var(--ivory);margin-bottom:2px}
    .limit-guide-en{font-size:.74rem;color:var(--dim)}

    .limit-actions{display:flex;flex-direction:column;gap:12px;width:100%}
    .btn-upgrade{display:flex;flex-direction:column;align-items:center;gap:2px;text-decoration:none;background:#B33A52;color:var(--ivory);border-radius:10px;padding:14px;font-weight:700;transition:opacity .2s}
    .btn-upgrade:hover{opacity:.88}
    .btn-upgrade-kr{font-size:.9rem}
    .btn-upgrade-en{font-size:.72rem;opacity:.85}
    .btn-home{display:flex;flex-direction:column;align-items:center;gap:2px;text-decoration:none;border:1px solid rgba(255,255,255,.2);color:var(--ivory);border-radius:10px;padding:14px;font-weight:600;transition:background .2s}
    .btn-home:hover{background:rgba(255,255,255,.06)}
    .btn-home-kr{font-size:.86rem}
    .btn-home-en{font-size:.7rem;color:var(--muted)}

    @media (max-width: 560px){
      .limit-card{padding:36px 24px}
    }
  </style>
</Layout>