---
import Layout from '../layouts/Layout.astro';
---
<Layout title="TAERIJAY+ AUDIT UNION">
	<main class="w-full min-h-screen bg-[#0A192F] flex items-center justify-center p-4 font-noto relative">
		<a href="/" class="absolute top-6 left-6 text-slate-400 hover:text-[#00F0FF] text-sm font-black font-spartan">◀ RETURN HOME</a>
		<div class="w-full max-w-[560px] border border-[#5B0E1B] bg-[#071120] rounded-2xl p-6 md:p-8 flex flex-col gap-6 shadow-2xl">
			<div class="text-center border-b border-[#5B0E1B]/30 pb-4 font-spartan">
				<span class="text-2xl font-black text-white tracking-widest">TAERIJAY+ LAW AUDIT</span>
			</div>
			<div class="flex flex-col gap-4">
				<!-- 규약 명세에 따른 한국법 x 국제법 마스터 체크 박스 시스템 -->
				<div class="flex flex-col gap-3 p-4 border border-[#5B0E1B] rounded-xl bg-baseBg max-h-[220px] overflow-y-auto no-scrollbar">
					<label class="flex items-start gap-2.5 cursor-pointer border-b border-[#5B0E1B]/20 pb-2">
						<input type="checkbox" id="chkK" class="mt-1 accent-[#00F0FF]" />
						<span class="text-xs text-white font-medium">
							[필수] 대한민국 정보통신망법 제22조 의거 개인정보 수집 이용 동의함.<br/>
							<span class="text-slate-400 font-light block font-spartan">Korean IT Network Act data sovereignty bound.</span>
						</span>
					</label>
					<label class="flex items-start gap-2.5 cursor-pointer">
						<input type="checkbox" id="chkG" class="mt-1 accent-[#00F0FF]" />
						<span class="text-xs text-white font-medium">
							[필수] 국제 개인정보 보호법(EU GDPR / 미국 CCPA) 위탁 조항 동의함.<br/>
							<span class="text-slate-400 font-light block font-spartan">Consent to global standard GDPR/CCPA criteria mappings.</span>
						</span>
					</label>
				</div>
				<button id="oauthBtnSubmit" class="w-full py-4 bg-white text-[#0A192F] font-spartan font-black text-sm rounded-xl opacity-50 cursor-not-allowed" disabled>CONTINUE WITH GOOGLE GMAIL</button>
			</div>
		</div>
	</main>
	<script is:inline>
		document.addEventListener('DOMContentLoaded', () => {
			const k = document.getElementById('chkK'); const g = document.getElementById('chkG'); const b = document.getElementById('oauthBtnSubmit');
			const check = () => { if(k.checked && g.checked){ b.disabled=false; b.classList.remove('opacity-50','cursor-not-allowed'); }else{ b.disabled=true; b.classList.add('opacity-50','cursor-not-allowed'); }};
			[k,g].forEach(c => c.addEventListener('change', check));
			b.addEventListener('click', () => { localStorage.setItem('taerijay_auth_state','authorized'); window.location.href='/?auth=success'; });
		});
	</script>
</Layout>