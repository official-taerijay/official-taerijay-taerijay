---
interface Props {
	title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=League+Spartan:wght@200;400;600;800&family=Noto+Sans:wght@300;400;500;700&display=swap" rel="stylesheet">
		<script is:inline src="https://cdn.tailwindcss.com"></script>
		<script is:inline>
			tailwind.config = {
				theme: {
					extend: {
						colors: {
							baseBg: '#0A192F',
							brandBorder: '#5B0E1B',
							neonCyan: '#00F0FF',
							neonOrange: '#FF6B00',
							neonYellow: '#FFFB00',
							neonRed: '#FF2E2E',
							neonGreen: '#00FF66',
							neonPurple: '#E000FF',
							masterBurgundy: '#990011',
						},
						fontFamily: {
							'spartan': ['"League Spartan"', 'sans-serif'],
							'noto': ['"Noto Sans"', 'sans-serif']
						}
					}
				}
			}
		</script>
		<style>
			/* 모바일 긴 영문 및 긴 한글 단어 강제 탈출 차단 장치 */
			.break-keep {
				word-break: keep-all;
			}
			.break-words {
				word-wrap: break-word;
				overflow-wrap: break-word;
			}
			/* 과도한 헤더 볼드 가공 완화 */
			.font-spartan {
				font-family: "League Spartan", sans-serif;
				letter-spacing: 0.05em;
			}
		</style>
	</head>
	<body class="bg-[#0A192F] text-[#FBF9F4] antialiased">
		<slot />
	</body>
</html>