---
// src/layouts/Layout.astro
// 모든 채널 페이지 공통 레이아웃
// Props: title, channelName, channelColor

interface Props {
  title?: string;
  channelName?: string;
  channelColor?: string;
}

const { title = 'TAERIJAY+', channelName = '', channelColor = '#F16B24' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
  <meta name="google" content="notranslate" />
  <title>{title} · TAERIJAY+</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=League+Spartan:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg:       #0A192F;
      --burgundy: #5B0E1B;
      --ivory:    #FBF9F4;
      --muted:    #7A9AB5;
      --accent:   v(--channelColor);
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--ivory);
      font-family: 'League Spartan', sans-serif;
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
    }

    /* ═════════════════════════════
       NAV
    ═════════════════════════════ */
    .nav {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 16px 20px;
      border-bottom: 1px solid rgba(91,14,27,0.35);
      position: sticky;
      top: 0;
      background: rgba(10,25,47,0.95);
      backdrop-filter: blur(8px);
      z-index: 100;
    }

    .nav-logo {
      font-family: 'Playfair Display', serif;
      font-size: 18px;
      font-weight: 700;
      letter-spacing: 0.08em;
      color: var(--ivory);
      text-decoration: none;
    }

    .nav-logo span { color: var(--burgundy); font-style: italic; }

    .nav-controls {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .lang-toggle {
      display: flex;
      align-items: center;
      border: 1px solid rgba(91,14,27,0.4);
      border-radius: 100px;
      overflow: hidden;
    }

    .lang-btn {
      padding: 5px 10px;
      font-family: 'League Spartan', sans-serif;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      background: transparent;
      border: none;
      color: var(--muted);
      cursor: pointer;
      transition: background 0.2s, color 0.2s;
    }

    .lang-btn.active {
      background: var(--burgundy);
      color: var(--ivory);
    }

    .lang-btn:hover:not(.active) { color: var(--ivory); }

    .nav-link {
      padding: 6px 14px;
      border: 1px solid var(--burgundy);
      border-radius: 2px;
      background: rgba(91,14,27,0.2);
      color: var(--ivory);
      font-family: 'League Spartan', sans-serif;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      text-decoration: none;
      cursor: pointer;
      transition: background 0.2s;
      white-space: nowrap;
    }

    .nav-link:hover { background: rgba(91,14,27,0.45); }

    /* ═════════════════════════════
       MAIN CONTENT
    ═════════════════════════════ */
    .page-wrap {
      width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      flex: 1;
    }

    .main-content {
      width: 100%;
      max-width: 1200px;
      padding: 40px 24px;
    }

    @media (max-width: 480px) {
      .main-content { padding: 24px 16px; }
      .nav { padding: 14px 16px; }
    }

    @media (min-width: 481px) and (max-width: 1024px) {
      .main-content { padding: 32px 24px; }
    }

    @media (min-width: 1025px) {
      .main-content { padding: 48px 40px; }
    }

    /* ═════════════════════════════
       SLOT CONTENT
    ═════════════════════════════ */
    ::slotted(*) {
      width: 100%;
    }

    /* ═════════════════════════════
       FOOTER
    ═════════════════════════════ */
    .footer {
      width: 100%;
      border-top: 1px solid rgba(91,14,27,0.3);
      padding: 28px 24px 40px;
      margin-top: auto;
    }

    .footer-social {
      display: flex;
      gap: 12px;
      margin-bottom: 16px;
      flex-wrap: wrap;
    }

    .social-link {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.08em;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }

    .social-link:hover { color: var(--ivory); }

    .footer-biz {
      font-size: 10px;
      color: rgba(122,154,181,0.5);
      line-height: 1.8;
    }

    .footer-biz strong { color: rgba(122,154,181,0.75); }

    /* ═════════════════════════════
       MODAL SYSTEM
    ═════════════════════════════ */
    .modal-overlay {
      display: none;
      position: fixed;
      top: 0; left: 0; right: 0; bottom: 0;
      background: rgba(0,0,0,0.65);
      backdrop-filter: blur(3px);
      z-index: 200;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }

    .modal-overlay.visible {
      display: flex;
      animation: fadeIn 0.2s ease-out;
    }

    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

    .modal-content {
      background: var(--bg);
      border: 1px solid var(--burgundy);
      border-radius: 3px;
      max-width: 480px;
      width: 100%;
      max-height: 75dvh;
      overflow-y: auto;
      position: relative;
      animation: slideUp 0.3s ease-out;
    }

    @keyframes slideUp { from { transform: translateY(20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }

    .modal-header {
      padding: 20px;
      border-bottom: 1px solid rgba(91,14,27,0.3);
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      background: rgba(10,25,47,0.95);
      backdrop-filter: blur(4px);
    }

    .modal-title {
      font-family: 'Playfair Display', serif;
      font-size: 18px;
      font-weight: 600;
      color: var(--ivory);
      margin: 0;
    }

    .modal-close {
      width: 28px; height: 28px;
      background: transparent;
      border: 1px solid rgba(91,14,27,0.5);
      border-radius: 2px;
      color: var(--ivory);
      font-size: 18px;
      cursor: pointer;
      transition: background 0.2s;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .modal-close:hover { background: rgba(91,14,27,0.3); }

    .modal-body {
      padding: 24px;
      font-size: 13px;
      line-height: 1.8;
      color: rgba(251,249,244,0.85);
    }

    .modal-body h2 {
      font-family: 'Playfair Display', serif;
      font-size: 16px;
      font-weight: 600;
      color: var(--ivory);
      margin: 18px 0 12px;
      margin-top: 0;
    }

    .modal-body h2:first-child { margin-top: 0; }

    .modal-body p { margin-bottom: 12px; }
    .modal-body ul { margin: 12px 0 12px 20px; }
    .modal-body li { margin-bottom: 6px; }

    .modal-body strong { color: var(--ivory); font-weight: 600; }

    .modal-body a {
      color: #F16B24;
      text-decoration: none;
      transition: opacity 0.2s;
    }

    .modal-body a:hover { opacity: 0.7; }

    /* ═════════════════════════════
       MODAL BUTTONS
    ═════════════════════════════ */
    .modal-buttons {
      display: flex;
      flex-direction: column;
      gap: 10px;
      padding: 0 24px 24px;
      border-top: 1px solid rgba(91,14,27,0.25);
      margin-top: 12px;
    }

    .modal-btn {
      padding: 12px;
      border-radius: 2px;
      font-family: 'League Spartan', sans-serif;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      text-decoration: none;
      cursor: pointer;
      transition: opacity 0.2s;
      border: 1px solid;
    }

    .modal-btn:hover { opacity: 0.8; }

    .modal-btn.primary {
      background: var(--burgundy);
      border-color: var(--burgundy);
      color: var(--ivory);
    }

    .modal-btn.secondary {
      background: transparent;
      border-color: rgba(91,14,27,0.5);
      color: var(--muted);
    }
  </style>
</head>

<body>

  <!-- NAV -->
  <nav class="nav">
    <a href="/" class="nav-logo">TAERIJAY<span>+</span></a>
    <div class="nav-controls">
      <div class="lang-toggle" id="langToggle" role="group" aria-label="Language">
        <button class="lang-btn active" data-lang="ko" title="한국어">한</button>
        <button class="lang-btn" data-lang="en" title="English">EN</button>
        <button class="lang-btn" data-lang="auto" title="Auto">AUTO</button>
      </div>
      <a href="/" class="nav-link">← Home</a>
    </div>
  </nav>

  <!-- MAIN -->
  <div class="page-wrap">
    <div class="main-content">
      <slot />
    </div>
  </div>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-social">
      <a href="https://www.youtube.com/@taerijay" class="social-link" target="_blank" rel="noopener">유튜브</a>
      <a href="https://www.youtube.com/@taerijay" class="social-link social-en" target="_blank" rel="noopener">YouTube</a>
      <a href="https://www.instagram.com/taerijay" class="social-link" target="_blank" rel="noopener">인스타그램</a>
      <a href="https://www.instagram.com/taerijay" class="social-link social-en" target="_blank" rel="noopener">Instagram</a>
      <a href="https://www.tiktok.com/@taerijay" class="social-link" target="_blank" rel="noopener">TikTok</a>
      <button class="social-link modal-trigger" data-modal="tos" style="background:none;border:none;padding:0;cursor:pointer;">이용약관</button>
      <button class="social-link modal-trigger social-en" data-modal="tos" style="background:none;border:none;padding:0;cursor:pointer;">Terms</button>
      <button class="social-link modal-trigger" data-modal="privacy" style="background:none;border:none;padding:0;cursor:pointer;">개인정보</button>
      <button class="social-link modal-trigger social-en" data-modal="privacy" style="background:none;border:none;padding:0;cursor:pointer;">Privacy</button>
      <button class="social-link modal-trigger" data-modal="refund" style="background:none;border:none;padding:0;cursor:pointer;">환불정책</button>
      <button class="social-link modal-trigger social-en" data-modal="refund" style="background:none;border:none;padding:0;cursor:pointer;">Refunds</button>
      <button class="social-link modal-trigger" data-modal="biz" style="background:none;border:none;padding:0;cursor:pointer;">사업자정보</button>
      <button class="social-link modal-trigger social-en" data-modal="biz" style="background:none;border:none;padding:0;cursor:pointer;">Company</button>
    </div>

    <div class="footer-biz">
      <strong>TAERIJAY (태리재이)</strong><br/>
      <span>사업자등록번호: 673-51-01148 · 통신판매번호: 2026-Hwadosudo-0247</span>
      <span class="footer-en">Business Registration: 673-51-01148 · Communication Sales: 2026-Hwadosudo-0247</span><br/>
      <span>경기도 남양주시 화도읍 · official@taerijay.com</span>
      <span class="footer-en">Namyangju, Gyeonggi-do · official@taerijay.com</span>
    </div>
  </footer>

  <!-- MODALS -->

  <!-- Terms of Service -->
  <div class="modal-overlay" id="modal-tos">
    <div class="modal-content">
      <div class="modal-header">
        <h2 class="modal-title">이용약관</h2>
        <h2 class="modal-title modal-title-en">Terms of Service</h2>
        <button class="modal-close" aria-label="Close">&times;</button>
      </div>
      <div class="modal-body">
        <h2>TAERIJAY+ 이용약관</h2>
        <p><strong>1. 서비스 이용 동의</strong></p>
        <p>본 서비스는 한국 여행 및 라이프스타일 정보 데이터베이스를 제공합니다. 가입 시점부터 이용약관에 자동 동의됩니다.</p>

        <p><strong>2. 계정 및 보안</strong></p>
        <p>Google 계정으로만 로그인 가능합니다. 귀하의 계정에 대한 모든 활동은 귀하의 책임입니다.</p>

        <p><strong>3. 결제 및 환불</strong></p>
        <p>모든 결제는 Paddle을 통해 처리되며, 디지털 콘텐츠의 특성상 구매 후 환불이 불가능합니다. 단, 중복 결제 시 환불 가능합니다.</p>

        <p><strong>4. 지적재산권</strong></p>
        <p>TAERIJAY+ 플랫폼의 모든 콘텐츠는 저작권으로 보호됩니다. 무단 복제, 배포, 수정을 금합니다.</p>

        <p><strong>5. 약관 변경</strong></p>
        <p>당사는 사전 공지 없이 약관을 변경할 수 있습니다. 변경 사항은 웹사이트에 게시됩니다.</p>

        <hr style="border:none;border-top:1px solid rgba(91,14,27,0.25);margin:20px 0;"/>

        <h2 class="modal-title-en">TAERIJAY+ Terms of Service</h2>
        <p class="modal-title-en"><strong>1. Agreement to Terms</strong></p>
        <p class="modal-title-en">This service provides verified Korea travel and lifestyle information. By signing up, you automatically agree to these terms.</p>

        <p class="modal-title-en"><strong>2. Account &amp; Security</strong></p>
        <p class="modal-title-en">Login is available only via Google account. You are responsible for all activity under your account.</p>

        <p class="modal-title-en"><strong>3. Payment &amp; Refunds</strong></p>
        <p class="modal-title-en">All payments are processed via Paddle. Digital content is non-refundable after purchase, except for duplicate transactions.</p>

        <p class="modal-title-en"><strong>4. Intellectual Property</strong></p>
        <p class="modal-title-en">All content on TAERIJAY+ is copyright protected. Unauthorized reproduction, distribution, or modification is prohibited.</p>

        <p class="modal-title-en"><strong>5. Changes to Terms</strong></p>
        <p class="modal-title-en">We may modify these terms without prior notice. Changes will be posted on our website.</p>
      </div>
    </div>
  </div>

  <!-- Privacy Policy -->
  <div class="modal-overlay" id="modal-privacy">
    <div class="modal-content">
      <div class="modal-header">
        <h2 class="modal-title">개인정보 처리방침</h2>
        <h2 class="modal-title modal-title-en">Privacy Policy</h2>
        <button class="modal-close" aria-label="Close">&times;</button>
      </div>
      <div class="modal-body">
        <h2>개인정보 처리방침</h2>
        <p><strong>1. 수집하는 정보</strong></p>
        <p>TAERIJAY+는 Google 계정에서만 정보를 수집합니다: 이메일, 이름, 프로필 사진.</p>

        <p><strong>2. 정보 사용</strong></p>
        <p>수집된 정보는 계정 관리 및 서비스 제공 목적으로만 사용됩니다.</p>

        <p><strong>3. 정보 보호</strong></p>
        <p>귀하의 개인정보는 안전하게 보호됩니다. TAERIJAY+는 결제 정보를 수집하지 않습니다 — Paddle이 처리합니다.</p>

        <p><strong>4. 제3자 공유</strong></p>
        <p>개인정보는 제3자와 공유되지 않습니다.</p>

        <p><strong>5. 쿠키 및 로컬 스토리지</strong></p>
        <p>당사는 사용자 환경 설정 및 세션 관리를 위해 로컬 스토리지를 사용합니다.</p>

        <hr style="border:none;border-top:1px solid rgba(91,14,27,0.25);margin:20px 0;"/>

        <h2 class="modal-title-en">Privacy Policy</h2>
        <p class="modal-title-en"><strong>1. Information We Collect</strong></p>
        <p class="modal-title-en">TAERIJAY+ collects information only from Google accounts: email, name, and profile photo.</p>

        <p class="modal-title-en"><strong>2. How We Use Information</strong></p>
        <p class="modal-title-en">Collected information is used solely for account management and service delivery.</p>

        <p class="modal-title-en"><strong>3. Data Protection</strong></p>
        <p class="modal-title-en">Your personal information is protected securely. TAERIJAY+ does not collect payment information — Paddle handles this.</p>

        <p class="modal-title-en"><strong>4. Third-Party Sharing</strong></p>
        <p class="modal-title-en">Personal information is not shared with third parties.</p>

        <p class="modal-title-en"><strong>5. Cookies &amp; Local Storage</strong></p>
        <p class="modal-title-en">We use local storage for user preferences and session management.</p>
      </div>
    </div>
  </div>

  <!-- Refund Policy -->
  <div class="modal-overlay" id="modal-refund">
    <div class="modal-content">
      <div class="modal-header">
        <h2 class="modal-title">환불 정책</h2>
        <h2 class="modal-title modal-title-en">Refund Policy</h2>
        <button class="modal-close" aria-label="Close">&times;</button>
      </div>
      <div class="modal-body">
        <h2>환불 정책</h2>
        <p><strong>디지털 콘텐츠의 특성상, 구매 후 환불이 불가능합니다.</strong></p>

        <p><strong>1. 환불 불가 사유</strong></p>
        <p>TAERIJAY+의 모든 패스는 디지털 서비스이므로, 활성화 후 환불 요청이 불가능합니다.</p>

        <p><strong>2. 환불 가능 사유</strong></p>
        <p>다음의 경우 환불 가능합니다:</p>
        <ul>
          <li>중복 결제 (동일 상품 2회 이상 구매)</li>
          <li>Paddle 시스템 오류로 인한 결제</li>
          <li>서비스 제공 불능 (계정 복구 불가)</li>
        </ul>

        <p><strong>3. 환불 신청 절차</strong></p>
        <p>환불이 필요한 경우 <strong>official@taerijay.com</strong>으로 연락하세요. 72시간 이내 답변드립니다.</p>

        <p><strong>4. 처리 기간</strong></p>
        <p>승인된 환불은 5-7 영업일 내 귀하의 결제 수단으로 환급됩니다.</p>

        <hr style="border:none;border-top:1px solid rgba(91,14,27,0.25);margin:20px 0;"/>

        <h2 class="modal-title-en">Refund Policy</h2>
        <p class="modal-title-en"><strong>Due to the digital nature of our content, refunds are not available after purchase.</strong></p>

        <p class="modal-title-en"><strong>1. Non-Refundable Purchases</strong></p>
        <p class="modal-title-en">All TAERIJAY+ passes are digital services. Once activated, refund requests cannot be processed.</p>

        <p class="modal-title-en"><strong>2. Refundable Circumstances</strong></p>
        <p class="modal-title-en">Refunds are possible in these cases:</p>
        <ul>
          <li class="modal-title-en">Duplicate charges (purchasing the same product twice)</li>
          <li class="modal-title-en">Payment errors due to Paddle system failure</li>
          <li class="modal-title-en">Service inability (account recovery impossible)</li>
        </ul>

        <p class="modal-title-en"><strong>3. Refund Request Process</strong></p>
        <p class="modal-title-en">For refund inquiries, contact <strong>official@taerijay.com</strong>. We respond within 72 hours.</p>

        <p class="modal-title-en"><strong>4. Processing Timeline</strong></p>
        <p class="modal-title-en">Approved refunds will be returned to your original payment method within 5-7 business days.</p>
      </div>
    </div>
  </div>

  <!-- Business Info -->
  <div class="modal-overlay" id="modal-biz">
    <div class="modal-content">
      <div class="modal-header">
        <h2 class="modal-title">사업자 정보</h2>
        <h2 class="modal-title modal-title-en">Company Information</h2>
        <button class="modal-close" aria-label="Close">&times;</button>
      </div>
      <div class="modal-body">
        <h2>TAERIJAY (태리재이)</h2>
        <p><strong>사업자등록번호</strong> 673-51-01148</p>
        <p><strong>통신판매신고번호</strong> 2026-Hwadosudo-0247</p>
        <p><strong>소재지</strong> 경기도 남양주시 화도읍</p>
        <p><strong>대표</strong> 개인사업자</p>
        <p><strong>이메일</strong> official@taerijay.com</p>

        <hr style="border:none;border-top:1px solid rgba(91,14,27,0.25);margin:20px 0;"/>

        <h2 class="modal-title-en">TAERIJAY (태리재이)</h2>
        <p class="modal-title-en"><strong>Business Registration</strong> 673-51-01148</p>
        <p class="modal-title-en"><strong>Communication Sales Registration</strong> 2026-Hwadosudo-0247</p>
        <p class="modal-title-en"><strong>Location</strong> Hwado-eup, Namyangju, Gyeonggi-do, Korea</p>
        <p class="modal-title-en"><strong>Operator</strong> Individual Proprietor</p>
        <p class="modal-title-en"><strong>Email</strong> official@taerijay.com</p>

        <p style="margin-top:24px;font-size:11px;color:rgba(122,154,181,0.6);">
          모든 정보는 정확한 것을 기재하였습니다. 변경 시 지체 없이 수정하겠습니다.<br/>
          All information provided is accurate. We will update any changes promptly.
