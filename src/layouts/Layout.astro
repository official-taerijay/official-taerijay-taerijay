    <p class="footer-copy">© 2026 TAERIJAY · 사업자등록번호 673-51-01148 · taerijay.com</p>
  </footer>

  <script>
    const nav = document.getElementById('nav');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 40) nav.classList.add('nav-scrolled');
      else nav.classList.remove('nav-scrolled');
    });

    const hamburgerBtn = document.getElementById('hamburger-btn');
    const sideMenu = document.getElementById('side-menu');
    const sideClose = document.getElementById('side-close');
    hamburgerBtn.addEventListener('click', () => { sideMenu.hidden = false; });
    sideClose.addEventListener('click', () => { sideMenu.hidden = true; });
    sideMenu.addEventListener('click', (e) => { if (e.target === sideMenu) sideMenu.hidden = true; });

    const langTrigger = document.getElementById('lang-trigger');
    const langMenu = document.getElementById('lang-menu');
    const langCurrent = document.getElementById('lang-current');

    langTrigger.addEventListener('click', (e) => {
      e.stopPropagation();
      langMenu.hidden = !langMenu.hidden;
    });

    document.querySelectorAll('.lang-option').forEach((opt) => {
      opt.addEventListener('click', () => {
        langCurrent.textContent = opt.dataset.name;
        localStorage.setItem('taerijay_lang', opt.dataset.code);
        langMenu.hidden = true;
      });
    });

    document.addEventListener('click', (e) => {
      if (!langMenu.hidden && !e.target.closest('.lang-dropdown')) {
        langMenu.hidden = true;
      }
    });

    window.addEventListener('DOMContentLoaded', () => {
      const saved = localStorage.getItem('taerijay_lang');
      if (saved) {
        const opt = document.querySelector(`.lang-option[data-code="${saved}"]`);
        if (opt) langCurrent.textContent = opt.dataset.name;
      }
      setTimeout(() => {
        const s = document.getElementById('splash');
        if (s) { s.style.opacity = '0'; setTimeout(() => s.remove(), 500); }
      }, 700);

      const kr = document.getElementById('nav-account-kr');
      const en = document.getElementById('nav-account-en');
      const sideLink = document.getElementById('side-account-link');
      const loggedIn = !!sessionStorage.getItem('user_email');
      if (kr && en) {
        if (loggedIn) {
          kr.textContent = '로그아웃';
          en.textContent = 'Log Out';
        } else {
          kr.textContent = '회원가입/로그인';
          en.textContent = 'Sign Up / Log In';
        }
      }
      if (sideLink) sideLink.textContent = loggedIn ? '로그아웃' : '회원가입/로그인';
    });
  </script>

  <style is:global>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --bg:#0A192F;--border:#5B0E1B;--ivory:#FBF9F4;--muted:#8b96a8;--dim:#5d6c82;--gold:#D4AF37;
      --f-display:-apple-system,BlinkMacSystemFont,"SF Pro Display","Segoe UI",Roboto,Helvetica,Arial,sans-serif;--f-body:-apple-system,BlinkMacSystemFont,"SF Pro Text","Segoe UI",Roboto,Helvetica,Arial,sans-serif;
      --container: min(1200px, 92vw);
    }
    html,body{background:var(--bg);color:var(--ivory);font-family:var(--f-body);min-height:100vh;overflow-x:hidden;scroll-behavior:smooth}
    button{font:inherit}
    a{color:inherit}

    .splash{position:fixed;inset:0;background:var(--bg);display:flex;align-items:center;justify-content:center;z-index:9999;transition:opacity .5s ease}
    .splash-brand{font-family:var(--f-display);font-weight:900;font-size:clamp(1.8rem,6vw,2.6rem);letter-spacing:.06em}

    .nav{position:fixed;top:0;left:0;right:0;z-index:200;transition:background .3s ease,border-color .3s ease}
    .nav-scrolled{background:rgba(10,25,47,.92);backdrop-filter:blur(10px);border-bottom:1px solid rgba(91,14,27,.4)}
    .nav-inner{width:var(--container);margin:0 auto;display:flex;align-items:center;justify-content:space-between;padding:16px 0}
    .nav-logo{font-family:var(--f-display);font-weight:900;font-size:clamp(1rem,3vw,1.15rem);letter-spacing:.05em;color:#B33A52;text-decoration:none}
    .hamburger{display:flex;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:6px}
    .hamburger span{display:block;width:22px;height:2px;background:var(--ivory)}
    .nav-right{display:flex;flex-direction:column;align-items:flex-end;gap:8px}
    .nav-account-btn{display:flex;flex-direction:column;align-items:center;gap:1px;text-decoration:none;background:rgba(91,14,27,.55);border:1px solid #8B1A2A;border-radius:8px;padding:6px 14px}
    .nav-account-btn:hover{background:rgba(91,14,27,.8)}
    .nav-account-kr{font-size:.78rem;font-weight:700;color:var(--ivory)}
    .nav-account-en{font-size:.62rem;font-weight:600;color:var(--muted)}

    .lang-dropdown{position:relative}
    .lang-trigger{display:flex;align-items:center;gap:6px;background:transparent;border:1px solid rgba(255,255,255,.18);color:var(--ivory);font-size:.76rem;font-weight:600;padding:8px 12px;border-radius:6px;cursor:pointer}
    .lang-menu{position:absolute;top:calc(100% + 8px);right:0;background:#151f33;border:1px solid rgba(255,255,255,.12);border-radius:10px;box-shadow:0 16px 40px rgba(0,0,0,.5);max-height:320px;overflow-y:auto;min-width:180px;z-index:300}
    .lang-option{display:block;width:100%;text-align:left;background:transparent;border:none;color:var(--ivory);font-size:.82rem;padding:10px 16px;cursor:pointer;transition:background .15s}
    .lang-option:hover{background:rgba(255,255,255,.08)}

    .side-menu{position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:300}
    .side-menu-inner{position:absolute;top:0;left:0;height:100%;width:min(320px,80vw);background:#0d1f3d;padding:24px;display:flex;flex-direction:column;overflow-y:auto}
    .side-close{align-self:flex-end;background:none;border:none;color:var(--ivory);font-size:1.8rem;cursor:pointer;margin-bottom:20px}
    .side-logo{font-family:var(--f-display);font-weight:900;font-size:1.3rem;margin-bottom:28px;text-decoration:none;color:#B33A52}
    .side-links{display:flex;flex-direction:column;gap:16px}
    .side-links a{text-decoration:none;font-size:.9rem;color:var(--c,var(--muted));font-weight:600}
    .side-divider{height:1px;background:rgba(255,255,255,.08);margin:20px 0}
    .side-account-link{color:var(--ivory)!important;font-weight:700!important}
    .side-links-plain a{color:var(--ivory);font-weight:700;letter-spacing:.04em}
    .side-links-legal{flex-direction:row;flex-wrap:wrap;gap:14px}
    .side-links-legal a{font-size:.78rem;color:var(--muted);font-weight:500}
    .side-social{display:flex;gap:10px;flex-wrap:wrap}

    main{padding-top:0}

    .footer{width:var(--container);margin:0 auto;padding:40px 0 48px;border-top:1px solid rgba(255,255,255,.08);text-align:center}
    .footer-links{display:flex;justify-content:center;gap:28px;flex-wrap:wrap;margin-bottom:24px}
    .footer-links a{text-decoration:none;font-size:.82rem;color:var(--muted);text-align:center;line-height:1.6}
    .footer-en{font-size:.7rem;color:var(--dim)}
    .footer-social{display:flex;gap:14px;justify-content:center;margin-bottom:20px}
    .social-icon{
      width:40px;height:40px;
      display:flex;align-items:center;justify-content:center;
      text-decoration:none;
      transition:transform .15s;
      background:none;
      border:none;
    }
    .social-icon svg{width:36px;height:36px;display:block}
    .social-icon:hover{transform:translateY(-2px)}
    .footer-copy{font-size:.74rem;color:var(--dim)}

    @media (max-width: 560px){
      .lang-trigger{padding:6px 9px;font-size:.7rem}
      .lang-menu{right:-40px;max-width:calc(100vw - 24px)}
    }

    @media (prefers-reduced-motion: reduce){
      *{transition-duration:.01ms!important;animation-duration:.01ms!important;scroll-behavior:auto!important}
    }
  </style>
</body>
</html>