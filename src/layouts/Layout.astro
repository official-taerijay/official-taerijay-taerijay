---
// src/layouts/Layout.astro
// TAERIJAY 공통 레이아웃 — 스플래시 / 폰트 / 인증 가드 / 로그인·결제 공통 모달
// 브랜드 타이틀: TAERIJAY (전체) / 채널 로고: taerijay+채널명 (소문자 고정)

export interface Props {
  title: string;
  description?: string;
  /** 채널 페이지에서만 true — 미인증 시 /01-auth/auth 로 강제 리다이렉트 */
  requireAuth?: boolean;
  /** 채널 브랜드 컬러 (로고/포인트 컬러 동적 적용) */
  channelColor?: string;
  /** 채널명 (소문자 고정) — 있으면 "taerijay+채널명" 로고, 없으면 브랜드 타이틀 "TAERIJAY" */
  channelName?: string;
}

const {
  title,
  description = 'TAERIJAY — 검증된 한국 여행/라이프스타일 정보 플랫폼',
  requireAuth = false,
  channelColor = '#00E5FF',
  channelName = '',
} = Astro.props;

// 브랜드 타이틀 = "TAERIJAY" (전체) / 채널 로고 = "taerijay+채널명" (소문자 고정)
const isChannel = channelName.length > 0;
const logoBase = isChannel ? 'taerijay' : 'TAERIJAY';
const logoSuffix = isChannel ? `+${channelName.toLowerCase()}` : '';
---

<!doctype html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>{title} | TAERIJAY</title>
  <meta name="description" content={description} />

  <!-- 폰트: Playfair Display(디스플레이) + League Spartan(본문/UI) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,900;1,600&family=League+Spartan:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet"
  />

  <!-- Firebase Auth -->
  <script type="module" is:inline>
    import { initializeApp } from 'https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js';
    import {
      getAuth,
      GoogleAuthProvider,
      signInWithPopup,
      signOut,
      onAuthStateChanged,
    } from 'https://www.gstatic.com/firebasejs/10.12.2/firebase-auth.js';

    const firebaseConfig = {
      apiKey: import.meta.env.PUBLIC_FIREBASE_API_KEY,
      authDomain: 'taerijay-platform.firebaseapp.com',
      projectId: 'taerijay-platform',
    };

    const app = initializeApp(firebaseConfig);
    const auth = getAuth(app);
    const provider = new GoogleAuthProvider();

    window.taerijayAuth = { auth, provider, signInWithPopup, signOut, onAuthStateChanged };
  </script>

  <!-- Paddle Billing v3 -->
  <script src="https://cdn.paddle.com/paddle/v2/paddle.js" is:inline></script>
  <script type="module" is:inline>
    window.addEventListener('load', () => {
      if (window.Paddle) {
        Paddle.Environment.set('production');
        Paddle.Initialize({
          token: import.meta.env.PUBLIC_PADDLE_VENDOR_TOKEN,
        });
      }
    });
  </script>
</head>

<body data-require-auth={requireAuth} data-channel-color={channelColor}>

  <!-- ═══════════ 스플래시 스크린 — 풀스크린 TAERIJAY 로고 ═══════════ -->
  <div id="splash-screen" class="splash-screen">
    <div class="splash-logo">
      <span class="splash-taerijay">{logoBase}</span>
      {isChannel && <span class="splash-plus" style={`color:${channelColor}`}>{logoSuffix}</span>}
    </div>
  </div>

  <!-- ═══════════ 모바일 퍼스트 고정 컨테이너 ═══════════ -->
  <div class="app-container">
    <slot />
  </div>

  <!-- ═══════════ 공통 모달: 로그인 ═══════════ -->
  <div id="auth-modal" class="modal-overlay" hidden>
    <div class="modal-box">
      <button class="modal-close" data-close="auth-modal" aria-label="닫기">&times;</button>
      <div class="modal-logo">{logoBase}{isChannel && <span style={`color:${channelColor}`}>{logoSuffix}</span>}</div>
      <p class="modal-desc">구글 계정으로 로그인하고<br />전 채널 콘텐츠를 확인하세요</p>
      <button id="google-signin-btn" class="btn-google">
        <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
          <path fill="#4285F4" d="M17.64 9.2c0-.64-.06-1.25-.16-1.84H9v3.48h4.84a4.14 4.14 0 0 1-1.8 2.72v2.26h2.9c1.7-1.57 2.7-3.88 2.7-6.62z"/>
          <path fill="#34A853" d="M9 18c2.43 0 4.47-.8 5.96-2.18l-2.9-2.26c-.8.54-1.84.86-3.06.86-2.35 0-4.34-1.59-5.05-3.72H.95v2.33A9 9 0 0 0 9 18z"/>
          <path fill="#FBBC05" d="M3.95 10.7A5.4 5.4 0 0 1 3.66 9c0-.59.1-1.17.29-1.7V4.97H.95A9 9 0 0 0 0 9c0 1.45.35 2.83.95 4.03l3-2.33z"/>
          <path fill="#EA4335" d="M9 3.58c1.32 0 2.5.45 3.44 1.35l2.58-2.58C13.46.89 11.43 0 9 0A9 9 0 0 0 .95 4.97l3 2.33C4.66 5.17 6.65 3.58 9 3.58z"/>
        </svg>
        Google로 로그인
      </button>
    </div>
  </div>

  <!-- ═══════════ 공통 모달: 결제 (Paddle) ═══════════ -->
  <div id="payment-modal" class="modal-overlay" hidden>
    <div class="modal-box">
      <button class="modal-close" data-close="payment-modal" aria-label="닫기">&times;</button>
      <div class="modal-logo">{logoBase}{isChannel && <span style={`color:${channelColor}`}>{logoSuffix}</span>}</div>
      <p class="modal-desc" id="payment-plan-label">요금제를 선택하세요</p>
      <div id="payment-plan-list" class="plan-list"></div>
    </div>
  </div>

  <!-- ═══════════ 공통 모달: 기기 제한 ═══════════ -->
  <div id="device-limit-modal" class="modal-overlay" hidden>
    <div class="modal-box">
      <button class="modal-close" data-close="device-limit-modal" aria-label="닫기">&times;</button>
      <div class="modal-logo">{logoBase}{isChannel && <span style={`color:${channelColor}`}>{logoSuffix}</span>}</div>
      <p class="modal-desc">동시 접속 가능한 기기 수를<br />초과했습니다</p>
      <a href="/03-device-limit/" class="btn-google" style="justify-content:center;">기기 관리로 이동</a>
    </div>
  </div>

  <script type="module" is:inline define:vars={{ requireAuth }}>
    // ── 스플래시 스크린 ──
    window.addEventListener('DOMContentLoaded', () => {
      const splash = document.getElementById('splash-screen');
      setTimeout(() => {
        splash.classList.add('splash-hide');
        setTimeout(() => splash.remove(), 600);
      }, 900);
    });

    // ── 모달 공통 제어 ──
    document.querySelectorAll('[data-close]').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.getElementById(btn.dataset.close).hidden = true;
      });
    });
    window.openModal = (id) => { document.getElementById(id).hidden = false; };
    window.closeModal = (id) => { document.getElementById(id).hidden = true; };

    // ── 채널 방어벽: sessionStorage user_email 검증 ──
    if (requireAuth) {
      const userEmail = sessionStorage.getItem('user_email');
      if (!userEmail) {
        window.location.href = '/01-auth/auth';
      }
    }

    // ── 구글 로그인 버튼 ──
    const signinBtn = document.getElementById('google-signin-btn');
    if (signinBtn) {
      signinBtn.addEventListener('click', async () => {
        try {
          const { auth, provider, signInWithPopup } = window.taerijayAuth;
          const result = await signInWithPopup(auth, provider);
          sessionStorage.setItem('user_email', result.user.email);
          window.closeModal('auth-modal');
          window.location.reload();
        } catch (err) {
          console.error('로그인 실패:', err);
        }
      });
    }
  </script>

  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,900;1,600&family=League+Spartan:wght@300;400;500;600;700;800&display=swap');

    :root {
      --tj-bg: #0A192F;
      --tj-border: #5B0E1B;
      --tj-font-display: 'Playfair Display', serif;
      --tj-font-body: 'League Spartan', sans-serif;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      background: var(--tj-bg);
      color: #FBF9F4;
      font-family: var(--tj-font-body);
      min-height: 100vh;
      overflow-x: hidden;
    }

    h1, h2, h3, .font-display {
      font-family: var(--tj-font-display);
    }

    .app-container {
      max-width: 480px;
      margin: 0 auto;
      min-height: 100vh;
      background: var(--tj-bg);
      border-left: 1px solid var(--tj-border);
      border-right: 1px solid var(--tj-border);
      position: relative;
    }

    /* ── 스플래시 ── */
    .splash-screen {
      position: fixed;
      inset: 0;
      background: var(--tj-bg);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 9999;
      transition: opacity 0.6s ease;
    }
    .splash-screen.splash-hide { opacity: 0; pointer-events: none; }
    .splash-logo {
      font-family: var(--tj-font-display);
      font-weight: 900;
      font-size: 2.6rem;
      letter-spacing: 0.04em;
      color: #FBF9F4;
    }
    .splash-plus { font-weight: 700; }

    /* ── 모달 공통 ── */
    .modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(10, 25, 47, 0.85);
      backdrop-filter: blur(4px);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 999;
      padding: 24px;
    }
    .modal-box {
      position: relative;
      width: 100%;
      max-width: 400px;
      background: var(--tj-bg);
      border: 1px solid var(--tj-border);
      border-radius: 16px;
      padding: 36px 28px 28px;
      text-align: center;
    }
    .modal-close {
      position: absolute;
      top: 12px; right: 14px;
      background: none; border: none;
      color: #FBF9F4; font-size: 1.4rem;
      cursor: pointer; line-height: 1;
      opacity: 0.6;
    }
    .modal-close:hover { opacity: 1; }
    .modal-logo {
      font-family: var(--tj-font-display);
      font-weight: 900;
      font-size: 1.4rem;
      margin-bottom: 14px;
    }
    .modal-desc {
      font-size: 0.92rem;
      line-height: 1.6;
      color: #cfd6e0;
      margin-bottom: 24px;
    }
    .btn-google {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      background: #FBF9F4;
      color: #0A192F;
      border: none;
      border-radius: 10px;
      padding: 13px;
      font-family: var(--tj-font-body);
      font-weight: 600;
      font-size: 0.94rem;
      cursor: pointer;
      text-decoration: none;
    }
    .plan-list { display: flex; flex-direction: column; gap: 10px; }
  </style>
</body>
</html>