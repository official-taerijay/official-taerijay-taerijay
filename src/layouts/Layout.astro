---
export interface Props {
  title?: string;
}
const { title = 'TAERIJAY' } = Astro.props;

const channels = {
  entertainment: { slug: 'entertainment', color: '#00E5FF' },
  protocol:      { slug: 'protocol',      color: '#F16B24' },
  mini:          { slug: 'mini',          color: '#e8e4dc' },
  daiso:         { slug: 'daiso',         color: '#E1261C' },
  oliveyoung:    { slug: 'oliveyoung',    color: '#6F8B2E' },
  emart:         { slug: 'emart',         color: '#FFDD00' },
  convenience:   { slug: 'convenience',   color: '#A14D7C' },
};

const socialLinks = [
  { name: 'YouTube', href: '#', color: '#FF0000', bg: '#FFFFFF' },
  { name: 'Instagram', href: '#', color: '#E1306C', bg: 'gradient' },
  { name: 'TikTok', href: '#', color: '#000000', bg: '#000000' },
  { name: 'Google', href: '#', color: '#4285F4', bg: '#FFFFFF' },
  { name: 'Naver', href: '#', color: '#03C75A', bg: '#03C75A' },
];

const languages = [
  { code: 'en', name: 'English' },
  { code: 'ko', name: '한국어' },
  { code: 'ja', name: '日本語' },
  { code: 'zh-CN', name: '简体中文' },
  { code: 'zh-TW', name: '繁體中文' },
  { code: 'zh-HK', name: '中文（香港）' },
  { code: 'es', name: 'Español' },
  { code: 'fr', name: 'Français' },
  { code: 'de', name: 'Deutsch' },
  { code: 'it', name: 'Italiano' },
  { code: 'pt', name: 'Português' },
  { code: 'pt-BR', name: 'Português (Brasil)' },
  { code: 'ru', name: 'Русский' },
  { code: 'ar', name: 'العربية' },
  { code: 'hi', name: 'हिन्दी' },
  { code: 'th', name: 'ไทย' },
  { code: 'vi', name: 'Tiếng Việt' },
  { code: 'id', name: 'Bahasa Indonesia' },
  { code: 'ms', name: 'Bahasa Melayu' },
  { code: 'tl', name: 'Filipino' },
  { code: 'tr', name: 'Türkçe' },
  { code: 'nl', name: 'Nederlands' },
  { code: 'pl', name: 'Polski' },
  { code: 'sv', name: 'Svenska' },
  { code: 'nb', name: 'Norsk bokmål' },
  { code: 'da', name: 'Dansk' },
  { code: 'fi', name: 'Suomi' },
  { code: 'el', name: 'Ελληνικά' },
  { code: 'he', name: 'עברית' },
  { code: 'cs', name: 'Čeština' },
  { code: 'ro', name: 'Română' },
  { code: 'hu', name: 'Magyar' },
  { code: 'uk', name: 'Українська' },
  { code: 'bg', name: 'Български' },
  { code: 'sk', name: 'Slovenčina' },
  { code: 'hr', name: 'Hrvatski' },
  { code: 'sr', name: 'Српски' },
  { code: 'sl', name: 'Slovenščina' },
  { code: 'lt', name: 'Lietuvių' },
  { code: 'lv', name: 'Latviešu' },
  { code: 'et', name: 'Eesti' },
  { code: 'ca', name: 'Català' },
  { code: 'af', name: 'Afrikaans' },
  { code: 'sw', name: 'Kiswahili' },
  { code: 'bn', name: 'বাংলা' },
  { code: 'ta', name: 'தமிழ்' },
  { code: 'te', name: 'తెలుగు' },
  { code: 'ur', name: 'اردو' },
  { code: 'fa', name: 'فارسی' },
