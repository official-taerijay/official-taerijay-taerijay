---
interface Props {
	title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="ko" translate="no" class="h-full scroll-smooth select-none">
	<head>
		<meta charset="UTF-8" />
		<meta name="google" content="notranslate" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
		<title>{title}</title>
		
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=League+Spartan:wght@200;400;600;800&family=Noto+Sans:wght@300;400;500;700&display=swap" rel="stylesheet">
		
		<script is:inline src="https://cdn.tailwindcss.com"></script>
		<!-- 💡 [추가] 실시간 구글 로그인 세션을 통제하는 수파베이스 글로벌 인증 라이브러리 탑재 -->
		<script is:inline src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
		
		<script is:inline>
			tailwind.config = {
				theme: {
					extend: {
						colors: {
							baseBg: '#0A192F',
							brandBorder: '#5B0E1B',
							neonCyan: '#00F0FF',
							neonOrange: '#FF6B00',
							neonYellow: '#FFFB00',
							neonRed: '#FF2E2E',
							neonGreen: '#00FF66',
							neonPurple: '#E000FF',
							masterBurgundy: '#990011',
						},
						fontFamily: {
							'spartan': ['"League Spartan"', 'sans-serif'],
							'noto': ['"Noto Sans"', 'sans-serif']
						}
					}
				}
			}
		</script>
		<style>
			html, body {
				height: 100%;
				background-color: #0A192F;
				-webkit-font-smoothing: antialiased;
				-moz-osx-font-smoothing: grayscale;
				text-rendering: optimizeLegibility;
				-webkit-text-size-adjust: 100%;
				-ms-text-size-adjust: 100%;
			}
			body {
				font-family: "Noto Sans", sans-serif;
				word-break: keep-all;
				overflow-wrap: anywhere;
			}
			.font-spartan {
				font-family: "League Spartan", sans-serif;
				letter-spacing: 0.06em;
			}
		</style>
	</head>
	<body class="bg-[#0A192F] text-[#FBF9F4] flex flex-col min-h-screen">
		<slot />
	</body>
</html>