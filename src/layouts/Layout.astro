---
// src/layouts/Layout.astro
// 채널 페이지 공통 레이아웃 — 언어 토글(KO/EN/Auto) + 네비 + 푸터

interface Props {
  title?: string;
  channelName?: string;   // 'protocol' | 'mini' | 'daiso' | 'oliveyoung' | 'emart' | 'convenience' | 'entertainment'
  channelColor?: string;  // 채널 accent 컬러 hex
  lang?: 'en' | 'ko';
}

const {
  title = 'TAERIJAY+',
  channelName = '',
  channelColor = '#F16B24',
  lang = 'en',
} = Astro.props;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
  <meta name="google" content="notranslate" />
  <title>{title} · TAERIJAY+</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=League+Spartan:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg:        #0A192F;
      --burgundy:  #5B0E1B;
      --ivory:     #FBF9F4;
      --muted:     #7A9AB5;
      --accent:    #F16B24; /* 스크립트로 채널별 덮어씀 */
    }

    body {
      background: var(--bg);
      color: var(--ivory);
      font-family: 'League Spartan', sans-serif;
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    /* ── 공통 벨트 ── */
    .belt {
      width: 100%;
      max-width: 480px;
      padding: 0 16px;
    }

    /* ══════════════
        NAV
     ══════════════ */
    .layout-nav {
      width: 100%;
      max-width: 480px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 16px 16px 12px;
      border-bottom: 1px solid rgba(91,14,27,0.35);
      position: sticky;
      top: 0;
      background: rgba(10,25,47,0.96);
      backdrop-filter: blur(10px);
      z-index: 100;
      gap: 10px;
    }

    /* 로고 */
    .nav-logo {
      font-family: 'Playfair Display', serif;
      font-size: 17px;
      font-weight: 700;
      letter-spacing: 0.08em;
      color: var(--ivory);
      text-decoration: none;
      flex-shrink: 0;
    }

    .nav-logo-plus { color: #ff3344; font-style: italic; }

    /* 채널 이름 뱃지 */
    .nav-channel-badge {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: lowercase;
      color: var(--accent);
      border: 1px solid var(--accent);
      border-radius: 100px;
      padding: 3px 10px;
      flex-shrink: 0;
      transition: color 0.3s, border-color 0.3s;
    }

    /* 우측 컨트롤 그룹 */
    .nav-controls {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-shrink: 0;
    }

    /* ── 언어 토글 ── */
    .lang-toggle {
      display: flex;
      align-items: center;
      border: 1px solid rgba(91,14,27,0.4);
      border-radius: 100px;
      overflow: hidden;
    }

    .lang-btn {
      padding: 4px 9px;
      font-family: 'League Spartan', sans-serif;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      background: transparent;
      border: none;
      color: var(--muted);
      cursor: pointer;
      transition: background 0.2s, color 0.2s;
    }

    .lang-btn.active {
      background: var(--burgundy);
      color: var(--ivory);
    }

    .lang-btn:hover:not(.active) { color: var(--ivory); }

    /* 인증 버튼 */
    .nav-auth {
      padding: 5px 12px;
      border: 1px solid var(--burgundy);
      border-radius: 2px;
      background: rgba(91,14,27,0.2);
      color: var(--ivory);
      font-family: 'League Spartan', sans-serif;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      text-decoration: none;
      cursor: pointer;
      transition: background 0.2s;
      white-space: nowrap;
    }

    .nav-auth:hover { background: rgba(91,14,27,0.45); }

    /* ══════════════
        MAIN SLOT
     ══════════════ */
    .layout-main {
      width: 100%;
      max-width: 480px;
      padding: 0 16px;
      flex: 1;
    }

    /* ══════════════
        FOOTER
     ══════════════ */
    .layout-footer {
      width: 100%;
      max-width: 480px;
      border-top: 1px solid rgba(91,14,27,0.28);
      padding: 24px 16px 36px;
      margin-top: auto;
    }

    .footer-nav {
      display: flex;
      flex-wrap: wrap;
      gap: 10px 16px;
      margin-bottom: 18px;
    }

    .footer-link {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.06em;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }

    .footer-link:hover { color: var(--ivory); }

    .footer-divider {
      height: 1px;
      background: rgba(91,14,27,0.2);
      margin-bottom: 16px;
    }

    .footer-social {
      display: flex;
      flex-wrap: wrap;
      gap: 10px 14px;
      margin-bottom: 16px;
    }

    .footer-biz {
      font-size: 10.5px;
      color: rgba(122,154,181,0.5);
      line-height: 1.8;
    }

    .footer-warning {
      margin-top: 12px;
      font-size: 9.5px;
      color: rgba(225,38,28,0.5);
      line-height: 1.6;
    }

    /* ── 언어 토글 대상 엔진 스타일 규격 ── */
    [data-en] { display: inline-block; }
    [data-ko] { display: none; }

    body.lang-ko [data-en] { display: none; }
    body.lang-ko [data-ko] { display: inline-block; }
  </style>
</head>

<body>

  <!-- ① NAV -->
  <nav class="layout-nav">
    <a href="/" class="nav-logo">
      TAERIJAY<span class="nav-logo-plus">+</span>
    </a>

    {channelName && (
      <span class="nav-channel-badge" id="channelBadge">
        {channelName}
      </span>
    )}

    <div class="nav-controls">
      <!-- 언어 토글 -->
      <div class="lang-toggle" id="langToggle" role="group" aria-label="Language">
        <button class="lang-btn active" data-lang="en" title="English">EN</button>
        <button class="lang-btn"        data-lang="ko" title="한국어">한</button>
        <button class="lang-btn"        data-lang="auto" title="Auto-detect">Auto</button>
      </div>

      <!-- 인증 버튼 -->
      <a href="/01-auth/auth" class="nav-auth" id="navAuthBtn">
        Sign In
      </a>
    </div>
  </nav>

  <!-- ② MAIN SLOT -->
  <main class="layout-main">
    <slot />
  </main>

  <!-- ③ FOOTER -->
  <footer class="layout-footer">

    <div class="footer-nav">
      <a href="/" class="footer-link" data-en>Home</a>
      <a href="/" class="footer-link" data-ko>홈</a>

      <button onclick="document.getElementById('modalTerms').classList.add('open')"
        class="footer-link" style="background:none;border:none;cursor:pointer;padding:0;"
        data-en>Terms of Service</button>
      <button onclick="document.getElementById('modalTerms').classList.add('open')"
        class="footer-link" style="background:none;border:none;cursor:pointer;padding:0;"
        data-ko>이용약관</button>

      <button onclick="document.getElementById('modalPrivacy').classList.add('open')"
        class="footer-link" style="background:none;border:none;cursor:pointer;padding:0;"
        data-en>Privacy Policy</button>
      <button onclick="document.getElementById('modalPrivacy').classList.add('open')"
        class="footer-link" style="background:none;border:none;cursor:pointer;padding:0;"
        data-ko>개인정보처리방침</button>

      <button onclick="document.getElementById('modalRefund').classList.add('open')"
        class="footer-link" style="background:none;border:none;cursor:pointer;padding:0;"
        data-en>Refund Policy</button>
      <button onclick="document.getElementById('modalRefund').classList.add('open')"
        class="footer-link" style="background:none;border:none;cursor:pointer;padding:0;"
        data-ko>환불정책</button>

      <button onclick="document.getElementById('modalBiz').classList.add('open')"
        class="footer-link" style="background:none;border:none;cursor:pointer;padding:0;"
        data-en>Business Info</button>
      <button onclick="document.getElementById('modalBiz').classList.add('open')"
        class="footer-link" style="background:none;border:none;cursor:pointer;padding:0;"
        data-ko>사업자정보</button>
    </div>

    <div class="footer-divider"></div>

    <div class="footer-social">
      <a href="https://www.youtube.com/@taerijay"  class="footer-link" target="_blank" rel="noopener">YouTube</a>
      <a href="https://www.instagram.com/taerijay" class="footer-link" target="_blank" rel="noopener">Instagram</a>
      <a href="https://www.tiktok.com/@taerijay"   class="footer-link" target="_blank" rel="noopener">TikTok</a>
      <a href="https://taerijay.blogspot.com"       class="footer-link" target="_blank" rel="noopener">Google Blog</a>
      <a href="https://blog.naver.com/taerijay"     class="footer-link" target="_blank" rel="noopener">Naver Blog</a>
    </div>

    <div class="footer-biz">
      TAERIJAY (태리재이) · 673-51-01148 · 2026-Hwadosudo-0247<br>
      경기도 남양주시 화도읍 · official@taerijay.com
    </div>

    <div class="footer-warning">
      🚨 We do not operate any channels other than these five official platforms. Beware of imitation websites!
    </div>

  </footer>


  <!-- ════════════════════════
        MODALS
   ════════════════════════ -->
  <style>
    .modal-ov {
      display: none; position: fixed; inset: 0;
      background: rgba(10,25,47,0.92); backdrop-filter: blur(8px);
      z-index: 300; align-items: center; justify-content: center;
      padding: 24px 16px;
    }
    .modal-ov.open { display: flex; }
    .modal-box {
      width: 100%; max-width: 420px;
      border: 1px solid var(--burgundy); border-radius: 3px;
      background: #0D1A2E; padding: 28px 22px; max-height: 80dvh;
      overflow-y: auto;
    }
    .modal-h {
      font-family: 'Playfair Display', serif; font-size: 18px;
      font-weight: 600; margin-bottom: 16px;
    }
    .modal-body {
      font-size: 12px; color: var(--muted); line-height: 1.8;
      margin-bottom: 20px;
    }
    .modal-body strong { color: var(--ivory); }
    .modal-row { margin-bottom: 12px; }
    .modal-key {
      font-size: 9.5px; font-weight: 700; letter-spacing: 0.15em;
      text-transform: uppercase; color: rgba(122,154,181,0.6);
    }
    .modal-val { font-size: 13px; color: var(--ivory); margin-top: 2px; }
    .m-close {
      width: 100%; padding: 11px;
      background: transparent; border: 1px solid rgba(91,14,27,0.4);
      border-radius: 2px; color: var(--muted);
      font-family: 'League Spartan', sans-serif;
      font-size: 12px; font-weight: 600; letter-spacing: 0.1em;
      text-transform: uppercase; cursor: pointer; transition: border-color 0.2s;
    }
    .m-close:hover { border-color: var(--burgundy); color: var(--ivory); }
  </style>

  <!-- Terms -->
  <div class="modal-ov" id="modalTerms" onclick="if(event.target===this)this.classList.remove('open')">
    <div class="modal-box">
      <div class="modal-h">Terms of Service</div>
      <div class="modal-body">
        <strong>1. Service Overview</strong><br>
        TAERIJAY+ provides a premium Korea travel &amp; lifestyle information platform accessible via paid subscription channels.<br><br>
        <strong>2. Subscription</strong><br>
        All plans are one-time purchases granting 12 months of unlimited access. No automatic renewal. Access is tied to 1 registered ID and 1 device per plan.<br><br>
        <strong>3. Usage Restrictions</strong><br>
        Account sharing, re-sale, or redistribution of content is strictly prohibited. TAERIJAY reserves the right to revoke access without refund upon policy violations.<br><br>
        <strong>4. Content Updates</strong><br>
        New content is added on the 10th and 20th of each month. TAERIJAY does not guarantee the accuracy of third-party information referenced within the platform.<br><br>
        <strong>5. Governing Law</strong><br>
        These terms are governed by the laws of the Republic of Korea.
      </div>
      <button class="m-close" onclick="document.getElementById('modalTerms').classList.remove('open')">Close</button>
    </div>
  </div>

  <!-- Privacy -->
  <div class="modal-ov" id="modalPrivacy" onclick="if(event.target===this)this.classList.remove('open')">
    <div class="modal-box">
      <div class="modal-h">Privacy Policy</div>
      <div class="modal-body">
        <strong>Data Collected</strong><br>
        · Google login email address (via Firebase Authentication)<br>
        · Paddle-processed payment data (TAERIJAY does not store card details)<br><br>
        <strong>Purpose of Collection</strong><br>
        · Identity verification and access control<br>
        · Subscription status management<br><br>
        <strong>Data Retention</strong><br>
        · Minimum data collection principle applied<br>
        · Email retained for the duration of active subscription<br><br>
        <strong>Third-Party Services</strong><br>
        · Google Firebase (authentication)<br>
        · Paddle (payment processing — PCI DSS compliant)<br><br>
        <strong>Contact</strong><br>
        official@taerijay.com
      </div>
      <button class="m-close" onclick="document.getElementById('modalPrivacy').classList.remove('open')">Close</button>
    </div>
  </div>

  <!-- Refund -->
  <div class="modal-ov" id="modalRefund" onclick="if(event.target===this)this.classList.remove('open')">
    <div class="modal-box">
      <div class="modal-h">Refund Policy</div>
      <div class="modal-body">
        <strong>No-Refund Principle</strong><br>
        Due to the nature of digital content, all sales are final and non-refundable once access is activated.<br><br>
        <strong>Exception — Duplicate Payment</strong><br>
        If a duplicate charge occurs, a full refund will be processed within 7 business days upon verified request.<br><br>
        <strong>How to Request</strong><br>
        Email official@taerijay.com with your registered Google email and Paddle order ID.<br><br>
        <strong>⚠️ Note</strong><br>
        Refund requests citing "didn't use the service" or "changed my mind" will not be processed under Korean e-commerce digital goods regulations.
      </div>
      <button class="m-close" onclick="document.getElementById('modalRefund').classList.remove('open')">Close</button>
    </div>
  </div>

  <!-- Business Info -->
  <div class="modal-ov" id="modalBiz" onclick="if(event.target===this)this.classList.remove('open')">
    <div class="modal-box">
      <div class="modal-h">Business Information</div>
      <div class="modal-row"><div class="modal-key">상호명 · Company</div><div class="modal-val">TAERIJAY (태리재이)</div></div>
      <div class="modal-row"><div class="modal-key">사업자등록번호</div><div class="modal-val">673-51-01148</div></div>
      <div class="modal-row"><div class="modal-key">통신판매업신고번호</div><div class="modal-val">2026-Hwadosudo-0247</div></div>
      <div class="modal-row"><div class="modal-key">소재지</div><div class="modal-val">경기도 남양주시 화도읍</div></div>
      <div class="modal-row"><div class="modal-key">이메일 · Email</div><div class="modal-val">official@taerijay.com</div></div>
      <button class="m-close" onclick="document.getElementById('modalBiz').classList.remove('open')">Close</button>
    </div>
  </div>


  <!-- ════════════════════════
        SCRIPTS
   ════════════════════════ -->
  <script define:vars={{ channelColor }}>
    // Astro 전용 CSS 환경변수 연동 아키텍처 (is:inline 버그 완전 소각)
    document.documentElement.style.setProperty('--accent', channelColor);
  </script>

  <script is:inline>
    (function () {
      // ── 로그인 상태 → 네비 버튼 ──
      const email  = sessionStorage.getItem('user_email');
      const authBtn = document.getElementById('navAuthBtn');
      if (email && authBtn) {
        authBtn.textContent = 'My Account';
      }

      // ── 언어 토글 로직 엔진 ──
      const LANG_KEY = 'tj_lang';
      const toggle   = document.getElementById('langToggle');
      const buttons  = toggle ? toggle.querySelectorAll('.lang-btn') : [];

      function getBrowserLang() {
        const nav = (navigator.language || 'en').toLowerCase();
        return nav.startsWith('ko') ? 'ko' : 'en';
      }

      function applyLang(selectedOption) {
        // 1. 실제 화면에 적용될 언어 계산 (auto면 브라우저 언어 추적)
        const targetLang = selectedOption === 'auto' ? getBrowserLang() : selectedOption;
        
        // 2. body class 토글을 통해 언어에 맞는 텍스트 온오프 가동
        document.body.classList.toggle('lang-ko', targetLang === 'ko');
        
        // 3. 버튼 활성화(active) UI 상태 동기화
        buttons.forEach(btn => {
          btn.classList.toggle('active', btn.dataset.lang === selectedOption);
        });
      }

      // 초기 실행 구조 세팅
      const savedSetting = localStorage.getItem(LANG_KEY) || 'en';
      applyLang(savedSetting);

      // 토글 버튼 이벤트 슛
      buttons.forEach(btn => {
        btn.addEventListener('click', function () {
          const chosen = this.dataset.lang;
          localStorage.setItem(LANG_KEY, chosen);
          applyLang(chosen);
        });
      });
    })();
  </script>

</body>
</html>