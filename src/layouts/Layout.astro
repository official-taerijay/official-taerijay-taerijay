---
<!doctype html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>{title}</title>
  <meta name="description" content="TAERIJAY — 검증된 한국 여행/라이프스타일 정보 스트리밍" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
</head>
<body>
  <div id="splash" class="splash"><span class="splash-brand">TAERIJAY</span></div>

  <!-- 헤더: 로그인 없음 — 로그인은 결제 시점에만 등장 -->
  <header class="nav" id="nav">
    <div class="nav-inner">
      <button type="button" class="hamburger" id="hamburger-btn" aria-label="메뉴">
        <span></span><span></span><span></span>
      </button>
      <a href="/" class="nav-logo">TAERIJAY</a>
      <div class="nav-right">
        <div class="lang-dropdown">
          <button type="button" class="lang-trigger" id="lang-trigger">
            <span id="lang-current">English</span>
            <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </button>
          <div class="lang-menu" id="lang-menu" hidden>
            {languages.map((l) => (
              <button type="button" class="lang-option" data-code={l.code} data-name={l.name}>{l.name}</button>
            ))}
          </div>
        </div>
        <a href="/01-auth/auth" class="nav-account-btn" id="nav-account-btn">
          <span class="nav-account-kr" id="nav-account-kr">회원가입/로그인</span>
          <span class="nav-account-en" id="nav-account-en" data-i18n="en">Sign Up / Log In</span>
        </a>
      </div>
    </div>
  </header>

  <div class="side-menu" id="side-menu" hidden>
    <div class="side-menu-inner">
      <button type="button" class="side-close" id="side-close">×</button>

      <a href="/" class="side-logo">TAERIJAY</a>

      <nav class="side-links side-links-channels">
        {Object.values(channels).map((ch) => (
          <a href={`/04-channels/${ch.slug}`} style={`--c:${ch.color}`}>taerijay+{ch.slug}</a>
        ))}
      </nav>

      <div class="side-divider"></div>

      <nav class="side-links side-links-account">
        <a href="/01-auth/auth" class="side-account-link" id="side-account-link">회원가입/로그인</a>
      </nav>

      <div class="side-divider"></div>

      <nav class="side-links side-links-plain">
        <a href="/pricing">PRICING</a>
      </nav>

      <div class="side-divider"></div>

      <nav class="side-links side-links-legal">
        <a href="#">Business</a>
        <a href="#">Terms</a>
        <a href="#">Privacy</a>
        <a href="#">Refund</a>
      </nav>

      <div class="side-divider"></div>

      <div class="side-social">
        <a href="#" class="social-icon" title="YouTube" aria-label="YouTube">
          <svg viewBox="0 0 24 24" width="18" height="18"><path fill="#FF0000" d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.6 12 3.6 12 3.6s-7.5 0-9.4.5A3 3 0 0 0 .5 6.2 31 31 0 0 0 0 12a31 31 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.5 9.4.5 9.4.5s7.5 0 9.4-.5a3 3 0 0 0 2.1-2.1A31 31 0 0 0 24 12a31 31 0 0 0-.5-5.8Z"/><path fill="#fff" d="M9.6 15.6 15.8 12 9.6 8.4v7.2Z"/></svg>
        </a>
