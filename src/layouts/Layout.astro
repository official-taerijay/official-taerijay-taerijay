  </div>

  <!-- SCRIPTS -->
  <script is:inline>
    // 모달 시스템
    const modals = document.querySelectorAll('.modal-overlay');
    const triggers = document.querySelectorAll('.modal-trigger');
    const closeButtons = document.querySelectorAll('.modal-close');

    triggers.forEach(trigger => {
      trigger.addEventListener('click', function () {
        const modalId = `modal-${this.dataset.modal}`;
        document.getElementById(modalId)?.classList.add('visible');
      });
    });

    closeButtons.forEach(btn => {
      btn.addEventListener('click', function () {
        this.closest('.modal-overlay').classList.remove('visible');
      });
    });

    modals.forEach(modal => {
      modal.addEventListener('click', function (e) {
        if (e.target === this) {
          this.classList.remove('visible');
        }
      });
    });

    // 언어 토글
    const LANG_KEY = 'tj_lang';
    const toggle = document.getElementById('langToggle');
    const buttons = toggle ? toggle.querySelectorAll('.lang-btn') : [];

    function applyLang(showEn) {
      document.querySelectorAll('.social-en, .footer-en, .modal-title-en').forEach(el => {
        el.style.display = showEn ? 'inline' : 'none';
      });

      buttons.forEach(btn => {
        btn.classList.toggle('active', 
          (btn.dataset.lang === 'en') === showEn || btn.dataset.lang === 'auto'
        );
      });
    }

    const saved = localStorage.getItem(LANG_KEY) || 'ko';
    const showEn = saved === 'en';
    applyLang(showEn);

    buttons.forEach(btn => {
      btn.addEventListener('click', function () {
        const chosen = this.dataset.lang;
        if (chosen === 'auto') {
          localStorage.setItem(LANG_KEY, 'auto');
          applyLang(false);
        } else if (chosen === 'en') {
          localStorage.setItem(LANG_KEY, 'en');
          applyLang(true);
        } else {
          localStorage.setItem(LANG_KEY, 'ko');
          applyLang(false);
        }
      });
    });

    // 로그인 상태 확인
    const email = sessionStorage.getItem('user_email');
    const homeLink = document.querySelector('.nav-link');
    if (email && homeLink) {
      homeLink.textContent = '← My Account';
      homeLink.href = '/01-auth/auth';
    }
  </script>

</body>
