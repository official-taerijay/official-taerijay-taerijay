---
interface Props {
	title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=League+Spartan:wght@100..900&family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Noto+Sans:ital,wght@0,100..900;1,100..900&family=Noto+Sans+Arabic:wght@100..900&family=Noto+Sans+Hebrew:wght@100..900&family=Noto+Sans+SC:wght@100..900&family=Noto+Sans+TC:wght@100..900&display=swap" rel="stylesheet">
		<script is:inline src="https://cdn.tailwindcss.com"></script>
		<script is:inline>
			tailwind.config = {
				theme: {
					extend: {
						colors: {
							baseBg: '#0A192F',
							brandBorder: '#5B0E1B',
							neonCyan: '#00F0FF',
							neonOrange: '#FF6B00',
							neonYellow: '#FFFB00',
							neonRed: '#FF2E2E',
							neonGreen: '#00FF66',
							neonPurple: '#E000FF',
							masterBurgundy: '#990011',
						},
						fontFamily: {
							'playfair': ['"Playfair Display"', 'serif'],
							'spartan': ['"League Spartan"', 'sans-serif'],
							'noto': ['"Noto Sans"', '"Noto Sans Arabic"', '"Noto Sans Hebrew"', '"Noto Sans SC"', '"Noto Sans TC"', 'sans-serif']
						}
					}
				}
			}
		</script>
	</head>
	<body class="bg-[#0A192F] text-[#FBF9F4] antialiased">
		<slot />
	</body>
</html>