          <svg viewBox="0 0 24 24" width="18" height="18"><rect width="24" height="24" rx="6" fill="#fff"/><path fill="#4285F4" d="M22.6 12.3c0-.8-.1-1.5-.2-2.2H12v4.2h5.9a5 5 0 0 1-2.2 3.3v2.7h3.5c2.1-1.9 3.4-4.7 3.4-8Z"/><path fill="#34A853" d="M12 23c2.7 0 5-.9 6.6-2.4l-3.5-2.7c-.9.6-2 1-3.1 1-2.6 0-4.8-1.7-5.6-4.1H2.1v2.6A11 11 0 0 0 12 23Z"/><path fill="#FBBC05" d="M6.4 14.8a6.6 6.6 0 0 1 0-5.6V6.6H2.1a11 11 0 0 0 0 9.8l4.3-2.6Z"/><path fill="#EA4335" d="M12 5.4c1.5 0 2.8.5 3.8 1.5l3-3A11 11 0 0 0 12 1a11 11 0 0 0-9.9 5.6l4.3 2.6c.8-2.4 3-4.2 5.6-4.2Z"/></svg>
        </a>
        <a href="#" class="social-icon" title="Naver" aria-label="Naver">
          <svg viewBox="0 0 24 24" width="18" height="18"><rect width="24" height="24" rx="6" fill="#03C75A"/><path fill="#fff" d="M14.4 13.6 9.7 6.5H6.5v11h3.1v-7.1l4.7 7.1h3.2v-11h-3.1v7.1Z"/></svg>
        </a>
      </div>
    </div>
  </div>

  <main>
    <slot />
  </main>

  <footer class="footer">
    <div class="footer-links">
      <a href="#"><span class="footer-kr">이용약관</span><br/><span class="footer-en" data-i18n="en">Terms</span></a>
      <a href="#"><span class="footer-kr">개인정보</span><br/><span class="footer-en" data-i18n="en">Privacy</span></a>
      <a href="#"><span class="footer-kr">환불정책</span><br/><span class="footer-en" data-i18n="en">Refund</span></a>
      <a href="#"><span class="footer-kr">사업자정보</span><br/><span class="footer-en" data-i18n="en">Business</span></a>
    </div>
    <div class="footer-social">
      <a href="#" class="social-icon social-yt" title="YouTube" aria-label="YouTube">
        <svg viewBox="0 0 24 24" width="20" height="20"><path fill="#FF0000" d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.6 12 3.6 12 3.6s-7.5 0-9.4.5A3 3 0 0 0 .5 6.2 31 31 0 0 0 0 12a31 31 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.5 9.4.5 9.4.5s7.5 0 9.4-.5a3 3 0 0 0 2.1-2.1A31 31 0 0 0 24 12a31 31 0 0 0-.5-5.8Z"/><path fill="#fff" d="M9.6 15.6 15.8 12 9.6 8.4v7.2Z"/></svg>
      </a>
      <a href="#" class="social-icon social-ig" title="Instagram" aria-label="Instagram">
        <svg viewBox="0 0 24 24" width="20" height="20">
          <defs>
            <radialGradient id="igGrad" cx="30%" cy="107%" r="150%">
              <stop offset="0%" stop-color="#FFDD55"/>
              <stop offset="10%" stop-color="#FFDD55"/>
              <stop offset="50%" stop-color="#FF543E"/>
              <stop offset="100%" stop-color="#C837AB"/>
            </radialGradient>
          </defs>
          <rect width="24" height="24" rx="6" fill="url(#igGrad)"/>
          <rect x="4" y="4" width="16" height="16" rx="4" fill="none" stroke="#fff" stroke-width="1.6"/>
          <circle cx="12" cy="12" r="3.6" fill="none" stroke="#fff" stroke-width="1.6"/>
          <circle cx="17" cy="7" r="1" fill="#fff"/>
        </svg>
