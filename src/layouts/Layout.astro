---
export interface Props {
  title?: string;
}
const { title = 'TAERIJAY' } = Astro.props;

const channels = {
  entertainment: { slug: 'entertainment', color: '#00E5FF' },
  protocol:      { slug: 'protocol',      color: '#F16B24' },
  mini:          { slug: 'mini',          color: '#e8e4dc' },
  daiso:         { slug: 'daiso',         color: '#E1261C' },
  oliveyoung:    { slug: 'oliveyoung',    color: '#6F8B2E' },
  emart:         { slug: 'emart',         color: '#FFDD00' },
  convenience:   { slug: 'convenience',   color: '#A14D7C' },
};

const socialLinks = [
  { name: 'YouTube',    icon: '▶', color: '#FF0000' },
  { name: 'Instagram',  icon: '◎', color: '#E1306C' },
  { name: 'TikTok',     icon: '♪', color: '#25F4EE' },
  { name: 'Google Blog', icon: 'G', color: '#4285F4' },
  { name: 'Naver Blog',  icon: 'N', color: '#03C75A' },
];

const languages = [
  { code: 'en', name: 'English' },
  { code: 'ko', name: '한국어' },
  { code: 'ja', name: '日本語' },
  { code: 'zh-CN', name: '简体中文' },
  { code: 'zh-TW', name: '繁體中文' },
  { code: 'zh-HK', name: '中文（香港）' },
  { code: 'es', name: 'Español' },
  { code: 'fr', name: 'Français' },
  { code: 'de', name: 'Deutsch' },
  { code: 'it', name: 'Italiano' },
  { code: 'pt', name: 'Português' },
  { code: 'pt-BR', name: 'Português (Brasil)' },
  { code: 'ru', name: 'Русский' },
  { code: 'ar', name: 'العربية' },
  { code: 'hi', name: 'हिन्दी' },
  { code: 'th', name: 'ไทย' },
  { code: 'vi', name: 'Tiếng Việt' },
  { code: 'id', name: 'Bahasa Indonesia' },
  { code: 'ms', name: 'Bahasa Melayu' },
  { code: 'tl', name: 'Filipino' },
  { code: 'tr', name: 'Türkçe' },
  { code: 'nl', name: 'Nederlands' },
  { code: 'pl', name: 'Polski' },
  { code: 'sv', name: 'Svenska' },
  { code: 'nb', name: 'Norsk bokmål' },
  { code: 'da', name: 'Dansk' },
  { code: 'fi', name: 'Suomi' },
  { code: 'el', name: 'Ελληνικά' },
  { code: 'he', name: 'עברית' },
  { code: 'cs', name: 'Čeština' },
  { code: 'ro', name: 'Română' },
  { code: 'hu', name: 'Magyar' },
  { code: 'uk', name: 'Українська' },
  { code: 'bg', name: 'Български' },
  { code: 'sk', name: 'Slovenčina' },
  { code: 'hr', name: 'Hrvatski' },
  { code: 'sr', name: 'Српски' },
  { code: 'sl', name: 'Slovenščina' },
  { code: 'lt', name: 'Lietuvių' },
  { code: 'lv', name: 'Latviešu' },
  { code: 'et', name: 'Eesti' },
  { code: 'ca', name: 'Català' },
  { code: 'af', name: 'Afrikaans' },
  { code: 'sw', name: 'Kiswahili' },
  { code: 'bn', name: 'বাংলা' },
  { code: 'ta', name: 'தமிழ்' },
  { code: 'te', name: 'తెలుగు' },
  { code: 'ur', name: 'اردو' },
  { code: 'fa', name: 'فارسی' },
  { code: 'az', name: 'azərbaycan' },
  { code: 'bs', name: 'bosanski' },
  { code: 'cy', name: 'Cymraeg' },
];
---
<!doctype html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>{title}</title>
  <meta name="description" content="TAERIJAY — 검증된 한국 여행/라이프스타일 정보 스트리밍" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,900;1,600&family=League+Spartan:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
</head>
<body>
  <div id="splash" class="splash"><span class="splash-brand">TAERIJAY</span></div>

  <!-- 헤더: 로그인 없음 — 로그인은 결제 시점에만 등장 -->
  <header class="nav" id="nav">
    <div class="nav-inner">
      <button type="button" class="hamburger" id="hamburger-btn" aria-label="메뉴">
        <span></span><span></span><span></span>
      </button>
      <a href="/" class="nav-logo">TAERIJAY</a>
      <div class="nav-right">
        <div class="lang-dropdown">
          <button type="button" class="lang-trigger" id="lang-trigger">
            <span id="lang-current">English</span>
            <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </button>
          <div class="lang-menu" id="lang-menu" hidden>
            {languages.map((l) => (
              <button type="button" class="lang-option" data-code={l.code} data-name={l.name}>{l.name}</button>
            ))}
          </div>
        </div>
      </div>
    </div>
  </header>

  <div class="side-menu" id="side-menu" hidden>
    <div class="side-menu-inner">
      <button type="button" class="side-close" id="side-close">×</button>
      <a href="/" class="side-logo">TAERIJAY</a>
      <nav class="side-links">
        <a href="/">홈 · Home</a>
        {Object.values(channels).map((ch) => (
          <a href={`/04-channels/${ch.slug}`} style={`--c:${ch.color}`}>taerijay+{ch.slug}</a>
        ))}
      </nav>
    </div>
  </div>

  <main>
    <slot />
  </main>

  <footer class="footer">
    <div class="footer-links">
      <a href="#"><span class="footer-kr">이용약관</span><br/><span class="footer-en" data-i18n="en">Terms</span></a>
      <a href="#"><span class="footer-kr">개인정보</span><br/><span class="footer-en" data-i18n="en">Privacy</span></a>
      <a href="#"><span class="footer-kr">환불정책</span><br/><span class="footer-en" data-i18n="en">Refund</span></a>
      <a href="#"><span class="footer-kr">사업자정보</span><br/><span class="footer-en" data-i18n="en">Business</span></a>
    </div>
    <div class="footer-social">
      {socialLinks.map((s) => (
        <a href="#" class="social-icon" style={`--sc:${s.color}`} title={s.name} aria-label={s.name}>{s.icon}</a>
      ))}
    </div>
    <p class="footer-copy">© 2026 TAERIJAY · 사업자등록번호 673-51-01148 · taerijay.com</p>
  </footer>

  <script>
    const nav = document.getElementById('nav');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 40) nav.classList.add('nav-scrolled');
      else nav.classList.remove('nav-scrolled');
    });

    const hamburgerBtn = document.getElementById('hamburger-btn');
    const sideMenu = document.getElementById('side-menu');
    const sideClose = document.getElementById('side-close');
    hamburgerBtn.addEventListener('click', () => { sideMenu.hidden = false; });
    sideClose.addEventListener('click', () => { sideMenu.hidden = true; });
    sideMenu.addEventListener('click', (e) => { if (e.target === sideMenu) sideMenu.hidden = true; });

    const langTrigger = document.getElementById('lang-trigger');
    const langMenu = document.getElementById('lang-menu');
    const langCurrent = document.getElementById('lang-current');

    langTrigger.addEventListener('click', (e) => {
      e.stopPropagation();
      langMenu.hidden = !langMenu.hidden;
    });

    document.querySelectorAll('.lang-option').forEach((opt) => {
      opt.addEventListener('click', () => {
        langCurrent.textContent = opt.dataset.name;
        localStorage.setItem('taerijay_lang', opt.dataset.code);
        langMenu.hidden = true;
      });
    });

    document.addEventListener('click', (e) => {
      if (!langMenu.hidden && !e.target.closest('.lang-dropdown')) {
        langMenu.hidden = true;
      }
    });

    window.addEventListener('DOMContentLoaded', () => {
      const saved = localStorage.getItem('taerijay_lang');
      if (saved) {
        const opt = document.querySelector(`.lang-option[data-code="${saved}"]`);
        if (opt) langCurrent.textContent = opt.dataset.name;
      }
      setTimeout(() => {
        const s = document.getElementById('splash');
        if (s) { s.style.opacity = '0'; setTimeout(() => s.remove(), 500); }
      }, 700);
    });
  </script>

  <style is:global>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --bg:#0A192F;--border:#5B0E1B;--ivory:#FBF9F4;--muted:#8b96a8;--dim:#5d6c82;--gold:#D4AF37;
      --f-display:'Playfair Display',serif;--f-body:'League Spartan',sans-serif;
      --container: min(1200px, 92vw);
    }
    html,body{background:var(--bg);color:var(--ivory);font-family:var(--f-body);min-height:100vh;overflow-x:hidden;scroll-behavior:smooth}
    button{font:inherit}
    a{color:inherit}

    .splash{position:fixed;inset:0;background:var(--bg);display:flex;align-items:center;justify-content:center;z-index:9999;transition:opacity .5s ease}
    .splash-brand{font-family:var(--f-display);font-weight:900;font-size:clamp(1.8rem,6vw,2.6rem);letter-spacing:.06em}

    .nav{position:fixed;top:0;left:0;right:0;z-index:200;transition:background .3s ease,border-color .3s ease}
    .nav-scrolled{background:rgba(10,25,47,.92);backdrop-filter:blur(10px);border-bottom:1px solid rgba(91,14,27,.4)}
    .nav-inner{width:var(--container);margin:0 auto;display:flex;align-items:center;justify-content:space-between;padding:16px 0}
    .nav-logo{font-family:var(--f-display);font-weight:900;font-size:clamp(1rem,3vw,1.15rem);letter-spacing:.05em;color:var(--ivory);text-decoration:none}
    .hamburger{display:flex;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:6px}
    .hamburger span{display:block;width:22px;height:2px;background:var(--ivory)}
    .nav-right{display:flex;align-items:center;gap:12px}

    .lang-dropdown{position:relative}
    .lang-trigger{display:flex;align-items:center;gap:6px;background:transparent;border:1px solid rgba(255,255,255,.18);color:var(--ivory);font-size:.76rem;font-weight:600;padding:8px 12px;border-radius:6px;cursor:pointer}
    .lang-menu{position:absolute;top:calc(100% + 8px);right:0;background:#151f33;border:1px solid rgba(255,255,255,.12);border-radius:10px;box-shadow:0 16px 40px rgba(0,0,0,.5);max-height:320px;overflow-y:auto;min-width:180px;z-index:300}
    .lang-option{display:block;width:100%;text-align:left;background:transparent;border:none;color:var(--ivory);font-size:.82rem;padding:10px 16px;cursor:pointer;transition:background .15s}
    .lang-option:hover{background:rgba(255,255,255,.08)}

    .side-menu{position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:300}
    .side-menu-inner{position:absolute;top:0;left:0;height:100%;width:min(320px,80vw);background:#0d1f3d;padding:24px;display:flex;flex-direction:column}
    .side-close{align-self:flex-end;background:none;border:none;color:var(--ivory);font-size:1.8rem;cursor:pointer;margin-bottom:20px}
    .side-logo{font-family:var(--f-display);font-weight:900;font-size:1.3rem;margin-bottom:32px;text-decoration:none;color:var(--ivory)}
    .side-links{display:flex;flex-direction:column;gap:18px}
    .side-links a{text-decoration:none;font-size:.9rem;color:var(--c,var(--muted));font-weight:600}

    main{padding-top:0}

    .footer{width:var(--container);margin:0 auto;padding:40px 0 48px;border-top:1px solid rgba(255,255,255,.08);text-align:center}
    .footer-links{display:flex;justify-content:center;gap:28px;flex-wrap:wrap;margin-bottom:24px}
    .footer-links a{text-decoration:none;font-size:.82rem;color:var(--muted);text-align:center;line-height:1.6}
    .footer-en{font-size:.7rem;color:var(--dim)}
    .footer-social{display:flex;gap:14px;justify-content:center;margin-bottom:20px}
    .social-icon{
      width:40px;height:40px;border-radius:50%;
      border:2px solid var(--sc);color:var(--sc);
      display:flex;align-items:center;justify-content:center;
      text-decoration:none;font-size:1rem;font-weight:700;
      transition:background .2s,transform .15s;
      background:color-mix(in srgb, var(--sc) 12%, transparent);
    }
    .social-icon:hover{background:color-mix(in srgb, var(--sc) 24%, transparent);transform:translateY(-2px)}
    .footer-copy{font-size:.74rem;color:var(--dim)}

    @media (max-width: 560px){
      .lang-trigger{padding:6px 9px;font-size:.7rem}
      .lang-menu{right:-40px;max-width:calc(100vw - 24px)}
    }

    @media (prefers-reduced-motion: reduce){
      *{transition-duration:.01ms!important;animation-duration:.01ms!important;scroll-behavior:auto!important}
    }
  </style>
</body>
</html>