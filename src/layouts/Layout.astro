---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="TAERIJAY+ - Global K-Travel Platform" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		
		<!-- 글로벌 통합 폰트 바인딩 -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=League+Spartan:wght@100..900&family=Noto+Sans+KR:wght@100..900&display=swap" rel="stylesheet">
		
		<!-- Vercel 컴파일 최적화용 고성능 Tailwind CSS 엔진 주입 -->
		<script is:inline src="https://cdn.tailwindcss.com"></script>
		<script is:inline>
			tailwind.config = {
				theme: {
					extend: {
						colors: {
							baseBg: '#0A192F',
							brandBorder: '#5B0E1B',
							neonCyan: '#00E5FF',
							vividRed: '#E1261C',
							brightYellow: '#FFDD00',
							satinIvory: '#FBF9F4',
							classicOrange: '#F16B24',
							oliveGreen: '#6F8B2E',
							neonPurple: '#A14D7C',
						}
					}
				}
			}
		</script>
		<style is:global>
			body {
				background-color: #0A192F;
				font-family: 'Noto Sans KR', sans-serif;
				color: #FBF9F4;
				overflow-x: hidden;
				margin: 0;
				padding: 0;
			}
			/* 디즈니+ 슬라이더 전용 터치 트랙바 최적화 */
			::-webkit-scrollbar {
				width: 6px;
				height: 6px;
			}
			::-webkit-scrollbar-track {
				background: #0A192F;
			}
			::-webkit-scrollbar-thumb {
				background: #5B0E1B;
				border-radius: 3px;
			}
			.no-scrollbar::-webkit-scrollbar {
				display: none;
			}
			.no-scrollbar {
				-ms-overflow-style: none;
				scrollbar-width: none;
			}
		</style>
	</head>
	<body class="bg-[#0A192F] min-h-screen w-full">
		<slot />
	</body>
</html>