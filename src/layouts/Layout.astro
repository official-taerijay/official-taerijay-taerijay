        <svg viewBox="0 0 24 24" width="20" height="20">
          <rect width="24" height="24" rx="6" fill="#000"/>
          <path fill="#25F4EE" d="M14.5 3.2c.4 1.6 1.5 2.7 3.1 3v2.3c-1.2 0-2.3-.4-3.1-1v6.1c0 2.5-2 4.5-4.5 4.5S5.5 16.1 5.5 13.6c0-2.3 1.7-4.2 4-4.5v2.4c-.9.2-1.6 1.1-1.6 2.1 0 1.2 1 2.2 2.2 2.2s2.2-1 2.2-2.2V3.2h2.2Z" transform="translate(-1,0)"/>
          <path fill="#FE2C55" d="M14 3.2c.4 1.6 1.5 2.7 3.1 3v2.3c-1.2 0-2.3-.4-3.1-1v6.1c0 2.5-2 4.5-4.5 4.5S5 16.1 5 13.6c0-2.3 1.7-4.2 4-4.5v2.4c-.9.2-1.6 1.1-1.6 2.1 0 1.2 1 2.2 2.2 2.2s2.2-1 2.2-2.2V3.2H14Z"/>
        </svg>
      </a>
      <a href="#" class="social-icon social-google" title="Google" aria-label="Google">
        <svg viewBox="0 0 24 24" width="20" height="20"><rect width="24" height="24" rx="6" fill="#fff"/><path fill="#4285F4" d="M22.6 12.3c0-.8-.1-1.5-.2-2.2H12v4.2h5.9a5 5 0 0 1-2.2 3.3v2.7h3.5c2.1-1.9 3.4-4.7 3.4-8Z"/><path fill="#34A853" d="M12 23c2.7 0 5-.9 6.6-2.4l-3.5-2.7c-.9.6-2 1-3.1 1-2.6 0-4.8-1.7-5.6-4.1H2.1v2.6A11 11 0 0 0 12 23Z"/><path fill="#FBBC05" d="M6.4 14.8a6.6 6.6 0 0 1 0-5.6V6.6H2.1a11 11 0 0 0 0 9.8l4.3-2.6Z"/><path fill="#EA4335" d="M12 5.4c1.5 0 2.8.5 3.8 1.5l3-3A11 11 0 0 0 12 1a11 11 0 0 0-9.9 5.6l4.3 2.6c.8-2.4 3-4.2 5.6-4.2Z"/></svg>
